function saveCalEvent(){
  var payload = {
    title: document.getElementById('evf-title').value.trim(),
    date: document.getElementById('evf-date').value,
    startTime: document.getElementById('evf-start').value,
    endTime: document.getElementById('evf-end').value,
    location: document.getElementById('evf-loc').value.trim(),
    description: document.getElementById('evf-desc').value.trim(),
    calendarId: document.getElementById('evf-cal').value
  };
  if (!payload.title) { toast('Title required','err'); return; }
  if (!payload.date || !payload.startTime || !payload.endTime) { toast('Date and time required','err'); return; }
  if (payload.endTime <= payload.startTime) { toast('End time must be after start','err'); return; }
  var btn = document.getElementById('ev-form-save');
  if (btn) { btn.disabled = true; btn.textContent = 'Saving...'; }
  if (_calEditMode && _calCurrentEvent) {
    payload.eventId = _calCurrentEvent.id;
    google.script.run
      .withSuccessHandler(function(r){
        if (btn) { btn.disabled = false; btn.textContent = 'Save Changes'; }
        if (!r || !r.success) { toast(r && r.error ? r.error : 'Save failed','err'); return; }
        closeModal('ev-form-modal');
        toast('Event updated','ok');
        _calCache = {};
        loadCalendarPageData();
      })
      .withFailureHandler(function(e){
        if (btn) { btn.disabled = false; btn.textContent = 'Save Changes'; }
        toast(e.message || 'Save failed','err');
      })
      .updateCalendarEvent(JSON.stringify(payload));
  } else {
    google.script.run
      .withSuccessHandler(function(r){
        if (btn) { btn.disabled = false; btn.textContent = 'Create Event'; }
        if (!r || !r.success) { toast(r && r.error ? r.error : 'Create failed','err'); return; }
        closeModal('ev-form-modal');
        toast('Event created','ok');
        _calCache = {};
        loadCalendarPageData();
      })
      .withFailureHandler(function(e){
        if (btn) { btn.disabled = false; btn.textContent = 'Create Event'; }
        toast(e.message || 'Create failed','err');
      })
      .createCalendarEvent(JSON.stringify(payload));
  }
}

function confirmDeleteEvent(){
  if (!_calCurrentEvent) return;
  var ev = _calCurrentEvent;
  if (!confirm('Delete "' + ev.title + '"?\n\nThis removes it from your Google Calendar.')) return;
  google.script.run
