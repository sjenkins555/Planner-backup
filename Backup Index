    if(d.length === 8){
      // If we have class start/end times, build a timed event in the user's local time.
      // Format: YYYYMMDDTHHMMSS/YYYYMMDDTHHMMSS (Google Calendar URL-encoded "dates" param)
      if (classTimes && classTimes.startTime && classTimes.endTime){
        var s = classTimes.startTime.replace(':','') + '00';
        var e = classTimes.endTime.replace(':','') + '00';
        params.push('dates=' + d + 'T' + s + '/' + d + 'T' + e);
        params.push('ctz=' + encodeURIComponent(Intl.DateTimeFormat().resolvedOptions().timeZone || 'America/Chicago'));
      } else {
        // All-day event when no class time is available
        params.push('dates=' + d + '/' + d);
      }
    }
  }
  if(details) params.push('details=' + encodeURIComponent(details));
  if(guestEmails && guestEmails.length) params.push('add=' + encodeURIComponent(guestEmails.join(',')));
  window.open(url + (params.length ? '?' + params.join('&') : ''), '_blank');
}

// Looks up the start/end times for a given subject on a given due date.
// Honors A/B day rotation when active. Returns null if no matching class found.
function findClassTimesForSubject(subject, dueDate){
  if (!subject || !mySchedule || !mySchedule.length) return null;
  // Determine which day type applies on the due date (defaults to 'A' for non-AB schedules)
  var dayType = 'A';
  if (dueDate && activeBell){
    // For now we use today's day type. A future enhancement could look up the calendar
    // for the actual due date, but most tasks are added for soon-upcoming dates.
    dayType = (activeBell.dayType || 'A').toUpperCase();
    if (dayType !== 'A' && dayType !== 'B') dayType = 'A';
  }
  for (var i = 0; i < mySchedule.length; i++){
    var p = mySchedule[i];
    var subjA = String(p.subject||'').replace(/^\[(.+?)\]\(.+\)$/, '$1').trim();
    var subjB = String(p.subjectB||'').replace(/^\[(.+?)\]\(.+\)$/, '$1').trim();
    if (subjA === subject || subjB === subject){
      // Bell schedule times override the student's saved times when an override is active
      var startT = p.startTime, endT = p.endTime;
      if (activeBell && activeBell.schedule && activeBell.schedule.periods){
        for (var j = 0; j < activeBell.schedule.periods.length; j++){
          if (String(activeBell.schedule.periods[j].period) === String(p.period)){
            startT = activeBell.schedule.periods[j].startTime || startT;
            endT   = activeBell.schedule.periods[j].endTime   || endT;
            break;
          }
        }
      }
      if (startT && endT) return {startTime:startT, endTime:endT};
    }
  }
  return null;
}
 
