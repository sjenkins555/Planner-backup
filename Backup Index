function loadSchedule(){google.script.run.withSuccessHandler(function(r){mySchedule=r.schedule||[];renderSchedule();}).getMySchedule();}
function renderSchedule(){
  var el=document.getElementById('sched-area');if(!el)return;
  if(!mySchedule.length){el.innerHTML='<div class="empty"><p>Click the gear to add classes.</p></div>';return;}
  var now=new Date(),cur=now.getHours()*60+now.getMinutes();
  var cols=prefs.schedCols||['period','subject','teacher','room','time'];
  var customCols=prefs.schedCustomCols||[];
  var hl=prefs.schedHighlight!==false;
  // Determine A or B day for today
  var todayDayType = (activeBell && activeBell.dayType) ? String(activeBell.dayType).toUpperCase() : '';
  var showAB = prefs.schedShowAB || 'auto'; // 'A','B','auto'
  var effectiveAB = showAB === 'auto' ? (todayDayType === 'B' ? 'B' : 'A') : showAB;
  // Build a banner if a non-default bell schedule is active
  var bannerHtml = '';
  if (activeBell && activeBell.hasOverride && activeBell.schedule) {
    var dayLbl = todayDayType ? ' &middot; '+todayDayType+' Day' : '';
    bannerHtml = '<div style="background:'+(activeBell.schedule.color||'var(--a3)')+'22;border:1px solid '+(activeBell.schedule.color||'var(--a4)')+';border-radius:8px;padding:6px 10px;margin-bottom:10px;font-size:11px;color:var(--tx2);display:flex;align-items:center;gap:8px;"><strong style="color:var(--tx);">'+esc(activeBell.schedule.name)+'</strong>'+dayLbl+(activeBell.notes?' &middot; <span style="color:var(--tx3);">'+esc(activeBell.notes)+'</span>':'')+'<button class="btn btn-ghost btn-sm" style="margin-left:auto;font-size:10px;padding:2px 7px;" onclick="toggleABView()">View '+(effectiveAB==='A'?'B':'A')+' Day</button></div>';
  } else if (mySchedule.some(function(p){return p.abDay;})) {
    bannerHtml = '<div style="background:var(--a5);border:1px solid var(--a4);border-radius:8px;padding:6px 10px;margin-bottom:10px;font-size:11px;color:var(--tx2);display:flex;align-items:center;gap:8px;">Showing <strong style="color:var(--a2);">'+effectiveAB+' Day</strong> classes<button class="btn btn-ghost btn-sm" style="margin-left:auto;font-size:10px;padding:2px 7px;" onclick="toggleABView()">Switch to '+(effectiveAB==='A'?'B':'A')+'</button></div>';
  }
  // Use bell schedule period times if active, otherwise the student's own times
  var bellPeriods = (activeBell && activeBell.schedule && activeBell.schedule.periods) ? activeBell.schedule.periods : [];
  function bellTimeFor(period){
    for (var i=0;i<bellPeriods.length;i++){
      if (String(bellPeriods[i].period)===String(period)) return bellPeriods[i];
    }
    return null;
  }
  var sorted=mySchedule.slice().sort(function(a,b){return Number(a.period)-Number(b.period);});
  var thead='<tr>';
  if(cols.indexOf('period')>-1)thead+='<th>#</th>';
  if(cols.indexOf('subject')>-1)thead+='<th>Subject</th>';
  if(cols.indexOf('teacher')>-1)thead+='<th>Teacher</th>';
  if(cols.indexOf('room')>-1)thead+='<th>Room</th>';
  if(cols.indexOf('time')>-1)thead+='<th>Time</th>';
  customCols.forEach(function(col){thead+='<th>'+esc(col.name)+'</th>';});
  thead+='</tr>';
  var rows=sorted.map(function(p){
    // Pick the right subject/teacher/room based on A/B day
    var displaySubj = p.subject||'';
    var displayTeach = p.teacher||'';
    var displayRoom = p.room||'';
    if (p.abDay && effectiveAB === 'B') {
      displaySubj = p.subjectB || p.subject || '';
      displayTeach = p.teacherB || p.teacher || '';
      displayRoom = p.roomB || p.room || '';
    }
    // Override times with bell schedule if available
    var bp = bellTimeFor(p.period);
    var startT = bp ? bp.startTime : (p.startTime||'');
    var endT = bp ? bp.endTime : (p.endTime||'');
    var pForCheck = {startTime:startT, endTime:endT};
    var on=isNowPeriod(pForCheck,cur);
    var lm=displaySubj.match(/^\[(.+?)\]\((https?:\/\/[^\)]+)\)$/);
    var subjHtml=lm
      ?'<a href="'+esc(lm[2])+'" target="_blank" style="color:var(--a2);text-decoration:none;" onmouseover="this.style.textDecoration=\'underline\'" onmouseout="this.style.textDecoration=\'none\'">'+esc(lm[1])+'</a>'
      :esc(displaySubj);
    var abBadge = p.abDay ? '<span style="font-size:9px;font-weight:700;background:var(--a5);border:1px solid var(--a4);color:var(--a2);border-radius:4px;padding:1px 5px;margin-left:5px;">'+effectiveAB+'</span>' : '';
    var rc=(on&&hl)?' class="sched-row-now"':'';
    var tr='<tr'+rc+'>';
    if(cols.indexOf('period')>-1)tr+='<td><span class="per-num">'+esc(String(p.period))+'</span></td>';
    if(cols.indexOf('subject')>-1)tr+='<td>'+subjHtml+abBadge+(on?'<span class="now-tag">Now</span>':'')+'</td>';
    if(cols.indexOf('teacher')>-1)tr+='<td class="muted">'+esc(displayTeach||'--')+'</td>';
    if(cols.indexOf('room')>-1)tr+='<td class="muted">'+esc(displayRoom||'--')+'</td>';
    if(cols.indexOf('time')>-1)tr+='<td class="muted">'+fmtTime(startT||'')+(endT?' – '+fmtTime(endT):'')+'</td>';
    customCols.forEach(function(col){
      var val=(p.custom&&p.custom[col.id])||'';
      tr+='<td class="muted">'+esc(val||'--')+'</td>';
    });
    tr+='</tr>';
    return tr;
  }).join('');
  el.innerHTML=bannerHtml+'<table class="sched-tbl"><thead>'+thead+'</thead><tbody>'+rows+'</tbody></table>';
}

