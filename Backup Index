function pickCdEmoji(el){document.querySelectorAll('.em-opt').forEach(function(e){e.classList.remove('sel');});el.classList.add('sel');}
function saveCd(){
  var name=document.getElementById('cd-name').value.trim(),date=document.getElementById('cd-date').value;
  if(!name||!date){toast('Fill in name and date','err');return;}
  var sel=document.querySelector('.em-opt.sel');var emoji=sel?sel.dataset.em:'&#127881;';
  if(!prefs.countdowns)prefs.countdowns=[];
  if(cdEditId){
    for(var i=0;i<prefs.countdowns.length;i++){if(prefs.countdowns[i].id===cdEditId){prefs.countdowns[i]={id:cdEditId,name:name,date:date,emoji:emoji};break;}}
    toast('Countdown updated','ok');
  } else {
    prefs.countdowns.push({id:'cd-'+Date.now()+'-'+Math.random().toString(36).slice(2,7),name:name,date:date,emoji:emoji});
    toast('Countdown added!','ok');
  }
  closeModal('cd-modal');renderCountdowns();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}
function deleteCd(id){
  prefs.countdowns=(prefs.countdowns||[]).filter(function(c){return c.id!==id;});
  closeModal('cd-modal');renderCountdowns();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  toast('Removed','inf');
