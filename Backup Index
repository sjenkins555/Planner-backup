  editingTaskId=null;renderTasks();
}
function saveEditTask(id){
  var titleEl=document.getElementById('te-title');
  var titleVal=titleEl?titleEl.value.trim():'';
  if(!titleVal){toast('Title is required','err');return;}
  var subjEl=document.getElementById('te-subj'),priEl=document.getElementById('te-pri');
  var dueEl=document.getElementById('te-due'),notesEl=document.getElementById('te-notes');
  var subjVal=subjEl?subjEl.value.trim():'',priVal=priEl?priEl.value:'medium';
  var dueVal=dueEl?dueEl.value:'',notesVal=notesEl?notesEl.value.trim():'';
  for(var i=0;i<myTasks.length;i++){
