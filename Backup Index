function renderScoresChart(){
  var el=document.getElementById('scores-chart');if(!el)return;
  var data=prefs.testingScores||{goal:null,entries:{}};
  var entries=data.entries||{};
  var goal=data.goal?Number(data.goal):null;
  var KEYS=['6-fall','6-winter','6-spring','7-fall','7-winter','7-spring','8-fall','8-winter','8-spring'];
  var S_LABELS=['Fall','Win','Spr','Fall','Win','Spr','Fall','Win','Spr'];
  var G_LABELS=['6th Grade','7th Grade','8th Grade'];
  var vals=KEYS.map(function(k){return entries[k]?Number(entries[k]):null;});
  var nonNull=vals.filter(function(v){return v!==null;});
  if(!nonNull.length&&!goal){
    el.innerHTML='<div class="empty" style="padding:20px 0;"><div class="empty-ico">&#128200;</div><p style="font-size:12px;">Click &#9881; Edit to enter scores.</p></div>';
    return;
  }
  var allVals=goal?nonNull.concat([goal]):nonNull;
  var rawMax=allVals.length?Math.max.apply(null,allVals):1200;
  var rawMin=allVals.length?Math.min.apply(null,allVals):400;
  var pad=Math.max(120,Math.ceil((rawMax-rawMin)*0.25));
  var maxV=Math.ceil((rawMax+pad)/50)*50;
  var minV=Math.max(0,Math.floor((rawMin-pad)/50)*50);
  var W=440,H=210,PL=48,PR=18,PT=22,PB=50;
  var cW=W-PL-PR,cH=H-PT-PB;
  function toX(i){return PL+i*(cW/8);}
  function toY(v){return PT+cH*(1-(v-minV)/(maxV-minV));}
  var svg='<svg viewBox="0 0 '+W+' '+H+'" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block;overflow:visible;">';
  // Y gridlines + labels
  for(var t=0;t<=4;t++){
    var tv=Math.round(minV+(maxV-minV)*t/4);
    var ty=toY(tv);
    svg+='<line x1="'+PL+'" y1="'+ty+'" x2="'+(W-PR)+'" y2="'+ty+'" stroke="rgba(255,255,255,.05)" stroke-width="1"/>';
    svg+='<text x="'+(PL-5)+'" y="'+(ty+4)+'" fill="rgba(148,163,184,.55)" font-size="9" text-anchor="end" font-family="DM Sans,sans-serif">'+tv+'</text>';
  }
  // Grade group bands
  [[0,2],[3,5],[6,8]].forEach(function(b,gi){
    var x1=toX(b[0])-(cW/8)*0.38,x2=toX(b[1])+(cW/8)*0.38;
    svg+='<rect x="'+x1+'" y="'+PT+'" width="'+(x2-x1)+'" height="'+cH+'" rx="4" fill="rgba(255,255,255,.02)"/>';
    svg+='<text x="'+((toX(b[0])+toX(b[1]))/2)+'" y="'+(H-7)+'" fill="rgba(99,102,241,.7)" font-size="9" font-weight="700" text-anchor="middle" font-family="DM Sans,sans-serif">'+G_LABELS[gi]+'</text>';
    if(gi<2){var sx=toX(b[1])+(cW/8)*0.5;svg+='<line x1="'+sx+'" y1="'+PT+'" x2="'+sx+'" y2="'+(PT+cH)+'" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="3,3"/>';}
  });
  // Goal dotted line
  if(goal){
    var clampedG=Math.max(minV,Math.min(maxV,goal));
    var gy=toY(clampedG);
    svg+='<line x1="'+PL+'" y1="'+gy+'" x2="'+(W-PR)+'" y2="'+gy+'" stroke="var(--a2)" stroke-width="1.5" stroke-dasharray="5,4" opacity=".9"/>';
    svg+='<rect x="'+(W-PR-36)+'" y="'+(gy-11)+'" width="36" height="13" rx="3" fill="rgba(14,22,44,.85)"/>';
    svg+='<text x="'+(W-PR-4)+'" y="'+(gy-2)+'" fill="var(--a2)" font-size="9" font-weight="700" text-anchor="end" font-family="DM Sans,sans-serif">'+goal+' L</text>';
  }
  // Build line segments (break at nulls)
  var segments=[],cur=[];
  for(var i=0;i<9;i++){
    if(vals[i]!==null){cur.push({x:toX(i),y:toY(vals[i]),v:vals[i]});}
    else{if(cur.length)segments.push(cur);cur=[];}
  }
  if(cur.length)segments.push(cur);
  // Area fill under each segment
  segments.forEach(function(seg,si){
    if(seg.length<1)return;
    var gradId='areag'+si;
    svg+='<defs><linearGradient id="'+gradId+'" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--a1)" stop-opacity=".3"/><stop offset="100%" stop-color="var(--a1)" stop-opacity=".01"/></linearGradient></defs>';
    var aPath='M '+seg[0].x+' '+(PT+cH);
    seg.forEach(function(p){aPath+=' L '+p.x+' '+p.y;});
    aPath+=' L '+seg[seg.length-1].x+' '+(PT+cH)+' Z';
    svg+='<path d="'+aPath+'" fill="url(#'+gradId+')" />';
  });
  // Lines
  segments.forEach(function(seg){
    if(seg.length<2)return;
    var d='M '+seg[0].x+' '+seg[0].y;
    seg.forEach(function(p,pi){if(pi>0)d+=' L '+p.x+' '+p.y;});
    svg+='<path d="'+d+'" fill="none" stroke="var(--a1)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>';
    svg+='<path d="'+d+'" fill="none" stroke="var(--a2)" stroke-width="1" stroke-linejoin="round" stroke-linecap="round" opacity=".45"/>';
  });
  // Dots, value labels, and x-axis labels
  for(var i=0;i<9;i++){
    var x=toX(i);
    if(vals[i]!==null){
      var y=toY(vals[i]);
      svg+='<circle cx="'+x+'" cy="'+y+'" r="5" fill="var(--a1)" stroke="#0f172a" stroke-width="2.5"/>';
      svg+='<circle cx="'+x+'" cy="'+y+'" r="2.5" fill="var(--a2)"/>';
      var lblY=(y<PT+16)?y+18:y-10;
      svg+='<text x="'+x+'" y="'+lblY+'" fill="var(--a2)" font-size="9" font-weight="700" text-anchor="middle" font-family="DM Sans,sans-serif">'+vals[i]+'</text>';
    } else {
      svg+='<circle cx="'+x+'" cy="'+(PT+cH/2)+'" r="3.5" fill="none" stroke="rgba(255,255,255,.1)" stroke-width="1.5" stroke-dasharray="2,2"/>';
    }
    svg+='<text x="'+x+'" y="'+(PT+cH+15)+'" fill="rgba(148,163,184,.5)" font-size="8" text-anchor="middle" font-family="DM Sans,sans-serif">'+S_LABELS[i]+'</text>';
  }
  // Axes
  svg+='<line x1="'+PL+'" y1="'+PT+'" x2="'+PL+'" y2="'+(PT+cH)+'" stroke="rgba(255,255,255,.12)" stroke-width="1"/>';
  svg+='<line x1="'+PL+'" y1="'+(PT+cH)+'" x2="'+(W-PR)+'" y2="'+(PT+cH)+'" stroke="rgba(255,255,255,.12)" stroke-width="1"/>';
  svg+='<text x="12" y="'+(PT+cH/2)+'" fill="rgba(148,163,184,.45)" font-size="9" text-anchor="middle" font-family="DM Sans,sans-serif" transform="rotate(-90,12,'+(PT+cH/2)+')">Lexile</text>';
  svg+='</svg>';
  el.innerHTML=svg;
}
