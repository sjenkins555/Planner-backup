  else if(_us==='sporty'&&(bt==='default'||!bt)){bg.style.background='#0e1633';bg.style.backgroundImage='none';bg.style.backgroundSize='';ov.style.background='transparent';}
  else if(_us==='zen-dark'&&(bt==='default'||!bt)){bg.style.background='#111110';bg.style.backgroundImage='none';bg.style.backgroundSize='';ov.style.background='transparent';}
  else if(_us==='notebook-dark'){bg.style.background='#0d1220';bg.style.backgroundImage='repeating-linear-gradient(0deg,transparent 0,transparent 27px,rgba(255,255,255,.04) 28px)';bg.style.backgroundSize='100% 28px';ov.style.background='transparent';}
