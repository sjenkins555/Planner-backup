// ── AUTO-REFRESH ON TAB FOCUS ─────────────────────────────────
// Each entry: {id, fn, minMinutes, lastRun}
// fn runs when the tab regains focus AND minMinutes have passed since lastRun.
// Add new widgets here as they need refresh logic.
var _autoRefreshTargets = [];
var _autoRefreshLastFocusCheck = Date.now();

function registerAutoRefresh(id, fn, minMinutes){
  // Avoid duplicate registration
  for (var i = 0; i < _autoRefreshTargets.length; i++){
    if (_autoRefreshTargets[i].id === id){
      _autoRefreshTargets[i].fn = fn;
      _autoRefreshTargets[i].minMinutes = minMinutes;
      return;
    }
  }
  _autoRefreshTargets.push({id:id, fn:fn, minMinutes:minMinutes||10, lastRun:Date.now()});
}

function _checkAutoRefresh(){
  if (document.hidden) return;
  var now = Date.now();
  _autoRefreshTargets.forEach(function(t){
    var elapsedMin = (now - t.lastRun) / 60000;
    if (elapsedMin >= t.minMinutes){
      try { t.fn(); } catch(e) { console.warn('Auto-refresh failed for '+t.id, e); }
      t.lastRun = now;
    }
  });
}

document.addEventListener('visibilitychange', function(){
  if (!document.hidden) _checkAutoRefresh();
});
window.addEventListener('focus', _checkAutoRefresh);

