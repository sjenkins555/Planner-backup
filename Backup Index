var _lastTs=null;
function timerToggle(){
  timerState.running=!timerState.running;var btn=document.getElementById('timer-start-btn');if(btn)btn.textContent=timerState.running?'Pause':'Start';
  if(timerState.running){if(timerState.mode==='timer'&&timerState.elapsed===0){var mIn=document.getElementById('t-min'),sIn=document.getElementById('t-sec');timerState.target=((parseInt(mIn?mIn.value:5)||0)*60+(parseInt(sIn?sIn.value:0)||0))*1000;}_lastTs=performance.now();timerTick();}
  else{cancelAnimationFrame(timerState.raf);}
}
function timerTick(){if(!timerState.running)return;var now=performance.now(),delta=now-(_lastTs||now);_lastTs=now;timerState.elapsed+=delta;if(timerState.mode==='timer'&&timerState.elapsed>=timerState.target){timerState.elapsed=timerState.target;timerState.running=false;updateTimerDisplay();var btn=document.getElementById('timer-start-btn');if(btn)btn.textContent='Start';toast("Time's up!",'ok');return;}updateTimerDisplay();timerState.raf=requestAnimationFrame(timerTick);}
function updateTimerDisplay(){
  var isTimer=timerState.mode==='timer',ms=isTimer?Math.max(0,timerState.target-timerState.elapsed):timerState.elapsed,total=Math.floor(ms/1000),m=Math.floor(total/60),s=total%60;
  var el=document.getElementById('timer-disp');if(el)el.textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  var pct=timerState.target>0?(isTimer?1-timerState.elapsed/timerState.target:timerState.elapsed/timerState.target):0;
  var ring=document.getElementById('timer-ring');
  if(ring){var style=prefs.timerStyle||'circle';if(style==='circle'){ring.setAttribute('stroke-dashoffset',(2*Math.PI*60)*(1-Math.min(pct,1)));}else if(style==='bar'){ring.style.width=(Math.min(pct,1)*100)+'%';}}
}
function timerReset(){cancelAnimationFrame(timerState.raf);timerState.running=false;timerState.elapsed=0;timerState.laps=[];updateTimerDisplay();var btn=document.getElementById('timer-start-btn');if(btn)btn.textContent='Start';var ll=document.getElementById('lap-list');if(ll)ll.innerHTML='';}
function timerLap(){if(!timerState.running&&timerState.elapsed===0)return;var lapTime=timerState.elapsed-timerState.lapStart;timerState.lapStart=timerState.elapsed;var total=Math.floor(lapTime/1000),m=Math.floor(total/60),s=total%60;timerState.laps.push(String(m).padStart(2,'0')+':'+String(s).padStart(2,'0'));var ll=document.getElementById('lap-list');if(ll)ll.innerHTML=timerState.laps.map(function(l,i){return '<div class="lap-row"><span>Lap '+(i+1)+'</span><span>'+l+'</span></div>';}).reverse().join('');}

// ══════════════════════════════════════════════════════════════
// CALENDAR — Custom themed views (month / week / agenda)
// Pulls events from Google Calendar API, renders in design system.
// Mark-done state stored in EventStatus sheet (per user, per event).
// ══════════════════════════════════════════════════════════════
var calMode = 'month';
var calCursor = null;        // Date — anchor for current view
var _calCalendars = [];      // user's calendars
var _calEvents = [];         // events for current visible range
var _calDoneMap = {};        // { eventId: true }
var _calCache = {};          // key -> { events, calendars, statuses, fetchedAt }
var _calCacheTTL = 60000;    // 1 min
var _calCurrentEvent = null;
var _calEditMode = false;

function buildCalPage(){
  var pid = CU.role === 'teacher' ? 'my-cal' : 'cal';
  calMode = prefs.calMode || 'month';
  if (!prefs.hiddenCals) prefs.hiddenCals = [];
  if (!calCursor) calCursor = new Date();
  panel(pid).innerHTML =
    '<div class="cal-shell">' +
      '<div class="cal-toolbar">' +
        '<button class="cal-nav-btn" onclick="calNav(-1)" title="Previous">&lsaquo;</button>' +
        '<button class="cal-today-btn" onclick="calGoToday()">Today</button>' +
        '<button class="cal-nav-btn" onclick="calNav(1)" title="Next">&rsaquo;</button>' +
        '<div class="cal-title" id="cal-title">&mdash;</div>' +
        '<div class="cal-view-seg">' +
          '<button class="cal-view-opt" id="cv-month"  onclick="setCalView(\'month\')">Month</button>' +
          '<button class="cal-view-opt" id="cv-week"   onclick="setCalView(\'week\')">Week</button>' +
          '<button class="cal-view-opt" id="cv-agenda" onclick="setCalView(\'agenda\')">Agenda</button>' +
        '</div>' +
      '</div>' +
      '<div class="cal-body">' +
        '<div class="cal-side">' +
          '<button class="cal-new-btn" onclick="openCalCreate()">+ New Event</button>' +
          '<div class="cal-side-title">My Calendars</div>' +
          '<div id="cal-list-area"><div style="font-size:11px;color:var(--tx4);">Loading...</div></div>' +
          '<div class="cal-side-title">Quick</div>' +
          '<button class="btn btn-ghost btn-sm" style="width:100%;justify-content:center;font-size:11px;margin-bottom:6px;" onclick="reloadCal()">&#8635; Refresh</button>' +
          '<a href="https://calendar.google.com" target="_blank" class="btn btn-ghost btn-sm" style="width:100%;justify-content:center;font-size:11px;">Open in Google</a>' +
        '</div>' +
        '<div class="cal-main-area">' +
          '<div class="cal-load-overlay" id="cal-load"><div class="spinner"></div></div>' +
          '<div id="cal-view-host" style="display:flex;flex-direction:column;flex:1;min-height:0;"></div>' +
        '</div>' +
      '</div>' +
    '</div>';
  highlightCalView(calMode);
  updateCalTitle();
  loadCalendarPageData();
}

function setCalView(m){
  calMode = m;
  prefs.calMode = m;
  highlightCalView(m);
  updateCalTitle();
  loadCalendarPageData();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}

function highlightCalView(m){
  ['month','week','agenda'].forEach(function(x){
    var b = document.getElementById('cv-'+x);
    if (b) b.classList.toggle('sel', x === m);
  });
}

function calGoToday(){ calCursor = new Date(); updateCalTitle(); loadCalendarPageData(); }

function calNav(dir){
  if (!calCursor) calCursor = new Date();
  var d = new Date(calCursor);
  if (calMode === 'month') { d.setDate(1); d.setMonth(d.getMonth() + dir); }
  else if (calMode === 'week') { d.setDate(d.getDate() + 7 * dir); }
  else { d.setDate(d.getDate() + 14 * dir); }
  calCursor = d;
  updateCalTitle();
  loadCalendarPageData();
}

function updateCalTitle(){
  var el = document.getElementById('cal-title');
  if (!el) return;
  var d = calCursor || new Date();
  if (calMode === 'month') {
    el.textContent = MONTHS[d.getMonth()] + ' ' + d.getFullYear();
  } else if (calMode === 'week') {
    var r = _calVisibleRange();
    var s = new Date(r.start), e = new Date(r.end); e.setDate(e.getDate() - 1);
    if (s.getMonth() === e.getMonth()) {
      el.textContent = MSHRT[s.getMonth()] + ' ' + s.getDate() + '\u2013' + e.getDate() + ', ' + s.getFullYear();
    } else {
      el.textContent = MSHRT[s.getMonth()] + ' ' + s.getDate() + ' \u2013 ' + MSHRT[e.getMonth()] + ' ' + e.getDate();
    }
  } else {
    var s = new Date(d); s.setHours(0,0,0,0);
    var e = new Date(s); e.setDate(e.getDate() + 14);
    el.textContent = MSHRT[s.getMonth()] + ' ' + s.getDate() + ' \u2013 ' + MSHRT[e.getMonth()] + ' ' + e.getDate();
  }
}

function _calVisibleRange(){
  var d = calCursor || new Date();
  if (calMode === 'month') {
    var first = new Date(d.getFullYear(), d.getMonth(), 1);
    var start = new Date(first); start.setDate(first.getDate() - first.getDay());
    var end = new Date(start); end.setDate(start.getDate() + 42);
    return {start: start, end: end};
  }
  if (calMode === 'week') {
    var start = new Date(d); start.setDate(d.getDate() - d.getDay()); start.setHours(0,0,0,0);
    var end = new Date(start); end.setDate(start.getDate() + 7);
    return {start: start, end: end};
  }
  var s = new Date(d); s.setHours(0,0,0,0);
  var e = new Date(s); e.setDate(e.getDate() + 14);
  return {start: s, end: e};
}

function _cacheKey(){
  var r = _calVisibleRange();
  return calMode + '|' + r.start.toISOString() + '|' + r.end.toISOString() + '|' + (prefs.hiddenCals || []).slice().sort().join(',');
}

function showCalLoading(on){
  var el = document.getElementById('cal-load');
  if (el) el.classList.toggle('visible', !!on);
}

function loadCalendarPageData(){
  var range = _calVisibleRange();
  var key = _cacheKey();
  var cached = _calCache[key];
  if (cached && (Date.now() - cached.fetchedAt) < _calCacheTTL) {
    _calEvents = cached.events;
    _calCalendars = cached.calendars || _calCalendars;
    _calDoneMap = cached.statuses || _calDoneMap;
    renderCalSidebar();
    renderCurrentView();
    return;
  }
  showCalLoading(true);
  google.script.run
    .withSuccessHandler(function(r){
      showCalLoading(false);
      if (!r) { calShowError('No response from server.'); return; }
      if (r.error) { calShowError(r.error); return; }
      _calCalendars = r.calendars || [];
      _calEvents = r.events || [];
      _calDoneMap = r.statuses || {};
      if (r.eventsError) {
        calShowError(r.eventsError);
        return;
      }
      _calCache[key] = {
        events: _calEvents,
        calendars: _calCalendars,
        statuses: _calDoneMap,
        fetchedAt: Date.now()
      };
      renderCalSidebar();
      renderCurrentView();
    })
    .withFailureHandler(function(e){
      showCalLoading(false);
      calShowError(e.message || 'Failed to load calendar data.');
    })
    .getCalendarPageData(range.start.toISOString(), range.end.toISOString(), JSON.stringify(prefs.hiddenCals || []));
}

function calShowError(msg){
  var host = document.getElementById('cal-view-host');
  if (host) host.innerHTML = '<div style="padding:30px;text-align:center;color:#f87171;font-size:13px;line-height:1.7;">' + esc(msg) + '<br><br><button class="btn btn-ghost btn-sm" onclick="reloadCal()">Retry</button></div>';
}

function reloadCal(){
  delete _calCache[_cacheKey()];
  loadCalendarPageData();
}

function renderCalSidebar(){
  var area = document.getElementById('cal-list-area');
  if (!area) return;
  if (!_calCalendars.length) {
    area.innerHTML = '<div style="font-size:11px;color:var(--tx4);">No calendars found.</div>';
    return;
  }
  var hidden = prefs.hiddenCals || [];
  area.innerHTML = _calCalendars.map(function(c){
    var off = hidden.indexOf(c.id) > -1;
    return '<div class="cal-list-row' + (off ? ' off' : '') + '" onclick="toggleCalendarById(\'' + esc(c.id) + '\')" title="' + esc(c.name) + '">' +
      '<div class="cal-list-sw" style="background:' + esc(c.color) + ';"></div>' +
      '<div class="cal-list-name">' + esc(c.name) + '</div>' +
    '</div>';
  }).join('');
}

function toggleCalendarById(id){
  if (!prefs.hiddenCals) prefs.hiddenCals = [];
  var idx = prefs.hiddenCals.indexOf(id);
  if (idx > -1) prefs.hiddenCals.splice(idx, 1);
  else prefs.hiddenCals.push(id);
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  renderCalSidebar();
  reloadCal();
}

// ─── VIEW RENDERING ──────────────────────────────────────────
function renderCurrentView(){
  var host = document.getElementById('cal-view-host');
  if (!host) return;
  if (calMode === 'month') host.innerHTML = renderMonthHTML();
  else if (calMode === 'week') host.innerHTML = renderWeekHTML();
  else host.innerHTML = renderAgendaHTML();
}

function renderMonthHTML(){
  var range = _calVisibleRange();
  var first = new Date(calCursor.getFullYear(), calCursor.getMonth(), 1);
  var thisMonth = first.getMonth();
  var todayStr = _ymdLocal(new Date());
  var byDay = {};
  _calEvents.forEach(function(ev){
    var k = _ymdLocal(new Date(ev.start));
    if (!byDay[k]) byDay[k] = [];
    byDay[k].push(ev);
  });
  Object.keys(byDay).forEach(function(k){
    byDay[k].sort(function(a, b){ return new Date(a.start) - new Date(b.start); });
  });
  var DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var head = '<div class="cal-month-head">' + DAYS_SHORT.map(function(d){ return '<div>' + d + '</div>'; }).join('') + '</div>';
  var cells = '';
  var d = new Date(range.start);
  for (var i = 0; i < 42; i++) {
    var k = _ymdLocal(d);
    var inMonth = d.getMonth() === thisMonth;
    var isToday = k === todayStr;
    var evs = byDay[k] || [];
    var maxShow = 3;
    var shown = evs.slice(0, maxShow);
    var more = evs.length - maxShow;
    var evHtml = shown.map(function(ev){
      var done = !!_calDoneMap[ev.id];
      var bg = ev.calendarColor || '#6366f1';
      return '<div class="cal-ev' + (done ? ' done' : '') + '" style="background:' + bg + '22;border-left-color:' + bg + ';" ' +
             'onclick="event.stopPropagation();openCalEventDetail(\'' + esc(ev.id) + '\')" title="' + esc(ev.title) + '">' + esc(ev.title) + '</div>';
    }).join('');
    if (more > 0) evHtml += '<div class="cal-more" onclick="event.stopPropagation();showDayEvents(\'' + k + '\')">+' + more + ' more</div>';
    cells += '<div class="cal-cell' + (inMonth ? '' : ' other-mo') + (isToday ? ' today' : '') + '" onclick="openCalCreateForDate(\'' + k + '\')">' +
      '<div class="cal-day-num">' + d.getDate() + '</div>' + evHtml +
    '</div>';
    d.setDate(d.getDate() + 1);
  }
  return '<div class="cal-month">' + head + '<div class="cal-month-grid">' + cells + '</div></div>';
}

function renderWeekHTML(){
  var range = _calVisibleRange();
  var todayStr = _ymdLocal(new Date());
  var DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var headCells = '<div></div>';
  var i;
  for (i = 0; i < 7; i++) {
    var d = new Date(range.start); d.setDate(d.getDate() + i);
    var k = _ymdLocal(d);
    var cls = (k === todayStr) ? ' class="today"' : '';
    headCells += '<div' + cls + '>' + DAYS_SHORT[d.getDay()] + '<span class="wd-num">' + d.getDate() + '</span></div>';
  }
  var timeStart = 6, timeEnd = 22;
  var hours = '', h;
  for (h = timeStart; h < timeEnd; h++) {
    var label = (prefs.timeFormat === '24h') ? (String(h).padStart(2,'0') + ':00') : ((h % 12 || 12) + (h < 12 ? 'a' : 'p'));
    hours += '<div class="cal-hr">' + label + '</div>';
  }
  var dayCols = '';
  for (i = 0; i < 7; i++) {
    var dd = new Date(range.start); dd.setDate(dd.getDate() + i);
    var kk = _ymdLocal(dd);
    var dayHrs = '';
    for (h = timeStart; h < timeEnd; h++) dayHrs += '<div class="cal-hr"></div>';
    var dayEvts = _calEvents.filter(function(ev){ return _ymdLocal(new Date(ev.start)) === kk && !ev.allDay; });
    var evHtml = dayEvts.map(function(ev){
      var s = new Date(ev.start), e = new Date(ev.end || ev.start);
      var startMin = (s.getHours() - timeStart) * 60 + s.getMinutes();
      var endMin   = (e.getHours() - timeStart) * 60 + e.getMinutes();
      if (endMin <= startMin) endMin = startMin + 30;
      var top = startMin * (42/60);
      var height = Math.max(20, (endMin - startMin) * (42/60));
      var done = !!_calDoneMap[ev.id];
      var bg = ev.calendarColor || '#6366f1';
      var timeLbl = _fmtTimeLocal(s) + ' \u2013 ' + _fmtTimeLocal(e);
      return '<div class="cal-week-ev' + (done ? ' done' : '') + '" style="top:' + top + 'px;height:' + height + 'px;background:' + bg + '22;border-left-color:' + bg + ';" ' +
        'onclick="event.stopPropagation();openCalEventDetail(\'' + esc(ev.id) + '\')">' +
        '<span class="ev-time">' + timeLbl + '</span>' +
        '<span class="ev-title">' + esc(ev.title) + '</span>' +
      '</div>';
    }).join('');
    dayCols += '<div class="cal-day-col" onclick="openCalCreateForDate(\'' + kk + '\')">' + dayHrs + evHtml + '</div>';
  }
  return '<div class="cal-week">' +
    '<div class="cal-week-head">' + headCells + '</div>' +
    '<div class="cal-week-grid">' +
      '<div class="cal-week-time-col">' + hours + '</div>' +
      dayCols +
    '</div>' +
  '</div>';
}

function renderAgendaHTML(){
  if (!_calEvents.length) {
    return '<div class="cal-agenda"><div class="cal-agenda-empty">No upcoming events.</div></div>';
  }
  var todayStr = _ymdLocal(new Date());
  var byDay = {};
  _calEvents.forEach(function(ev){
    var k = _ymdLocal(new Date(ev.start));
    if (!byDay[k]) byDay[k] = [];
    byDay[k].push(ev);
  });
  var keys = Object.keys(byDay).sort();
  var html = '<div class="cal-agenda">';
  keys.forEach(function(k){
    var evs = byDay[k].sort(function(a, b){ return new Date(a.start) - new Date(b.start); });
    var d = new Date(k + 'T12:00:00');
    var isToday = k === todayStr;
    var label = DAYS[d.getDay()] + ', ' + MSHRT[d.getMonth()] + ' ' + d.getDate() + (isToday ? ' (Today)' : '');
    html += '<div class="cal-agenda-day">' +
      '<div class="cal-agenda-date' + (isToday ? ' today' : '') + '">' + label + '</div>' +
      evs.map(function(ev){
        var done = !!_calDoneMap[ev.id];
        var bg = ev.calendarColor || '#6366f1';
        var s = new Date(ev.start);
        var timeLbl = ev.allDay ? 'All day' : _fmtTimeLocal(s);
        return '<div class="cal-agenda-row' + (done ? ' done' : '') + '" style="border-left-color:' + bg + ';" onclick="openCalEventDetail(\'' + esc(ev.id) + '\')">' +
          '<div class="cal-agenda-time">' + timeLbl + '</div>' +
          '<div class="cal-agenda-title">' + esc(ev.title) + '</div>' +
          '<div class="cal-agenda-cal">' + esc(ev.calendarName || '') + '</div>' +
        '</div>';
      }).join('') +
    '</div>';
  });
  html += '</div>';
  return html;
}

function _ymdLocal(d){
  var y = d.getFullYear();
  var m = String(d.getMonth() + 1).padStart(2, '0');
  var dd = String(d.getDate()).padStart(2, '0');
  return y + '-' + m + '-' + dd;
}

function _fmtTimeLocal(d){
  var h = d.getHours(), m = d.getMinutes();
  if (prefs.timeFormat === '24h') return String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0');
  var ap = h >= 12 ? 'pm' : 'am';
  h = h % 12 || 12;
  return h + (m === 0 ? '' : ':' + String(m).padStart(2,'0')) + ap;
}

// ─── EVENT DETAIL MODAL ──────────────────────────────────────
function openCalEventDetail(eventId){
  var ev = null;
  for (var i = 0; i < _calEvents.length; i++) if (_calEvents[i].id === eventId) { ev = _calEvents[i]; break; }
  if (!ev) { toast('Event not found','err'); return; }
  _calCurrentEvent = ev;
  var done = !!_calDoneMap[ev.id];
  var bodyEl = document.getElementById('ev-detail-body');
  if (!bodyEl) return;
  var s = new Date(ev.start), e = new Date(ev.end || ev.start);
  var dateStr = DAYS[s.getDay()] + ', ' + MONTHS[s.getMonth()] + ' ' + s.getDate() + ', ' + s.getFullYear();
  var timeStr = ev.allDay ? 'All day' : (_fmtTimeLocal(s) + ' \u2013 ' + _fmtTimeLocal(e));
  var calColor = ev.calendarColor || '#6366f1';
  var html = '<div class="ev-cal-pill"><div class="pill-dot" style="background:' + esc(calColor) + ';"></div><span>' + esc(ev.calendarName || 'Calendar') + '</span></div>' +
    '<div style="font-size:18px;font-weight:600;color:var(--tx);margin-bottom:6px;line-height:1.3;">' + esc(ev.title) + '</div>' +
    '<div class="ev-detail-row"><span class="ev-icon">&#128197;</span><div class="ev-text">' + esc(dateStr) + '<br><span style="color:var(--tx3);font-size:12px;">' + esc(timeStr) + '</span></div></div>';
  if (ev.location) html += '<div class="ev-detail-row"><span class="ev-icon">&#128205;</span><div class="ev-text">' + esc(ev.location) + '</div></div>';
  if (ev.description) html += '<div class="ev-detail-row"><span class="ev-icon">&#128221;</span><div class="ev-text" style="white-space:pre-wrap;">' + esc(ev.description) + '</div></div>';
  html += '<div class="ev-done-toggle' + (done ? ' done' : '') + '" id="ev-done-toggle" onclick="toggleEventDone()">' +
    '<input type="checkbox" id="ev-done-cb" ' + (done ? 'checked' : '') + ' onclick="event.stopPropagation();toggleEventDone()">' +
    '<span class="ev-done-toggle-lbl">Mark as done</span>' +
  '</div>';
  if (ev.recurring) {
    html += '<div class="ev-recurring-note">This is a recurring event. To edit or delete it, open it in Google Calendar.</div>';
  }
  bodyEl.innerHTML = html;
  var footEl = document.getElementById('ev-detail-foot');
  if (footEl) {
    if (ev.recurring) {
      footEl.innerHTML = '<button class="btn btn-ghost" onclick="closeModal(\'ev-detail-modal\')">Close</button>' +
        '<a class="btn btn-primary" target="_blank" href="' + esc(ev.htmlLink) + '">Edit in Google</a>';
    } else {
      footEl.innerHTML = '<button class="btn btn-ghost" onclick="closeModal(\'ev-detail-modal\')">Close</button>' +
        '<button class="btn btn-danger btn-sm" onclick="confirmDeleteEvent()">Delete</button>' +
        '<button class="btn btn-primary" onclick="openCalEdit()">Edit</button>';
    }
  }
  openModal('ev-detail-modal');
}

function toggleEventDone(){
  if (!_calCurrentEvent) return;
  var ev = _calCurrentEvent;
  var newState = !_calDoneMap[ev.id];
  _calDoneMap[ev.id] = newState;
  var toggle = document.getElementById('ev-done-toggle');
  var cb = document.getElementById('ev-done-cb');
  if (toggle) toggle.classList.toggle('done', newState);
  if (cb) cb.checked = newState;
  google.script.run
    .withSuccessHandler(function(r){
      if (!r || !r.success) {
        _calDoneMap[ev.id] = !newState;
        if (toggle) toggle.classList.toggle('done', !newState);
        if (cb) cb.checked = !newState;
        toast('Could not save status','err');
        return;
      }
      Object.keys(_calCache).forEach(function(k){
        if (_calCache[k].statuses) _calCache[k].statuses[ev.id] = newState;
      });
      renderCurrentView();
    })
    .withFailureHandler(function(){
      _calDoneMap[ev.id] = !newState;
      if (toggle) toggle.classList.toggle('done', !newState);
      if (cb) cb.checked = !newState;
      toast('Could not save status','err');
    })
    .setEventStatus(ev.id, newState);
}

// ─── CREATE / EDIT MODAL ─────────────────────────────────────
function openCalCreate(){
  _calEditMode = false;
  _calCurrentEvent = null;
  var ds = _ymdLocal(calCursor || new Date());
  fillCalForm({
    title:'', description:'', location:'',
    date: ds, startTime:'09:00', endTime:'10:00',
    calendarId: (_calCalendars[0] ? _calCalendars[0].id : 'primary')
  });
  document.getElementById('ev-form-title').textContent = 'New Event';
  document.getElementById('ev-form-save').textContent = 'Create Event';
  openModal('ev-form-modal');
  setTimeout(function(){ var t = document.getElementById('evf-title'); if(t) t.focus(); }, 60);
}

function openCalCreateForDate(dateStr){
  _calEditMode = false;
  _calCurrentEvent = null;
  fillCalForm({
    title:'', description:'', location:'',
    date: dateStr, startTime:'09:00', endTime:'10:00',
    calendarId: (_calCalendars[0] ? _calCalendars[0].id : 'primary')
  });
  document.getElementById('ev-form-title').textContent = 'New Event';
  document.getElementById('ev-form-save').textContent = 'Create Event';
  openModal('ev-form-modal');
  setTimeout(function(){ var t = document.getElementById('evf-title'); if(t) t.focus(); }, 60);
}

function openCalEdit(){
  if (!_calCurrentEvent) return;
  var ev = _calCurrentEvent;
  if (ev.recurring) { window.open(ev.htmlLink, '_blank'); return; }
  _calEditMode = true;
  var s = new Date(ev.start), e = new Date(ev.end || ev.start);
  fillCalForm({
    title: ev.title,
    description: ev.description || '',
    location: ev.location || '',
    date: _ymdLocal(s),
