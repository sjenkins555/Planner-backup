function repairSheets() {
  const ss = SpreadsheetApp.openById('1G1J9nhaEonNnD5rQq3YRqh1KatuAwlcHd5yDb99db9Y');
  const required = allSheetDefs();
  const created = [];
  for (const [name, headers] of Object.entries(required)) {
    let sheet = ss.getSheetByName(name);
    if (!sheet) {
      sheet = ss.insertSheet(name);
      sheet.getRange(1,1,1,headers.length).setValues([headers]);
      sheet.getRange(1,1,1,headers.length).setFontWeight('bold').setBackground('#1a1d2e').setFontColor('#e2e8f0');
      created.push(name);
    }
  }
  ensureConfigRows(ss.getSheetByName('Config'));
  SpreadsheetApp.getUi().alert(created.length
    ? '✅ Repair complete!\n\nCreated: ' + created.join(', ') + '\n\nUpdate your email in the Config sheet!'
    : '✅ All sheets present — nothing needed repairing!');
}

