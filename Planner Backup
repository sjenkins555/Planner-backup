// ─── CALENDAR LIST ─────────────────────────────────────────────
// Returns the user's Google Calendar list so the front-end can show toggles.
// Requires the Calendar advanced service to be enabled, OR falls back gracefully.
function getMyCalendars() {
  try {
    var cals = [];
    // Try the Calendar API advanced service first (must be enabled in Apps Script)
    if (typeof Calendar !== 'undefined' && Calendar.CalendarList) {
      var list = Calendar.CalendarList.list({minAccessRole: 'reader', maxResults: 50});
      if (list && list.items) {
        list.items.forEach(function(c) {
          cals.push({
            id: c.id,
            name: c.summary || c.id,
            color: c.backgroundColor || '#6366f1',
            primary: !!c.primary
          });
        });
        // Put primary first
        cals.sort(function(a,b){ return (b.primary?1:0)-(a.primary?1:0); });
        return cals;
      }
    }
    // Fallback: use CalendarApp (always available, gives less detail)
    var calApp = CalendarApp.getAllCalendars();
    calApp.forEach(function(c) {
      cals.push({
        id: c.getId(),
        name: c.getName(),
        color: c.getColor() || '#6366f1',
        primary: c.getId() === getEmail()
      });
    });
    cals.sort(function(a,b){ return (b.primary?1:0)-(a.primary?1:0); });
    return cals;
  } catch(e) {
    // Return just the primary calendar so the page still works
    var email = getEmail();
    return [{id: email, name: 'My Calendar', color: '#6366f1', primary: true}];
  }
}

