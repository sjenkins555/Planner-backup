// ─── FLASHCARDS ───────────────────────────────────────────────
function getMyFlashcardSets() {
  const email=getEmail(); const sheet=getSheet('Flashcards'); if(!sheet) return [];
  const data=sheet.getDataRange().getValues(); const sets=[];
  for(let i=1;i<data.length;i++){
    if(data[i][0]===email){try{sets.push({name:data[i][1],cards:JSON.parse(data[i][2]||'[]')});}catch(e){sets.push({name:data[i][1],cards:[]});}}
  }
  return sets;
}
function saveFlashcardSet(setName,cardsJson) {
  const email=getEmail(); const sheet=getSheet('Flashcards'); if(!sheet) return{success:false};
  const data=sheet.getDataRange().getValues();
  for(let i=1;i<data.length;i++){if(data[i][0]===email&&data[i][1]===setName){sheet.getRange(i+1,3).setValue(cardsJson);return{success:true};}}
  sheet.appendRow([email,setName,cardsJson]); return{success:true};
}
function deleteFlashcardSet(setName) {
  const email=getEmail(); const sheet=getSheet('Flashcards'); if(!sheet) return{success:false};
  const data=sheet.getDataRange().getValues();
  for(let i=1;i<data.length;i++){if(data[i][0]===email&&data[i][1]===setName){sheet.deleteRow(i+1);return{success:true};}}
  return{success:false};
}

