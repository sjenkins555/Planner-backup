  return e;
}
function safeDate(val) {
  if(!val) return '';
  try{return Utilities.formatDate(new Date(val),Session.getScriptTimeZone(),'yyyy-MM-dd');}catch(e){return String(val);}
}

// ─── FIX: safeTime converts Sheets time fractions/Dates to HH:MM strings ─────
function safeTime(val) {
  if (val === null || val === undefined || val === '') return '';
  // Google Sheets stores times as a decimal fraction of 24 hours (e.g. 0.333 = 08:00)
  if (typeof val === 'number') {
    var totalMin = Math.round(val * 24 * 60);
    var h = Math.floor(totalMin / 60) % 24;
    var m = totalMin % 60;
    return String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0');
  }
  // Date objects (also possible depending on sheet format)
  if (val instanceof Date) {
    return String(val.getHours()).padStart(2,'0') + ':' + String(val.getMinutes()).padStart(2,'0');
  }
  // Already a string — return as-is
  return String(val);
}

