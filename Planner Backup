// ─── SETUP ────────────────────────────────────────────────────
function setupSpreadsheet() {
  const ss=SpreadsheetApp.openById('1G1J9nhaEonNnD5rQq3YRqh1KatuAwlcHd5yDb99db9Y');
  const defs=allSheetDefs();
  const firstRowData={
    'Config':[['Key','Value'],['TEACHER_EMAILS','yourname@yourdomain.edu'],['APP_NAME','Cedar Hollow Planner']]
  };
  for(const [name,headers] of Object.entries(defs)){
    let sheet=ss.getSheetByName(name);
    if(!sheet) sheet=ss.insertSheet(name); else sheet.clear();
    const rows=firstRowData[name]||[headers];
    sheet.getRange(1,1,rows.length,rows[0].length).setValues(rows);
    sheet.getRange(1,1,1,rows[0].length).setFontWeight('bold').setBackground('#1a1d2e').setFontColor('#e2e8f0');
  }
  const d=ss.getSheetByName('Sheet1');if(d)ss.deleteSheet(d);
  SpreadsheetApp.getUi().alert('✅ Setup complete!\n\n1. Open Config sheet, replace placeholder teacher email.\n2. Deploy as Web App (Execute as: Me).\n3. Share the URL with students.');
}

