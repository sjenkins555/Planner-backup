function ensureConfigRows(config) {
  if (!config) return;
  const keys = config.getDataRange().getValues().map(r => r[0]);
  if (!keys.includes('TEACHER_EMAILS')) config.appendRow(['TEACHER_EMAILS','yourname@yourdomain.edu']);
  if (!keys.includes('APP_NAME'))       config.appendRow(['APP_NAME','Cedar Hollow Planner']);
}

function promptAddTeacher() {
  const ui = SpreadsheetApp.getUi();
  const result = ui.prompt('Add Teacher Email','Enter email to grant teacher access:',ui.ButtonSet.OK_CANCEL);
  if (result.getSelectedButton() !== ui.Button.OK) return;
  const email = result.getResponseText().trim();
  if (!email||!email.includes('@')) { ui.alert('❌ Invalid email.'); return; }
  const config = SpreadsheetApp.openById('1G1J9nhaEonNnD5rQq3YRqh1KatuAwlcHd5yDb99db9Y').getSheetByName('Config');
  if (!config) { ui.alert('❌ Config sheet not found. Run First-Time Setup first.'); return; }
  const data = config.getDataRange().getValues();
  for (let i = 0; i < data.length; i++) {
    if (data[i][0]==='TEACHER_EMAILS') {
      const current = String(data[i][1]).split(',').map(e=>e.trim()).filter(Boolean);
      if (current.includes(email)) { ui.alert(`ℹ️ ${email} is already a teacher.`); return; }
      current.push(email);
      config.getRange(i+1,2).setValue(current.join(','));
      ui.alert(`✅ ${email} added as a teacher!`);
      return;
    }
  }
  ui.alert('❌ TEACHER_EMAILS row not found.');
}

