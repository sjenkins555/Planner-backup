function adminAdjustRowBalance(studentEmail, delta, reason) {
  try {
    var u = getCurrentUser();
    if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
    var d = parseInt(delta, 10);
    if (isNaN(d) || d === 0) return {success: false, error: 'Adjustment must be a non-zero number.'};
    if (Math.abs(d) > 100) return {success: false, error: 'Adjustment too large (max ±100).'};
    if (!studentEmail) return {success: false, error: 'No account selected.'};

    var users = getSheet('Users');
    var found = false;
    if (users) {
      var uData = users.getDataRange().getValues();
      for (var i = 1; i < uData.length; i++) {
        if (String(uData[i][0]) === studentEmail) { found = true; break; }
      }
    }
    if (!found) return {success: false, error: 'Account not found.'};

    var cur = _getRowBalance(studentEmail);
    var newBal = Math.max(0, cur + d);
    _setRowBalance(studentEmail, newBal);

    var txSheet = getSheet('RowTransactions');
    if (txSheet) {
      txSheet.appendRow([
        generateId(), studentEmail, u.email,
        d > 0 ? 'admin_credit' : 'admin_debit',
        Math.abs(d),
        'Manual Adjustment',
        String(reason || ''),
        'completed',
        new Date().toISOString(),
        new Date().toISOString(),
        ''
      ]);
    }
    return {success: true, newBalance: newBal};
  } catch(e) {
    return {success: false, error: e.toString()};
  }
}

function adminGetAllRowTransactions(limit) {
  try {
    var u = getCurrentUser();
    if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized', transactions: []};
    var sheet = getSheet('RowTransactions');
    if (!sheet) return {success: true, transactions: []};
    var data = sheet.getDataRange().getValues();

    var users = getSheet('Users');
    var nameMap = {};
    if (users) {
      var uData = users.getDataRange().getValues();
      for (var k = 1; k < uData.length; k++) {
        nameMap[String(uData[k][0])] = String(uData[k][1] || '');
      }
    }

    var out = [];
    for (var i = 1; i < data.length; i++) {
      if (!data[i][0]) continue;
      out.push({
        id: String(data[i][0] || ''),
        studentEmail: String(data[i][1] || ''),
        studentName: nameMap[String(data[i][1])] || String(data[i][1]),
        teacherEmail: String(data[i][2] || ''),
        teacherName: nameMap[String(data[i][2])] || String(data[i][2]),
        type: String(data[i][3] || ''),
        amount: Number(data[i][4]) || 0,
        category: String(data[i][5] || ''),
        description: String(data[i][6] || ''),
        status: String(data[i][7] || ''),
        createdAt: data[i][8] ? new Date(data[i][8]).toISOString() : '',
        resolvedAt: data[i][9] ? new Date(data[i][9]).toISOString() : '',
        comment: String(data[i][10] || '')
      });
    }
    out.sort(function(a, b) {
      var da = new Date(a.createdAt || 0).getTime();
      var db = new Date(b.createdAt || 0).getTime();
      return db - da;
    });
    var lim = parseInt(limit, 10);
    if (!isNaN(lim) && lim > 0) out = out.slice(0, lim);
    return {success: true, transactions: out};
  } catch(e) {
    return {success: false, error: e.toString(), transactions: []};
  }
}

function adminSpendRows(studentEmail, amount, item) {
  try {
    var u = getCurrentUser();
    if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
    var amt = parseInt(amount, 10);
    if (isNaN(amt) || amt < 1) return {success: false, error: 'Amount must be at least 1.'};
    var cur = _getRowBalance(studentEmail);
    if (amt > cur) return {success: false, error: 'Not enough ROWs (balance is ' + cur + ').'};
    var newBal = cur - amt;
    _setRowBalance(studentEmail, newBal);
    var txSheet = getSheet('RowTransactions');
    if (txSheet) {
      txSheet.appendRow([
        generateId(), studentEmail, u.email, 'spend',
        amt, 'Hawk Shop', String(item || ''), 'completed',
        new Date().toISOString(), new Date().toISOString(), ''
      ]);
    }
    return {success: true, newBalance: newBal};
  } catch(e) {
    return {success: false, error: e.toString()};
  }
}

