// ─── BELL SCHEDULES ──────────────────────────────────────────
function getAllBellSchedules() {
  try {
    var sheet = getSheet('BellSchedules');
    if (!sheet) return [];
    var data = sheet.getDataRange().getValues();
    var out = [];
    for (var i = 1; i < data.length; i++) {
      if (!data[i][0]) continue;
      var periods = [];
      try { periods = JSON.parse(data[i][3] || '[]'); } catch(e) {}
      out.push({
        id: String(data[i][0]),
        name: String(data[i][1] || ''),
        isDefault: data[i][2] === true || String(data[i][2]).toLowerCase() === 'true',
        periods: periods,
        color: String(data[i][4] || '#6366f1'),
        createdAt: String(data[i][5] || '')
      });
    }
    return out;
  } catch(e) { return []; }
}

function getDefaultBellSchedule() {
  var all = getAllBellSchedules();
  for (var i = 0; i < all.length; i++) if (all[i].isDefault) return all[i];
  return all.length ? all[0] : null;
}

function saveBellSchedule(scheduleJson) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  var sched;
  try { sched = JSON.parse(scheduleJson); } catch(e) { return {success: false, error: 'Bad JSON'}; }
  if (!sched.name) return {success: false, error: 'Name is required'};
  var sheet = getSheet('BellSchedules');
  if (!sheet) return {success: false, error: 'Run Repair Missing Sheets first.'};
  var data = sheet.getDataRange().getValues();
  var periodsJson = JSON.stringify(sched.periods || []);
  if (sched.isDefault) {
    for (var i = 1; i < data.length; i++) {
      if (data[i][0] && data[i][0] !== sched.id) sheet.getRange(i + 1, 3).setValue(false);
    }
  }
  if (sched.id) {
    for (var i = 1; i < data.length; i++) {
      if (String(data[i][0]) === String(sched.id)) {
        sheet.getRange(i + 1, 2).setValue(sched.name);
        sheet.getRange(i + 1, 3).setValue(!!sched.isDefault);
        sheet.getRange(i + 1, 4).setValue(periodsJson);
        sheet.getRange(i + 1, 5).setValue(sched.color || '#6366f1');
        return {success: true, id: sched.id};
      }
    }
  }
  var newId = generateId();
  sheet.appendRow([newId, sched.name, !!sched.isDefault, periodsJson, sched.color || '#6366f1', new Date().toISOString()]);
  return {success: true, id: newId};
}

function deleteBellSchedule(id) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  var sheet = getSheet('BellSchedules');
  if (!sheet) return {success: false};
  var data = sheet.getDataRange().getValues();
  for (var i = 1; i < data.length; i++) {
    if (String(data[i][0]) === String(id)) {
      sheet.deleteRow(i + 1);
      var calSheet = getSheet('ScheduleCalendar');
      if (calSheet) {
        var cData = calSheet.getDataRange().getValues();
        for (var j = cData.length - 1; j >= 1; j--) {
          if (String(cData[j][1]) === String(id)) calSheet.deleteRow(j + 1);
        }
      }
      return {success: true};
    }
  }
  return {success: false, error: 'Not found'};
}

// ─── SCHEDULE CALENDAR ───────────────────────────────────────
function getScheduleCalendar(startDate, endDate) {
  try {
    var sheet = getSheet('ScheduleCalendar');
    if (!sheet) return [];
    var data = sheet.getDataRange().getValues();
    var out = [];
    var s = startDate ? new Date(startDate + 'T00:00:00') : null;
    var e = endDate ? new Date(endDate + 'T23:59:59') : null;
    for (var i = 1; i < data.length; i++) {
      if (!data[i][0]) continue;
      var d = data[i][0] instanceof Date ? data[i][0] : new Date(data[i][0]);
      if (isNaN(d)) continue;
      if (s && d < s) continue;
      if (e && d > e) continue;
      out.push({
        date: Utilities.formatDate(d, Session.getScriptTimeZone(), 'yyyy-MM-dd'),
        bellScheduleId: String(data[i][1] || ''),
        dayType: String(data[i][2] || ''),
        notes: String(data[i][3] || '')
      });
    }
    return out;
  } catch(e) { return []; }
}

function setScheduleCalendarEntry(dateStr, bellScheduleId, dayType, notes) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  if (!dateStr) return {success: false, error: 'Date is required'};
  var sheet = getSheet('ScheduleCalendar');
  if (!sheet) return {success: false, error: 'Run Repair Missing Sheets first.'};
  var data = sheet.getDataRange().getValues();
  var target = new Date(dateStr + 'T12:00:00');
  var targetKey = Utilities.formatDate(target, Session.getScriptTimeZone(), 'yyyy-MM-dd');
  for (var i = 1; i < data.length; i++) {
    if (!data[i][0]) continue;
    var d = data[i][0] instanceof Date ? data[i][0] : new Date(data[i][0]);
    if (isNaN(d)) continue;
    var k = Utilities.formatDate(d, Session.getScriptTimeZone(), 'yyyy-MM-dd');
    if (k === targetKey) {
      if (!bellScheduleId && !dayType) {
        sheet.deleteRow(i + 1);
        return {success: true, cleared: true};
      }
      sheet.getRange(i + 1, 2).setValue(bellScheduleId || '');
      sheet.getRange(i + 1, 3).setValue(dayType || '');
      sheet.getRange(i + 1, 4).setValue(notes || '');
      return {success: true};
    }
  }
  if (!bellScheduleId && !dayType) return {success: true};
  sheet.appendRow([target, bellScheduleId || '', dayType || '', notes || '']);
  return {success: true};
}

function setScheduleCalendarRange(startDateStr, endDateStr, bellScheduleId, dayType, notes, daysOfWeekJson) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  var dows = null;
  if (daysOfWeekJson) {
    try { dows = JSON.parse(daysOfWeekJson); } catch(e) {}
  }
  var s = new Date(startDateStr + 'T12:00:00');
  var e = new Date(endDateStr + 'T12:00:00');
  if (isNaN(s) || isNaN(e) || e < s) return {success: false, error: 'Bad date range'};
  var count = 0;
  var d = new Date(s);
  while (d <= e) {
    if (!dows || dows.indexOf(d.getDay()) > -1) {
      var ds = Utilities.formatDate(d, Session.getScriptTimeZone(), 'yyyy-MM-dd');
      setScheduleCalendarEntry(ds, bellScheduleId, dayType, notes);
      count++;
    }
    d.setDate(d.getDate() + 1);
  }
  return {success: true, count: count};
}

function getActiveBellScheduleForDate(dateStr) {
  var entries = getScheduleCalendar(dateStr, dateStr);
  var entry = entries.length ? entries[0] : null;
  var def = getDefaultBellSchedule();
  var schedule = def;
  if (entry && entry.bellScheduleId) {
    var all = getAllBellSchedules();
    for (var i = 0; i < all.length; i++) {
      if (all[i].id === entry.bellScheduleId) { schedule = all[i]; break; }
    }
  }
  return {
    schedule: schedule,
    dayType: entry ? entry.dayType : '',
    notes: entry ? entry.notes : '',
    hasOverride: !!entry
  };
}

function getMyScheduleWithBell(dateStr) {
  try {
    var u = getCurrentUser();
    if (u.error) return {schedule: [], bellSchedules: [], activeBell: null};
    var ds = dateStr || Utilities.formatDate(new Date(), Session.getScriptTimeZone(), 'yyyy-MM-dd');
    return {
      schedule: getScheduleForEmail(u.email).schedule,
      bellSchedules: getAllBellSchedules(),
      activeBell: getActiveBellScheduleForDate(ds)
    };
  } catch(e) {
    return {schedule: [], bellSchedules: [], activeBell: null, error: e.toString()};
  }
}

