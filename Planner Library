function getSheet(name) {
  return SpreadsheetApp.openById(PLANNER_SHEET_ID).getSheetByName(name);
}

function generateId() {
  return Utilities.getUuid();
}

function getEmail() {
  let e = '';
  try { e = Session.getActiveUser().getEmail(); } catch(_){}
  if (!e) try { e = Session.getEffectiveUser().getEmail(); } catch(_){}
  return e;
}

function safeDate(val) {
  if (!val) return '';
  try { return Utilities.formatDate(new Date(val), Session.getScriptTimeZone(), 'yyyy-MM-dd'); }
  catch(e) { return String(val); }
}

function safeTime(val) {
  if (val === null || val === undefined || val === '') return '';
  if (typeof val === 'number') {
    var totalMin = Math.round(val * 24 * 60);
    var h = Math.floor(totalMin / 60) % 24;
    var m = totalMin % 60;
    return String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
  }
  if (val instanceof Date) {
    return String(val.getHours()).padStart(2, '0') + ':' + String(val.getMinutes()).padStart(2, '0');
  }
  return String(val);
}

// ─── USER IDENTITY ───────────────────────────────────────────
function getCurrentUser() {
  try {
    const email = getEmail();
    if (!email) {
      return {
        error: 'EMPTY_EMAIL',
        message: 'Google could not detect your account.\n\nFix: Deploy → Manage Deployments → ✏️ → "Execute as: Me" → New Version → Deploy.'
      };
    }
    const sheet = getSheet('Users');
    if (!sheet) return {
      error: 'NO_SHEET',
      message: 'Users sheet missing. Open 🎓 Planner Admin → Repair Missing Sheets.'
    };
    const data = sheet.getDataRange().getValues();
    let realRole = null, name = '', group = '';
    for (let i = 1; i < data.length; i++) {
      if (data[i][0] === email) {
        realRole = data[i][2];
        name = data[i][1];
        group = data[i][3] || '';
        break;
      }
    }
    if (realRole === null) {
      const parts = email.split('@')[0].replace(/[._]/g, ' ').split(' ');
      name = parts.map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      realRole = isTeacherEmail(email) ? 'teacher' : 'student';
      sheet.appendRow([email, name, realRole, '', new Date().toISOString()]);
    }
    // Honor view-as-student override if the real user is actually a teacher
    let viewAs = null;
    try {
      viewAs = PropertiesService.getUserProperties().getProperty('viewAsRole');
    } catch(e) {}
    let displayRole = realRole;
    if (realRole === 'teacher' && viewAs === 'student') {
      displayRole = 'student';
    }
    return {
      email: email,
      name: name,
      role: displayRole,
      realRole: realRole,
      group: group
    };
  } catch(e) {
    return {error: 'EXCEPTION', message: e.toString()};
  }
}

function isTeacherEmail(email) {
  try {
    const data = getSheet('Config').getDataRange().getValues();
    for (const r of data) {
      if (r[0] === 'TEACHER_EMAILS') {
        return String(r[1]).split(',').map(e => e.trim().toLowerCase()).includes(email.toLowerCase());
      }
    }
  } catch(e) {}
  return false;
}

function updateMyName(name) {
  const email = getEmail();
  const sheet = getSheet('Users');
  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (data[i][0] === email) {
      sheet.getRange(i + 1, 2).setValue(name);
      return {success: true};
    }
  }
  return {success: false};
}

function setViewAsRole(role) {
  try {
    var u = getCurrentUser();
    if (u.error) return {success: false, error: u.message};
    if (u.realRole !== 'teacher') return {success: false, error: 'Only teachers can use view-as mode.'};
    var props = PropertiesService.getUserProperties();
    if (role === 'student') {
      props.setProperty('viewAsRole', 'student');
    } else {
      props.deleteProperty('viewAsRole');
    }
    return {success: true};
  } catch(e) {
    return {success: false, error: e.toString()};
  }
}

function getViewAsRole() {
  try {
    var role = PropertiesService.getUserProperties().getProperty('viewAsRole');
    return {success: true, viewAs: role || null};
  } catch(e) {
    return {success: true, viewAs: null};
  }
}

// ─── TASKS ───────────────────────────────────────────────────
function getMyTasks() {
  const user = getCurrentUser();
  if (user.error) return [];
  return getTasksForEmail(user.email);
}

function getTasksForEmail(email) {
  const sheet = getSheet('Tasks');
  if (!sheet) return [];
  const data = sheet.getDataRange().getValues();
  const tasks = [];
  for (let i = 1; i < data.length; i++) {
    if (data[i][1] === email && data[i][6] !== 'deleted') {
      tasks.push({
        id: data[i][0],
        title: data[i][2],
        subject: data[i][3] || '',
        dueDate: safeDate(data[i][4]),
        priority: data[i][5] || 'medium',
        status: data[i][6] || 'pending',
        notes: data[i][7] || '',
        assignedBy: data[i][8] || ''
      });
    }
  }
  return tasks.sort((a, b) => {
    if (a.status === 'completed' && b.status !== 'completed') return 1;
    if (a.status !== 'completed' && b.status === 'completed') return -1;
    if (!a.dueDate && b.dueDate) return 1;
    if (a.dueDate && !b.dueDate) return -1;
    if (a.dueDate && b.dueDate) return new Date(a.dueDate) - new Date(b.dueDate);
    return 0;
  });
}

function addMyTask(title, subject, dueDate, priority, notes) {
  const user = getCurrentUser();
  if (user.error) return {success: false};
  return _addTask(user.email, title, subject, dueDate, priority, notes, user.email);
}

function _addTask(assignedTo, title, subject, dueDate, priority, notes, assignedBy) {
  const id = generateId();
  getSheet('Tasks').appendRow([
    id,
    assignedTo,
    title,
    subject || '',
    dueDate || '',
    priority || 'medium',
    'pending',
    notes || '',
    assignedBy || '',
    new Date().toISOString()
  ]);
  return {success: true, id: id};
}

function setTaskStatus(taskId, status) {
  const data = getSheet('Tasks').getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (data[i][0] === taskId) {
      getSheet('Tasks').getRange(i + 1, 7).setValue(status);
      return {success: true};
    }
  }
  return {success: false};
}

function deleteTask(taskId) {
  return setTaskStatus(taskId, 'deleted');
}

function updateTask(taskId, title, subject, dueDate, priority, notes) {
  const sheet = getSheet('Tasks');
  if (!sheet) return {success: false, error: 'Tasks sheet missing'};
  const data = sheet.getDataRange().getValues();
  for (let i = 1; i < data.length; i++) {
    if (data[i][0] === taskId) {
      sheet.getRange(i + 1, 3).setValue(title || '');
      sheet.getRange(i + 1, 4).setValue(subject || '');
      sheet.getRange(i + 1, 5).setValue(dueDate || '');
      sheet.getRange(i + 1, 6).setValue(priority || 'medium');
      sheet.getRange(i + 1, 8).setValue(notes || '');
      return {success: true};
    }
  }
  return {success: false, error: 'Task not found'};
}

