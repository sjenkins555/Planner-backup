function runDataCleanup(target) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  try {
    var ss = SpreadsheetApp.openById(PLANNER_SHEET_ID);
    var removed = 0;
    if (target === 'tasks_completed') {
      var sheet = ss.getSheetByName('Tasks');
      if (sheet) {
        var data = sheet.getDataRange().getValues();
        for (var i = data.length - 1; i >= 1; i--) {
          if (data[i][6] === 'completed' || data[i][6] === 'deleted') {
            sheet.deleteRow(i + 1); removed++;
          }
        }
      }
    } else if (target === 'tasks_deleted') {
      var sheet = ss.getSheetByName('Tasks');
      if (sheet) {
        var data = sheet.getDataRange().getValues();
        for (var i = data.length - 1; i >= 1; i--) {
          if (data[i][6] === 'deleted') {
            sheet.deleteRow(i + 1); removed++;
          }
        }
      }
    }
    return {success: true, removed: removed};
  } catch(e) {
    return {success: false, error: e.toString()};
  }
}

function importLunchData(rows) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  if (!Array.isArray(rows) || !rows.length) return {success: false, error: 'No rows'};
  var sheet = getSheet('LunchMenu');
  if (!sheet) return {success: false, error: 'LunchMenu sheet missing'};
  var added = 0;
  for (var i = 0; i < rows.length; i++) {
