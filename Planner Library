}

function repairSheetsFromApp() {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  try {
    var ss = SpreadsheetApp.openById(PLANNER_SHEET_ID);
    var defs = allSheetDefs();
    var created = 0;
    for (var name in defs) {
      var sheet = ss.getSheetByName(name);
      if (!sheet) {
        sheet = ss.insertSheet(name);
        sheet.appendRow(defs[name]);
        sheet.setFrozenRows(1);
        created++;
      } else if (sheet.getLastRow() === 0) {
        sheet.appendRow(defs[name]);
        sheet.setFrozenRows(1);
      }
    }
    return {success: true, created: created};
  } catch(e) {
    return {success: false, error: e.toString()};
  }
}

function graduateStudents(emails) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  if (!Array.isArray(emails) || !emails.length) return {success: false, error: 'No emails'};
  try {
    var ss = SpreadsheetApp.openById(PLANNER_SHEET_ID);
    var emailSet = {};
    emails.forEach(function(e) { emailSet[String(e).toLowerCase()] = true; });
    var purgeFromSheet = function(sheetName, emailColumnIndex) {
      var sheet = ss.getSheetByName(sheetName);
      if (!sheet) return 0;
      var data = sheet.getDataRange().getValues();
      var removed = 0;
      for (var i = data.length - 1; i >= 1; i--) {
        if (emailSet[String(data[i][emailColumnIndex] || '').toLowerCase()]) {
          sheet.deleteRow(i + 1); removed++;
        }
      }
      return removed;
    };
    var report = {};
    report.users = purgeFromSheet('Users', 0);
    report.tasks = purgeFromSheet('Tasks', 1);
    report.schedule = purgeFromSheet('Schedule', 0);
    report.notes = purgeFromSheet('Notes', 0);
    report.links = purgeFromSheet('Links', 0);
    report.prefs = purgeFromSheet('Prefs', 0);
    report.rowAccounts = purgeFromSheet('RowAccounts', 0);
    report.rowTransactions = purgeFromSheet('RowTransactions', 1);
    return {success: true, report: report};
  } catch(e) {
    return {success: false, error: e.toString()};
  }
}

