  return setTaskStatus(taskId, 'deleted');
}

function saveGroup(name, emailsArr) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  if (!name) return {success: false, error: 'Group name required'};
  var sheet = getSheet('Groups');
  if (!sheet) return {success: false, error: 'Groups sheet missing'};
  var emails = (emailsArr || []).join(',');
  var data = sheet.getDataRange().getValues();
  for (var i = 1; i < data.length; i++) {
    if (data[i][0] === name) {
      sheet.getRange(i + 1, 2).setValue(emails);
      return {success: true};
    }
  }
  sheet.appendRow([name, emails, new Date().toISOString()]);
  return {success: true};
}

function deleteGroup(name) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  var sheet = getSheet('Groups');
  if (!sheet) return {success: false};
