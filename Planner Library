function requestRow(teacherEmail, category, description) {
  try {
    var u = getCurrentUser();
    if (u.error) return {success: false, error: 'Could not identify you. Refresh and try again.'};
    if (u.role !== 'student') return {success: false, error: 'Switch to View as Student mode to test requesting ROWs.'};
    if (!teacherEmail || !category || !description) {
      return {success: false, error: 'Pick a teacher, category, and write a short description.'};
    }
    if (String(description).trim().length < 3) return {success: false, error: 'Description is too short.'};
    if (String(description).length > 500) return {success: false, error: 'Description is too long (max 500 chars).'};

    var users = getSheet('Users');
    if (!users) return {success: false, error: 'Users sheet missing.'};
    var uData = users.getDataRange().getValues();
    var validTeacher = false;
    for (var i = 1; i < uData.length; i++) {
      if (String(uData[i][0]) === teacherEmail && String(uData[i][2]) === 'teacher') {
        validTeacher = true; break;
      }
    }
    if (!validTeacher) return {success: false, error: 'That teacher was not found.'};

    var txSheet = getSheet('RowTransactions');
    if (!txSheet) return {success: false, error: 'RowTransactions sheet missing — run Repair Missing Sheets.'};

    var id = generateId();
    txSheet.appendRow([
      id, u.email, teacherEmail, 'request',
      1,
      String(category), String(description),
      'pending', new Date().toISOString(), '', ''
    ]);
    return {success: true, id: id};
  } catch(e) {
    return {success: false, error: e.toString()};
  }
}

