// ─── LUNCH MENU ──────────────────────────────────────────────
function getLunchMenu() {
  try {
    var sheet = getSheet('LunchMenu');
    if (!sheet) return [];
    var data = sheet.getDataRange().getValues();
    if (data.length < 2) return [];
    var now = new Date();
    var dow = now.getDay();
    var mon = new Date(now);
    mon.setDate(now.getDate() - (dow === 0 ? 6 : dow - 1));
    mon.setHours(0, 0, 0, 0);
    var sun = new Date(mon);
    sun.setDate(mon.getDate() + 6);
    sun.setHours(23, 59, 59, 999);
    var rows = [];
    for (var i = 1; i < data.length; i++) {
      var raw = data[i][0];
      if (!raw) continue;
      var d = raw instanceof Date ? raw : new Date(raw);
      if (isNaN(d)) continue;
      d.setHours(12, 0, 0, 0);
      if (d >= mon && d <= sun) {
        rows.push({
          date: Utilities.formatDate(d, Session.getScriptTimeZone(), 'yyyy-MM-dd'),
          main:  String(data[i][1] || '').trim(),
          side1: String(data[i][2] || '').trim(),
          side2: String(data[i][3] || '').trim(),
          side3: String(data[i][4] || '').trim(),
          veg:   String(data[i][5] || '').trim(),
          notes: String(data[i][6] || '').trim()
        });
      }
    }
    return rows;
  } catch(e) {
    return [];
  }
}

