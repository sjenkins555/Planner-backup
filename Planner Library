        subjectB: extra.subjectB || '',
        teacherB: extra.teacherB || '',
        roomB: extra.roomB || '',
        custom: extra.custom || {}
      });
    }
  }
  return {schedule: sched.sort((a, b) => Number(a.period) - Number(b.period))};
}

function saveMySchedule(scheduleJson) {
  const u = getCurrentUser();
  if (u.error) return {success: false};
  const sched = JSON.parse(scheduleJson);
  const s = getSheet('Schedule');
  const d = s.getDataRange().getValues();
  for (let i = d.length; i >= 1; i--) {
    if (d[i - 1][0] === u.email) s.deleteRow(i);
  }
  for (const p of sched) {
    var extra = {
      abDay: !!p.abDay,
      subjectB: p.subjectB || '',
      teacherB: p.teacherB || '',
      roomB: p.roomB || '',
      custom: p.custom || {}
    };
    s.appendRow([u.email, p.period, p.subject, p.teacher || '', p.room || '', p.startTime || '', p.endTime || '', JSON.stringify(extra)]);
  }
  return {success: true};
}

