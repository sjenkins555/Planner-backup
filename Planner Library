  const d = s.getDataRange().getValues();
  const sched = [];
  for (let i = 1; i < d.length; i++) {
    if (d[i][0] === email) {
      var extra = {};
      try { if (d[i][7]) extra = JSON.parse(d[i][7]); } catch(e) {}
      sched.push({
        period: d[i][1],
        subject: d[i][2],
        teacher: d[i][3],
