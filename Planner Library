function pushAssignment(targetType, targetValue, title, subject, dueDate, priority, notes) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {success: false, error: 'Not authorized'};
  if (!title) return {success: false, error: 'Title required'};
  var targets = [];
  if (targetType === 'all') {
    targets = getStudentList().map(function(s) { return s.email; });
  } else if (targetType === 'group') {
    var groups = getGroups();
    for (var i = 0; i < groups.length; i++) {
      if (groups[i].name === targetValue) { targets = groups[i].emails; break; }
    }
  } else if (targetType === 'individual') {
    if (targetValue) targets = [targetValue];
  }
  if (!targets.length) return {success: false, error: 'No targets'};
  var count = 0;
  for (var i = 0; i < targets.length; i++) {
    _addTask(targets[i], title, subject, dueDate, priority, notes, u.email);
    count++;
  }
  return {success: true, count: count};
}

function getStudentPlannerData(email) {
  var u = getCurrentUser();
  if (u.realRole !== 'teacher') return {error: 'Not authorized'};
  if (!email) return {error: 'No student email'};
