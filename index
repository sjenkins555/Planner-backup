  tabDefs.forEach(function(t){if(t.id==='_s')return;var b=document.getElementById('nb-'+t.id);if(b)b.classList.toggle('active',t.id===id);});
  var def=null;for(var i=0;i<tabDefs.length;i++){if(tabDefs[i].id===id){def=tabDefs[i];break;}}if(!def||!def.fn)return;
