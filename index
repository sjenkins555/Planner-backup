var _lastTs=null;
function timerToggle(){
  timerState.running=!timerState.running;var btn=document.getElementById('timer-start-btn');if(btn)btn.textContent=timerState.running?'Pause':'Start';
  if(timerState.running){if(timerState.mode==='timer'&&timerState.elapsed===0){var mIn=document.getElementById('t-min'),sIn=document.getElementById('t-sec');timerState.target=((parseInt(mIn?mIn.value:5)||0)*60+(parseInt(sIn?sIn.value:0)||0))*1000;}_lastTs=performance.now();timerTick();}
  else{cancelAnimationFrame(timerState.raf);}
}
function timerTick(){if(!timerState.running)return;var now=performance.now(),delta=now-(_lastTs||now);_lastTs=now;timerState.elapsed+=delta;if(timerState.mode==='timer'&&timerState.elapsed>=timerState.target){timerState.elapsed=timerState.target;timerState.running=false;updateTimerDisplay();var btn=document.getElementById('timer-start-btn');if(btn)btn.textContent='Start';toast("Time's up!",'ok');return;}updateTimerDisplay();timerState.raf=requestAnimationFrame(timerTick);}
function updateTimerDisplay(){
  var isTimer=timerState.mode==='timer',ms=isTimer?Math.max(0,timerState.target-timerState.elapsed):timerState.elapsed,total=Math.floor(ms/1000),m=Math.floor(total/60),s=total%60;
  var el=document.getElementById('timer-disp');if(el)el.textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
  var pct=timerState.target>0?(isTimer?1-timerState.elapsed/timerState.target:timerState.elapsed/timerState.target):0;
  var ring=document.getElementById('timer-ring');
  if(ring){var style=prefs.timerStyle||'circle';if(style==='circle'){ring.setAttribute('stroke-dashoffset',(2*Math.PI*60)*(1-Math.min(pct,1)));}else if(style==='bar'){ring.style.width=(Math.min(pct,1)*100)+'%';}}
}
function timerReset(){cancelAnimationFrame(timerState.raf);timerState.running=false;timerState.elapsed=0;timerState.laps=[];updateTimerDisplay();var btn=document.getElementById('timer-start-btn');if(btn)btn.textContent='Start';var ll=document.getElementById('lap-list');if(ll)ll.innerHTML='';}
function timerLap(){if(!timerState.running&&timerState.elapsed===0)return;var lapTime=timerState.elapsed-timerState.lapStart;timerState.lapStart=timerState.elapsed;var total=Math.floor(lapTime/1000),m=Math.floor(total/60),s=total%60;timerState.laps.push(String(m).padStart(2,'0')+':'+String(s).padStart(2,'0'));var ll=document.getElementById('lap-list');if(ll)ll.innerHTML=timerState.laps.map(function(l,i){return '<div class="lap-row"><span>Lap '+(i+1)+'</span><span>'+l+'</span></div>';}).reverse().join('');}

// ══════════════════════════════════════════════════════════════
// CALENDAR v2 — tasks + Google Calendar events on one grid
// Tasks colored by subject (from prefs.subjectColors)
// Events shown by Google Calendar's color
// ══════════════════════════════════════════════════════════════
var calMode = 'month';
var calCursor = null;
var _calSelectedDay = null;
var _calEvents = [];
var _calCache = {};
var _calCacheTTL = 300000; // 5 min
var _calOverdueOpen = false;
var _calCalsOpen = false;
var _eventStatuses = {}; // {eventId: 'completed' | ''}

// Map subject -> color. Uses prefs.subjectColors if set, else hash fallback.
function getSubjectColor(subject){
  if (!subject) return '#6366f1';
  var key = String(subject).trim();
  if (prefs.subjectColors && prefs.subjectColors[key]) return prefs.subjectColors[key];
  var h = 0;
  for (var i = 0; i < key.length; i++) h = (h * 31 + key.charCodeAt(i)) | 0;
  return TAB_COLORS[Math.abs(h) % TAB_COLORS.length];
}

function _ymdLocal(d){
  var y = d.getFullYear();
  var m = String(d.getMonth() + 1).padStart(2, '0');
  var dd = String(d.getDate()).padStart(2, '0');
  return y + '-' + m + '-' + dd;
}

function _fmtTimeLocal(d){
  var h = d.getHours(), m = d.getMinutes();
  if (prefs.timeFormat === '24h') return String(h).padStart(2,'0') + ':' + String(m).padStart(2,'0');
  var ap = h >= 12 ? 'pm' : 'am';
  h = h % 12 || 12;
  return h + (m === 0 ? '' : ':' + String(m).padStart(2,'0')) + ap;
}

function buildCalPage(){
  var pid = CU.role === 'teacher' ? 'my-cal' : 'cal';
  calMode = prefs.calMode || 'month';
  if (!calCursor) calCursor = new Date();
  if (!_calSelectedDay) _calSelectedDay = _ymdLocal(new Date());
  panel(pid).innerHTML =
    '<div class="cal2-shell">' +
      '<div class="cal2-tb">' +
        '<div class="cal2-tb-l">' +
          '<button class="cal2-today" onclick="calGoToday()">Today</button>' +
          '<button class="cal2-arrow" onclick="calNav(-1)" title="Previous">&lsaquo;</button>' +
          '<button class="cal2-arrow" onclick="calNav(1)" title="Next">&rsaquo;</button>' +
          '<div class="cal2-title" id="cal2-title">&mdash;</div>' +
        '</div>' +
        '<div class="cal2-tb-r">' +
          '<div class="cal2-vsw">' +
            '<button class="cal2-vopt" id="cv-week" onclick="setCalView(\'week\')">Week</button>' +
            '<button class="cal2-vopt" id="cv-month" onclick="setCalView(\'month\')">Month</button>' +
            '<button class="cal2-vopt" id="cv-agenda" onclick="setCalView(\'agenda\')">Agenda</button>' +
          '</div>' +
          '<button class="cal2-new" onclick="calOpenAdd()">+ New</button>' +
        '</div>' +
      '</div>' +
      '<div class="cal2-body">' +
        '<div class="cal2-main">' +
          '<div class="cal2-load" id="cal2-load"><div class="soaring-spinner"><div class="halo"></div><div class="crest"></div></div></div>' +
          '<div id="cal2-host"></div>' +
        '</div>' +
        '<div class="cal2-rail" id="cal2-rail"></div>' +
      '</div>' +
      '<div class="cal2-foot">' +
        '<div class="cal2-legend">' +
          '<span class="lg"><span class="lg-dot"></span>Task / Event</span>' +
