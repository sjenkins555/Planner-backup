  if(id===homeId&&_savedHomeNode){content.innerHTML='';content.appendChild(_savedHomeNode);return;}
  content.innerHTML='<div class="tab-pane active" id="tp-'+id+'"></div>';
  try{def.fn();}catch(e){var p=panel(id);if(p)p.innerHTML='<div style="color:#ef4444;padding:24px;font-size:13px;">Error: '+e.message+'</div>';console.error(e);}
