function openCalendarEvent(title, dueDate, details, guestEmails, classTimes){
  if (!title) { toast('Need a title to create event','err'); return; }
  if (!dueDate) { toast('Need a due date to create event','err'); return; }
  // Build start/end ISO strings in the user's local timezone
  var startISO, endISO, allDay = false;
  if (classTimes && classTimes.startTime && classTimes.endTime) {
    var sParts = classTimes.startTime.split(':');
    var eParts = classTimes.endTime.split(':');
    var sd = new Date(dueDate + 'T00:00:00');
    sd.setHours(parseInt(sParts[0],10), parseInt(sParts[1],10), 0, 0);
    var ed = new Date(dueDate + 'T00:00:00');
    ed.setHours(parseInt(eParts[0],10), parseInt(eParts[1],10), 0, 0);
    startISO = sd.toISOString();
    endISO = ed.toISOString();
  } else {
    // All-day event on the due date
    startISO = dueDate;
    var ed = new Date(dueDate + 'T00:00:00');
    ed.setDate(ed.getDate() + 1);
    endISO = _ymdLocal(ed);
    allDay = true;
  }
  var opts = {
    description: details || '',
    allDay: allDay,
    guests: (guestEmails && guestEmails.length) ? guestEmails : []
  };
  toast('Adding to Google Calendar…','inf');
  google.script.run
    .withSuccessHandler(function(r){
      if (r && r.success) {
        toast('Added to Google Calendar','ok');
        // Bust the calendar cache so the new event shows up next time you open the tab
        if (typeof _calCache !== 'undefined') _calCache = {};
      } else {
        toast((r && r.error) || 'Could not add event','err');
      }
    })
    .withFailureHandler(function(e){
      toast('Could not add event: ' + (e && e.message ? e.message : 'unknown error'),'err');
    })
    .createCalendarEvent(title, startISO, endISO, JSON.stringify(opts));
}

// Looks up the start/end times for a given subject on a given due date.
// Honors A/B day rotation when active. Returns null if no matching class found.
function findClassTimesForSubject(subject, dueDate){
  if (!subject || !mySchedule || !mySchedule.length) return null;
  // Determine which day type applies on the due date (defaults to 'A' for non-AB schedules)
  var dayType = 'A';
  if (dueDate && activeBell){
    // For now we use today's day type. A future enhancement could look up the calendar
    // for the actual due date, but most tasks are added for soon-upcoming dates.
    dayType = (activeBell.dayType || 'A').toUpperCase();
    if (dayType !== 'A' && dayType !== 'B') dayType = 'A';
  }
  for (var i = 0; i < mySchedule.length; i++){
    var p = mySchedule[i];
    var subjA = String(p.subject||'').replace(/^\[(.+?)\]\(.+\)$/, '$1').trim();
    var subjB = String(p.subjectB||'').replace(/^\[(.+?)\]\(.+\)$/, '$1').trim();
    if (subjA === subject || subjB === subject){
      // Bell schedule times override the student's saved times when an override is active
      var startT = p.startTime, endT = p.endTime;
      if (activeBell && activeBell.schedule && activeBell.schedule.periods){
        for (var j = 0; j < activeBell.schedule.periods.length; j++){
          if (String(activeBell.schedule.periods[j].period) === String(p.period)){
            startT = activeBell.schedule.periods[j].startTime || startT;
            endT   = activeBell.schedule.periods[j].endTime   || endT;
            break;
          }
        }
      }
      if (startT && endT) return {startTime:startT, endTime:endT};
    }
  }
  return null;
}
 
