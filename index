function renderWeatherInit(){if(prefs.weatherLat&&prefs.weatherLon)return '<div class="weather-loading"><div class="spinner" style="margin:0 auto 8px;"></div>Loading weather...</div>';return '<div style="text-align:center;padding:16px;"><p style="font-size:13px;color:var(--tx2);margin-bottom:14px;">Tap to set up weather.</p><button class="btn btn-primary" onclick="flipWidget(\'weather\')">Set Up Weather</button></div>';}
function loadWeather(){
  if(!prefs.weatherLat||!prefs.weatherLon)return;
  showWidgetLoader('weather','sm');
  fetchWeatherData(prefs.weatherLat,prefs.weatherLon,prefs.weatherCity||'');
