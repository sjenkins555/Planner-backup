// Builds the list of subjects from the student's schedule for the task subject dropdown
// A/B day classes appear as "Math (A)" and "Algebra (B)" so students can tell them apart
function getSubjectOptions(){
  var subjects = [];
  var seen = {};
  (mySchedule||[]).forEach(function(p){
    var subj = String(p.subject||'').trim();
    // Strip any [label](url) link wrapper to show just the label
    var lm = subj.match(/^\[(.+?)\]\((https?:\/\/[^\)]+)\)$/);
    if (lm) subj = lm[1];
    if (subj && !seen[subj]){
      seen[subj] = true;
      subjects.push({label: p.abDay ? subj+' (A)' : subj, value: subj, period: p.period});
    }
    if (p.abDay){
      var subjB = String(p.subjectB||'').trim();
      var lmB = subjB.match(/^\[(.+?)\]\((https?:\/\/[^\)]+)\)$/);
      if (lmB) subjB = lmB[1];
      if (subjB && !seen[subjB]){
        seen[subjB] = true;
        subjects.push({label: subjB+' (B)', value: subjB, period: p.period});
      }
    }
  });
  return subjects;
}

// Renders a <select> for the subject dropdown. Returns a string of <option> tags.
function buildSubjectDropdownOptions(currentValue){
  var opts = getSubjectOptions();
  var html = '<option value="">— No subject —</option>';
  var matched = false;
  opts.forEach(function(o){
    var sel = (o.value === currentValue) ? ' selected' : '';
    if (sel) matched = true;
    html += '<option value="'+esc(o.value)+'"'+sel+'>'+esc(o.label)+'</option>';
  });
  // If the current value isn't in the schedule (e.g. legacy task or custom subject),
  // include it so it stays selected and the student can keep using it.
  if (currentValue && !matched){
    html = '<option value="'+esc(currentValue)+'" selected>'+esc(currentValue)+' (custom)</option>' + html;
  }
  return html;
}

