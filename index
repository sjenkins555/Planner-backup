  return '';
}

// Closes the wrapper opened by buildWidgetSpecificSettings (only for clock/timer).
function closeWidgetSpecificWrap(id){
  return (id === 'clock' || id === 'timer') ? '</div>' : '';
}

// Build the full Style tab HTML for the flip back of widget `id`.
// Includes color pickers, alpha sliders, exclude-from-bg toggle, size grid, and reset button.
function buildStylePanelHTML(id){
  if (!prefs.widgetStyles) prefs.widgetStyles = {};
  var s = prefs.widgetStyles[id] || {};
  var bgC = s.bgColor || '', bgA = s.bgAlpha == null ? 88 : s.bgAlpha;
  var bdC = s.borderColor || '', bdA = s.borderAlpha == null ? 100 : s.borderAlpha;
  var txC = s.textColor || '', txA = s.textAlpha == null ? 100 : s.textAlpha;
  var exc = s.excludeFromBg ? 'checked' : '';
  var inWidgetMode = (prefs.bgTarget === 'widgets' && prefs.bgType === 'image');
  var useBg = s.bgColor ? 'checked' : '';
  var useBd = s.borderColor ? 'checked' : '';
  var useTx = s.textColor ? 'checked' : '';

  // Current size — grid lets user pick cols × rows
  var defSz = id.startsWith('embed-') ? DEF_TILE_SIZES['embed'] : DEF_TILE_SIZES[id];
  var cur = Object.assign({}, defSz || {c:2,r:1}, (prefs.tileSizes && prefs.tileSizes[id]) || {});
  var sizeGrid = '';
  for (var r = 1; r <= 2; r++){
    for (var c = 1; c <= 4; c++){
      var sel = (c === cur.c && r === cur.r) ? ' sel' : '';
      sizeGrid += '<div class="style-sz-cell' + sel + '" onclick="pickSz(\'' + id + '\',' + c + ',' + r + ')">' + c + '\u00d7' + r + '</div>';
    }
  }

  var widgetSpec = buildWidgetSpecificSettings(id);
  return '<div class="style-panel">'
    + widgetSpec
    + '<div class="style-section-title" style="' + (widgetSpec ? '' : 'margin-top:0;') + '">Colors</div>'
    + '<div class="style-row">'
      + '<label><input type="checkbox" id="sp-use-bd-' + id + '" ' + useBd + ' style="accent-color:var(--a1);margin-right:4px;vertical-align:-2px;">Border</label>'
      + '<input type="color" id="sp-bdc-' + id + '" value="' + normalizeHex(bdC || '#2a3546') + '">'
      + '<input type="range" id="sp-bda-' + id + '" min="0" max="100" value="' + bdA + '">'
      + '<span class="style-alpha" id="sp-bda-v-' + id + '">' + bdA + '%</span></div>'
    + '<div class="style-row">'
      + '<label><input type="checkbox" id="sp-use-tx-' + id + '" ' + useTx + ' style="accent-color:var(--a1);margin-right:4px;vertical-align:-2px;">Text</label>'
      + '<input type="color" id="sp-txc-' + id + '" value="' + normalizeHex(txC || '#e2e8f0') + '">'
      + '<input type="range" id="sp-txa-' + id + '" min="0" max="100" value="' + txA + '">'
      + '<span class="style-alpha" id="sp-txa-v-' + id + '">' + txA + '%</span></div>'
    + '<div class="style-row">'
      + '<label><input type="checkbox" id="sp-use-bg-' + id + '" ' + useBg + ' style="accent-color:var(--a1);margin-right:4px;vertical-align:-2px;">Background</label>'
      + '<input type="color" id="sp-bgc-' + id + '" value="' + normalizeHex(bgC || '#111827') + '">'
      + '<input type="range" id="sp-bga-' + id + '" min="0" max="100" value="' + bgA + '">'
      + '<span class="style-alpha" id="sp-bga-v-' + id + '">' + bgA + '%</span></div>'
    + '<div style="font-size:10px;color:var(--tx4);line-height:1.5;margin-top:4px;">Uncheck to use the global theme setting instead.</div>'
    + '<label class="style-toggle">'
      + '<input type="checkbox" id="sp-exc-' + id + '" ' + exc + '>'
      + '<div><div class="style-toggle-lbl">Use solid background only</div>'
      + '<div class="style-toggle-hint">' + (inWidgetMode ? 'Hides the page bg image on this widget.' : '(Only applies when "Apply image to: Each widget" is set in Settings.)') + '</div></div></label>'
    + '<div class="style-section">'
      + '<div class="style-section-title">Size</div>'
      + '<div class="style-sz-grid">' + sizeGrid + '</div>'
      + '<div style="font-size:10px;color:var(--tx4);">Columns \u00d7 rows</div>'
    + '</div>'
    + '<div class="style-footer">'
      + '<button class="btn btn-danger btn-sm" onclick="resetWidgetStyle(\'' + id + '\')">Reset Colors</button>'
      + '<div style="display:flex;gap:6px;">'
      + '<button class="btn btn-primary btn-sm" onclick="unflipWidget(\'' + id + '\')">Done</button>'
      + '</div></div>'
    + closeWidgetSpecificWrap(id)
    + '</div>';
}

// Wire up live-update listeners for the style panel inputs.
// Saves prefs to the server with a 700ms debounce.
function attachStyleListeners(id){
  function liveUpdate(){
    if (!prefs.widgetStyles) prefs.widgetStyles = {};
    var useBd = document.getElementById('sp-use-bd-' + id).checked;
    var useTx = document.getElementById('sp-use-tx-' + id).checked;
    var useBg = document.getElementById('sp-use-bg-' + id).checked;
    var st = {
      borderColor:   useBd ? document.getElementById('sp-bdc-' + id).value : null,
      borderAlpha:   Number(document.getElementById('sp-bda-' + id).value),
      textColor:     useTx ? document.getElementById('sp-txc-' + id).value : null,
      textAlpha:     Number(document.getElementById('sp-txa-' + id).value),
      bgColor:       useBg ? document.getElementById('sp-bgc-' + id).value : null,
      bgAlpha:       Number(document.getElementById('sp-bga-' + id).value),
      excludeFromBg: document.getElementById('sp-exc-' + id).checked
    };
    // Drop empty entries entirely so prefs stay clean
    if (!st.borderColor && !st.textColor && !st.bgColor && !st.excludeFromBg){
      delete prefs.widgetStyles[id];
    } else {
      prefs.widgetStyles[id] = st;
    }
    applyWidgetStyle(id);
    document.getElementById('sp-bga-v-' + id).textContent = st.bgAlpha + '%';
    document.getElementById('sp-bda-v-' + id).textContent = st.borderAlpha + '%';
    document.getElementById('sp-txa-v-' + id).textContent = st.textAlpha + '%';
    // Debounced save
    clearTimeout(window._styleSaveTimer);
    window._styleSaveTimer = setTimeout(function(){
      google.script.run.saveMyPrefs(JSON.stringify(prefs));
    }, 700);
  }
  ['sp-bgc','sp-bga','sp-bdc','sp-bda','sp-txc','sp-txa','sp-exc','sp-use-bg','sp-use-bd','sp-use-tx'].forEach(function(eid){
    var el = document.getElementById(eid + '-' + id);
    if (el) el.addEventListener('input', liveUpdate);
  });
}

// Clear all custom style overrides for a widget and re-render its style panel.
function resetWidgetStyle(id){
  if (prefs.widgetStyles && prefs.widgetStyles[id]){
    delete prefs.widgetStyles[id];
    applyWidgetStyle(id);
    google.script.run.saveMyPrefs(JSON.stringify(prefs));
  }
  var back = document.getElementById('tb-' + id);
  if (back) back.innerHTML = buildBackPanel(id, 'style');
  setTimeout(function(){ attachStyleListeners(id); }, 10);
  toast('Style reset', 'inf');
}


