<!-- ═══════════════════════════════════════════════════════════════════
     SECTION: LOADING SCREEN
     Shown until getBootData succeeds. Includes animated crest, progress
     ring, and fallback error panel if the boot request fails.
     ═══════════════════════════════════════════════════════════════════ -->
<div id="loading">
  <div class="ld-halo"></div>
  <div class="ld-specks" id="ld-specks"></div>
  <div class="ld-brand"><span class="ld-pip"></span>Hawks Middle School</div>
  <div class="ld-crest-wrap">
    <svg class="ld-ring" viewBox="0 0 380 380" aria-hidden="true">
      <circle class="ld-track" cx="190" cy="190" r="180"/>
      <circle class="ld-prog"  cx="190" cy="190" r="180" id="ld-prog"/>
    </svg>
    <div class="ld-logo-hold">
      <img src="https://raw.githubusercontent.com/sjenkins555/cedar-hollow-assets/main/CH%20Hawks%20Crest.png" class="ld-logo" alt="Hawks crest">
    </div>
  </div>
  <div id="ls-wrap">
    <div class="ld-text">
      <span>Loading</span>
      <span class="ld-dot"></span><span class="ld-dot"></span><span class="ld-dot"></span>
    </div>
    <div class="ld-pbar"><div class="ld-pfill" id="ld-pfill"></div></div>
    <p id="load-hint">Still loading &mdash; checking your account&hellip;</p>
  </div>
  <div id="load-err">
    <h3>Could not load your planner</h3>
    <p id="load-err-msg"></p>
    <div class="err-steps">
      <strong>Most common fix:</strong><br>
      1. Extensions &rarr; Apps Script<br>
      2. Deploy &rarr; Manage Deployments &rarr; &#9998; Edit<br>
      3. "Execute as" &rarr; <strong>Me</strong> &rarr; New version &rarr; Deploy
    </div>
  </div>
</div>


<!-- ═══════════════════════════════════════════════════════════════════
     SECTION: LINK RAIL
     Vertical sidebar of assigned/teacher links. Populated by
     loadMyAssignedLinks() in the second <script> block.
     ═══════════════════════════════════════════════════════════════════ -->
<div id="link-rail"></div>


<!-- ═══════════════════════════════════════════════════════════════════
     SECTION: MAIN APP SHELL
     Contains topbar (logo, clock, user pill, settings), navstrip (tab
     buttons rendered by renderNav), and content area (where each tab's
     widgets render). Hidden until bootApp() fires.
     ═══════════════════════════════════════════════════════════════════ -->
<div id="app">
  <header class="topbar">
    <div class="brand">
      <div class="ch-logo xs">CH</div>
      <span class="brand-name">Hawks Middle School Planner</span>
      <span class="role-pill" id="role-badge">Student</span>
    </div>
    <div class="topbar-right">
      <span id="live-clock"></span>
      <button class="view-as-btn" id="view-as-toggle" onclick="toggleViewAs()" style="display:none;" title="Preview the planner as a student">View as Student</button>
      <div class="icon-btn" onclick="openSettings()" title="Customize"><svg class="ui-ic" viewBox="0 0 16 16"><circle cx="8" cy="8" r="2" fill="none" stroke="currentColor" stroke-width="1.6"/><path d="M8 2v1.5M8 12.5V14M14 8h-1.5M3.5 8H2M12.2 3.8l-1 1M4.8 11.2l-1 1M12.2 12.2l-1-1M4.8 4.8l-1-1" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg></div>
      <div class="icon-btn" onclick="openWidgetPicker()" title="Add Widgets"><svg class="ui-ic" viewBox="0 0 16 16"><path d="M8 3v10M3 8h10" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"/></svg></div>
      <div class="user-pill" onclick="openModal('name-modal')">
        <div class="avatar" id="top-av">?</div>
        <span id="uname">...</span>
      </div>
    </div>
  </header>
  <nav class="navstrip" id="navstrip"></nav>
  <div class="page" id="content"></div>
</div>


<!-- Toast notification container (filled by toast() helper) -->
<div id="toasts"></div>


<!-- ═══════════════════════════════════════════════════════════════════
     SECTION: MODALS
     Each .overlay div is a full-screen modal that toggles via .open
     class. openModal('id') / closeModal('id') control them.
     ═══════════════════════════════════════════════════════════════════ -->

<!-- Modal: Add Task (used from the home page + button) -->
<div class="overlay" id="task-modal">
  <div class="mbox">
    <div class="mtitle">Add Task</div>
    <div class="fg"><label class="flbl">Title *</label><input class="finp" id="m-tt" placeholder="—Task Title—"></div>
    <div class="fr">
      <div class="fg"><label class="flbl">Subject</label><select class="fsel" id="m-ts"></select></div>
      <div class="fg"><label class="flbl">Priority</label>
        <select class="fsel" id="m-tp"><option value="high">High</option><option value="medium" selected>Medium</option><option value="low">Low</option></select>
      </div>
    </div>
    <div class="fg"><label class="flbl">Due Date</label><input type="date" class="finp" id="m-td"></div>
    <div class="fg"><label class="flbl">Notes</label><textarea class="fta" id="m-tn" placeholder="—Notes—"></textarea></div>
    <div class="fg"><label class="flbl">&#9200; Remind me at (optional)</label><input type="datetime-local" class="finp" id="m-tr" placeholder="Set a reminder"></div>
    <div class="mfooter">
      <button class="btn btn-ghost" onclick="closeModal('task-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="doAddTask()">Add Task</button>
    </div>
  </div>
</div>

<!-- Modal: Add Link -->
<div class="overlay" id="link-modal">
  <div class="mbox">
    <div class="mtitle">Add Link</div>
    <div class="fg"><label class="flbl">Label</label><input class="finp" id="m-ll" placeholder="—Link Label—"></div>
    <div class="fg"><label class="flbl">URL</label><input class="finp" id="m-lu" placeholder="—URL—"></div>
    <div class="mfooter">
      <button class="btn btn-ghost" onclick="closeModal('link-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="doAddLink()">Save</button>
    </div>
  </div>
</div>

<!-- Modal: Update display name -->
<div class="overlay" id="name-modal">
  <div class="mbox">
    <div class="mtitle">Update Display Name</div>
    <div class="fg"><label class="flbl">Name</label><input class="finp" id="m-name" placeholder="—Your Name—"></div>
    <div class="mfooter">
      <button class="btn btn-ghost" onclick="closeModal('name-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="doUpdateName()">Save</button>
    </div>
  </div>
</div>

<!-- Modal: New / Edit Group (teacher only) -->
<div class="overlay" id="group-modal">
  <div class="mbox">
    <div class="mtitle">&#128101; <span id="gm-title">New Group</span></div>
    <div class="fg"><label class="flbl">Group Name</label><input class="finp" id="m-gn" placeholder="—Group Name—"></div>
    <div class="fg"><label class="flbl">Students</label>
      <div id="grp-list" style="max-height:210px;overflow-y:auto;display:flex;flex-direction:column;gap:5px;margin-top:5px;"></div>
    </div>
    <div class="mfooter">
      <button class="btn btn-ghost" onclick="closeModal('group-modal')">Cancel</button>
      <button class="btn btn-primary" onclick="doSaveGroup()">Save Group</button>
    </div>
  </div>
</div>

<!-- Modal: Weather setup (geolocate or manual city) -->
<div class="overlay" id="weather-modal">
  <div class="mbox">
    <div class="mtitle">Set Up Weather</div>
    <p style="font-size:13px;color:var(--tx2);margin-bottom:16px;line-height:1.6;">Click <strong>Use My Location</strong> to auto-detect, or type a city below.</p>
    <div style="display:flex;gap:8px;margin-bottom:14px;">
      <button class="btn btn-primary" style="flex:1;" onclick="useGeoLocation()">Use My Location</button>
    </div>
    <div style="text-align:center;color:var(--tx3);font-size:12px;margin-bottom:14px;">&mdash; or enter manually &mdash;</div>
    <div class="fg"><label class="flbl">City Name</label><input class="finp" id="w-city" placeholder="e.g. Grand Island, NE"></div>
