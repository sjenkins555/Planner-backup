/* ═══════════════════════════════════════════════════════════════════
   1. ROW REWARDS — STUDENT-SIDE
   "My ROWs" widget shows the student's balance, pending requests, and
   recent history. Students request a ROW from a teacher; teachers
   approve/deny via the ROW Approvals widget.
   ═══════════════════════════════════════════════════════════════════ */

// Currently-selected category in the ROW request flip panel
var _rowSelectedCat = 'Respect';

// Load the user's ROW balance + history. Teachers see a personal-only view
// (their teacher account history is in ROW Approvals instead).
function loadMyRows(){
  if (!CU){
    var num = document.getElementById('row-bal-num');
    if (num) num.textContent = '—';
    return;
  }
  // Teachers don't request ROWs from other teachers — hide the request button
  var btn = document.getElementById('row-req-btn');
  if (btn) btn.style.display = (CU.role === 'student') ? '' : 'none';

  showWidgetLoader('rowbank', 'sm');

  // Balance
  google.script.run.withSuccessHandler(function(r){
    var num = document.getElementById('row-bal-num');
    if (num) num.textContent = r.success ? String(r.balance) : '0';
  }).withFailureHandler(function(){
    var num = document.getElementById('row-bal-num');
    if (num) num.textContent = '0';
  }).getMyRowBalance();

  // History
  google.script.run.withSuccessHandler(function(r){
    renderMyRowHistory(r && r.history ? r.history : []);
    hideWidgetLoader('rowbank');
  }).withFailureHandler(function(){
    renderMyRowHistory([]);
    hideWidgetLoader('rowbank');
  }).getMyRowHistory();

  // Cache the teacher list so the request flip can populate instantly
  if (!window._rowTeachers && CU.role === 'student'){
    google.script.run.withSuccessHandler(function(list){
      window._rowTeachers = list || [];
    }).getTeacherListForRow();
  }
}

// Render the pending-requests area + recent history list inside the My ROWs widget.
function renderMyRowHistory(history){
  var pendArea = document.getElementById('row-pending-area');
  var histArea = document.getElementById('row-hist-area');
  if (!histArea) return;

  // For teacher accounts, suppress 'request' events — those belong in ROW Approvals
  var isTeacher = CU && CU.realRole === 'teacher';
  if (isTeacher) history = history.filter(function(h){ return h.type !== 'request'; });

  var pending = history.filter(function(h){ return h.status === 'pending' && h.type === 'request'; });

  // Pending block
  if (pendArea){
    if (pending.length){
      pendArea.innerHTML = pending.map(function(p){
        return '<div class="row-pending"><span><strong>Pending</strong> &mdash; ' + esc(p.category) + '</span><button class="btn btn-ghost btn-sm" style="margin-left:auto;font-size:10px;padding:2px 7px;" onclick="cancelRowReq(\'' + esc(p.id) + '\')">Cancel</button></div>';
      }).join('');
    } else {
      pendArea.innerHTML = '';
    }
  }

  // History list (most recent 20)
  if (!history.length){
    histArea.innerHTML = '<div style="text-align:center;padding:10px 6px;color:var(--tx4);font-size:11px;">No ROW activity yet. Earn your first ROW!</div>';
    return;
  }
  histArea.innerHTML = history.slice(0, 20).map(function(h){
    // Color + amount string based on transaction type and status
    var amtClass = 'pos', amtStr = '+' + h.amount;
    if (h.status === 'pending'){ amtClass = 'pend'; amtStr = '?'; }
    else if (h.status === 'denied'){ amtClass = 'deny'; amtStr = '—'; }
    else if (h.type === 'spend' || h.type === 'admin_debit'){ amtClass = 'neg'; amtStr = '−' + h.amount; }

    var statusLbl = h.status === 'pending'  ? '<span class="row-hist-status pending">Pending</span>'
                  : h.status === 'approved' ? '<span class="row-hist-status approved">Approved</span>'
                  : h.status === 'denied'   ? '<span class="row-hist-status denied">Denied</span>'
                  : '<span class="row-hist-status completed">' + esc(h.type === 'spend' ? 'Spent' : h.type === 'admin_credit' ? 'Added' : 'Adjusted') + '</span>';

    var when = h.createdAt ? fmtDate(h.createdAt.slice(0,10)) : '';
    return '<div class="row-hist-item"><div class="row-hist-body"><div class="row-hist-cat">' + esc(h.category || 'ROW') + '</div><div class="row-hist-meta">' + esc(h.description || '') + (when ? ' &middot; ' + when : '') + '</div></div>' + statusLbl + '<div class="row-hist-amt ' + amtClass + '">' + amtStr + '</div></div>';
  }).join('');
}

// Highlight the clicked category card in the ROW request flip panel.
function pickRowCat(el){
  document.querySelectorAll('#row-cat-grid .row-cat-opt').forEach(function(e){ e.classList.remove('sel'); });
  el.classList.add('sel');
  _rowSelectedCat = el.dataset.cat;
}

// Module-level flag — true while a request is in flight or in its
// 3-second cool-down. Lives outside submitRowRequest so it survives
// across button re-renders and DOM reshuffles.
var _rowSubmitLocked = false;

// Submit a new ROW request to the selected teacher.
// Quadruple-locked against spam: (1) JS flag blocks function entry,
// (2) button disabled, (3) spinner shown, (4) 3-second minimum
// cool-down before the lock releases even on instant server replies.
function submitRowRequest(){
  if (_rowSubmitLocked) return;  // hard block — already in flight or cooling down

  var teachSel = document.getElementById('row-teach-sel');
  var descEl   = document.getElementById('row-desc');
  var teacher  = teachSel ? teachSel.value : '';
  var desc     = descEl ? descEl.value.trim() : '';
  var sel      = document.querySelector('#row-cat-grid .row-cat-opt.sel');
  var cat      = sel ? sel.dataset.cat : _rowSelectedCat;

  if (!teacher){ toast('Pick a teacher', 'err'); return; }
  if (!desc || desc.length < 3){ toast('Write a short description', 'err'); return; }

  // Engage the lock immediately, before anything else can run
  _rowSubmitLocked = true;
  var lockStart = Date.now();

  // Find the visible "Send Request" button. We scan all buttons rather
  // than scoping to a container because the button may live on the
  // widget back, the flip panel, or elsewhere depending on the layout.
  var btn = null;
  var candidates = document.querySelectorAll('button');
  for (var i = 0; i < candidates.length; i++){
    if (/Send Request/i.test(candidates[i].textContent) && candidates[i].offsetParent !== null){
      btn = candidates[i];
      break;
    }
  }
  var origHTML = btn ? btn.innerHTML : '';
  if (btn){
    btn.disabled = true;
    btn.innerHTML = '<span style="display:inline-block;width:11px;height:11px;border:2px solid currentColor;border-right-color:transparent;border-radius:50%;animation:row-spin 0.6s linear infinite;vertical-align:-2px;margin-right:7px;"></span>Sending...';
  }

  // One-time inject of the spinner keyframes so we don't need any CSS edits
  if (!document.getElementById('row-spin-kf')){
    var style = document.createElement('style');
    style.id = 'row-spin-kf';
    style.textContent = '@keyframes row-spin{to{transform:rotate(360deg)}}';
    document.head.appendChild(style);
  }

  // Unlock helper — enforces 3-second minimum regardless of server speed
  function unlock(){
    var elapsed = Date.now() - lockStart;
    var remaining = Math.max(0, 3000 - elapsed);
    setTimeout(function(){
      _rowSubmitLocked = false;
      if (btn){
        btn.disabled = false;
        btn.innerHTML = origHTML || 'Send Request';
      }
    }, remaining);
  }

  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      unflipWidget('rowbank');
      toast('Request sent to teacher!', 'ok');
      loadMyRows();
    } else {
      toast(r.error || 'Could not send request', 'err');
    }
    unlock();
  }).withFailureHandler(function(e){
    toast((e && e.message) ? e.message : 'Could not send request', 'err');
    unlock();
  }).requestRow(teacher, cat, desc);
}

// Cancel a pending ROW request the student created.
// Cancel a pending ROW request. The cancel button disables and shows
// "Cancelling..." the moment the student confirms, so they can't
// double-click it and they get clear feedback during the server call.
function cancelRowReq(id){
  appConfirm('This will cancel your pending ROW request. You can always submit a new one.', {
    title: 'Cancel this request?',
    okText: 'Yes, cancel it',
    cancelText: 'Keep it',
    tone: 'warn'
  }).then(function(ok){
    if (!ok) return;

    // Find the cancel button for THIS request and lock it. We scan all
    // buttons with the matching onclick handler since the pending list
    // doesn't give individual cancel buttons unique IDs.
    var btn = null;
    var candidates = document.querySelectorAll('#row-pending-area button');
    for (var i = 0; i < candidates.length; i++){
      if (candidates[i].getAttribute('onclick') && candidates[i].getAttribute('onclick').indexOf(id) > -1){
        btn = candidates[i];
        break;
      }
    }
    var origText = btn ? btn.textContent : '';
    if (btn){
      btn.disabled = true;
      btn.textContent = 'Cancelling...';
    }

    google.script.run.withSuccessHandler(function(r){
      if (r.success){
        toast('Request cancelled', 'inf');
        loadMyRows();  // re-renders the pending area, button goes away with the row
      } else {
        toast(r.error || 'Could not cancel', 'err');
        // Restore the button so they can try again
        if (btn){ btn.disabled = false; btn.textContent = origText; }
      }
    }).withFailureHandler(function(e){
      toast((e && e.message) || 'Could not cancel', 'err');
      if (btn){ btn.disabled = false; btn.textContent = origText; }
    }).cancelMyRowRequest(id);
  });
}


