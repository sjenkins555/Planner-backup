   1. LOADING SCREEN ANIMATION
   Sparks, progress ring, and progress bar animate while waiting for
   getBootData. Stops when #loading is hidden.
   ═══════════════════════════════════════════════════════════════════ */
(function initLoadingScreen(){
  // Spawn 14 random sparks at the bottom of the loading screen
  var layer = document.getElementById('ld-specks');
  if (layer){
    for (var i = 0; i < 14; i++){
      var s = document.createElement('span');
      s.className = 'ld-spark';
      s.style.cssText = 'left:'+(Math.random()*100)+'%;'
        + 'bottom:'+(-5-Math.random()*10)+'%;'
        + 'width:'+(2+Math.random()*3)+'px;'
        + 'height:'+(2+Math.random()*3)+'px;'
        + 'animation-delay:'+(Math.random()*6)+'s;'
        + 'animation-duration:'+(4+Math.random()*5)+'s;';
      layer.appendChild(s);
    }
  }
  // Animate the circular progress ring + horizontal progress bar
  var ring = document.getElementById('ld-prog');
  var fill = document.getElementById('ld-pfill');
  var CIRC = 1131; // circumference of r=180 circle
  var pct = 0;
  function ldTick(){
    var el = document.getElementById('loading');
    if (!el || el.style.display === 'none') return;
    pct += 0.5 + Math.random() * 1.8;
    if (pct > 100) pct = 0;
    if (ring) ring.style.strokeDashoffset = (CIRC * (1 - pct/100)).toString();
    if (fill) fill.style.width = pct + '%';
    requestAnimationFrame(ldTick);
  }
  requestAnimationFrame(ldTick);
})();


