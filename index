/* ═══════════════════════════════════════════════════════════════════
   15. SHARED HELPERS
   String/date/time formatting used everywhere.
   ═══════════════════════════════════════════════════════════════════ */

// ─── In-app confirm dialog ──────────────────────────────────────
// Replacement for the browser's native confirm() popup, which looks
// alarming in school environments. Returns a Promise that resolves
// to true (confirmed) or false (cancelled). Styled to match the app.
//
// Usage:
//   appConfirm('Delete this note?').then(function(ok){ if (ok) ... });
//   appConfirm('Cancel this request?', {okText:'Yes, cancel', cancelText:'Keep it', tone:'warn'}).then(...);
function appConfirm(message, opts){
  opts = opts || {};
  var okText     = opts.okText     || 'Confirm';
  var cancelText = opts.cancelText || 'Cancel';
  var title      = opts.title      || 'Are you sure?';
  var tone       = opts.tone       || 'warn'; // 'warn' | 'danger' | 'info'

  // Tear down any prior instance (defensive — shouldn't normally happen)
  var existing = document.getElementById('app-confirm-modal');
  if (existing) existing.remove();

  return new Promise(function(resolve){
    var btnColor = tone === 'danger' ? '#ef4444' : (tone === 'info' ? 'var(--a2)' : '#fbbf24');
    var btnTextColor = tone === 'info' ? '#fff' : '#000';

    var ov = document.createElement('div');
    ov.id = 'app-confirm-modal';
    ov.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:9999;display:flex;align-items:center;justify-content:center;animation:appcfFade .15s ease-out;';
    ov.innerHTML =
      '<div style="background:var(--bg2);border:1px solid var(--border);border-radius:12px;max-width:380px;width:90%;padding:22px 24px;box-shadow:0 20px 60px rgba(0,0,0,.5);animation:appcfPop .18s cubic-bezier(.2,.9,.3,1.4);">'
        + '<div style="font-size:15px;font-weight:600;color:var(--tx);margin-bottom:8px;">' + esc(title) + '</div>'
        + '<div style="font-size:13px;color:var(--tx2);line-height:1.5;margin-bottom:18px;">' + esc(message) + '</div>'
        + '<div style="display:flex;gap:8px;justify-content:flex-end;">'
          + '<button id="appcf-cancel" class="btn btn-ghost btn-sm" style="font-size:12px;padding:6px 14px;">' + esc(cancelText) + '</button>'
          + '<button id="appcf-ok" class="btn btn-sm" style="font-size:12px;padding:6px 14px;background:' + btnColor + ';color:' + btnTextColor + ';border:none;font-weight:600;">' + esc(okText) + '</button>'
        + '</div>'
      + '</div>';

    // One-time inject of the fade/pop keyframes
    if (!document.getElementById('appcf-kf')){
      var style = document.createElement('style');
      style.id = 'appcf-kf';
      style.textContent = '@keyframes appcfFade{from{opacity:0}to{opacity:1}}@keyframes appcfPop{from{opacity:0;transform:scale(.92)}to{opacity:1;transform:scale(1)}}';
      document.head.appendChild(style);
    }

    document.body.appendChild(ov);

    function close(result){
      ov.style.opacity = '0';
      setTimeout(function(){ if (ov.parentNode) ov.remove(); }, 120);
      document.removeEventListener('keydown', onKey);
      resolve(result);
    }

    function onKey(e){
      if (e.key === 'Escape') close(false);
      else if (e.key === 'Enter') close(true);
    }
    document.addEventListener('keydown', onKey);

    document.getElementById('appcf-ok').onclick     = function(){ close(true);  };
    document.getElementById('appcf-cancel').onclick = function(){ close(false); };
    ov.onclick = function(e){ if (e.target === ov) close(false); };

    // Auto-focus the cancel button — safer default than auto-confirming
    setTimeout(function(){
      var cb = document.getElementById('appcf-cancel');
      if (cb) cb.focus();
    }, 50);
  });
}

// Show a transient toast notification. Types: 'inf' (default), 'ok', 'err'.
function toast(msg, type){
  type = type || 'inf';
  var el = document.createElement('div');
  el.className = 'toast ' + type;
  el.textContent = msg;
  document.getElementById('toasts').appendChild(el);
  setTimeout(function(){ el.remove(); }, 3200);
}

// Convert "HH:MM" 24-hour string to 12-hour format if user prefs say so.
function fmtTime(t){
  if (!t) return '';
  if (!prefs || prefs.timeFormat !== '12h') return t;
  try {
    var p = t.split(':'), h = parseInt(p[0]), m = p[1];
    var ap = h >= 12 ? 'PM' : 'AM';
    h = h % 12 || 12;
    return h + ':' + m + ' ' + ap;
  } catch(e){
    return t;
  }
}

// HTML-escape a string before injecting into innerHTML.
function esc(s){
  return String(s || '')
    .replace(/&/g,'&amp;')
    .replace(/</g,'&lt;')
    .replace(/>/g,'&gt;')
    .replace(/"/g,'&quot;');
}

// Format YYYY-MM-DD as "Mon 5" (short).
function fmtDate(ds){
  if (!ds) return '';
  try {
    var d = new Date(ds + 'T12:00:00');
    return MSHRT[d.getMonth()] + ' ' + d.getDate();
  } catch(e){ return ds; }
}

// Format YYYY-MM-DD as "May 5, 2026" (full).
function fmtDateFull(ds){
  if (!ds) return '';
  try {
    var d = new Date(ds + 'T12:00:00');
    return MONTHS[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
  } catch(e){ return ds; }
}


/* ═══════════════════════════════════════════════════════════════════
   16. SCIENCE EASTER EGG
   When a task title matches one of the SCIENCE_PHRASES, the entire
   page goes into a celebratory "science mode" (raining icons, banner).
   Triggered from flipSaveTask in index_home_widgets.html.
   ═══════════════════════════════════════════════════════════════════ */

var SCIENCE_PHRASES = ['science is awesome', 'science is the best', 'science rules'];
var _scienceActive = false;
var _scienceInterval = null;
var _scienceTimeout = null;

// Returns true if a task title matches a science trigger phrase.
function checkScienceTrigger(taskTitle){
  if (!taskTitle) return false;
  var clean = String(taskTitle).toLowerCase().trim().replace(/[.!?,]+$/, '');
  return SCIENCE_PHRASES.indexOf(clean) > -1;
}

// Start the easter egg: banner + raining icons for ~12 seconds.
function activateScienceMode(){
  if (_scienceActive) return;
  _scienceActive = true;
  document.body.classList.add('science-mode');

  // Banner
  var banner = document.createElement('div');
  banner.className = 'science-banner';
  banner.innerHTML = 'SCIENCE RULES<small>brought to you by your favorite science teacher</small>';
  document.body.appendChild(banner);
  setTimeout(function(){ if (banner.parentNode) banner.remove(); }, 2500);

  // Rain
  _scienceInterval = setInterval(dropScienceFace, 280);
  _scienceTimeout = setTimeout(function(){
    if (_scienceInterval){ clearInterval(_scienceInterval); _scienceInterval = null; }
  }, 12000);
}

// Tear down science mode (rain stops, mode class removed).
function deactivateScienceMode(){
  _scienceActive = false;
  document.body.classList.remove('science-mode');
  if (_scienceInterval){ clearInterval(_scienceInterval); _scienceInterval = null; }
  if (_scienceTimeout){ clearTimeout(_scienceTimeout); _scienceTimeout = null; }
  document.querySelectorAll('.science-drop').forEach(function(el){ el.remove(); });
}

// Drop a single random-sized "science face" element from the top of the screen.
function dropScienceFace(){
  var d = document.createElement('div');
  d.className = 'science-drop';
  var size = 50 + Math.random() * 70;
  d.style.width = size + 'px';
  d.style.height = size + 'px';
  d.style.left = (Math.random() * 100) + 'vw';
  d.style.animationDuration = (2.5 + Math.random() * 2.5) + 's';
  d.style.opacity = (0.6 + Math.random() * 0.4).toFixed(2);
  document.body.appendChild(d);
  setTimeout(function(){ if (d.parentNode) d.remove(); }, 6000);
}

</script>


