var _rowHistData = [];        // cached transactions
var _rowHistFilter = 'all';   // 'all' | 'approved' | 'denied'

// Build and open the approval history modal. Fetches data on open.
function openRowHistoryModal(){
  // Tear down any prior instance
  var existing = document.getElementById('row-hist-modal');
  if (existing) existing.remove();

  var ov = document.createElement('div');
  ov.id = 'row-hist-modal';
  ov.className = 'overlay open';
  ov.innerHTML =
    '<div class="smx" style="max-width:760px;height:min(640px,88vh);">'
      + '<div class="smx-head">'
        + '<div><span class="smx-title">ROW Approval History</span></div>'
        + '<button class="smx-close" onclick="closeRowHistoryModal()" aria-label="Close"><svg class="ic" width="14" height="14"><use href="#i-close"/></svg></button>'
      + '</div>'
      + '<div class="smx-tabs" role="tablist">'
        + '<button class="smx-tab active" data-rh-tab="all" onclick="switchRowHistTab(\'all\')">All</button>'
        + '<button class="smx-tab" data-rh-tab="approved" onclick="switchRowHistTab(\'approved\')">Approved</button>'
        + '<button class="smx-tab" data-rh-tab="denied" onclick="switchRowHistTab(\'denied\')">Denied</button>'
      + '</div>'
      + '<div style="padding:14px 22px 0;flex-shrink:0;">'
        + '<div style="position:relative;">'
        + '<svg class="ui-ic" viewBox="0 0 16 16" style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--tx3);pointer-events:none;"><use href="#i-search"/></svg>'
        + '<input class="finp" type="text" id="rh-search" placeholder="Search by student name or email..." oninput="renderRowHistList()" style="padding-left:36px;">'
        + '</div>'
      + '</div>'
      + '<div class="smx-body" id="rh-list-body" style="padding-top:14px;"><div style="color:var(--tx3);padding:30px;text-align:center;font-size:13px;">Loading...</div></div>'
      + '<div class="smx-foot">'
        + '<div class="smx-foot-info" id="rh-count">—</div>'
        + '<button class="btn btn-ghost" onclick="closeRowHistoryModal()">Close</button>'
      + '</div>'
    + '</div>';
  ov.addEventListener('click', function(e){ if (e.target === ov) closeRowHistoryModal(); });
  document.body.appendChild(ov);

  // Reset state and fetch
  _rowHistData = [];
  _rowHistFilter = 'all';
  google.script.run.withSuccessHandler(function(r){
    if (!r.success){
      var b = document.getElementById('rh-list-body');
      if (b) b.innerHTML = '<div style="color:#f87171;padding:14px;">' + esc(r.error || 'Unknown error') + '</div>';
      return;
    }
    _rowHistData = r.transactions || [];
    renderRowHistList();
  }).withFailureHandler(function(e){
    var b = document.getElementById('rh-list-body');
    if (b) b.innerHTML = '<div style="color:#f87171;padding:14px;">' + esc(e.message || 'Unknown error') + '</div>';
  }).getMyApprovalHistory();
}

// Close the history modal.
function closeRowHistoryModal(){
  var modal = document.getElementById('row-hist-modal');
  if (modal) modal.remove();
}

// Switch between All / Approved / Denied tabs.
function switchRowHistTab(tab){
  _rowHistFilter = tab;
  document.querySelectorAll('[data-rh-tab]').forEach(function(b){
    b.classList.toggle('active', b.dataset.rhTab === tab);
  });
  renderRowHistList();
}

// Filter + render the transaction list (called on tab change and search input).
function renderRowHistList(){
  var body = document.getElementById('rh-list-body');
  if (!body) return;

  var search = (document.getElementById('rh-search') || {}).value || '';
  search = search.trim().toLowerCase();

  var filtered = (_rowHistData || []).filter(function(t){
    if (_rowHistFilter !== 'all' && t.status !== _rowHistFilter) return false;
    if (search){
      if (t.studentName.toLowerCase().indexOf(search) === -1 &&
          t.studentEmail.toLowerCase().indexOf(search) === -1) return false;
    }
    return true;
  });

  // Footer count
  var countEl = document.getElementById('rh-count');
  if (countEl) countEl.textContent = filtered.length + ' transaction' + (filtered.length === 1 ? '' : 's');

  if (!filtered.length){
    body.innerHTML = '<div style="text-align:center;padding:36px 20px;color:var(--tx3);font-size:13px;">No transactions match your filter.</div>';
    return;
  }

  // Render each transaction as a card with status pill, amount, category, description
  body.innerHTML = filtered.map(function(t){
    var color = t.status === 'approved' ? '#22c55e' : t.status === 'denied' ? '#f87171' : '#fbbf24';
    var bg    = t.status === 'approved' ? 'rgba(34,197,94,.12)' : t.status === 'denied' ? 'rgba(239,68,68,.12)' : 'rgba(245,158,11,.12)';
    var when  = t.resolvedAt ? fmtDate(t.resolvedAt.slice(0,10)) : (t.createdAt ? fmtDate(t.createdAt.slice(0,10)) : '');
    var amtStr = t.status === 'approved' ? '+' + t.amount : (t.status === 'denied' ? '—' : '?');

    return '<div style="background:var(--bg3);border:1px solid var(--border);border-radius:9px;padding:11px 13px;margin-bottom:8px;">'
      + '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">'
        + '<div style="flex:1;min-width:0;">'
          + '<div style="font-size:13px;font-weight:600;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(t.studentName) + '</div>'
          + '<div style="font-size:10px;color:var(--tx3);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(t.studentEmail) + (when ? ' · ' + when : '') + '</div>'
        + '</div>'
        + '<span style="font-size:9px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;background:' + bg + ';color:' + color + ';border-radius:4px;padding:2px 8px;">' + esc(t.status) + '</span>'
        + '<span style="font-family:\'DM Mono\',monospace;font-weight:700;font-size:14px;color:' + color + ';min-width:36px;text-align:right;">' + amtStr + '</span>'
      + '</div>'
      + '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px;">'
        + '<span style="font-size:9px;font-weight:700;letter-spacing:.4px;text-transform:uppercase;background:var(--a5);color:var(--a2);border:1px solid var(--a4);border-radius:4px;padding:1px 6px;">' + esc(t.category) + '</span>'
      + '</div>'
      + '<div style="font-size:12px;color:var(--tx);line-height:1.5;padding:7px 0 2px;border-top:1px solid var(--border);">' + esc(t.description) + '</div>'
      + (t.comment ? '<div style="font-size:11px;color:var(--tx3);margin-top:4px;font-style:italic;">Your comment: ' + esc(t.comment) + '</div>' : '')
    + '</div>';
  }).join('');
}


/* ═══════════════════════════════════════════════════════════════════
   4. LINK RAIL
   Vertical sidebar of assigned links (students see assigned-by-teacher
   links, teachers see their own My Links). Drag-and-drop reorderable.
   Collapsible with a side-arrow button.
   ═══════════════════════════════════════════════════════════════════ */

// Build a Google favicon URL for a given site.
function faviconUrl(url){
  try {
    var d = new URL(url.startsWith('http') ? url : 'https://' + url).hostname;
    return 'https://www.google.com/s2/favicons?domain=' + d + '&sz=64';
  } catch(e){
    return '';
  }
}

// Fetch the link list for the current user and pass to renderLinkRail.
// Uses preloaded boot data if available (avoids extra round-trip).
function loadMyAssignedLinks(){
  // Use preloaded data if it's fresh
  if (window._preloadedAssignedLinks !== undefined && window._preloadedAssignedLinks !== null){
    if (!(CU && CU.role === 'teacher')){
      renderLinkRail(window._preloadedAssignedLinks || []);
      window._preloadedAssignedLinks = null;
      return;
    }
    window._preloadedAssignedLinks = null;
  }

  if (CU && CU.role === 'teacher'){
    // Teachers: show their own My Links
    google.script.run
      .withSuccessHandler(function(r){
        var links = (r.links || []).map(function(l){
          return { id:l.url, label:l.label, url:l.url, iconUrl:'' };
        });
        renderLinkRail(links);
      })
      .withFailureHandler(function(){})
      .getMyLinks();
  } else {
    // Students: show links assigned by teachers
    google.script.run
      .withSuccessHandler(function(links){ renderLinkRail(links || []); })
      .withFailureHandler(function(){})
      .getMyAssignedLinks();
  }
}

// Render the link rail given an array of {id, label, url, iconUrl} objects.
// Handles empty state for teachers (still shows the collapse arrow), drag
// reordering, and the collapse toggle.
function renderLinkRail(links){
  var rail = document.getElementById('link-rail');
  if (!rail) return;
  var isTeacher = CU && CU.role === 'teacher';

  // Empty state
  if (!links || !links.length){
    if (!isTeacher){
      // Students with no assigned links: hide rail entirely
      rail.classList.remove('visible');
      document.body.classList.remove('has-rail');
      rail.innerHTML = '';
      return;
    }
    // Teachers: keep the rail visible (hint + collapse arrow)
    document.body.classList.add('has-rail');
    rail.classList.add('visible');
    var isColl = prefs && prefs.railCollapsed || false;
    if (isColl){ rail.classList.add('rail-collapsed'); document.body.classList.add('rail-collapsed'); }
    else { rail.classList.remove('rail-collapsed'); document.body.classList.remove('rail-collapsed'); }
    rail.innerHTML = '';
    if (!isColl){
      var hint = document.createElement('div');
      hint.style.cssText = 'font-size:8px;color:var(--tx4);text-align:center;padding:6px 3px;line-height:1.6;width:52px;';
      hint.textContent = 'Add links via My Links widget';
      rail.appendChild(hint);
    }
    var colBtnE = document.createElement('div');
    colBtnE.className = 'rail-collapse-btn';
    colBtnE.textContent = isColl ? '\u25B6' : '\u25C4';
    colBtnE.title = isColl ? 'Expand' : 'Collapse';
    colBtnE.onclick = function(){
      prefs.railCollapsed = !prefs.railCollapsed;
      rail.classList.toggle('rail-collapsed', prefs.railCollapsed);
      document.body.classList.toggle('rail-collapsed', prefs.railCollapsed);
      colBtnE.textContent = prefs.railCollapsed ? '\u25B6' : '\u25C4';
      colBtnE.title = prefs.railCollapsed ? 'Expand' : 'Collapse';
      google.script.run.saveMyPrefs(JSON.stringify(prefs));
      renderLinkRail([]);
    };
    rail.appendChild(colBtnE);
    return;
  }

  // Apply saved drag-reorder
  var order = prefs.railLinkOrder || [];
  if (order.length){
    links = links.slice().sort(function(a, b){
      var ai = order.indexOf(a.id), bi = order.indexOf(b.id);
      if (ai === -1) ai = 9999;
      if (bi === -1) bi = 9999;
      return ai - bi;
    });
  }

  document.body.classList.add('has-rail');
  rail.classList.add('visible');

  // Build link items
  rail.innerHTML = links.map(function(l){
    var href = l.url.startsWith('http') ? l.url : 'https://' + l.url;
    var fav = faviconUrl(href);
    var src = l.iconUrl || fav;
    return '<div class="rail-item" draggable="true" data-id="' + esc(l.id) + '">'
      + '<a class="rail-link" href="' + esc(href) + '" target="_blank" rel="noopener">'
      + '<img src="' + esc(src) + '" onerror="if(this.src!==\'' + esc(fav) + '\')this.src=\'' + esc(fav) + '\';" alt="' + esc(l.label) + '">'
      + '<span class="rail-tip">' + esc(l.label) + '</span>'
      + '</a>'
      + '<div class="rail-label">' + esc(l.label.slice(0,8)) + '</div>'
      + '</div>';
  }).join('');

  // Drag-to-reorder wiring
  var _rdSrc = null;
  rail.querySelectorAll('.rail-item').forEach(function(item){
    item.addEventListener('dragstart', function(e){
      _rdSrc = item;
      e.dataTransfer.effectAllowed = 'move';
      setTimeout(function(){ item.style.opacity = '.35'; }, 0);
    });
    item.addEventListener('dragend', function(){
      item.style.opacity = '';
      _rdSrc = null;
      rail.querySelectorAll('.rail-item').forEach(function(i){ i.style.outline = ''; });
    });
    item.addEventListener('dragover', function(e){
      e.preventDefault();
      if (item !== _rdSrc) item.style.outline = '2px solid var(--a1)';
    });
    item.addEventListener('dragleave', function(){ item.style.outline = ''; });
    item.addEventListener('drop', function(e){
      e.preventDefault();
      item.style.outline = '';
      if (!_rdSrc || _rdSrc === item) return;

      // Compute new order
      var ids = Array.from(rail.querySelectorAll('.rail-item')).map(function(i){ return i.dataset.id; });
      var srcId = _rdSrc.dataset.id, dstId = item.dataset.id;
      var fi = ids.indexOf(srcId);
      if (fi > -1) ids.splice(fi, 1);
      var ti = ids.indexOf(dstId);
      if (ti > -1) ids.splice(ti, 0, srcId);
      else ids.push(srcId);

      prefs.railLinkOrder = ids;
      google.script.run.saveMyPrefs(JSON.stringify(prefs));

      // Re-sort and re-render
      var reordered = links.slice().sort(function(a, b){
        var ai = ids.indexOf(a.id), bi = ids.indexOf(b.id);
        if (ai === -1) ai = 9999;
        if (bi === -1) bi = 9999;
        return ai - bi;
      });
      renderLinkRail(reordered);
    });
  });

  // Collapse toggle
  var colBtn = document.createElement('div');
  colBtn.className = 'rail-collapse-btn';
  var isColl = prefs.railCollapsed || false;
  if (isColl){ rail.classList.add('rail-collapsed'); document.body.classList.add('rail-collapsed'); }
  else { rail.classList.remove('rail-collapsed'); document.body.classList.remove('rail-collapsed'); }
  colBtn.textContent = isColl ? '\u25B6' : '\u25C4';
  colBtn.title = isColl ? 'Expand' : 'Collapse';
  colBtn.onclick = function(){
    prefs.railCollapsed = !prefs.railCollapsed;
    rail.classList.toggle('rail-collapsed', prefs.railCollapsed);
    document.body.classList.toggle('rail-collapsed', prefs.railCollapsed);
    colBtn.textContent = prefs.railCollapsed ? '\u25B6' : '\u25C4';
    colBtn.title = prefs.railCollapsed ? 'Expand' : 'Collapse';
    google.script.run.saveMyPrefs(JSON.stringify(prefs));
  };
  rail.appendChild(colBtn);
}


/* ═══════════════════════════════════════════════════════════════════
   5. STUDENT VIEW HELPERS
   Used inside the teacher's "View as Student" preview to show what
   links the student would see. Only renderAssignedLinksSection lives
   here — the rest of the student view is in index_teacher_widgets.
   ═══════════════════════════════════════════════════════════════════ */

// Build the assigned-links section for a student preview. Returns HTML.
function renderAssignedLinksSection(assignedLinks){
  if (!assignedLinks || !assignedLinks.length){
    return '<div style="color:var(--tx4);font-size:13px;">No links assigned.</div>';
  }
  return '<div style="display:flex;flex-wrap:wrap;gap:10px;">' + assignedLinks.map(function(l){
    var href = l.url.startsWith('http') ? l.url : 'https://' + l.url;
    var fav = faviconUrl(href);
    var src = l.iconUrl || fav;
    return '<a href="' + esc(href) + '" target="_blank" rel="noopener" style="display:flex;flex-direction:column;align-items:center;gap:4px;text-decoration:none;">'
      + '<div style="width:48px;height:48px;border-radius:12px;overflow:hidden;background:rgba(255,255,255,.06);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;transition:border-color .15s;" onmouseover="this.style.borderColor=\'var(--a4)\'" onmouseout="this.style.borderColor=\'var(--border)\'">'
      + '<img src="' + esc(src) + '" onerror="if(this.src!==\'' + esc(fav) + '\')this.src=\'' + esc(fav) + '\';" style="width:32px;height:32px;object-fit:contain;" alt="' + esc(l.label) + '"></div>'
      + '<span style="font-size:10px;color:var(--tx3);font-weight:500;max-width:52px;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(l.label) + '</span>'
      + '</a>';
  }).join('') + '</div>';
}


/* ═══════════════════════════════════════════════════════════════════
   6. REPAIR SHEETS BUTTON
   Admin tool: re-creates any missing tabs in the spreadsheet without
   touching existing data. Wired up to a button in the Admin tab's
   Repair widget (rendered by index_admin_widgets).
   ═══════════════════════════════════════════════════════════════════ */

function doRepairSheets(){
  var btn = document.getElementById('repair-btn');
  var res = document.getElementById('repair-result');
  if (btn) btn.textContent = 'Running...';
  if (res) res.innerHTML = '';

  google.script.run
    .withSuccessHandler(function(r){
      if (btn) btn.textContent = '&#128295; Run Repair Now';
      if (!res) return;
      if (r.success){
        // Two outcomes: created some tabs, or everything was already fine
        res.innerHTML = r.created.length
          ? '<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:10px;padding:12px 14px;font-size:13px;color:#22c55e;">&#10003; Created: <strong>' + r.created.join(', ') + '</strong><br><span style="color:var(--tx3);font-size:12px;">All existing data is untouched.</span></div>'
          : '<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:10px;padding:12px 14px;font-size:13px;color:#22c55e;">&#10003; All sheets already present — nothing needed fixing.</div>';
      } else {
        res.innerHTML = '<div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:10px;padding:12px 14px;font-size:13px;color:#f87171;">&#10005; ' + esc(r.error || 'Unknown error') + '</div>';
      }
    })
    .withFailureHandler(function(e){
      if (btn) btn.textContent = '&#128295; Run Repair Now';
      if (res) res.innerHTML = '<div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:10px;padding:12px 14px;font-size:13px;color:#f87171;">&#10005; ' + esc(e.message || 'Script error') + '</div>';
    })
    .repairSheetsFromApp();
}

</script>


