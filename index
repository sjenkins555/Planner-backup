function tickClock(){
  var now=new Date(),h24=String(now.getHours()).padStart(2,'0'),m=String(now.getMinutes()).padStart(2,'0'),s=String(now.getSeconds()).padStart(2,'0');
  var is24=prefs&&prefs.timeFormat==='24h';
  var dispH=is24?h24:String(now.getHours()%12||12).padStart(2,'0');
  var ampm=is24?'':' '+(now.getHours()>=12?'PM':'AM');
  var lc=document.getElementById('live-clock');if(lc)lc.textContent=dispH+':'+m+':'+s+ampm;
  updateClock(now,h24,m,s);
}
function updateClock(now,h,m,s){
  var style=prefs?prefs.clockStyle:'digital',el=document.getElementById('clk-main');if(!el)return;
  var is24=prefs&&prefs.timeFormat==='24h',ph=now.getHours();
  if(style==='digital'){el.textContent=is24?h+':'+m+':'+s:String(ph%12||12).padStart(2,'0')+':'+m+':'+s+' '+(ph>=12?'PM':'AM');}
  else if(style==='analog'){drawAnalog(now);}
  else if(style==='minimal'){el.innerHTML=is24?h+':'+m:String(ph%12||12)+':'+m+'<span class="clk-ampm">'+(ph>=12?'PM':'AM')+'</span>';}
  else if(style==='word'){el.innerHTML=timeToWords(now);}
}
function drawAnalog(now){
  var svg=document.getElementById('analog-svg');if(!svg)return;
  var SVG_NS='http://www.w3.org/2000/svg';
  var hr=now.getHours()%12,mn=now.getMinutes(),sc=now.getSeconds();
  var hA=hr*30+mn*0.5,mA=mn*6+sc*0.1,sA=sc*6,cx=100,cy=100;
  // Clear existing children
  while(svg.firstChild) svg.removeChild(svg.firstChild);
  function mkEl(tag, attrs){
    var el=document.createElementNS(SVG_NS, tag);
    for(var k in attrs) el.setAttribute(k, attrs[k]);
    return el;
  }
  function mkHand(ang,len,w,col){
    var a=(ang-90)*Math.PI/180;
    return mkEl('line', {x1:cx, y1:cy, x2:cx+Math.cos(a)*len, y2:cy+Math.sin(a)*len, stroke:col, 'stroke-width':w, 'stroke-linecap':'round'});
  }
  svg.appendChild(mkEl('circle', {cx:cx, cy:cy, r:90, fill:'none', stroke:'rgba(255,255,255,0.06)', 'stroke-width':2}));
  svg.appendChild(mkEl('circle', {cx:cx, cy:cy, r:88, fill:'rgba(15,23,42,0.4)'}));
  for(var i=0;i<12;i++){
    var a=(i*30-90)*Math.PI/180, r1=80, r2=i%3===0?70:75;
    svg.appendChild(mkEl('line', {x1:cx+Math.cos(a)*r1, y1:cy+Math.sin(a)*r1, x2:cx+Math.cos(a)*r2, y2:cy+Math.sin(a)*r2, stroke:'rgba(255,255,255,0.2)', 'stroke-width':i%3===0?2:1}));
  }
  svg.appendChild(mkHand(hA,52,4,'rgba(255,255,255,0.8)'));
  svg.appendChild(mkHand(mA,70,3,'rgba(255,255,255,0.7)'));
  svg.appendChild(mkHand(sA,75,1.5,'var(--a1)'));
  svg.appendChild(mkEl('circle', {cx:cx, cy:cy, r:5, fill:'var(--a1)'}));
  svg.appendChild(mkEl('circle', {cx:cx, cy:cy, r:2, fill:'#fff'}));
}
function timeToWords(now){
  var nums=['twelve','one','two','three','four','five','six','seven','eight','nine','ten','eleven','twelve'],mins=['','five','ten','fifteen','twenty','twenty-five','thirty'];
  var h=now.getHours()%12,m=now.getMinutes(),nh=nums[h],nn=nums[h===11?0:h+1];
  if(m===0)return '<span>It\'s</span> <b>'+nh+' o\'clock</b>';
  if(m===15)return '<span>It\'s</span> <b>quarter past</b> <b>'+nh+'</b>';
  if(m===30)return '<span>It\'s</span> <b>half past</b> <b>'+nh+'</b>';
  if(m===45)return '<span>It\'s</span> <b>quarter to</b> <b>'+nn+'</b>';
  if(m<30){var t=mins[Math.round(m/5)];return '<span>It\'s</span> <b>'+(t||m)+' past</b> <b>'+nh+'</b>';}
  var rm=60-m,t2=mins[Math.round(rm/5)];return '<span>It\'s</span> <b>'+(t2||rm)+' to</b> <b>'+nn+'</b>';
}

