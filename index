// Render the navstrip from tabDefs. Called once after buildStudentNav/buildTeacherNav.
function renderNav(){
  document.getElementById('navstrip').innerHTML = tabDefs.map(function(t){
    if (t.id === '_s') return '<div class="nav-sep"></div>';
    var ico = t.svg ? '<svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="' + t.svg + '"/></svg>' : (t.icon || '');
    return '<button class="nav-btn" id="nb-' + t.id + '" onclick="switchTab(\'' + t.id + '\')">' + ico + ' ' + t.label + '</button>';
  }).join('');
}

// Switch to a tab. Caches the home tab DOM so revisiting it doesn't rebuild.
// Also sets body.dataset.activeTab so per-tab CSS tints can apply.
function switchTab(id){
  var homeId = CU && CU.role === 'teacher' ? 'my-home' : 'home';
  document.body.dataset.activeTab = id;

  // Mark the active button
  tabDefs.forEach(function(t){
    if (t.id === '_s') return;
    var b = document.getElementById('nb-' + t.id);
    if (b) b.classList.toggle('active', t.id === id);
  });

  // Find the tab definition
  var def = null;
  for (var i = 0; i < tabDefs.length; i++){
    if (tabDefs[i].id === id){ def = tabDefs[i]; break; }
  }
  if (!def || !def.fn) return;

  var content = document.getElementById('content');

  // Save home panel before navigating away from it
  if (id !== homeId){
    var hp = document.getElementById('tp-' + homeId);
    if (hp) _savedHomeNode = hp;
  }
  // Restore cached home panel instead of rebuilding
  if (id === homeId && _savedHomeNode){
    content.innerHTML = '';
    content.appendChild(_savedHomeNode);
    return;
  }

  content.innerHTML = '<div class="tab-pane active" id="tp-' + id + '"></div>';
  try {
    def.fn();
  } catch(e){
    var p = panel(id);
    if (p) p.innerHTML = '<div style="color:#ef4444;padding:24px;font-size:13px;">Error: ' + e.message + '</div>';
    console.error(e);
  }
}

// Helper: get the active tab pane element (or fall back to #content).
function panel(id){
  return document.getElementById('tp-' + id) || document.getElementById('content');
}


