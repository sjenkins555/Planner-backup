function flipToCustomize(id){
  _flipMode[id]='style';
  var tile=document.getElementById('tile-'+id);if(!tile)return;
  var back=document.getElementById('tb-'+id);if(!back)return;
  // If widget has no edit panel, go straight to style; otherwise default to Style tab
  back.innerHTML = buildBackPanel(id, 'style');
