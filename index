  var rows=mySchedule.length?mySchedule:(function(){var r=[];for(var i=0;i<7;i++)r.push({period:i+1,subject:'',teacher:'',room:'',startTime:'',endTime:''});return r;})();
  var rh='';rows.forEach(function(p,i){rh+='<tr><td style="padding:4px 5px;"><input class="finp" style="width:50px" value="'+esc(String(p.period))+'" data-i="'+i+'" data-f="period"></td><td style="padding:4px 5px;"><input class="finp" value="'+esc(p.subject||'')+'" data-i="'+i+'" data-f="subject" placeholder="—Subject—"></td><td style="padding:4px 5px;"><input class="finp" value="'+esc(p.teacher||'')+'" data-i="'+i+'" data-f="teacher" placeholder="—Name—"></td><td style="padding:4px 5px;"><input class="finp" style="width:68px" value="'+esc(p.room||'')+'" data-i="'+i+'" data-f="room" placeholder="—Room—"></td><td style="padding:4px 5px;"><input type="time" class="finp" style="width:112px" value="'+(p.startTime||'')+'" data-i="'+i+'" data-f="startTime"></td><td style="padding:4px 5px;"><input type="time" class="finp" style="width:112px" value="'+(p.endTime||'')+'" data-i="'+i+'" data-f="endTime"></td></tr>';});
  div.innerHTML='<div class="mbox wide"><div class="mtitle">&#128203; Edit Class Schedule</div><div style="overflow-y:auto;max-height:55vh;"><table style="width:100%;border-collapse:collapse;"><thead><tr><th style="padding:5px 7px;font-size:11px;color:var(--tx3);text-align:left;">#</th><th style="padding:5px 7px;font-size:11px;color:var(--tx3);text-align:left;">Subject</th><th style="padding:5px 7px;font-size:11px;color:var(--tx3);text-align:left;">Teacher</th><th style="padding:5px 7px;font-size:11px;color:var(--tx3);text-align:left;">Room</th><th style="padding:5px 7px;font-size:11px;color:var(--tx3);text-align:left;">Start</th><th style="padding:5px 7px;font-size:11px;color:var(--tx3);text-align:left;">End</th></tr></thead><tbody id="se-rows">'+rh+'</tbody></table></div><div style="display:flex;justify-content:space-between;align-items:center;margin-top:14px;"><button class="btn btn-ghost btn-sm" onclick="addSchedRow()">+ Add Row</button><div style="display:flex;gap:8px;"><button class="btn btn-ghost" onclick="document.getElementById(\'se-ov\').remove()">Cancel</button><button class="btn btn-primary" onclick="saveSchedule()">Save</button></div></div></div>';
  document.body.appendChild(div);
}
function addSchedRow(){
  var tb=document.getElementById('se-rows'),i=tb.querySelectorAll('tr').length,tr=document.createElement('tr');
  tr.innerHTML='<td style="padding:4px 5px;"><input class="finp" style="width:50px" value="'+(i+1)+'" data-i="'+i+'" data-f="period"></td><td style="padding:4px 5px;"><input class="finp" data-i="'+i+'" data-f="subject" placeholder="—Class—"></td><td style="padding:4px 5px;"><input class="finp" data-i="'+i+'" data-f="teacher" placeholder="—Name—"></td><td style="padding:4px 5px;"><input class="finp" style="width:68px" data-i="'+i+'" data-f="room" placeholder="—Room—"></td><td style="padding:4px 5px;"><input type="time" class="finp" style="width:112px" data-i="'+i+'" data-f="startTime"></td><td style="padding:4px 5px;"><input type="time" class="finp" style="width:112px" data-i="'+i+'" data-f="endTime"></td>';
  tb.appendChild(tr);
