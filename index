function setWeatherView(v){prefs.weatherView=v;document.querySelectorAll('.weather-vbtn').forEach(function(b){b.className='btn btn-sm weather-vbtn '+(b.dataset.view===v?'btn-primary':'btn-ghost');});loadWeather();google.script.run.saveMyPrefs(JSON.stringify(prefs));}
function fetchWeatherData(lat,lon,city){
  var vw=prefs.weatherView||'today';var el=document.getElementById('weather-body');if(!el)return;
  el.innerHTML='<div class="weather-loading"><div class="spinner" style="margin:0 auto 8px;"></div>Loading...</div>';
  var url;
  if(vw==='today'){url='https://api.open-meteo.com/v1/forecast?latitude='+lat+'&longitude='+lon+'&current_weather=true&temperature_unit=fahrenheit&windspeed_unit=mph';}
  else{var days=vw==='5day'?5:10;url='https://api.open-meteo.com/v1/forecast?latitude='+lat+'&longitude='+lon+'&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_probability_max&temperature_unit=fahrenheit&timezone=auto&forecast_days='+days;}
  fetch(url).then(function(r){return r.json();}).then(function(data){
    if(vw==='today'){
      var cw=data.current_weather,code=cw.weathercode,icon=WMO_ICONS[code]||'&#127777;',desc=WMO_DESC[code]||'';
      el.innerHTML='<div class="weather-display"><div class="weather-icon">'+icon+'</div><div class="weather-temp">'+toDisplayTemp(cw.temperature)+tempLabel()+'</div><div class="weather-desc">'+desc+'</div><div class="weather-city">'+(city||'Your Location')+'</div><div class="weather-meta"><div class="weather-meta-item">Wind: '+Math.round(cw.windspeed)+' mph</div></div><button class="btn btn-ghost btn-sm" style="margin-top:12px;width:100%;" onclick="loadWeather()">Refresh</button></div>';
    } else {
      var d=data.daily,cols=d.time.length,html='<div style="display:grid;grid-template-columns:repeat('+cols+',1fr);gap:4px;overflow-x:auto;">';
      for(var i=0;i<cols;i++){
        var dt=new Date(d.time[i]+'T12:00:00'),dn=DAYS[dt.getDay()].substring(0,3);
        var ico=WMO_ICONS[d.weathercode[i]]||'&#127777;';
        var precip=(d.precipitation_probability_max&&d.precipitation_probability_max[i]!=null)?d.precipitation_probability_max[i]:null;
        html+='<div style="text-align:center;padding:8px 3px;background:var(--bg3);border:1px solid var(--border);border-radius:10px;"><div style="font-size:9px;font-weight:600;color:var(--a2);margin-bottom:3px;letter-spacing:.3px;">'+dn+'</div><div style="font-size:18px;margin:2px 0;">'+ico+'</div><div style="font-size:12px;font-weight:700;color:var(--tx);">'+toDisplayTemp(d.temperature_2m_max[i])+tempLabel()+'</div><div style="font-size:10px;color:var(--tx3);">'+toDisplayTemp(d.temperature_2m_min[i])+tempLabel()+'</div>'+(precip!=null?'<div style="font-size:9px;color:#38bdf8;margin-top:2px;">&#128167;'+precip+'%</div>':'')+'</div>';
      }
      html+='</div><button class="btn btn-ghost btn-sm" style="margin-top:10px;width:100%;" onclick="loadWeather()">Refresh</button>';
      el.innerHTML=html;
    }
  }).catch(function(){
    if(el)el.innerHTML='<div class="weather-err">Could not load weather.</div>';
  }).finally(function(){
    hideWidgetLoader('weather');
  });
}
function useGeoLocation(){
  if(!navigator.geolocation){toast('Geolocation not supported','err');return;}
  navigator.geolocation.getCurrentPosition(function(pos){
    var lat=pos.coords.latitude,lon=pos.coords.longitude;prefs.weatherLat=lat;prefs.weatherLon=lon;
    fetch('https://nominatim.openstreetmap.org/reverse?lat='+lat+'&lon='+lon+'&format=json').then(function(r){return r.json();}).then(function(d){var city=(d.address.city||d.address.town||d.address.village||'')+(d.address.state?', '+d.address.state:'');prefs.weatherCity=city;google.script.run.saveMyPrefs(JSON.stringify(prefs));closeModal('weather-modal');fetchWeatherData(lat,lon,city);}).catch(function(){prefs.weatherCity='';google.script.run.saveMyPrefs(JSON.stringify(prefs));closeModal('weather-modal');fetchWeatherData(lat,lon,'');});
  },function(){toast('Could not get location. Try manual entry.','err');});
}
function useManualCity(){
  var city=document.getElementById('w-city').value.trim();if(!city){toast('Enter a city name','err');return;}
  fetch('https://nominatim.openstreetmap.org/search?q='+encodeURIComponent(city)+'&format=json&limit=1').then(function(r){return r.json();}).then(function(data){if(!data.length){toast('City not found.','err');return;}var lat=parseFloat(data[0].lat),lon=parseFloat(data[0].lon);prefs.weatherLat=lat;prefs.weatherLon=lon;prefs.weatherCity=city;google.script.run.saveMyPrefs(JSON.stringify(prefs));closeModal('weather-modal');fetchWeatherData(lat,lon,city);}).catch(function(){toast('Could not find city.','err');});
}

