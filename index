function faviconUrl(url){try{var d=new URL(url.startsWith('http')?url:'https://'+url).hostname;return'https://www.google.com/s2/favicons?domain='+d+'&sz=64';}catch(e){return '';}}
function loadMyAssignedLinks(){
  // Use the data preloaded by getBootData if it's available — no extra round-trip.
  if(window._preloadedAssignedLinks!==undefined && window._preloadedAssignedLinks!==null){
    if(!(CU&&CU.role==='teacher')){
      renderLinkRail(window._preloadedAssignedLinks||[]);
      window._preloadedAssignedLinks=null;
      return;
    }
    window._preloadedAssignedLinks=null;
  }
  if(CU&&CU.role==='teacher'){
    google.script.run
      .withSuccessHandler(function(r){
        var links=(r.links||[]).map(function(l){
          return{id:l.url,label:l.label,url:l.url,iconUrl:''};
        });
        renderLinkRail(links);
      })
      .withFailureHandler(function(){})
      .getMyLinks();
  }else{
    google.script.run
      .withSuccessHandler(function(links){renderLinkRail(links||[]);})
      .withFailureHandler(function(){})
      .getMyAssignedLinks();
  }
}
function renderLinkRail(links){
  var rail=document.getElementById('link-rail');if(!rail)return;
  var isTeacher=CU&&CU.role==='teacher';
  if(!links||!links.length){
    if(!isTeacher){rail.classList.remove('visible');document.body.classList.remove('has-rail');rail.innerHTML='';return;}
    // Teachers: always show rail even when empty, so the arrow is always accessible
    document.body.classList.add('has-rail');rail.classList.add('visible');
    var isColl=prefs&&prefs.railCollapsed||false;
    if(isColl){rail.classList.add('rail-collapsed');document.body.classList.add('rail-collapsed');}
    else{rail.classList.remove('rail-collapsed');document.body.classList.remove('rail-collapsed');}
    rail.innerHTML='';
    if(!isColl){
      var hint=document.createElement('div');
      hint.style.cssText='font-size:8px;color:var(--tx4);text-align:center;padding:6px 3px;line-height:1.6;width:52px;';
      hint.textContent='Add links via My Links widget';
      rail.appendChild(hint);
    }
    var colBtnE=document.createElement('div');
    colBtnE.className='rail-collapse-btn';
    colBtnE.textContent=isColl?'\u25B6':'\u25C4';
    colBtnE.title=isColl?'Expand':'Collapse';
    colBtnE.onclick=function(){
      prefs.railCollapsed=!prefs.railCollapsed;
      rail.classList.toggle('rail-collapsed',prefs.railCollapsed);
      document.body.classList.toggle('rail-collapsed',prefs.railCollapsed);
      colBtnE.textContent=prefs.railCollapsed?'\u25B6':'\u25C4';
      colBtnE.title=prefs.railCollapsed?'Expand':'Collapse';
      google.script.run.saveMyPrefs(JSON.stringify(prefs));
      renderLinkRail([]);
    };
    rail.appendChild(colBtnE);
    return;
  }
  // Apply saved order
  var order=prefs.railLinkOrder||[];
  if(order.length){
    links=links.slice().sort(function(a,b){
      var ai=order.indexOf(a.id),bi=order.indexOf(b.id);
      if(ai===-1)ai=9999;if(bi===-1)bi=9999;return ai-bi;
    });
  }
  document.body.classList.add('has-rail');rail.classList.add('visible');
  rail.innerHTML=links.map(function(l){
    var href=l.url.startsWith('http')?l.url:'https://'+l.url;
    var fav=faviconUrl(href);var src=l.iconUrl||fav;
    return '<div class="rail-item" draggable="true" data-id="'+esc(l.id)+'">'
      +'<a class="rail-link" href="'+esc(href)+'" target="_blank" rel="noopener">'
      +'<img src="'+esc(src)+'" onerror="if(this.src!==\''+esc(fav)+'\')this.src=\''+esc(fav)+'\';" alt="'+esc(l.label)+'">'
      +'<span class="rail-tip">'+esc(l.label)+'</span>'
      +'</a>'
      +'<div class="rail-label">'+esc(l.label.slice(0,8))+'</div>'
      +'</div>';
  }).join('');
  // Drag-to-reorder
  var _rdSrc=null;
  rail.querySelectorAll('.rail-item').forEach(function(item){
    item.addEventListener('dragstart',function(e){
      _rdSrc=item;e.dataTransfer.effectAllowed='move';
      setTimeout(function(){item.style.opacity='.35';},0);
    });
    item.addEventListener('dragend',function(){
      item.style.opacity='';_rdSrc=null;
      rail.querySelectorAll('.rail-item').forEach(function(i){i.style.outline='';});
    });
    item.addEventListener('dragover',function(e){
      e.preventDefault();
      if(item!==_rdSrc)item.style.outline='2px solid var(--a1)';
    });
    item.addEventListener('dragleave',function(){item.style.outline='';});
    item.addEventListener('drop',function(e){
      e.preventDefault();item.style.outline='';
      if(!_rdSrc||_rdSrc===item)return;
      var ids=Array.from(rail.querySelectorAll('.rail-item')).map(function(i){return i.dataset.id;});
      var srcId=_rdSrc.dataset.id,dstId=item.dataset.id;
      var fi=ids.indexOf(srcId);if(fi>-1)ids.splice(fi,1);
      var ti=ids.indexOf(dstId);if(ti>-1)ids.splice(ti,0,srcId);else ids.push(srcId);
      prefs.railLinkOrder=ids;
      google.script.run.saveMyPrefs(JSON.stringify(prefs));
      // Re-sort and re-render
      var reordered=links.slice().sort(function(a,b){
        var ai=ids.indexOf(a.id),bi=ids.indexOf(b.id);
        if(ai===-1)ai=9999;if(bi===-1)bi=9999;return ai-bi;
      });
      renderLinkRail(reordered);
    });
  });
  // ── Collapse toggle ──
  var colBtn=document.createElement('div');
  colBtn.className='rail-collapse-btn';
  var isColl=prefs.railCollapsed||false;
  if(isColl){rail.classList.add('rail-collapsed');document.body.classList.add('rail-collapsed');}
  else{rail.classList.remove('rail-collapsed');document.body.classList.remove('rail-collapsed');}
  colBtn.textContent=isColl?'\u25B6':'\u25C4';
  colBtn.title=isColl?'Expand':'Collapse';
  colBtn.onclick=function(){
    prefs.railCollapsed=!prefs.railCollapsed;
