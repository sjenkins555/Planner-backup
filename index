function saveSchedule(){
  var inputs=document.querySelectorAll('#se-rows input'),map={};
  inputs.forEach(function(inp){var i=inp.dataset.i;if(!map[i])map[i]={};map[i][inp.dataset.f]=inp.value;});
  var sched=Object.values(map).filter(function(p){return p.subject&&p.subject.trim();});
  document.getElementById('se-ov').remove();
  mySchedule=sched;renderSchedule();toast('Schedule saved','ok');
  google.script.run.saveMySchedule(JSON.stringify(sched));
}

