<!-- ═══════════════════════════════════════════════════════════════════
     SECTION: BACKGROUND LAYERS
     bg-layer holds the background image/gradient. bg-overlay is the
     dark scrim on top for text readability. Both controlled by
     applyBackground() in index_settings.html.
     ═══════════════════════════════════════════════════════════════════ -->
<div id="bg-layer"></div>
