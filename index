// Toggle a widget on or off in the user's tileOrder.
// Refuses to remove the last visible widget.
function toggleWidget(id){
  var def = null;

  // Resolve definition (either an embedded doc or a built-in widget)
  if (id.indexOf('embed-') === 0){
    var docId = id.replace('embed-','');
    var doc = null;
    for (var di = 0; di < myEmbeddedDocs.length; di++){
      if (myEmbeddedDocs[di].id === docId){ doc = myEmbeddedDocs[di]; break; }
    }
    if (!doc) return;
    def = {id:id, name:doc.title};
  } else {
    for (var i = 0; i < ALL_WIDGETS.length; i++){
      if (ALL_WIDGETS[i].id === id){ def = ALL_WIDGETS[i]; break; }
    }
    if (!def) return;
  }

  var idx = prefs.tileOrder.indexOf(id);
  if (idx > -1){
    if (prefs.tileOrder.length <= 1){ toast("Can't remove last widget", 'err'); return; }
    prefs.tileOrder.splice(idx, 1);
  } else {
    prefs.tileOrder.push(id);
  }

  var el = document.getElementById('wo-' + id);
  if (el) el.classList.toggle('active', prefs.tileOrder.indexOf(id) > -1);

  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  reloadHomeWidgets();
  toast(prefs.tileOrder.indexOf(id) > -1 ? def.name + ' added' : def.name + ' removed', 'inf');
}


