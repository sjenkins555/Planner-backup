/* ═══════════════════════════════════════════════════════════════════
   4. AUTO-REFRESH SYSTEM
   When the user comes back to a tab they left open, certain widgets
   need to refresh (reminders, schedule). Each widget registers itself
   with registerAutoRefresh(id, fn, minMinutes).
   ═══════════════════════════════════════════════════════════════════ */

var _autoRefreshTargets = []; // [{id, fn, minMinutes, lastRun}]
var _autoRefreshLastFocusCheck = Date.now();

// Register a widget for auto-refresh on tab focus.
// Re-calling with same id updates the existing entry instead of duplicating.
function registerAutoRefresh(id, fn, minMinutes){
  for (var i = 0; i < _autoRefreshTargets.length; i++){
    if (_autoRefreshTargets[i].id === id){
      _autoRefreshTargets[i].fn = fn;
      _autoRefreshTargets[i].minMinutes = minMinutes;
      return;
    }
  }
  _autoRefreshTargets.push({ id:id, fn:fn, minMinutes:minMinutes||10, lastRun:Date.now() });
}

// Walks every registered target and fires its fn if enough time has passed.
function _checkAutoRefresh(){
  if (document.hidden) return;
  var now = Date.now();
  _autoRefreshTargets.forEach(function(t){
    var elapsedMin = (now - t.lastRun) / 60000;
    if (elapsedMin >= t.minMinutes){
      try {
        if (t.id) showWidgetLoader(t.id, 'sm');
        t.fn();
      } catch(e) {
        console.warn('Auto-refresh failed for '+t.id, e);
        if (t.id) hideWidgetLoader(t.id);
      }
      t.lastRun = now;
    }
  });
}

document.addEventListener('visibilitychange', function(){
  if (!document.hidden) _checkAutoRefresh();
});
window.addEventListener('focus', _checkAutoRefresh);


/* ═══════════════════════════════════════════════════════════════════
   5. BOOT SEQUENCE
   window.onload kicks off getBootData (single round-trip that returns
   user, prefs, tasks, schedule, notes, links, embedded docs, bell
   schedules, and active bell). Then bootApp() builds the UI.
   ═══════════════════════════════════════════════════════════════════ */

window.onload = function(){
  // Start the live clock immediately (doesn't depend on server data)
  tickClock();
  setInterval(tickClock, 1000);

  // Slow-load hint and hard timeout
  var hint = setTimeout(function(){
    var h = document.getElementById('load-hint');
    if (h) h.style.display = 'block';
  }, 6000);
  var fail = setTimeout(function(){
    showErr('Request timed out (22s).\n\nFix: Deploy > Manage Deployments > Edit\n> Execute as: Me > New Version > Deploy.');
  }, 22000);

  google.script.run
    .withSuccessHandler(function(r){
      clearTimeout(hint);
      clearTimeout(fail);
      if (!r || r.error || (r.user && r.user.error)){
        showErr((r && r.message) || (r && r.user && r.user.message) || 'Unknown error loading planner.');
        return;
      }
      // Populate globals from boot data so widgets don't need extra round-trips
      CU = r.user;
      try { prefs = mergePrefs(r.prefs || {}); }
      catch(e) { prefs = Object.assign({}, DEF_PREFS); }

      myTasks = r.tasks || [];
      mySchedule = r.schedule || [];
      myNotes = r.notes || '';
      myNotesData = parseNotesData(myNotes);
      myLinks = r.links || [];
      myEmbeddedDocs = r.embeddedDocs || [];
      bellSchedules = r.bellSchedules || [];
      activeBell = r.activeBell || null;
      homeDataLoaded = true;

      // Stash assigned links for loadMyAssignedLinks (skip refetch)
      window._preloadedAssignedLinks = r.assignedLinks;

      try { applyAllPrefs(); } catch(e) { console.error('applyAllPrefs:', e); }
      try { bootApp(); } catch(e) { showErr('App failed to start: ' + e.message); }
    })
    .withFailureHandler(function(e){
      clearTimeout(hint);
      clearTimeout(fail);
      var details = 'Error: ' + (e && e.message ? e.message : String(e));
      if (e && e.name) details += '\n\nType: ' + e.name;
      details += '\n\nIf this mentions "permission" or "document", the script may be missing access to the spreadsheet OR the shared library. Send this whole message to Mr. Jenkins.';
      showErr(details);
    })
    .getBootData();
};

