// DRAG & DROP — handle-only, no accidental drags from card content
var dragSrc=null,_scrollRaf=null;

function _dragScroll(e){
  // Auto-scroll when dragging near top or bottom of the visible window
  var zone=64; // px — same height as topbar
  var y=e.clientY;
  var wh=window.innerHeight;
  if(_scrollRaf)cancelAnimationFrame(_scrollRaf);
  if(y<zone){
    var speed=Math.round((zone-y)/zone*18);
    (function tick(){_scrollRaf=requestAnimationFrame(function(){window.scrollBy(0,-speed);tick();});})();
  }else if(y>wh-zone){
    var speed=Math.round((y-(wh-zone))/zone*18);
    (function tick(){_scrollRaf=requestAnimationFrame(function(){window.scrollBy(0,speed);tick();});})();
  }
}
function _stopDragScroll(){if(_scrollRaf){cancelAnimationFrame(_scrollRaf);_scrollRaf=null;}}

function initDragDrop(){
  var NODRAG='input,textarea,button,a,select,.tile-sz-btn,.tile-style-btn,.tile-gear,.style-pop,.sz-pop,.min-btn,.face-back';
  document.querySelectorAll('.tile').forEach(function(tile){
    if(tile.dataset.dragInit==='1')return;
    tile.dataset.dragInit='1';
    tile.setAttribute('draggable','true');
    tile.addEventListener('dragstart',function(e){
      if(tile.classList.contains('flipped')){e.preventDefault();return;}
      if(e.target.closest && e.target.closest(NODRAG)){e.preventDefault();return;}
      dragSrc=tile;
      tile.classList.add('dragging');
      try{
        e.dataTransfer.effectAllowed='move';
        e.dataTransfer.setData('text/plain',tile.dataset.tile);
      }catch(err){}
    });
    tile.addEventListener('dragend',function(){
      tile.classList.remove('dragging');
      document.querySelectorAll('.tile').forEach(function(t){t.classList.remove('drag-over');});
      dragSrc=null;
      _stopDragScroll();
    });
    tile.addEventListener('dragover',function(e){
      if(!dragSrc||dragSrc===tile)return;
      if(dragSrc.parentNode!==tile.parentNode)return;
      e.preventDefault();
      e.dataTransfer.dropEffect='move';
      document.querySelectorAll('.tile').forEach(function(t){if(t!==tile)t.classList.remove('drag-over');});
      tile.classList.add('drag-over');
      _dragScroll(e);
    });
    tile.addEventListener('dragleave',function(e){
      if(!tile.contains(e.relatedTarget))tile.classList.remove('drag-over');
    });
    tile.addEventListener('drop',function(e){
      e.preventDefault();
      e.stopPropagation();
      tile.classList.remove('drag-over');
      _stopDragScroll();
      if(!dragSrc||dragSrc===tile)return;
      if(dragSrc.parentNode!==tile.parentNode)return;
      var gridId=tile.parentNode&&tile.parentNode.id;
      var srcId=dragSrc.dataset.tile,dstId=tile.dataset.tile;
      if(gridId==='t-tile-grid'){
        var to=(prefs.teacherTileOrder||[]).slice();
        var fi=to.indexOf(srcId); if(fi>-1)to.splice(fi,1);
        var ti=to.indexOf(dstId); if(ti>-1)to.splice(ti,0,srcId); else to.push(srcId);
        prefs.teacherTileOrder=to;
        buildTeacherDashboard();
        google.script.run.saveMyPrefs(JSON.stringify(prefs));
        toast('Layout saved','inf');
        return;
      }
      if(gridId==='a-tile-grid'){
        var ao=(prefs.adminTileOrder||[]).slice();
        var fi=ao.indexOf(srcId); if(fi>-1)ao.splice(fi,1);
        var ti=ao.indexOf(dstId); if(ti>-1)ao.splice(ti,0,srcId); else ao.push(srcId);
        prefs.adminTileOrder=ao;
        buildAdminPage();
        google.script.run.saveMyPrefs(JSON.stringify(prefs));
        toast('Layout saved','inf');
        return;
      }
      var o=(prefs.tileOrder||[]).slice();
      var fi=o.indexOf(srcId); if(fi>-1)o.splice(fi,1);
      var ti=o.indexOf(dstId); if(ti>-1)o.splice(ti,0,srcId); else o.push(srcId);
      prefs.tileOrder=o;
      var sv={tasks:myTasks.slice(),links:myLinks.slice(),sched:mySchedule.slice(),notes:myNotes,notesData:Object.assign({},myNotesData)};
      renderTileGrid();
      myTasks=sv.tasks;myLinks=sv.links;mySchedule=sv.sched;myNotes=sv.notes;myNotesData=sv.notesData||{};
      renderTasks();renderSchedule();renderLinks();renderCountdowns();renderNotesWidget();
      if(prefs.tileOrder.indexOf('weather')>-1)loadWeather();
      google.script.run.saveMyPrefs(JSON.stringify(prefs));
      toast('Layout saved','inf');
    });
  });
  document.addEventListener('dragleave',function(e){if(!e.relatedTarget)_stopDragScroll();},{passive:true});
}

// COUNTDOWN WIDGET
function renderCountdowns(){
  var el=document.getElementById('cd-area');if(!el)return;
  var cds=prefs.countdowns||[];
  if(!cds.length){el.innerHTML='<div class="empty"><p>No countdowns yet. Use the gear to add.</p></div>';return;}
  var now=new Date();now.setHours(0,0,0,0);
  var sorted=cds.slice().sort(function(a,b){
    var da=new Date(a.date+'T00:00:00'),db=new Date(b.date+'T00:00:00');
    var diffa=da-now,diffb=db-now;
    if(diffa>=0&&diffb<0)return -1;if(diffa<0&&diffb>=0)return 1;
    return Math.abs(diffa)-Math.abs(diffb);
  });
  el.innerHTML='<div class="cd-list">'+sorted.map(function(cd){
    var target=new Date(cd.date+'T00:00:00');
    var diff=Math.round((target-now)/(1000*60*60*24));
    var daysHtml;
    if(diff===0)daysHtml='<div class="cd-days today-cls">Today!<span class="cd-days-sub">is the day</span></div>';
    else if(diff>0)daysHtml='<div class="cd-days'+(diff<=7?' urgent':'')+'">'+diff+'<span class="cd-days-sub">days away</span></div>';
    else daysHtml='<div class="cd-days past">'+Math.abs(diff)+'<span class="cd-days-sub">days ago</span></div>';
    return '<div class="cd-item" onclick="openCdModal(\''+cd.id+'\')"><div class="cd-emoji">'+(cd.emoji||'&#127881;')+'</div><div class="cd-body"><div class="cd-name">'+esc(cd.name)+'</div><div class="cd-date-lbl">'+fmtDateFull(cd.date)+'</div></div>'+daysHtml+'</div>';
  }).join('')+'</div>';
}
