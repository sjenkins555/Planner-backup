// Add a new notes tab via prompt() and re-render the widget.
function addNoteTab(){
  var name = prompt('New tab name:');
  if (!name || !name.trim()) return;
  var id = 'nt-' + Date.now();
  var color = TAB_COLORS[((prefs.notesTabs || []).length) % TAB_COLORS.length];
  if (!prefs.notesTabs) prefs.notesTabs = [{id:'default', name:'Notes', color:'#6366f1'}];
  prefs.notesTabs.push({id:id, name:name.trim(), color:color});
  prefs.notesActiveTab = id;
  myNotesData[id] = '';
  renderNotesWidget();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}

// Open a context menu over a tab (right-click). Provides Rename, Change
// Color, and Delete actions.
function openTabCtx(evt, type, tabId){
  closeCtxMenu();
  var menu = document.createElement('div');
  menu.className = 'ctx-menu';
  var tabs = type === 'note' ? (prefs.notesTabs || []) : (prefs.taskLists || []);
  var canDel = tabs.length > 1;

  menu.innerHTML = '<div class="ctx-item" id="ctx-ren">&#9998; Rename</div>'
    + '<div class="ctx-item" id="ctx-col">&#127912; Change Color</div>'
    + (canDel ? '<hr class="ctx-sep"><div class="ctx-item danger" id="ctx-del">&#10005; Delete Tab</div>' : '');
  document.body.appendChild(menu);
  _ctxMenu = menu;

  menu.querySelector('#ctx-ren').onclick = function(e){ e.stopPropagation(); closeCtxMenu(); renameTab(type, tabId); };
  menu.querySelector('#ctx-col').onclick = function(e){ e.stopPropagation(); closeCtxMenu(); changeTabColor(type, tabId); };
  if (canDel) menu.querySelector('#ctx-del').onclick = function(e){ e.stopPropagation(); closeCtxMenu(); deleteTab(type, tabId); };

  // Position the menu and clamp to viewport
  var x = evt.clientX, y = evt.clientY;
  if (x + 160 > window.innerWidth) x = window.innerWidth - 165;
  if (y + 120 > window.innerHeight) y = window.innerHeight - 125;
  menu.style.left = x + 'px';
  menu.style.top = y + 'px';

  // Close on next click outside
  setTimeout(function(){ document.addEventListener('click', closeCtxMenu, {once:true}); }, 10);
}

// Tear down the context menu (no-op if none is open).
function closeCtxMenu(){
  if (_ctxMenu){
    try { _ctxMenu.remove(); } catch(e){}
    _ctxMenu = null;
  }
}

// Rename a tab via prompt() and re-render.
function renameTab(type, tabId){
  var tabs = type === 'note' ? (prefs.notesTabs || []) : (prefs.taskLists || []);
  var tab = null;
  for (var i = 0; i < tabs.length; i++){ if (tabs[i].id === tabId){ tab = tabs[i]; break; } }
  if (!tab) return;
  var n = prompt('Tab name:', tab.name);
  if (!n || !n.trim()) return;
  tab.name = n.trim();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  if (type === 'note') renderNotesWidget();
  else { renderTaskTabBar(); renderTasks(); }
}

// Open a color-picker modal for the given tab.
function changeTabColor(type, tabId){
  var tabs = type === 'note' ? (prefs.notesTabs || []) : (prefs.taskLists || []);
  var tab = null;
  for (var i = 0; i < tabs.length; i++){ if (tabs[i].id === tabId){ tab = tabs[i]; break; } }
  if (!tab) return;

  var ov = document.createElement('div');
  ov.className = 'overlay open';
  ov.innerHTML = '<div class="mbox" style="max-width:300px;">'
    + '<div class="mtitle">Pick Tab Color</div>'
    + '<div style="display:flex;gap:8px;flex-wrap:wrap;padding:4px 0;">'
    + TAB_COLORS.map(function(c){
        return '<div style="width:34px;height:34px;border-radius:9px;background:' + c + ';cursor:pointer;border:3px solid ' + (c === tab.color ? 'white' : 'transparent') + ';transition:all .1s;" onclick="pickTabColor(\'' + type + '\',\'' + tabId + '\',\'' + c + '\',this.closest(\'.overlay\'))"></div>';
      }).join('')
    + '</div><div class="mfooter"><button class="btn btn-ghost" onclick="this.closest(\'.overlay\').remove()">Cancel</button></div></div>';
  document.body.appendChild(ov);
}

// Apply the picked color to the tab and close the modal.
function pickTabColor(type, tabId, color, ovEl){
  var tabs = type === 'note' ? (prefs.notesTabs || []) : (prefs.taskLists || []);
  for (var i = 0; i < tabs.length; i++){
    if (tabs[i].id === tabId){ tabs[i].color = color; break; }
  }
  if (ovEl) ovEl.remove();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  if (type === 'note') renderNotesWidget();
  else { renderTaskTabBar(); renderTasks(); }
}

// Delete a tab. For notes, content is lost. For tasks, items move to All Tasks.
function deleteTab(type, tabId){
  if (!confirm('Delete this tab? ' + (type === 'note' ? 'Note content will be lost.' : 'Tasks in this list will move to All Tasks.'))) return;

  if (type === 'note'){
    prefs.notesTabs = (prefs.notesTabs || []).filter(function(t){ return t.id !== tabId; });
    if (prefs.notesActiveTab === tabId) prefs.notesActiveTab = prefs.notesTabs[0] ? prefs.notesTabs[0].id : 'default';
    delete myNotesData[tabId];
    myNotes = serializeNotesData(myNotesData);
    google.script.run.saveMyNotes(myNotes);
  } else {
    prefs.taskLists = (prefs.taskLists || []).filter(function(l){ return l.id !== tabId; });
    if (prefs.taskActiveList === tabId) prefs.taskActiveList = prefs.taskLists[0] ? prefs.taskLists[0].id : 'default';
    if (prefs.taskListMap){
      Object.keys(prefs.taskListMap).forEach(function(k){
        if (prefs.taskListMap[k] === tabId) delete prefs.taskListMap[k];
      });
    }
  }
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  if (type === 'note') renderNotesWidget();
  else { renderTaskTabBar(); renderTasks(); }
  toast('Tab deleted', 'inf');
}


