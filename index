/* ═══════════════════════════════════════════════════════════════════
   6. LIVE CLOCK & CLOCK STYLES
   tickClock runs every second. The topbar always shows digital time;
   the clock widget on the home page can be digital, analog, minimal,
   or word-clock style based on prefs.clockStyle.
   ═══════════════════════════════════════════════════════════════════ */

// Update the topbar clock + the clock widget every second.
function tickClock(){
  var now = new Date();
  var h24 = String(now.getHours()).padStart(2,'0');
  var m = String(now.getMinutes()).padStart(2,'0');
  var s = String(now.getSeconds()).padStart(2,'0');
  var is24 = prefs && prefs.timeFormat === '24h';
  var dispH = is24 ? h24 : String(now.getHours() % 12 || 12).padStart(2,'0');
  var ampm = is24 ? '' : ' ' + (now.getHours() >= 12 ? 'PM' : 'AM');
  var lc = document.getElementById('live-clock');
  if (lc) lc.textContent = dispH + ':' + m + ':' + s + ampm;
  updateClock(now, h24, m, s);
}

// Render the home-page clock widget in whichever style is selected.
function updateClock(now, h, m, s){
  var style = prefs ? prefs.clockStyle : 'digital';
  var el = document.getElementById('clk-main');
  if (!el) return;
  var is24 = prefs && prefs.timeFormat === '24h';
  var ph = now.getHours();
  if (style === 'digital'){
    el.textContent = is24
      ? h + ':' + m + ':' + s
      : String(ph % 12 || 12).padStart(2,'0') + ':' + m + ':' + s + ' ' + (ph >= 12 ? 'PM' : 'AM');
  } else if (style === 'analog'){
    drawAnalog(now);
  } else if (style === 'minimal'){
    el.innerHTML = is24
      ? h + ':' + m
      : String(ph % 12 || 12) + ':' + m + '<span class="clk-ampm">' + (ph >= 12 ? 'PM' : 'AM') + '</span>';
  } else if (style === 'word'){
    el.innerHTML = timeToWords(now);
  }
}

// Draw an analog clock face into #analog-svg.
function drawAnalog(now){
  var svg = document.getElementById('analog-svg');
  if (!svg) return;
  var SVG_NS = 'http://www.w3.org/2000/svg';
  var hr = now.getHours() % 12, mn = now.getMinutes(), sc = now.getSeconds();
  var hA = hr * 30 + mn * 0.5;
  var mA = mn * 6 + sc * 0.1;
  var sA = sc * 6;
  var cx = 100, cy = 100;

  // Clear existing children
  while (svg.firstChild) svg.removeChild(svg.firstChild);

  function mkEl(tag, attrs){
    var el = document.createElementNS(SVG_NS, tag);
    for (var k in attrs) el.setAttribute(k, attrs[k]);
    return el;
  }
  function mkHand(ang, len, w, col){
    var a = (ang - 90) * Math.PI / 180;
    return mkEl('line', {
      x1: cx, y1: cy,
      x2: cx + Math.cos(a) * len,
      y2: cy + Math.sin(a) * len,
      stroke: col, 'stroke-width': w, 'stroke-linecap': 'round'
    });
  }

  // Face + tick marks
  svg.appendChild(mkEl('circle', {cx:cx, cy:cy, r:90, fill:'none', stroke:'rgba(255,255,255,0.06)', 'stroke-width':2}));
  svg.appendChild(mkEl('circle', {cx:cx, cy:cy, r:88, fill:'rgba(15,23,42,0.4)'}));
  for (var i = 0; i < 12; i++){
    var a = (i * 30 - 90) * Math.PI / 180;
    var r1 = 80, r2 = i % 3 === 0 ? 70 : 75;
    svg.appendChild(mkEl('line', {
      x1: cx + Math.cos(a) * r1, y1: cy + Math.sin(a) * r1,
      x2: cx + Math.cos(a) * r2, y2: cy + Math.sin(a) * r2,
      stroke: 'rgba(255,255,255,0.2)', 'stroke-width': i % 3 === 0 ? 2 : 1
    }));
  }
  // Hands
  svg.appendChild(mkHand(hA, 52, 4, 'rgba(255,255,255,0.8)'));
  svg.appendChild(mkHand(mA, 70, 3, 'rgba(255,255,255,0.7)'));
  svg.appendChild(mkHand(sA, 75, 1.5, 'var(--a1)'));
  // Center cap
  svg.appendChild(mkEl('circle', {cx:cx, cy:cy, r:5, fill:'var(--a1)'}));
  svg.appendChild(mkEl('circle', {cx:cx, cy:cy, r:2, fill:'#fff'}));
}

// Convert the current time to natural-language words ("quarter past three").
function timeToWords(now){
  var nums = ['twelve','one','two','three','four','five','six','seven','eight','nine','ten','eleven','twelve'];
  var mins = ['','five','ten','fifteen','twenty','twenty-five','thirty'];
  var h = now.getHours() % 12;
  var m = now.getMinutes();
  var nh = nums[h];
  var nn = nums[h === 11 ? 0 : h + 1];
  if (m === 0)  return '<span>It\'s</span> <b>' + nh + ' o\'clock</b>';
  if (m === 15) return '<span>It\'s</span> <b>quarter past</b> <b>' + nh + '</b>';
  if (m === 30) return '<span>It\'s</span> <b>half past</b> <b>' + nh + '</b>';
  if (m === 45) return '<span>It\'s</span> <b>quarter to</b> <b>' + nn + '</b>';
  if (m < 30){
    var t = mins[Math.round(m / 5)];
    return '<span>It\'s</span> <b>' + (t || m) + ' past</b> <b>' + nh + '</b>';
  }
  var rm = 60 - m;
  var t2 = mins[Math.round(rm / 5)];
  return '<span>It\'s</span> <b>' + (t2 || rm) + ' to</b> <b>' + nn + '</b>';
}


/* ═══════════════════════════════════════════════════════════════════
   7. PER-WIDGET STYLE SYSTEM
   Each widget can have its own bg color, border color, text color, and
   alpha values. Stored in prefs.widgetStyles[widgetId]. The Style tab
   on each widget's flip back shows the controls.
   ═══════════════════════════════════════════════════════════════════ */

// Convert a hex color (#rgb or #rrggbb) to an rgba() string with alpha%.
function hexToRgba(hex, alpha){
  if (!hex) return '';
  hex = String(hex).replace('#','');
  if (hex.length === 3) hex = hex.split('').map(function(c){return c+c;}).join('');
  var r = parseInt(hex.substr(0,2), 16);
  var g = parseInt(hex.substr(2,2), 16);
  var b = parseInt(hex.substr(4,2), 16);
  if (isNaN(r) || isNaN(g) || isNaN(b)) return '';
  var a = alpha == null ? 1 : Math.max(0, Math.min(100, alpha)) / 100;
  return 'rgba(' + r + ',' + g + ',' + b + ',' + a + ')';
}

// Coerce any color value to a 7-char hex (or fallback). Used because
// <input type="color"> only accepts #rrggbb format.
function normalizeHex(c){
  if (!c) return '#111827';
  c = String(c);
  if (c.startsWith('rgb')) return '#111827';
  if (c.length === 4) return '#' + c[1]+c[1] + c[2]+c[2] + c[3]+c[3];
  if (c.length === 7) return c;
  return '#111827';
}

// Apply (or clear) per-widget custom colors to a tile by setting CSS vars.
function applyWidgetStyle(id){
  var tile = document.getElementById('tile-' + id);
  if (!tile) return;

  // Clear all overrides first (so toggling off works cleanly)
  tile.style.removeProperty('--card');
  tile.style.removeProperty('--card-border');
  var _innerCardClear = tile.querySelector('.card') || tile.querySelector('.clock-card');
  if (_innerCardClear) _innerCardClear.style.removeProperty('background');
  tile.style.removeProperty('--tx');
  tile.style.removeProperty('--tx2');
  tile.style.removeProperty('--tx3');
  tile.style.removeProperty('--tx4');
  tile.classList.remove('no-bg-image');

  var s = (prefs.widgetStyles || {})[id];
  if (!s) return;

  // Background
  if (s.bgColor){
    var _bgVal = hexToRgba(s.bgColor, s.bgAlpha == null ? 100 : s.bgAlpha);
    tile.style.setProperty('--card', _bgVal);
    var _innerCard = tile.querySelector('.card') || tile.querySelector('.clock-card');
    if (_innerCard) _innerCard.style.setProperty('background', _bgVal, 'important');
  }
  // Border
  if (s.borderColor){
    tile.style.setProperty('--card-border', hexToRgba(s.borderColor, s.borderAlpha == null ? 100 : s.borderAlpha));
  }
  // Text (applies to all 4 brightness levels)
  if (s.textColor){
    var c = hexToRgba(s.textColor, s.textAlpha == null ? 100 : s.textAlpha);
    tile.style.setProperty('--tx', c);
    tile.style.setProperty('--tx2', c);
    tile.style.setProperty('--tx3', c);
    tile.style.setProperty('--tx4', c);
  }
  // Hide page bg image on this widget if requested
  if (s.excludeFromBg) tile.classList.add('no-bg-image');
}

// For widgets like clock and timer, the Style panel includes a row of
// style picker buttons specific to that widget. Returns the HTML.
function buildWidgetSpecificSettings(id){
  if (id === 'clock'){
    var cs = prefs.clockStyle || 'digital';
    function opt(val, label){
      var sel = cs === val ? ' sel' : '';
      return '<div class="style-opt' + sel + '" onclick="pickClockStyleFromWidget(\'' + val + '\')">' + label + '</div>';
    }
    return '<div class="style-section-title" style="margin-top:0;">Clock Style</div>'
      + '<div class="style-opts" style="margin-bottom:4px;">'
        + opt('digital','Digital') + opt('analog','Analog') + opt('minimal','Minimal') + opt('word','Word Clock')
      + '</div>'
      + '<div style="font-size:10px;color:var(--tx4);line-height:1.5;margin-bottom:8px;">Changes the look of this widget only.</div>'
      + '<div class="style-section" style="margin-top:10px;">';
  }
  if (id === 'timer'){
    var ts = prefs.timerStyle || 'circle';
    function topt(val, label){
      var sel = ts === val ? ' sel' : '';
      return '<div class="style-opt' + sel + '" onclick="pickTimerStyleFromWidget(\'' + val + '\')">' + label + '</div>';
    }
    return '<div class="style-section-title" style="margin-top:0;">Timer Style</div>'
      + '<div class="style-opts" style="margin-bottom:4px;">'
        + topt('circle','Circle') + topt('bar','Bar') + topt('minimal','Minimal')
      + '</div>'
      + '<div style="font-size:10px;color:var(--tx4);line-height:1.5;margin-bottom:8px;">Visual layout for the timer display.</div>'
      + '<div class="style-section" style="margin-top:10px;">';
