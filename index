var _lunchData=[], _lunchDay=null;
function loadLunchMenu(){
  showWidgetLoader('lunch','sm');
  google.script.run
    .withSuccessHandler(function(rows){
      _lunchData=rows||[];
      buildLunchTabs();
      hideWidgetLoader('lunch');
    })
    .withFailureHandler(function(){
      var el=document.getElementById('lunch-body');
      if(el)el.innerHTML='<div class="lunch-empty">Could not load menu.</div>';
      hideWidgetLoader('lunch');
    })
    .getLunchMenu();
}
function buildLunchTabs(){
  var tabs=document.getElementById('lunch-tabs');
  var body=document.getElementById('lunch-body');
  if(!tabs||!body)return;
  var now=new Date(), dow=now.getDay();
  var mon=new Date(now); mon.setDate(now.getDate()-(dow===0?6:dow-1));
  var days=[];
  for(var i=0;i<5;i++){var d=new Date(mon);d.setDate(mon.getDate()+i);days.push(d);}
  var todayStr=now.toISOString().slice(0,10);
  var DAY_SHORT=['Mon','Tue','Wed','Thu','Fri'];
  tabs.innerHTML=days.map(function(d,i){
    var ds=d.toISOString().slice(0,10);
    var isToday=ds===todayStr;
    var cls='lunch-day-btn'+(isToday?' today':'');
    // Use data-date + onclick="showLunchDay(this.dataset.date)" to avoid quote nesting
    return '<button class="'+cls+'" data-date="'+ds+'" onclick="showLunchDay(this.dataset.date)">'+DAY_SHORT[i]+'<br><span style="font-size:9px;opacity:.7;">'+fmtDate(ds)+'</span></button>';
  }).join('');
  if(dow===0||dow===6){_lunchDay=days[0].toISOString().slice(0,10);}
  else{_lunchDay=todayStr;}
  showLunchDay(_lunchDay);
}
function showLunchDay(dateStr){
  _lunchDay=dateStr;
  // Highlight active tab
  document.querySelectorAll('.lunch-day-btn').forEach(function(b){
    b.classList.toggle('active',b.dataset.date===dateStr);
  });
  var body=document.getElementById('lunch-body');if(!body)return;
  // Find menu for this date
  var row=null;
  for(var i=0;i<_lunchData.length;i++){if(_lunchData[i].date===dateStr){row=_lunchData[i];break;}}
  if(!row){body.innerHTML='<div class="lunch-empty">No menu posted for this day.</div>';return;}
  var html='';
  if(row.main)html+='<div class="lunch-main">'+esc(row.main)+'</div>';
  var sides=[row.side1,row.side2,row.side3].filter(Boolean);
