// Local cache of the currently-displayed pending list. Lets us splice
// rows out instantly on approve/deny instead of re-fetching the whole
// list from the server every time.
var _rowPendingCache = [];

// Load pending ROW requests for the current teacher.
// Hardened: every step logs to console, render loop is wrapped in
// try/catch so a bad record can't kill the widget, and a 10-second
// timeout guarantees the user always sees an outcome.
function loadRowApprovals(){
  console.log('[ROW] loadRowApprovals called');

  var body = document.getElementById('row-approvals-body');
  if (!body){ console.warn('[ROW] body element not found — aborting'); return; }

  if (!CU || CU.role !== 'teacher'){
    body.innerHTML = '<div class="empty"><p style="font-size:12px;">Teacher access only.</p></div>';
    return;
  }

  body.innerHTML = '<div class="empty" style="padding:18px 8px;"><p style="font-size:12px;color:var(--tx3);">Loading requests...</p></div>';

  var resolved = false;
  var timeoutId = setTimeout(function(){
    if (resolved) return;
    resolved = true;
    var b = document.getElementById('row-approvals-body');
    if (b) b.innerHTML = '<div style="color:#f87171;font-size:12px;padding:10px;">Request timed out. Click Refresh to retry.</div>';
  }, 10000);

  google.script.run
    .withSuccessHandler(function(r){
      if (resolved) return;
      resolved = true;
      clearTimeout(timeoutId);
      console.log('[ROW] server returned:', r);

      if (!r || !r.success){
        body.innerHTML = '<div style="color:#f87171;font-size:12px;padding:10px;">' + esc((r && r.error) || 'Unknown error') + '</div>';
        return;
      }
      _rowPendingCache = (r.requests || []).slice();
      renderRowApprovalsList();
    })
    .withFailureHandler(function(e){
      if (resolved) return;
      resolved = true;
      clearTimeout(timeoutId);
      body.innerHTML = '<div style="color:#f87171;font-size:12px;padding:10px;">' + esc((e && e.message) || 'Server error') + '</div>';
    })
    .getPendingRowRequestsForTeacher();
}

// Render the cached pending list. Called by loadRowApprovals after
// fetch, and by approve/deny handlers after splicing the cache locally.
// Separating render from fetch is what makes approve/deny feel instant —
// we don't have to round-trip to the server just to redraw the list.
function renderRowApprovalsList(){
  var body = document.getElementById('row-approvals-body');
  if (!body) return;

  if (!_rowPendingCache.length){
    body.innerHTML = '<div class="empty" style="padding:18px 8px;"><p style="font-size:12px;">No pending requests.</p></div>';
    return;
  }

  // Header row with bulk-action controls. Approve All triggers a server
  // batch (one call, all requests at 1 ROW each) with a confirmation prompt.
  var header = '<div style="display:flex;align-items:center;gap:8px;padding:0 4px 8px;margin-bottom:6px;border-bottom:1px solid var(--border);">'
    + '<span style="font-size:11px;color:var(--tx3);">' + _rowPendingCache.length + ' pending</span>'
    + '<button class="btn btn-primary btn-sm" id="row-approve-all-btn" onclick="approveAllRows()" style="margin-left:auto;font-size:11px;padding:3px 9px;" title="Approve all pending at 1 ROW each">Approve All</button>'
    + '</div>';

  var rows = _rowPendingCache.map(function(req, idx){
    try {
      var when = '';
      if (req.createdAt && typeof fmtDate === 'function'){
        try { when = fmtDate(req.createdAt.slice(0,10)); } catch(eDate){ when = req.createdAt.slice(0,10); }
      }
      return '<div class="row-req" id="rr-' + esc(req.id) + '">'
        + '<div class="row-req-top">'
          + '<div class="row-req-name">' + esc(req.studentName || req.studentEmail || '?') + '</div>'
          + '<span class="row-req-cat">' + esc(req.category || '') + '</span>'
          + (when ? '<span class="row-req-time">' + esc(when) + '</span>' : '')
        + '</div>'
        + '<div class="row-req-desc">' + esc(req.description || '') + '</div>'
        + '<div class="row-req-actions" id="rra-' + esc(req.id) + '">'
          + '<input class="finp" type="number" id="ra-amt-' + esc(req.id) + '" value="1" min="1" max="10" title="Amount">'
          + '<input class="finp cmt" type="text" id="ra-cmt-' + esc(req.id) + '" placeholder="Comment (optional)" maxlength="200">'
          + '<button class="btn btn-primary btn-sm" id="ra-app-' + esc(req.id) + '" onclick="approveRowReq(\'' + esc(req.id) + '\')">Approve</button>'
          + '<button class="btn btn-danger btn-sm" id="ra-den-' + esc(req.id) + '" onclick="denyRowReq(\'' + esc(req.id) + '\')">Deny</button>'
        + '</div>'
      + '</div>';
    } catch(eRow){
      console.error('[ROW] failed to render request #' + idx, eRow, req);
      return '';
    }
  }).join('');

  body.innerHTML = header + '<div class="row-req-list">' + rows + '</div>';
}

// Lock a single row's buttons + show "Approving..." or "Denying..." text.
// Returns a function that, when called, removes the row from the DOM and
// splices it out of the local cache. Used by both approve/deny handlers.
function _lockRowReq(id, action){
  var appBtn = document.getElementById('ra-app-' + id);
  var denBtn = document.getElementById('ra-den-' + id);
  var amtInp = document.getElementById('ra-amt-' + id);
  var cmtInp = document.getElementById('ra-cmt-' + id);
  if (appBtn){ appBtn.disabled = true; if (action === 'approve') appBtn.textContent = 'Approving...'; }
  if (denBtn){ denBtn.disabled = true; if (action === 'deny')    denBtn.textContent = 'Denying...';   }
  if (amtInp) amtInp.disabled = true;
  if (cmtInp) cmtInp.disabled = true;

  // Return a "finish" callback: removes the row from DOM + cache
  return function(success){
    if (success){
      var rowEl = document.getElementById('rr-' + id);
      if (rowEl) rowEl.remove();
      _rowPendingCache = _rowPendingCache.filter(function(req){ return req.id !== id; });
      // If that was the last one, re-render to show the "No pending" state
      if (!_rowPendingCache.length) renderRowApprovalsList();
      else {
        // Update the "N pending" count in the header
        var countEl = document.querySelector('#row-approvals-body div span');
        if (countEl) countEl.textContent = _rowPendingCache.length + ' pending';
      }
    } else {
      // Re-enable the row's controls on failure
      if (appBtn){ appBtn.disabled = false; appBtn.textContent = 'Approve'; }
      if (denBtn){ denBtn.disabled = false; denBtn.textContent = 'Deny'; }
      if (amtInp) amtInp.disabled = false;
      if (cmtInp) cmtInp.disabled = false;
    }
  };
}

// Approve a single request. Disables the row immediately, shows "Approving...",
// removes the row from the DOM as soon as the server confirms.
function approveRowReq(id){
  var amt = parseInt((document.getElementById('ra-amt-' + id) || {}).value || 1, 10);
  var cmt = (document.getElementById('ra-cmt-' + id) || {}).value || '';
  if (isNaN(amt) || amt < 1 || amt > 10){ toast('Amount must be 1–10', 'err'); return; }

  var finish = _lockRowReq(id, 'approve');

  google.script.run.withSuccessHandler(function(r){
    if (r && r.success){
      toast('Approved ' + amt + ' ROW' + (amt > 1 ? 's' : ''), 'ok');
      finish(true);
    } else {
      toast((r && r.error) || 'Error', 'err');
      finish(false);
    }
  }).withFailureHandler(function(e){
    toast((e && e.message) || 'Could not approve', 'err');
    finish(false);
  }).approveRowRequest(id, amt, cmt);
}

// Deny a single request with confirmation. Same instant-row-removal pattern.
function denyRowReq(id){
  var cmt = (document.getElementById('ra-cmt-' + id) || {}).value || '';
  appConfirm('The student will see this request was denied. Make sure your comment (if any) is appropriate.', {
    title: 'Deny this ROW request?',
    okText: 'Yes, deny',
    cancelText: 'Go back',
    tone: 'danger'
  }).then(function(ok){
    if (!ok) return;

    var finish = _lockRowReq(id, 'deny');

    google.script.run.withSuccessHandler(function(r){
      if (r && r.success){
        toast('Denied', 'inf');
        finish(true);
      } else {
        toast((r && r.error) || 'Error', 'err');
        finish(false);
      }
    }).withFailureHandler(function(e){
      toast((e && e.message) || 'Could not deny', 'err');
      finish(false);
    }).denyRowRequest(id, cmt);
  });
}

// Approve every pending request at 1 ROW each. Fires N server calls in
// parallel so wall-clock time is roughly one Apps Script round-trip
// (~2-3s) instead of N round-trips. Updates UI as each one completes.
function approveAllRows(){
  if (!_rowPendingCache.length) return;
  var n = _rowPendingCache.length;
  if (!confirm('Approve all ' + n + ' pending requests at 1 ROW each?')) return;

  // Disable the Approve All button + lock every row
  var allBtn = document.getElementById('row-approve-all-btn');
  if (allBtn){ allBtn.disabled = true; allBtn.textContent = 'Approving ' + n + '...'; }

  var ids = _rowPendingCache.map(function(r){ return r.id; });
  var finishers = {};
  ids.forEach(function(id){ finishers[id] = _lockRowReq(id, 'approve'); });

  var done = 0;
  var succeeded = 0;
  ids.forEach(function(id){
    google.script.run.withSuccessHandler(function(r){
      done++;
      if (r && r.success){ succeeded++; finishers[id](true); }
      else { finishers[id](false); }
      if (allBtn){ allBtn.textContent = 'Approving ' + (n - done) + '...'; }
      if (done === n){
        toast('Approved ' + succeeded + ' of ' + n + ' requests', succeeded === n ? 'ok' : 'inf');
        if (allBtn){ allBtn.disabled = false; allBtn.textContent = 'Approve All'; }
      }
    }).withFailureHandler(function(){
      done++;
      finishers[id](false);
      if (done === n){
        toast('Approved ' + succeeded + ' of ' + n + ' requests', 'inf');
        if (allBtn){ allBtn.disabled = false; allBtn.textContent = 'Approve All'; }
      }
    }).approveRowRequest(id, 1, '');
  });
}
/* ═══════════════════════════════════════════════════════════════════
