// TASKS
function loadTasks(){google.script.run.withSuccessHandler(function(ts){myTasks=ts||[];renderTasks();}).getMyTasks();}
function renderTasks(){
  checkEmojiEasterEgg();
  renderTaskTabBar();
  var el=document.getElementById('task-area');if(!el)return;
  var activeList=prefs.taskActiveList||'default',listMap=prefs.taskListMap||{};
  var filtered=myTasks.filter(function(t){return activeList==='default'||(listMap[t.id]===activeList);});
  if(!filtered.length){el.innerHTML='<div class="empty"><p>'+(activeList==='default'?'All clear!':'No tasks in this list.')+'</p></div>';return;}
  var pend=filtered.filter(function(t){return t.status!=='completed';}),done=filtered.filter(function(t){return t.status==='completed';});
  var mode=prefs.taskSort||'default';
  var PRI={high:0,medium:1,low:2};
  function sortFn(a,b){
    if(mode==='duedate'){
      if(!a.dueDate&&b.dueDate)return 1;if(a.dueDate&&!b.dueDate)return -1;if(!a.dueDate&&!b.dueDate)return 0;
      return new Date(a.dueDate)-new Date(b.dueDate);
    }
    if(mode==='subject'){return (a.subject||'zzz').localeCompare(b.subject||'zzz');}
    if(mode==='dateadded'){return (myTasks.indexOf(b)-myTasks.indexOf(a));}
    if(mode==='alpha'){return (a.title||'').localeCompare(b.title||'');}
    // default: priority high->low, then due date
    var p=(PRI[a.priority]||1)-(PRI[b.priority]||1);
    if(p!==0)return p;
    if(!a.dueDate&&b.dueDate)return 1;if(a.dueDate&&!b.dueDate)return -1;
    if(a.dueDate&&b.dueDate)return new Date(a.dueDate)-new Date(b.dueDate);
    return 0;
  }
  pend.sort(sortFn);done.sort(sortFn);
  el.innerHTML='<div class="task-list">'+pend.concat(done).map(taskRow).join('')+'</div>';
}
function checkEmojiEasterEgg(){
  var wasOn=_emojiMode;
  var active=myTasks.some(function(t){
    return t.status!=='completed'&&t.status!=='deleted'&&String(t.title||'').trim().toLowerCase()==='put emojis everywhere';
  });
  _emojiMode=active;
  if(wasOn!==active){
    document.body.classList.toggle('emoji-mode',active);
    if(active)toast('🎉 Emoji mode ON — mark task complete to turn off','inf');
    else toast('Emoji mode off','inf');
    // Repaint any currently-rendered widget content so icons/emojis swap instantly
    var hp=document.getElementById('tp-home')||document.getElementById('tp-my-home');
    if(hp&&homeDataLoaded)reloadHomeWidgets();
  }
}
function emo(char,fallbackSvgId){
  // Returns an emoji (if easter-egg active) or an inline SVG icon
  if(_emojiMode&&char)return char;
  if(fallbackSvgId)return '<svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#'+fallbackSvgId+'"/></svg>';
  return '';
}
