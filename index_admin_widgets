/* ═══════════════════════════════════════════════════════════════════
   2. PAGE BUILDER
   Builds the 9-widget grid for the Admin tab. Each tile gets a
   resize gear; ordering and sizes persist via prefs.adminTileOrder
   and prefs.adminTileSizes.
   ═══════════════════════════════════════════════════════════════════ */

// Build the entire Admin tab. Renders an empty grid first, then fires each
// widget's render function in a 50ms setTimeout so the grid paints before
// any async data loads kick in.
function buildAdminPage(){
  // Tile definitions — one per admin widget
  var tileDefs = {
    abell:     {fn:renderABellWidget,     title:'Bell Schedules',         svg:'#w-schedule', defC:2, defR:2},
    aschedcal: {fn:renderASchedCalWidget, title:'Schedule Calendar',      svg:'#w-schedule', defC:4, defR:2},
    astats:    {fn:renderAStatsWidget,    title:'Spreadsheet Health',     svg:'#w-apps',     defC:2, defR:1},
    arepair:   {fn:renderARepairWidget,   title:'Repair Sheets',          svg:'#w-admin',    defC:2, defR:1},
    alunch:    {fn:renderALunchWidget,    title:'Lunch Menu Import',      svg:'#w-embed',    defC:4, defR:2},
    agrad:     {fn:renderAGradWidget,     title:'Graduate Students',      svg:'#w-student',  defC:2, defR:2},
    arow:      {fn:renderARowWidget,      title:'ROW Reward Accounts',    svg:'#w-student',  defC:4, defR:2},
    arem:      {fn:renderARemWidget,      title:'School-Wide Reminders',  svg:'#w-timer',    defC:2, defR:2},
    aclean:    {fn:renderACleanWidget,    title:'Data Cleanup',           svg:'#w-admin',    defC:4, defR:2}
  };

  // Reconcile saved order with the canonical default order:
  // - Drop any tile IDs that no longer exist (older prefs)
  // - Append any new tiles that weren't in the saved order
  var defaultOrder = ['abell','astats','arepair','aschedcal','alunch','agrad','arow','arem','aclean'];
  if (!prefs.adminTileOrder || !prefs.adminTileOrder.length){
    prefs.adminTileOrder = defaultOrder.slice();
  } else {
    var saved = prefs.adminTileOrder.filter(function(id){ return tileDefs[id]; });
    defaultOrder.forEach(function(id){ if (saved.indexOf(id) === -1) saved.push(id); });
    prefs.adminTileOrder = saved;
  }
  if (!prefs.adminTileSizes) prefs.adminTileSizes = {};

  // Draw the empty grid + tile shells
  panel('t-admin').innerHTML = '<div class="tile-grid" id="a-tile-grid" style="grid-auto-rows:minmax(180px,auto);"></div>';
  var grid = document.getElementById('a-tile-grid');
  if (!grid) return;

  grid.innerHTML = prefs.adminTileOrder.map(function(id){
    var t = tileDefs[id];
    if (!t) return '';
    var sz = prefs.adminTileSizes[id] || {c:t.defC, r:t.defR};
    var colSpan = Math.min(Math.max(sz.c || t.defC, 1), 4);
    var rowSpan = Math.min(Math.max(sz.r || t.defR, 1), 3);
    var minH = (rowSpan * 180) + ((rowSpan - 1) * 14);

    return '<div class="tile" id="tile-' + id + '" draggable="true" data-tile="' + id + '" '
      + 'style="grid-column:span ' + colSpan + ';grid-row:span ' + rowSpan + ';min-height:' + minH + 'px;">'
      + '<div class="card" style="display:flex;flex-direction:column;height:100%;overflow:hidden;">'
      +   '<div class="card-top">'
      +     '<div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="' + t.svg + '"/></svg> ' + t.title + '</div>'
      +     '<div class="tile-gear" onclick="openASzPicker(\'' + id + '\',event)" title="Resize"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h4M3 3v4M13 13h-4M13 13v-4M3 13h4M3 13v-4M13 3h-4M13 3v4"/></svg></div>'
      +   '</div>'
      +   '<div class="t-widget-body t-widget-scroll" id="aw-' + id + '"><div style="color:var(--tx3);font-size:12px;padding:20px;text-align:center;">Loading...</div></div>'
      + '</div></div>';
  }).join('');

  // Defer widget renders so the DOM has time to paint shells first.
  // Each renderer's errors are isolated so one bad widget doesn't kill the page.
  setTimeout(function(){
    prefs.adminTileOrder.forEach(function(id){
      var t = tileDefs[id];
      if (!t) return;
      try {
        t.fn();
      } catch(e){
        var el = document.getElementById('aw-' + id);
        if (el) el.innerHTML = '<div style="color:#f87171;font-size:12px;padding:10px;">Error: ' + esc(e.message) + '</div>';
        console.error(e);
      }
    });
    initDragDrop();
  }, 50);
}


/* ═══════════════════════════════════════════════════════════════════
   3. TILE SIZE PICKER
   Floating popup over a tile's gear icon with a 4×2 grid of size choices.
   ═══════════════════════════════════════════════════════════════════ */

// Open the size picker for an admin tile. Clicking the same tile's gear
// twice closes the popup; clicking outside also closes.
function openASzPicker(id, evt){
  evt.stopPropagation();
  // Close any existing popup first; if it was for the same tile, just close
  var old = document.getElementById('sz-pop');
  if (old){ old.remove(); if (old.dataset.wid === id) return; }

  // Default sizes (must match buildAdminPage's tileDefs)
  var defs = {abell:{c:2,r:2},aschedcal:{c:4,r:2},astats:{c:2,r:1},arepair:{c:2,r:1},alunch:{c:4,r:2},agrad:{c:2,r:2},arow:{c:4,r:2},arem:{c:2,r:2},aclean:{c:4,r:2}};
  var cur = Object.assign({}, defs[id] || {c:2,r:2}, (prefs.adminTileSizes && prefs.adminTileSizes[id]) || {});

  // Build the popup
  var pop = document.createElement('div');
  pop.id = 'sz-pop';
  pop.dataset.wid = id;
  pop.className = 'sz-pop';
  var html = '<div class="sz-pop-title">Size (cols \u00d7 rows)</div><div class="sz-grid">';
  for (var r = 1; r <= 2; r++){
    for (var c = 1; c <= 4; c++){
      var isSel = (c === cur.c && r === cur.r) ? ' sel' : '';
      html += '<div class="sz-cell' + isSel + '" onclick="pickASz(\'' + id + '\',' + c + ',' + r + ')">' + c + '\u00d7' + r + '</div>';
    }
  }
  html += '</div>';
  pop.innerHTML = html;
  document.body.appendChild(pop);

  // Position the popup near the tile's gear, clamped to viewport
  var tile  = document.getElementById('tile-' + id);
  var tRect = tile ? tile.getBoundingClientRect() : {top:100, bottom:300, left:100, right:400};
  var popW = 215, popH = 152;
  var left = tRect.right - popW - 14;
  var top  = tRect.bottom - popH - 44;
  if (left < tRect.left + 8) left = tRect.left + 8;
  if (top  < tRect.top  + 8) top  = tRect.top  + 8;
  if (left + popW > window.innerWidth  - 8) left = window.innerWidth  - popW - 8;
  if (top  + popH > window.innerHeight - 8) top  = window.innerHeight - popH - 8;
  if (left < 8) left = 8;
  if (top  < 8) top  = 8;
  pop.style.top  = top  + 'px';
  pop.style.left = left + 'px';

  // Click-outside to close (registered with a tiny delay so this click doesn't trigger it)
  setTimeout(function(){
    function away(e){ if (!pop.contains(e.target)){ pop.remove(); document.removeEventListener('click', away); } }
    document.addEventListener('click', away);
  }, 10);
}

// User picked a size from the popup → save to prefs, update the tile's
// CSS spans, persist prefs to server.
function pickASz(id, cols, rows){
  if (!prefs.adminTileSizes) prefs.adminTileSizes = {};
  prefs.adminTileSizes[id] = {c:cols, r:rows};

  var tile = document.getElementById('tile-' + id);
  if (tile){
    var minH = (rows * 180) + ((rows - 1) * 14);
    tile.style.gridColumn = 'span ' + cols;
    tile.style.gridRow    = 'span ' + rows;
    tile.style.minHeight  = minH + 'px';
  }

  var pop = document.getElementById('sz-pop');
  if (pop) pop.remove();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}


