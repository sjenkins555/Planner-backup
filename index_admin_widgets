   ═══════════════════════════════════════════════════════════════════ */

// Format a Date as YYYY-MM-DD. Named after the server's Utilities.formatDate
// so the intent is clear at the call site. Used by the schedule calendar.
function Utilities_format(d){
  var y  = d.getFullYear();
  var m  = String(d.getMonth() + 1).padStart(2, '0');
  var dd = String(d.getDate()).padStart(2, '0');
  return y + '-' + m + '-' + dd;
}

