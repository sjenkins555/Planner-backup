/* ═══════════════════════════════════════════════════════════════════
   9. DATA CLEANUP
   Sends three age thresholds to the server, which archives completed
   tasks, purges soft-deleted tasks, and removes old lunch entries.
   ═══════════════════════════════════════════════════════════════════ */

// Read the three age inputs, post to runDataCleanup, render the result.
function doDataCleanup(){
  var btn = document.getElementById('cleanup-btn');
  var res = document.getElementById('cleanup-result');

  // Defaults match the input element values (180/30/60)
  var completed = parseInt((document.getElementById('cl-completed') || {}).value || 180);
  var deleted   = parseInt((document.getElementById('cl-deleted')   || {}).value || 30);
  var lunch     = parseInt((document.getElementById('cl-lunch')     || {}).value || 60);

  if (btn) btn.textContent = 'Running...';
  if (res) res.innerHTML = '';

  google.script.run
    .withSuccessHandler(function(r){
      if (btn) btn.textContent = '&#129529; Run Cleanup';
      if (!res) return;
      if (!r.success){ res.innerHTML = '<div style="color:#f87171;">' + esc(r.error) + '</div>'; return; }

      var t = r.results.tasks || {};
      var l = r.results.lunch || {};
      res.innerHTML = '<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;padding:12px 14px;font-size:13px;color:#22c55e;">'
        + '&#10003; Cleanup complete<br>'
        + '<span style="font-size:12px;color:var(--tx2);">'
        +   'Tasks archived: ' + (t.archived || 0) + ' &bull; '
        +   'Deleted tasks purged: ' + (t.deleted || 0) + ' &bull; '
        +   'Old lunch entries removed: ' + (l.deleted || 0)
        +   (t.error ? '<br><span style="color:#f59e0b;">Task warning: '  + esc(t.error) + '</span>' : '')
        +   (l.error ? '<br><span style="color:#f59e0b;">Lunch warning: ' + esc(l.error) + '</span>' : '')
        + '</span></div>';
      loadAdminStats();
    })
    .withFailureHandler(function(e){
      if (btn) btn.textContent = '&#129529; Run Cleanup';
      if (res) res.innerHTML = '<div style="color:#f87171;">' + esc(e.message) + '</div>';
    })
    .runDataCleanup({completedDays:completed, deletedDays:deleted, lunchDays:lunch});
}


/* ═══════════════════════════════════════════════════════════════════
   10. BELL SCHEDULES — list + load + delete + set default
   ═══════════════════════════════════════════════════════════════════ */

// Fetch all bell schedules, refresh both the local cache and the
// global `bellSchedules` (used by the student schedule import).
function loadBellSchedules(){
  google.script.run.withSuccessHandler(function(list){
    _bellSchedulesCache = list || [];
    renderBellList();
    bellSchedules = _bellSchedulesCache;
  }).withFailureHandler(function(){
    var el = document.getElementById('bell-list');
    if (el) el.innerHTML = '<div style="color:#f87171;font-size:12px;">Could not load.</div>';
  }).getAllBellSchedules();
}

// Render the bell schedules list. Each row shows name + period count +
// default badge, with Edit / Set-Default / Delete buttons.
function renderBellList(){
  var el = document.getElementById('bell-list');
  if (!el) return;

  if (!_bellSchedulesCache.length){
    el.innerHTML = '<div style="color:var(--tx4);font-size:12px;text-align:center;padding:18px;">No bell schedules yet. Click <strong>+ New Schedule</strong> to start.</div>';
    return;
  }

  el.innerHTML = _bellSchedulesCache.map(function(b){
    var pcount   = (b.periods || []).length;
    var defBadge = b.isDefault
      ? '<span style="font-size:9px;font-weight:700;background:rgba(34,197,94,.12);color:#22c55e;border:1px solid rgba(34,197,94,.3);border-radius:4px;padding:2px 7px;letter-spacing:.4px;text-transform:uppercase;">Default</span>'
      : '';
    return '<div style="display:flex;align-items:center;gap:10px;padding:10px 12px;background:rgba(15,23,42,.6);border:1px solid var(--border);border-radius:9px;border-left:3px solid ' + esc(b.color || '#6366f1') + ';">'
      +   '<div style="flex:1;min-width:0;">'
      +     '<div style="display:flex;align-items:center;gap:7px;font-size:13px;font-weight:600;color:var(--tx);">' + esc(b.name) + defBadge + '</div>'
      +     '<div style="font-size:11px;color:var(--tx4);">' + pcount + ' period' + (pcount !== 1 ? 's' : '') + '</div>'
      +   '</div>'
      +   '<button class="btn btn-ghost btn-sm" onclick="openBellEditor(\'' + esc(b.id) + '\')">Edit</button>'
      +   (b.isDefault ? '' : '<button class="btn btn-ghost btn-sm" onclick="setBellDefault(\'' + esc(b.id) + '\')" title="Make default">★</button>')
      +   '<button class="btn btn-danger btn-sm" onclick="deleteBell(\'' + esc(b.id) + '\')">&#10005;</button>'
      + '</div>';
  }).join('');
}

// Mark a bell schedule as the default by re-saving it with isDefault=true.
// Server clears the flag on all others.
function setBellDefault(id){
  var bell = null;
  for (var i = 0; i < _bellSchedulesCache.length; i++){
    if (_bellSchedulesCache[i].id === id) bell = _bellSchedulesCache[i];
  }
  if (!bell) return;
  bell.isDefault = true;
  google.script.run.withSuccessHandler(function(r){
    if (r.success){ toast('Set as default', 'ok'); loadBellSchedules(); }
    else toast(r.error || 'Error', 'err');
  }).saveBellSchedule(JSON.stringify(bell));
}

// Confirm + delete a bell schedule. Server also clears any calendar
// dates that referenced it. Refreshes both the list and the calendar.
function deleteBell(id){
  var bell = null;
  for (var i = 0; i < _bellSchedulesCache.length; i++){
    if (_bellSchedulesCache[i].id === id) bell = _bellSchedulesCache[i];
  }
  if (!bell) return;
  if (!confirm('Delete "' + bell.name + '"?\n\nAny calendar dates assigned to this schedule will be cleared.')) return;

  google.script.run.withSuccessHandler(function(r){
    if (r.success){ toast('Deleted', 'inf'); loadBellSchedules(); renderSchedCalendar(); }
    else toast(r.error || 'Error', 'err');
  }).deleteBellSchedule(id);
}


/* ═══════════════════════════════════════════════════════════════════
   11. BELL SCHEDULES — editor modal
   Full-screen modal for creating/editing a bell schedule. Period rows
   have number/label/start/end inputs + a remove button.
   ═══════════════════════════════════════════════════════════════════ */

// Open the bell editor. Pass an id to edit an existing schedule, or no
// args to create a new one (with an 8-period default template).
function openBellEditor(id){
  _editingBellId = id || null;
  var bell = id ? _bellSchedulesCache.find(function(b){ return b.id === id; }) : null;

  // Pull values from existing bell, or sensible defaults for a new one
  var name      = bell ? bell.name : '';
  var color     = bell ? (bell.color || '#6366f1') : '#6366f1';
  var isDefault = bell ? bell.isDefault : false;
  var periods   = bell ? (bell.periods || []) : [
    {period:1, name:'Period 1', startTime:'08:00', endTime:'08:50'},
    {period:2, name:'Period 2', startTime:'08:55', endTime:'09:45'},
    {period:3, name:'Period 3', startTime:'09:50', endTime:'10:40'},
    {period:4, name:'Period 4', startTime:'10:45', endTime:'11:35'},
    {period:5, name:'Lunch',    startTime:'11:35', endTime:'12:15'},
    {period:6, name:'Period 5', startTime:'12:20', endTime:'13:10'},
    {period:7, name:'Period 6', startTime:'13:15', endTime:'14:05'},
    {period:8, name:'Period 7', startTime:'14:10', endTime:'15:00'}
  ];

  // Tear down any prior instance of the editor
  var existing = document.getElementById('bell-edit-ov');
  if (existing) existing.remove();

  var ov = document.createElement('div');
  ov.id = 'bell-edit-ov';
  ov.className = 'overlay open';

  var rowsHtml = periods.map(function(p, i){ return bellPeriodRowHtml(i, p); }).join('');
  ov.innerHTML = '<div class="mbox wide" style="max-width:640px;">'
    + '<div class="mtitle">' + (id ? 'Edit' : 'New') + ' Bell Schedule</div>'
    + '<div style="display:grid;grid-template-columns:1fr 100px 110px;gap:10px;margin-bottom:14px;">'
    +   '<div><label class="flbl">Name *</label><input class="finp" id="be-name" value="' + esc(name) + '" placeholder="e.g. Normal Schedule"></div>'
    +   '<div><label class="flbl">Color</label><input type="color" id="be-color" value="' + esc(color) + '" style="width:100%;height:36px;border:1px solid var(--border);border-radius:8px;background:none;cursor:pointer;padding:3px;"></div>'
    +   '<div><label class="flbl">Default</label><label style="display:flex;align-items:center;gap:6px;height:36px;font-size:12px;color:var(--tx2);cursor:pointer;"><input type="checkbox" id="be-default" ' + (isDefault ? 'checked' : '') + ' style="accent-color:var(--a1);width:16px;height:16px;">Use by default</label></div>'
    + '</div>'
    + '<div style="font-size:11px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:var(--tx3);margin-bottom:6px;">Periods</div>'
    + '<div id="be-periods" style="max-height:340px;overflow-y:auto;display:flex;flex-direction:column;gap:5px;">' + rowsHtml + '</div>'
    + '<button class="btn btn-ghost btn-sm" style="margin-top:10px;" onclick="addBellPeriodRow()">+ Add Period</button>'
    + '<div class="mfooter">'
    +   '<button class="btn btn-ghost" onclick="document.getElementById(\'bell-edit-ov\').remove()">Cancel</button>'
    +   '<button class="btn btn-primary" onclick="saveBellEditor()">Save Schedule</button>'
    + '</div>'
    + '</div>';
  document.body.appendChild(ov);
}

// Build a single period row's HTML — used by both initial render and
// addBellPeriodRow. data-bep attributes let saveBellEditor read values back.
function bellPeriodRowHtml(i, p){
  return '<div class="be-period-row" style="display:grid;grid-template-columns:60px 1fr 100px 100px 30px;gap:6px;align-items:center;">'
    + '<input class="finp" type="number" min="0" max="20" value="' + esc(String(p.period || (i + 1))) + '" data-bep="period" placeholder="#" style="text-align:center;font-size:12px;">'
    + '<input class="finp" value="' + esc(p.name || '') + '" data-bep="name" placeholder="Label (e.g. Period 1, Lunch)" style="font-size:12px;">'
    + '<input class="finp" type="time" value="' + esc(p.startTime || '') + '" data-bep="startTime" style="font-size:12px;">'
    + '<input class="finp" type="time" value="' + esc(p.endTime   || '') + '" data-bep="endTime" style="font-size:12px;">'
    + '<button class="btn btn-danger btn-sm" onclick="this.closest(\'.be-period-row\').remove()" style="padding:4px 8px;">&#10005;</button>'
    + '</div>';
}

// Append a fresh empty period row to the end of the editor's periods list.
function addBellPeriodRow(){
  var box = document.getElementById('be-periods');
  if (!box) return;
  var i = box.querySelectorAll('.be-period-row').length;
  var div = document.createElement('div');
  div.innerHTML = bellPeriodRowHtml(i, {period:i + 1, name:'', startTime:'', endTime:''});
  box.appendChild(div.firstChild);
}

// Collect the editor's values, validate, and save to the server.
// Skips empty period rows entirely. Refreshes both list and calendar on success.
function saveBellEditor(){
  var name = (document.getElementById('be-name').value || '').trim();
  if (!name){ toast('Name is required', 'err'); return; }

  var color     = document.getElementById('be-color').value;
  var isDefault = document.getElementById('be-default').checked;

  // Walk every row's inputs (data-bep="...") and assemble period objects
  var rows = document.querySelectorAll('#be-periods .be-period-row');
  var periods = [];
  rows.forEach(function(r){
    var p = {};
    r.querySelectorAll('input[data-bep]').forEach(function(inp){
      var k = inp.dataset.bep;
      if (k === 'period') p.period = parseInt(inp.value) || 0;
      else                p[k]     = inp.value || '';
    });
    // Skip totally empty rows
    if (p.name || p.startTime || p.endTime) periods.push(p);
  });
  if (!periods.length){ toast('Add at least one period', 'err'); return; }

  var payload = {
    id:        _editingBellId,
    name:      name,
    color:     color,
    isDefault: isDefault,
    periods:   periods
  };

  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      document.getElementById('bell-edit-ov').remove();
      toast('Saved', 'ok');
      loadBellSchedules();
      renderSchedCalendar();
    } else toast(r.error || 'Error', 'err');
  }).saveBellSchedule(JSON.stringify(payload));
}


/* ═══════════════════════════════════════════════════════════════════
   12. SCHEDULE CALENDAR — month grid + navigation
   Mini calendar showing which bell schedule applies on which date.
   Each cell is clickable to open the per-date entry modal.
   ═══════════════════════════════════════════════════════════════════ */

// Render the calendar header + empty grid, then load the current month's
// entries from the server and populate the grid.
function renderSchedCalendar(){
  var area = document.getElementById('sched-cal-area');
  if (!area) return;

  // Default to current month on first render
  if (!_schedCalDate) _schedCalDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
  var year  = _schedCalDate.getFullYear();
  var month = _schedCalDate.getMonth();
  var first = new Date(year, month, 1);
  var last  = new Date(year, month + 1, 0);
  var startStr = Utilities_format(first);
  var endStr   = Utilities_format(last);

  area.innerHTML = '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;">'
    +   '<button class="btn btn-ghost btn-sm" onclick="schedCalNav(-1)">&laquo; Prev</button>'
    +   '<div style="font-size:14px;font-weight:600;">' + MONTHS[month] + ' ' + year + '</div>'
    +   '<button class="btn btn-ghost btn-sm" onclick="schedCalNav(1)">Next &raquo;</button>'
    + '</div>'
    + '<div id="sched-cal-grid" style="display:grid;grid-template-columns:repeat(7,1fr);gap:3px;font-size:11px;"><div style="color:var(--tx4);text-align:center;padding:14px;">Loading...</div></div>';

  google.script.run.withSuccessHandler(function(entries){
    drawSchedCalendarGrid(year, month, entries || []);
  }).withFailureHandler(function(){
    drawSchedCalendarGrid(year, month, []);
  }).getScheduleCalendar(startStr, endStr);
}

// Move the calendar by ±N months and re-render.
function schedCalNav(dir){
  if (!_schedCalDate) _schedCalDate = new Date();
  _schedCalDate = new Date(_schedCalDate.getFullYear(), _schedCalDate.getMonth() + dir, 1);
  renderSchedCalendar();
}

// Paint the day cells inside #sched-cal-grid based on the entries[] list.
// Each day shows its number, the bell schedule's tinted background, and an
// optional A/B day-type marker in the upper right.
function drawSchedCalendarGrid(year, month, entries){
  var grid = document.getElementById('sched-cal-grid');
  if (!grid) return;

  // Index entries by date for quick lookup
  var entryMap = {};
  entries.forEach(function(e){ entryMap[e.date] = e; });
  // Index bell schedules by id
  var bellMap = {};
  _bellSchedulesCache.forEach(function(b){ bellMap[b.id] = b; });

  var first     = new Date(year, month, 1);
  var last      = new Date(year, month + 1, 0);
  var startDow  = first.getDay();
  var totalDays = last.getDate();
  var todayKey  = Utilities_format(new Date());

  // Day-of-week header row
  var DAYS_SHORT = ['S','M','T','W','T','F','S'];
  var html = DAYS_SHORT.map(function(d){
    return '<div style="font-weight:700;color:var(--tx3);text-align:center;padding:5px 0;font-size:10px;letter-spacing:.5px;">' + d + '</div>';
  }).join('');

  // Empty cells for days before the 1st of the month
  for (var i = 0; i < startDow; i++) html += '<div></div>';

  // Day cells
  for (var d = 1; d <= totalDays; d++){
    var dt    = new Date(year, month, d);
    var key   = Utilities_format(dt);
    var entry = entryMap[key];
    var bell  = entry ? bellMap[entry.bellScheduleId] : null;

    // Build the cell's tinted look from the bell schedule color
    var bgRgba = bell ? bell.color + '22' : 'rgba(255,255,255,.02)';
    var border = bell ? bell.color : 'var(--border)';
    var dayLabel  = (entry && entry.dayType)
      ? '<div style="position:absolute;top:2px;right:3px;font-size:8px;font-weight:700;color:' + (bell ? bell.color : 'var(--a2)') + ';">' + esc(entry.dayType) + '</div>'
      : '';
    var bellLabel = bell
      ? '<div style="font-size:8px;color:var(--tx2);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;line-height:1.2;">' + esc(bell.name) + '</div>'
      : '';
    var todayMark = key === todayKey ? 'box-shadow:inset 0 0 0 2px var(--a1);' : '';

    html += '<div onclick="openSchedCalEntry(\'' + key + '\')" style="position:relative;background:' + bgRgba + ';border:1px solid ' + border + ';border-radius:6px;padding:5px 6px;min-height:42px;cursor:pointer;transition:transform .1s;' + todayMark + '" onmouseover="this.style.transform=\'scale(1.04)\'" onmouseout="this.style.transform=\'\'">'
      + dayLabel
      + '<div style="font-weight:700;font-size:11px;color:var(--tx);">' + d + '</div>'
      + bellLabel
      + '</div>';
  }
  grid.innerHTML = html;
}


/* ═══════════════════════════════════════════════════════════════════
   13. SCHEDULE CALENDAR — per-date entry modal
   Click a day cell → modal with Bell Schedule dropdown, A/B Day
   selector, optional notes, and Save/Clear/Cancel buttons.
   ═══════════════════════════════════════════════════════════════════ */

// Open the entry modal for a single date. Fetches that date's existing
// entry first (if any) so the modal can pre-fill the dropdowns.
function openSchedCalEntry(dateStr){
  google.script.run.withSuccessHandler(function(entries){
    var entry = entries.length ? entries[0] : null;

    // Tear down any prior instance
    var existing = document.getElementById('sce-ov');
    if (existing) existing.remove();

    var ov = document.createElement('div');
    ov.className = 'overlay open';
    ov.id = 'sce-ov';

    // Bell schedule dropdown options (with default selected if matched)
    var bellOpts = '<option value="">— Use Default —</option>' + _bellSchedulesCache.map(function(b){
      return '<option value="' + esc(b.id) + '"' + (entry && entry.bellScheduleId === b.id ? ' selected' : '') + '>'
        + esc(b.name) + (b.isDefault ? ' (default)' : '') + '</option>';
    }).join('');

    // Pretty date heading: "Wednesday, May 5, 2026"
    var dt         = new Date(dateStr + 'T12:00:00');
    var prettyDate = DAYS[dt.getDay()] + ', ' + MONTHS[dt.getMonth()] + ' ' + dt.getDate() + ', ' + dt.getFullYear();
    var dayType    = entry ? entry.dayType || '' : '';

    // Day-type button helper (None/A/B)
    function dtBtn(val, lbl){
      var s = dayType === val ? 'background:var(--a3);border-color:var(--a1);color:var(--a2);' : '';
      return '<div onclick="pickSchedDayType(\'' + val + '\')" data-dt="' + val + '" style="flex:1;padding:8px 4px;border:1px solid var(--border);border-radius:7px;text-align:center;font-size:12px;font-weight:600;cursor:pointer;' + s + '">' + lbl + '</div>';
    }

    ov.innerHTML = '<div class="mbox" style="max-width:420px;">'
      + '<div class="mtitle">' + esc(prettyDate) + '</div>'
      + '<div class="fg"><label class="flbl">Bell Schedule</label><select class="fsel" id="sce-bell">' + bellOpts + '</select></div>'
      + '<div class="fg"><label class="flbl">Day Type (for A/B rotation)</label><div style="display:flex;gap:6px;">'
      +   '<div onclick="pickSchedDayType(\'\')" data-dt="" style="flex:1;padding:8px 4px;border:1px solid var(--border);border-radius:7px;text-align:center;font-size:12px;font-weight:600;cursor:pointer;' + (dayType === '' ? 'background:var(--a3);border-color:var(--a1);color:var(--a2);' : '') + '">None</div>'
      +   dtBtn('A', 'A Day')
      +   dtBtn('B', 'B Day')
      + '</div><input type="hidden" id="sce-daytype" value="' + esc(dayType) + '"></div>'
      + '<div class="fg"><label class="flbl">Notes (optional)</label><input class="finp" id="sce-notes" value="' + esc(entry ? entry.notes || '' : '') + '" placeholder="—e.g. Pep rally, Assembly—"></div>'
      + '<div class="mfooter">'
      +   '<button class="btn btn-ghost" onclick="document.getElementById(\'sce-ov\').remove()">Cancel</button>'
      +   (entry ? '<button class="btn btn-danger btn-sm" onclick="clearSchedCalEntry(\'' + dateStr + '\')">Clear</button>' : '')
      +   '<button class="btn btn-primary" onclick="saveSchedCalEntry(\'' + dateStr + '\')">Save</button>'
      + '</div></div>';
    document.body.appendChild(ov);
  }).getScheduleCalendar(dateStr, dateStr);
}

// Visually mark the picked day-type button and update the hidden input.
// Iterates all [data-dt] elements globally (the modal uses unique data-dt values).
function pickSchedDayType(val){
  document.querySelectorAll('[data-dt]').forEach(function(el){
    if (el.dataset.dt === val){
      // Tack the active styles onto the existing inline style string
      el.style.cssText = el.style.cssText + ';background:var(--a3);border-color:var(--a1);color:var(--a2);';
    } else {
      el.style.background   = '';
      el.style.borderColor  = 'var(--border)';
      el.style.color        = '';
    }
  });
  var inp = document.getElementById('sce-daytype');
  if (inp) inp.value = val;
}

// Save the entry's bell/dayType/notes to the server, close modal, refresh.
function saveSchedCalEntry(dateStr){
  var bell    = document.getElementById('sce-bell').value;
  var dayType = document.getElementById('sce-daytype').value;
  var notes   = document.getElementById('sce-notes').value;

  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      document.getElementById('sce-ov').remove();
      toast('Saved', 'ok');
      renderSchedCalendar();
    } else toast(r.error || 'Error', 'err');
  }).setScheduleCalendarEntry(dateStr, bell, dayType, notes);
}

// Clear an entry by saving an empty bell/dayType/notes (server interprets
// all-empty as "delete this date's entry").
function clearSchedCalEntry(dateStr){
  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      document.getElementById('sce-ov').remove();
      toast('Cleared', 'inf');
      renderSchedCalendar();
    }
  }).setScheduleCalendarEntry(dateStr, '', '', '');
}


/* ═══════════════════════════════════════════════════════════════════
   14. SCHEDULE CALENDAR — bulk-assign modal
   Apply a bell schedule to a date range, optionally filtered by
   day-of-week. Useful for "set every Wednesday this semester to Early Out".
   ═══════════════════════════════════════════════════════════════════ */

// Open the bulk-assign modal. Pre-checks Mon–Fri.
function openBulkBellAssign(){
  var existing = document.getElementById('bba-ov');
  if (existing) existing.remove();

  var bellOpts = '<option value="">— Clear (use default) —</option>' + _bellSchedulesCache.map(function(b){
    return '<option value="' + esc(b.id) + '">' + esc(b.name) + (b.isDefault ? ' (default)' : '') + '</option>';
  }).join('');

  var ov = document.createElement('div');
  ov.className = 'overlay open';
  ov.id = 'bba-ov';

  // Day-of-week checkboxes — Sun(0)–Sat(6); Mon–Fri pre-checked
  var DOW = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
  var dowChecks = DOW.map(function(d, i){
    return '<label style="display:flex;align-items:center;gap:5px;font-size:12px;cursor:pointer;"><input type="checkbox" class="bba-dow" data-d="' + i + '" ' + (i >= 1 && i <= 5 ? 'checked' : '') + ' style="accent-color:var(--a1);">' + d + '</label>';
  }).join('');

  ov.innerHTML = '<div class="mbox" style="max-width:480px;">'
    + '<div class="mtitle">Bulk Assign Bell Schedule</div>'
    + '<p style="font-size:13px;color:var(--tx3);line-height:1.6;margin-bottom:12px;">Apply a bell schedule to a range of dates. Useful for setting a default for the whole semester, or marking every Wednesday as Early Out.</p>'
    + '<div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px;">'
    +   '<div><label class="flbl">Start Date</label><input type="date" class="finp" id="bba-start"></div>'
    +   '<div><label class="flbl">End Date</label><input type="date" class="finp" id="bba-end"></div>'
    + '</div>'
    + '<div class="fg"><label class="flbl">Bell Schedule</label><select class="fsel" id="bba-bell">' + bellOpts + '</select></div>'
    + '<div class="fg"><label class="flbl">Day Type</label><select class="fsel" id="bba-daytype"><option value="">None</option><option value="A">A Day</option><option value="B">B Day</option></select></div>'
    + '<div class="fg"><label class="flbl">Days of Week to Include</label><div style="display:flex;gap:10px;flex-wrap:wrap;padding:8px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:8px;">' + dowChecks + '</div></div>'
    + '<div class="fg"><label class="flbl">Notes (optional)</label><input class="finp" id="bba-notes" placeholder="—e.g. Wednesday Early Out—"></div>'
    + '<div class="mfooter">'
    +   '<button class="btn btn-ghost" onclick="document.getElementById(\'bba-ov\').remove()">Cancel</button>'
    +   '<button class="btn btn-primary" onclick="doBulkBellAssign()">Apply to Range</button>'
    + '</div></div>';
  document.body.appendChild(ov);
}

// Validate inputs, collect checked DOWs as an int array, post to server.
// Server returns count of dates assigned.
function doBulkBellAssign(){
  var s = document.getElementById('bba-start').value;
  var e = document.getElementById('bba-end').value;
  if (!s || !e){ toast('Pick a date range', 'err'); return; }

  var bell    = document.getElementById('bba-bell').value;
  var dayType = document.getElementById('bba-daytype').value;
  var notes   = document.getElementById('bba-notes').value;
  var dows    = Array.from(document.querySelectorAll('.bba-dow:checked')).map(function(cb){ return parseInt(cb.dataset.d); });
  if (!dows.length){ toast('Pick at least one day of week', 'err'); return; }

  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      document.getElementById('bba-ov').remove();
      toast('Applied to ' + r.count + ' day(s)', 'ok');
      renderSchedCalendar();
    } else toast(r.error || 'Error', 'err');
  }).setScheduleCalendarRange(s, e, bell, dayType, notes, JSON.stringify(dows));
}


/* ═══════════════════════════════════════════════════════════════════
   15. GRADUATE STUDENTS
   Permanently removes selected students and all their data. Run
   annually after 8th-graders leave. Cannot be undone.
   ═══════════════════════════════════════════════════════════════════ */

// Load the full student roster into a checkbox list inside the widget.
function loadGradList(){
  var el  = document.getElementById('grad-list');
  var cnt = document.getElementById('grad-sel-count');
  if (el) el.innerHTML = '<div style="color:var(--tx3);font-size:12px;">Loading...</div>';

  google.script.run
    .withSuccessHandler(function(r){
      _gradStudents = r.students || [];
      if (!el) return;
      if (!_gradStudents.length){ el.innerHTML = '<div style="color:var(--tx4);font-size:13px;">No students registered yet.</div>'; return; }

      // Render alphabetically — the teacher visually identifies 8th graders
      el.innerHTML = _gradStudents.map(function(s, i){
        return '<label style="display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:8px;background:var(--bg3);border:1px solid var(--border);cursor:pointer;">'
          + '<input type="checkbox" data-i="' + i + '" onchange="updateGradCount()" style="width:15px;height:15px;accent-color:var(--a1);">'
          + '<div style="width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--a1),#a855f7);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700;color:white;flex-shrink:0;">' + esc(s.name.charAt(0)) + '</div>'
          + '<div style="flex:1;min-width:0;">'
          +   '<div style="font-size:13px;font-weight:600;">' + esc(s.name) + '</div>'
          +   '<div style="font-size:11px;color:var(--tx4);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(s.email) + '</div>'
          + '</div>'
          + '</label>';
      }).join('');
      updateGradCount();
    })
    .withFailureHandler(function(e){
      if (el) el.innerHTML = '<div style="color:#f87171;">' + esc(e.message) + '</div>';
    })
    .getStuGroupData();
}

// Update the "X students selected" count and toggle the Remove button.
function updateGradCount(){
  var checked = document.querySelectorAll('#grad-list input[type=checkbox]:checked');
  var cnt     = document.getElementById('grad-sel-count');
  var btn     = document.getElementById('grad-btn');
  if (cnt) cnt.textContent = checked.length + ' student' + (checked.length !== 1 ? 's' : '') + ' selected';
  if (btn) btn.style.display = checked.length ? 'inline-flex' : 'none';
}

// Confirm + permanently remove the selected students. Server purges
// all their data (tasks, prefs, etc.). Cannot be undone.
function doGraduate(){
  var checked = Array.from(document.querySelectorAll('#grad-list input[type=checkbox]:checked'));
  if (!checked.length){ toast('Select at least one student', 'err'); return; }

  // Resolve checked indices back to email/name pairs for the confirm prompt
  var selectedEmails = checked.map(function(cb){
    var i = parseInt(cb.dataset.i);
    return _gradStudents[i] ? _gradStudents[i].email : '';
  }).filter(Boolean);
  var names = checked.map(function(cb){
    var i = parseInt(cb.dataset.i);
    return _gradStudents[i] ? _gradStudents[i].name : '';
  }).filter(Boolean);

  if (!confirm('Permanently remove ' + selectedEmails.length + ' student(s)?\n\n' + names.join(', ') + '\n\nThis cannot be undone.')) return;

  var btn = document.getElementById('grad-btn');
  var res = document.getElementById('grad-result');
  if (btn) btn.textContent = 'Removing...';

  google.script.run
    .withSuccessHandler(function(r){
      if (btn){ btn.textContent = '&#127891; Remove Selected Students'; btn.style.display = 'none'; }
      if (!res) return;
      if (!r.success){ res.innerHTML = '<div style="color:#f87171;">' + esc(r.error) + '</div>'; return; }

      res.innerHTML = '<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;padding:12px 14px;font-size:13px;color:#22c55e;">'
        + '&#10003; Removed <strong>' + r.removed.students + '</strong> student(s) and all their data. '
        + '<span style="color:var(--tx3);">(' + r.removed.tasks + ' tasks purged)</span>'
        + '</div>';

      // Clean up the widget's UI state and force a stats refresh
      var gl = document.getElementById('grad-list');
      if (gl) gl.innerHTML = '';
      var sc = document.getElementById('grad-sel-count');
      if (sc) sc.textContent = '';
      // Force re-fetch on next teacher-tab navigation
      students = []; groups = [];
      loadAdminStats();
    })
    .withFailureHandler(function(e){
      if (btn) btn.textContent = '&#127891; Remove Selected Students';
      if (res) res.innerHTML = '<div style="color:#f87171;">' + esc(e.message) + '</div>';
    })
    .graduateStudents(JSON.stringify(selectedEmails));
}


/* ═══════════════════════════════════════════════════════════════════
   16. ROW REWARDS ADMIN — accounts (load, render, search, adjust)
   ═══════════════════════════════════════════════════════════════════ */

// Fetch all ROW accounts from the server, cache them, render the list.
function loadRowAdminAccounts(){
  var listEl = document.getElementById('row-admin-acct-list');
  if (listEl) listEl.innerHTML = '<div style="color:var(--tx3);font-size:12px;padding:10px;">Loading...</div>';

  google.script.run.withSuccessHandler(function(r){
    if (!r.success){
      if (listEl) listEl.innerHTML = '<div style="color:#f87171;font-size:12px;">' + esc(r.error || 'Error') + '</div>';
      return;
    }
    _rowAdminAccounts = r.accounts || [];
    renderRowAdminAccounts(_rowAdminAccounts);
  }).adminGetAllRowAccounts();
}

// Render the accounts list, splitting students from staff with a divider.
// Each row has +1 / ± / -1 quick-action buttons.
function renderRowAdminAccounts(list){
  var listEl = document.getElementById('row-admin-acct-list');
  if (!listEl) return;
  if (!list.length){
    listEl.innerHTML = '<div style="color:var(--tx4);font-size:12px;padding:10px;text-align:center;">No matching accounts.</div>';
    return;
  }

  // Split by role for grouped display
  var students = list.filter(function(a){ return a.role !== 'teacher'; });
  var teachers = list.filter(function(a){ return a.role === 'teacher'; });

  // Per-account row builder
  function renderItem(a){
    var roleBadge = a.role === 'teacher'
      ? '<span class="row-admin-role teacher">Teacher</span>'
      : '<span class="row-admin-role student">Student</span>';
    return '<div class="row-admin-acct"><div class="row-admin-acct-name">' + esc(a.name) + roleBadge
      + '<div style="font-size:10px;color:var(--tx4);font-weight:400;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(a.email) + '</div></div>'
      + '<div class="row-admin-acct-bal">' + a.balance + '</div>'
      + '<div class="row-admin-acct-actions">'
      +   '<button class="btn btn-primary btn-sm" onclick="adjustRowBalance(\'' + esc(a.email) + '\',1)">+1</button>'
      +   '<button class="btn btn-ghost btn-sm" onclick="promptAdjustRow(\'' + esc(a.email) + '\',\'' + esc(a.name) + '\')">&plusmn;</button>'
      +   '<button class="btn btn-danger btn-sm" onclick="adjustRowBalance(\'' + esc(a.email) + '\',-1)">&minus;1</button>'
      + '</div></div>';
  }

  var html = '';
  if (students.length){
    html += '<div style="font-size:10px;font-weight:700;color:var(--tx3);letter-spacing:.5px;text-transform:uppercase;margin:6px 2px 4px;">Students (' + students.length + ')</div>';
    html += students.map(renderItem).join('');
  }
  if (teachers.length){
    html += '<div style="font-size:10px;font-weight:700;color:var(--tx3);letter-spacing:.5px;text-transform:uppercase;margin:10px 2px 4px;padding-top:8px;border-top:1px solid var(--border);">Staff (' + teachers.length + ')</div>';
    html += teachers.map(renderItem).join('');
  }
  listEl.innerHTML = html;
}

// Filter cached accounts by name/email substring; re-render the list.
// Empty query → render the full list back.
function filterRowAccounts(){
  var q = (document.getElementById('row-admin-search') || {}).value || '';
  q = q.trim().toLowerCase();
  if (!q){ renderRowAdminAccounts(_rowAdminAccounts); return; }
  renderRowAdminAccounts(_rowAdminAccounts.filter(function(a){
    return a.name.toLowerCase().indexOf(q) > -1 || a.email.toLowerCase().indexOf(q) > -1;
  }));
}

// Quick +1/-1 adjustment via the row buttons.
function adjustRowBalance(email, delta){
  var reason = delta > 0 ? 'Quick add' : 'Quick deduct';
  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      toast((delta > 0 ? '+' : '') + delta + ' ROW. New balance: ' + r.newBalance, 'ok');
      // Update the cached balance in place so re-render shows new value
      _rowAdminAccounts.forEach(function(a){ if (a.email === email) a.balance = r.newBalance; });
      filterRowAccounts();
    } else toast(r.error || 'Error', 'err');
  }).adminAdjustRowBalance(email, delta, reason);
}

// Prompt for an arbitrary +/- adjustment with optional reason.
function promptAdjustRow(email, name){
  var amt = prompt('Adjust ROWs for ' + name + ':\n\nUse + to add, - to deduct.\nExample: 5 or -3');
  if (amt === null) return;
  var n = parseInt(String(amt).trim(), 10);
  if (isNaN(n) || n === 0){ toast('Enter a non-zero number', 'err'); return; }

  var reason = prompt('Reason (optional):') || '';
  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      toast((n > 0 ? '+' : '') + n + ' ROW. New balance: ' + r.newBalance, 'ok');
      _rowAdminAccounts.forEach(function(a){ if (a.email === email) a.balance = r.newBalance; });
      filterRowAccounts();
    } else toast(r.error || 'Error', 'err');
  }).adminAdjustRowBalance(email, n, reason);
}


/* ═══════════════════════════════════════════════════════════════════
   17. ROW REWARDS ADMIN — recent transactions
   Lazy-loaded list of the most recent ROW transactions across the
   whole school. Capped at 50 by adminGetAllRowTransactions.
   ═══════════════════════════════════════════════════════════════════ */

// Fetch and render the last 50 ROW transactions. Each row is color-coded
// by status (pending=amber / denied=gray / spend=red / approved=green).
function loadRowAdminTransactions(){
  var el = document.getElementById('row-admin-tx-list');
  if (el) el.innerHTML = '<div style="color:var(--tx4);">Loading...</div>';

  google.script.run.withSuccessHandler(function(r){
    if (!el) return;
    if (!r.success){ el.innerHTML = '<div style="color:#f87171;">' + esc(r.error || 'Error') + '</div>'; return; }
    if (!r.transactions.length){ el.innerHTML = '<div style="color:var(--tx4);text-align:center;padding:10px;">No transactions yet.</div>'; return; }

    el.innerHTML = r.transactions.map(function(t){
      // Resolve the amount string + color based on type/status
      var amtStr, color;
      if (t.status === 'pending'){ amtStr = '?'; color = '#fbbf24'; }
      else if (t.status === 'denied'){ amtStr = '&mdash;'; color = 'var(--tx4)'; }
      else if (t.type === 'spend' || t.type === 'admin_debit'){ amtStr = '&minus;' + t.amount; color = '#ef4444'; }
      else { amtStr = '+' + t.amount; color = '#22c55e'; }

      var when = t.createdAt ? fmtDate(t.createdAt.slice(0, 10)) : '';
      return '<div style="display:flex;align-items:center;gap:7px;padding:5px 7px;border-bottom:1px solid var(--border);">'
        + '<div style="flex:1;min-width:0;">'
        +   '<div style="color:var(--tx2);font-weight:600;">' + esc(t.studentName) + ' <span style="color:var(--tx4);font-weight:400;">&middot; ' + esc(t.category) + '</span></div>'
        +   '<div style="color:var(--tx4);font-size:10px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(t.description) + (when ? ' &middot; ' + when : '') + (t.teacherName ? ' &middot; ' + esc(t.teacherName) : '') + '</div>'
        + '</div>'
        + '<span style="color:' + color + ';font-family:DM Mono,monospace;font-weight:700;">' + amtStr + '</span>'
        + '</div>';
    }).join('');
  }).adminGetAllRowTransactions(50);
}


/* ═══════════════════════════════════════════════════════════════════
