// Submit a school-wide reminder. Confirms first since it sends to everyone.
// Empty datetime means "send now"; clears the form on success.
function doSendSchoolReminder(){
  var title = (document.getElementById('adm-rem-title') || {}).value || '';
  var body  = (document.getElementById('adm-rem-body')  || {}).value || '';
  var when  = (document.getElementById('adm-rem-when')  || {}).value || '';
  var res   = document.getElementById('adm-rem-result');

  if (!title.trim()){ toast('Title required', 'err'); return; }
  if (!confirm('Send this reminder to every student and teacher?')) return;

  var triggerISO = when ? new Date(when).toISOString() : '';

  google.script.run.withSuccessHandler(function(r){
    if (r && r.success){
      if (res) res.innerHTML = '<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;padding:10px 12px;font-size:13px;color:#22c55e;">&#10003; School-wide reminder sent.</div>';
      document.getElementById('adm-rem-title').value = '';
      document.getElementById('adm-rem-body').value  = '';
      document.getElementById('adm-rem-when').value  = '';
    } else {
      if (res) res.innerHTML = '<div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:8px;padding:10px 12px;font-size:13px;color:#f87171;">&#10005; ' + esc((r && r.error) || 'Unknown error') + '</div>';
    }
  }).sendSchoolReminder(title.trim(), body.trim(), triggerISO);
}


/* ═══════════════════════════════════════════════════════════════════
   6. SPREADSHEET HEALTH STATS
   Renders a usage bar (% of Google Sheets 10M-cell limit) plus a
   per-sheet row-count grid. Sheets with >5000 rows get amber styling.
   ═══════════════════════════════════════════════════════════════════ */

// Fetch and render the data stats overview.
function loadAdminStats(){
  var el = document.getElementById('stats-body');
  if (el) el.innerHTML = '<div style="color:var(--tx4);">Loading...</div>';

  google.script.run
    .withSuccessHandler(function(r){
      if (!el) return;
      if (!r || !r.success){
        el.innerHTML = '<div style="color:#f87171;">' + esc((r && r.error) || 'Stats unavailable') + '</div>';
        return;
      }

      var stats = Array.isArray(r.stats) ? r.stats : [];
      if (!stats.length){
        el.innerHTML = '<div style="color:var(--tx4);font-size:12px;padding:10px;text-align:center;">No stats available.</div>';
        return;
      }

      // Total cells used + percentage of Sheets limit
      var totalCells = stats.reduce(function(a, s){ return a + (s && s.cells ? s.cells : 0); }, 0);
      var pct = Math.round(totalCells / 100000 * 100) / 100;
      var barColor = pct < 50 ? '#22c55e' : pct < 80 ? '#f59e0b' : '#ef4444';

      var html = '<div style="margin-bottom:10px;">'
        + '<div style="display:flex;justify-content:space-between;font-size:12px;margin-bottom:4px;">'
        +   '<span style="color:var(--tx3);">Total cells used</span>'
        +   '<span style="color:var(--tx2);font-family:\'DM Mono\',monospace;">' + totalCells.toLocaleString() + ' / 10,000,000</span>'
        + '</div>'
        + '<div style="height:6px;background:rgba(255,255,255,.07);border-radius:99px;overflow:hidden;">'
        +   '<div style="height:100%;width:' + Math.min(pct, 100) + '%;background:' + barColor + ';border-radius:99px;transition:width .4s;"></div>'
        + '</div>'
        + '<div style="font-size:10px;color:var(--tx4);margin-top:3px;">' + pct + '% of Google Sheets limit</div>'
        + '</div>'
        + '<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:6px;">';

      // Per-sheet cards
      stats.forEach(function(s){
        if (!s || !s.name) return;
        var rows = s.rows || 0;
        var warn = rows > 5000;
        html += '<div style="background:rgba(255,255,255,.03);border:1px solid ' + (warn ? 'rgba(245,158,11,.3)' : 'var(--border)') + ';border-radius:8px;padding:8px 10px;">'
          + '<div style="font-size:11px;font-weight:600;color:' + (warn ? '#fbbf24' : 'var(--tx2)') + ';">' + esc(s.name) + '</div>'
          + '<div style="font-family:\'DM Mono\',monospace;font-size:13px;color:var(--tx);margin-top:2px;">' + rows.toLocaleString() + '</div>'
          + '<div style="font-size:10px;color:var(--tx4);">rows</div>'
          + '</div>';
      });
      html += '</div>';
      el.innerHTML = html;
    })
    .withFailureHandler(function(e){
      if (el) el.innerHTML = '<div style="color:#f87171;">' + esc(e && e.message ? e.message : 'Failed to load stats') + '</div>';
    })
    .getDataStats();
}


/* ═══════════════════════════════════════════════════════════════════
   7. LUNCH MENU IMPORT
   Posts pasted PDF text to the server's importLunchData parser.
   Server returns added/skipped/errors + the inferred target month.
   ═══════════════════════════════════════════════════════════════════ */

// Send the textarea contents to the server's lunch parser, then
// surface the success/skip/warn breakdown to the user.
function doLunchImport(){
  var ta   = document.getElementById('lunch-import-ta');
  var res  = document.getElementById('lunch-import-result');
  var text = ta ? ta.value : '';

  if (!text || !text.trim()){ toast('Paste some lunch data first', 'err'); return; }
  if (res) res.innerHTML = '<div style="color:var(--tx3);font-size:12px;">Importing...</div>';

  google.script.run
    .withSuccessHandler(function(r){
      if (!res) return;
      if (!r.success){
        res.innerHTML = '<div style="background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.2);border-radius:8px;padding:10px 12px;font-size:13px;color:#f87171;">&#10005; ' + esc(r.error) + '</div>';
        return;
      }
      var errHtml = r.errors && r.errors.length
        ? '<div style="margin-top:8px;font-size:11px;color:#f59e0b;">Warnings:<br>' + r.errors.map(function(e){ return esc(e); }).join('<br>') + '</div>'
        : '';
      var monthLbl = r.targetMonth ? ' to <strong>' + esc(r.targetMonth) + '</strong>' : '';
      res.innerHTML = '<div style="background:rgba(34,197,94,.08);border:1px solid rgba(34,197,94,.2);border-radius:8px;padding:10px 12px;font-size:13px;color:#22c55e;">'
        + '&#10003; Imported <strong>' + r.added + '</strong> day(s)' + monthLbl
        + (r.skipped ? ' &mdash; <span style="color:var(--tx3);">' + r.skipped + ' already existed, skipped</span>' : '')
        + '</div>' + errHtml;
      // Clear the textarea on any successful import
      if (r.added > 0 && ta) ta.value = '';
      loadAdminStats();
    })
    .withFailureHandler(function(e){
      if (res) res.innerHTML = '<div style="color:#f87171;">' + esc(e.message) + '</div>';
    })
    .importLunchData(text);
}


/* ═══════════════════════════════════════════════════════════════════
