<script>
/* ═══════════════════════════════════════════════════════════════════
   ║  index_admin_widgets.html — ADMIN TAB CHUNK
   ║  ─────────────────────────────────────────
   ║  Owns the entire Admin tab: 9 widgets in a draggable/resizable grid.
   ║  Only renders for users with realRole === 'teacher' (router enforces this).
   ║
   ║  Widgets (admin tile IDs):
   ║    abell      — Bell Schedules
   ║    aschedcal  — Schedule Calendar (which bells apply on which dates)
   ║    astats     — Spreadsheet Health
   ║    arepair    — Repair Sheets
   ║    alunch     — Lunch Menu Import
   ║    agrad      — Graduate Students
   ║    arow       — ROW Reward Accounts (admin view)
   ║    arem       — School-Wide Reminders
   ║    aclean     — Data Cleanup
   ║
   ║  TABLE OF CONTENTS
   ║  ─────────────────
   ║   1. STATE (caches + UI flags)
   ║   2. PAGE BUILDER (buildAdminPage)
   ║   3. TILE SIZE PICKER (openASzPicker, pickASz)
   ║   4. WIDGET RENDERERS — shell HTML for each of the 9 widgets
   ║   5. SCHOOL-WIDE REMINDERS (doSendSchoolReminder)
   ║   6. SPREADSHEET HEALTH STATS (loadAdminStats)
   ║   7. LUNCH MENU IMPORT (doLunchImport)
   ║   8. REPAIR SHEETS (doRepairSheets)
   ║   9. DATA CLEANUP (doDataCleanup)
   ║  10. BELL SCHEDULES — list + load + delete + set default
   ║  11. BELL SCHEDULES — editor modal (open, period rows, save)
   ║  12. SCHEDULE CALENDAR — month grid + navigation
   ║  13. SCHEDULE CALENDAR — per-date entry modal
   ║  14. SCHEDULE CALENDAR — bulk-assign modal
   ║  15. GRADUATE STUDENTS (load list, select, remove)
   ║  16. ROW REWARDS ADMIN — accounts (load, render, search, adjust)
   ║  17. ROW REWARDS ADMIN — recent transactions
   ║  18. HELPERS (Utilities_format date formatter)
   ═══════════════════════════════════════════════════════════════════ */


/* ═══════════════════════════════════════════════════════════════════
   1. STATE
   These caches let widgets share data without re-fetching across
   re-renders within a single Admin tab session.
   ═══════════════════════════════════════════════════════════════════ */
var _bellSchedulesCache = []; // current bell schedules (refreshed by loadBellSchedules)
