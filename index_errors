<script>
// ── ERROR DETECTOR ─────────────────────────────────────────────
// Catches all uncaught JavaScript errors and shows a dismissable
// panel with the message + line + a copy button.
// Loaded FIRST so it can catch errors in every chunk that follows.

(function(){
  var errorPanel = null;
  var errorLog = [];

  function buildPanel(){
    if (errorPanel) return errorPanel;
    var p = document.createElement('div');
    p.id = 'err-detector-panel';
    p.style.cssText = 'position:fixed;bottom:14px;left:14px;z-index:99999;'
      + 'max-width:480px;background:#1a0a0a;border:2px solid #ef4444;'
      + 'border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.6);'
      + 'font-family:DM Mono,ui-monospace,monospace;font-size:11px;'
      + 'color:#fca5a5;padding:0;display:none;';
    p.innerHTML =
      '<div style="display:flex;align-items:center;gap:8px;padding:8px 10px;'
        + 'background:#2a0e0e;border-bottom:1px solid #ef4444;border-radius:8px 8px 0 0;">'
        + '<span style="color:#ef4444;font-weight:700;font-size:10px;letter-spacing:.5px;'
        + 'text-transform:uppercase;flex:1;">⚠ Errors <span id="err-count">0</span></span>'
        + '<button id="err-copy-btn" style="background:#451a1a;border:1px solid #ef4444;'
        + 'color:#fca5a5;padding:3px 9px;border-radius:5px;cursor:pointer;font-size:10px;'
        + 'font-family:inherit;">Copy</button>'
        + '<button id="err-clear-btn" style="background:#451a1a;border:1px solid #ef4444;'
        + 'color:#fca5a5;padding:3px 9px;border-radius:5px;cursor:pointer;font-size:10px;'
        + 'font-family:inherit;">Clear</button>'
        + '<button id="err-close-btn" style="background:none;border:none;color:#fca5a5;'
        + 'cursor:pointer;font-size:16px;padding:0 4px;line-height:1;">×</button>'
      + '</div>'
      + '<div id="err-list" style="max-height:280px;overflow-y:auto;padding:8px 12px;'
        + 'line-height:1.5;"></div>';
    document.body.appendChild(p);
    errorPanel = p;
    document.getElementById('err-copy-btn').onclick = function(){
      var text = errorLog.map(function(e){
        return '[' + e.time + '] ' + e.msg + (e.src ? '\n  → ' + e.src + ':' + e.line : '');
      }).join('\n\n');
      // Copy via temp textarea (works in Apps Script iframe)
      var ta = document.createElement('textarea');
      ta.value = text;
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand('copy'); } catch(e){}
      ta.remove();
      var btn = document.getElementById('err-copy-btn');
      var orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(function(){ btn.textContent = orig; }, 1200);
    };
    document.getElementById('err-clear-btn').onclick = function(){
      errorLog = [];
      document.getElementById('err-list').innerHTML = '';
      document.getElementById('err-count').textContent = '0';
      errorPanel.style.display = 'none';
    };
    document.getElementById('err-close-btn').onclick = function(){
      errorPanel.style.display = 'none';
    };
    return p;
  }

  function showError(msg, src, line){
    var time = new Date().toLocaleTimeString();
    errorLog.push({ time: time, msg: msg, src: src || '', line: line || '' });
    var panel = buildPanel();
    panel.style.display = 'block';
    document.getElementById('err-count').textContent = errorLog.length;
    var list = document.getElementById('err-list');
    var entry = document.createElement('div');
    entry.style.cssText = 'padding:6px 0;border-bottom:1px solid rgba(239,68,68,.15);';
    var srcLine = (src || line) ? '<div style="color:#fbbf24;font-size:10px;margin-top:2px;">→ '
      + (src ? src.split('/').pop() : '') + (line ? ':' + line : '') + '</div>' : '';
    entry.innerHTML = '<div style="color:#94a3b8;font-size:9px;">' + time + '</div>'
      + '<div style="color:#fca5a5;word-break:break-word;">' + msg + '</div>'
      + srcLine;
    list.appendChild(entry);
    list.scrollTop = list.scrollHeight;
  }

  // Catch uncaught synchronous errors
  window.addEventListener('error', function(e){
    showError(e.message || 'Unknown error', e.filename || '', e.lineno || '');
  });

  // Catch uncaught promise rejections
  window.addEventListener('unhandledrejection', function(e){
    var msg = e.reason && e.reason.message
      ? e.reason.message
      : String(e.reason || 'Unhandled promise rejection');
    showError('Promise: ' + msg, '', '');
  });

  // Expose for manual logging from anywhere
  window.logError = function(msg, src, line){ showError(msg, src || '', line || ''); };
})();
</script>
