/* ═══════════════════════════════════════════════════════════════════
   23. LUNCH WIDGET
   _lunchData is populated by loadLunchMenu (called from the WIDGET_HTML
   refresh button + initial render). Tabs show Mon-Fri of the current
   week; weekends auto-display Monday's menu.
   ═══════════════════════════════════════════════════════════════════ */

var _lunchData = [];  // [{date, main, side1, side2, side3, veg, notes}, ...]
var _lunchDay  = null; // currently-displayed day's YMD string

// Fetch the school's lunch menu and re-render the day tabs.
function loadLunchMenu(){
  showWidgetLoader('lunch', 'sm');
  google.script.run
    .withSuccessHandler(function(rows){
      _lunchData = rows || [];
      buildLunchTabs();
      hideWidgetLoader('lunch');
    })
    .withFailureHandler(function(){
      var el = document.getElementById('lunch-body');
      if (el) el.innerHTML = '<div class="lunch-empty">Could not load menu.</div>';
      hideWidgetLoader('lunch');
    })
    .getLunchMenu();
}

// Render the Mon-Fri tab bar and pick a default day to display.
// On weekends, defaults to Monday's menu.
function buildLunchTabs(){
  var tabs = document.getElementById('lunch-tabs');
  var body = document.getElementById('lunch-body');
  if (!tabs || !body) return;

  var now = new Date();
  var dow = now.getDay();
  // Find Monday of this week
  var mon = new Date(now);
  mon.setDate(now.getDate() - (dow === 0 ? 6 : dow - 1));

  // Build Mon-Fri date list
  var days = [];
  for (var i = 0; i < 5; i++){
    var d = new Date(mon);
    d.setDate(mon.getDate() + i);
    days.push(d);
  }

  var todayStr  = now.toISOString().slice(0, 10);
  var DAY_SHORT = ['Mon','Tue','Wed','Thu','Fri'];

  tabs.innerHTML = days.map(function(d, i){
    var ds      = d.toISOString().slice(0, 10);
    var isToday = ds === todayStr;
    var cls     = 'lunch-day-btn' + (isToday ? ' today' : '');
    // data-date + onclick="showLunchDay(this.dataset.date)" avoids quote-escaping nightmares
    return '<button class="' + cls + '" data-date="' + ds + '" onclick="showLunchDay(this.dataset.date)">' + DAY_SHORT[i] + '<br><span style="font-size:9px;opacity:.7;">' + fmtDate(ds) + '</span></button>';
  }).join('');

  // Default day: today on weekdays, Monday on weekends
  if (dow === 0 || dow === 6){ _lunchDay = days[0].toISOString().slice(0, 10); }
  else                          { _lunchDay = todayStr; }
  showLunchDay(_lunchDay);
}

// Render a specific day's lunch menu inside #lunch-body.
function showLunchDay(dateStr){
  _lunchDay = dateStr;

  // Highlight active tab
  document.querySelectorAll('.lunch-day-btn').forEach(function(b){
    b.classList.toggle('active', b.dataset.date === dateStr);
  });

  var body = document.getElementById('lunch-body');
  if (!body) return;

  // Find the menu row for this date
  var row = null;
  for (var i = 0; i < _lunchData.length; i++){
    if (_lunchData[i].date === dateStr){ row = _lunchData[i]; break; }
  }
  if (!row){ body.innerHTML = '<div class="lunch-empty">No menu posted for this day.</div>'; return; }

  // Build the body — main, sides (filtered for non-empty), veg, notes
  var html = '';
  if (row.main) html += '<div class="lunch-main">' + esc(row.main) + '</div>';
  var sides = [row.side1, row.side2, row.side3].filter(Boolean);
  if (sides.length){ html += '<div class="lunch-sides">' + sides.map(function(s){ return '<div class="lunch-side">' + esc(s) + '</div>'; }).join('') + '</div>'; }
  if (row.veg)   html += '<div class="lunch-veg">' + esc(row.veg) + '</div>';
  if (row.notes) html += '<div class="lunch-side" style="margin-top:5px;">' + esc(row.notes) + '</div>';
  if (!html) html = '<div class="lunch-empty">No items listed for this day.</div>';
  body.innerHTML = html;
}


/* ═══════════════════════════════════════════════════════════════════
   24. SCORES WIDGET
   Renders a Lexile score line chart over 9 testing seasons (3 grades ×
   3 seasons each). Pure SVG — no chart library. Shows an optional goal
   as a dotted reference line.
   ═══════════════════════════════════════════════════════════════════ */

// Render the SVG line chart. Handles missing data points (broken lines),
// auto-scales y-axis with padding, and renders grade-group bands across
// the x-axis (6th / 7th / 8th).
function renderScoresChart(){
  var el = document.getElementById('scores-chart');
  if (!el) return;

  var data    = prefs.testingScores || {goal:null, entries:{}};
  var entries = data.entries || {};
  var goal    = data.goal ? Number(data.goal) : null;

  // Canonical 9-season key order (must match the editor's grid)
  var KEYS     = ['6-fall','6-winter','6-spring','7-fall','7-winter','7-spring','8-fall','8-winter','8-spring'];
  var S_LABELS = ['Fall','Win','Spr','Fall','Win','Spr','Fall','Win','Spr'];
  var G_LABELS = ['6th Grade','7th Grade','8th Grade'];

  var vals    = KEYS.map(function(k){ return entries[k] ? Number(entries[k]) : null; });
  var nonNull = vals.filter(function(v){ return v !== null; });

  // No data + no goal → empty state
  if (!nonNull.length && !goal){
    el.innerHTML = '<div class="empty" style="padding:20px 0;"><div class="empty-ico">&#128200;</div><p style="font-size:12px;">Click &#9881; Edit to enter scores.</p></div>';
    return;
  }

  // Y-axis range: pad max & min so points don't sit on the edges
  var allVals = goal ? nonNull.concat([goal]) : nonNull;
  var rawMax  = allVals.length ? Math.max.apply(null, allVals) : 1200;
  var rawMin  = allVals.length ? Math.min.apply(null, allVals) : 400;
  var pad     = Math.max(120, Math.ceil((rawMax - rawMin) * 0.25));
  var maxV    = Math.ceil((rawMax + pad) / 50) * 50;
  var minV    = Math.max(0, Math.floor((rawMin - pad) / 50) * 50);

  // SVG layout — viewBox + padding for axes/labels
  var W = 440, H = 210;
  var PL = 58, PR = 18, PT = 22, PB = 50;
  var cW = W - PL - PR;
  var cH = H - PT - PB;
  function toX(i){ return PL + i * (cW / 8); }       // 9 points → 8 intervals
  function toY(v){ return PT + cH * (1 - (v - minV) / (maxV - minV)); }

  var svg = '<svg viewBox="0 0 ' + W + ' ' + H + '" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;display:block;overflow:visible;">';

  // ── Y gridlines + tick labels (5 ticks) ──
  for (var t = 0; t <= 4; t++){
    var tv = Math.round(minV + (maxV - minV) * t / 4);
    var ty = toY(tv);
    svg += '<line x1="' + PL + '" y1="' + ty + '" x2="' + (W - PR) + '" y2="' + ty + '" stroke="rgba(255,255,255,.05)" stroke-width="1"/>';
    svg += '<text x="' + (PL - 5) + '" y="' + (ty + 4) + '" fill="rgba(148,163,184,.55)" font-size="9" text-anchor="end" font-family="DM Sans,sans-serif">' + tv + '</text>';
  }

  // ── Grade group bands (6th/7th/8th — 3 seasons each) + separators ──
  [[0,2],[3,5],[6,8]].forEach(function(b, gi){
    var x1 = toX(b[0]) - (cW / 8) * 0.38;
    var x2 = toX(b[1]) + (cW / 8) * 0.38;
    svg += '<rect x="' + x1 + '" y="' + PT + '" width="' + (x2 - x1) + '" height="' + cH + '" rx="4" fill="rgba(255,255,255,.02)"/>';
    svg += '<text x="' + ((toX(b[0]) + toX(b[1])) / 2) + '" y="' + (H - 7) + '" fill="var(--a2)" font-size="10" font-weight="600" text-anchor="middle" font-family="inherit" letter-spacing=".5">' + G_LABELS[gi] + '</text>';
    // Dashed separator between groups (after 6th and 7th)
    if (gi < 2){
      var sx = toX(b[1]) + (cW / 8) * 0.5;
      svg += '<line x1="' + sx + '" y1="' + PT + '" x2="' + sx + '" y2="' + (PT + cH) + '" stroke="rgba(255,255,255,.07)" stroke-width="1" stroke-dasharray="3,3"/>';
    }
  });

  // ── Goal dotted reference line + label ──
  if (goal){
    var clampedG = Math.max(minV, Math.min(maxV, goal));
    var gy = toY(clampedG);
    svg += '<line x1="' + PL + '" y1="' + gy + '" x2="' + (W - PR) + '" y2="' + gy + '" stroke="var(--a2)" stroke-width="1.5" stroke-dasharray="5,4" opacity=".9"/>';
    svg += '<rect x="' + (W - PR - 36) + '" y="' + (gy - 11) + '" width="36" height="13" rx="3" fill="rgba(14,22,44,.85)"/>';
    svg += '<text x="' + (W - PR - 4) + '" y="' + (gy - 2) + '" fill="var(--a2)" font-size="9" font-weight="600" text-anchor="end" font-family="inherit">' + goal + ' L</text>';
  }

  // ── Build line segments — break at nulls so gaps don't draw thru ──
  var segments = [], cur = [];
  for (var i = 0; i < 9; i++){
    if (vals[i] !== null){
      cur.push({x:toX(i), y:toY(vals[i]), v:vals[i]});
    } else {
      if (cur.length) segments.push(cur);
      cur = [];
    }
  }
  if (cur.length) segments.push(cur);

  // ── Area fill under each segment (gradient from accent color) ──
  segments.forEach(function(seg, si){
    if (seg.length < 1) return;
    var gradId = 'areag' + si;
    svg += '<defs><linearGradient id="' + gradId + '" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="var(--a1)" stop-opacity=".3"/><stop offset="100%" stop-color="var(--a1)" stop-opacity=".01"/></linearGradient></defs>';
    var aPath = 'M ' + seg[0].x + ' ' + (PT + cH);
    seg.forEach(function(p){ aPath += ' L ' + p.x + ' ' + p.y; });
    aPath += ' L ' + seg[seg.length - 1].x + ' ' + (PT + cH) + ' Z';
    svg += '<path d="' + aPath + '" fill="url(#' + gradId + ')" />';
  });

  // ── Lines (drawn twice — once thick, once thin lighter for sheen) ──
  segments.forEach(function(seg){
    if (seg.length < 2) return;
    var d = 'M ' + seg[0].x + ' ' + seg[0].y;
    seg.forEach(function(p, pi){ if (pi > 0) d += ' L ' + p.x + ' ' + p.y; });
    svg += '<path d="' + d + '" fill="none" stroke="var(--a1)" stroke-width="2.5" stroke-linejoin="round" stroke-linecap="round"/>';
    svg += '<path d="' + d + '" fill="none" stroke="var(--a2)" stroke-width="1" stroke-linejoin="round" stroke-linecap="round" opacity=".45"/>';
  });

  // ── Dots, value labels, x-axis season labels (filled OR placeholder) ──
  for (var i = 0; i < 9; i++){
    var x = toX(i);
    if (vals[i] !== null){
      var y = toY(vals[i]);
      svg += '<circle cx="' + x + '" cy="' + y + '" r="5" fill="var(--a1)" stroke="#0f172a" stroke-width="2.5"/>';
      svg += '<circle cx="' + x + '" cy="' + y + '" r="2.5" fill="var(--a2)"/>';
      // Drop the value label below the point if it would overflow the top
      var lblY = (y < PT + 16) ? y + 16 : y - 8;
      svg += '<text x="' + x + '" y="' + lblY + '" fill="var(--a2)" font-size="9" font-weight="600" text-anchor="middle" font-family="inherit">' + vals[i] + '</text>';
    } else {
      // Placeholder dashed circle for missing seasons
      svg += '<circle cx="' + x + '" cy="' + (PT + cH / 2) + '" r="3.5" fill="none" stroke="rgba(255,255,255,.1)" stroke-width="1.5" stroke-dasharray="2,2"/>';
    }
    svg += '<text x="' + x + '" y="' + (PT + cH + 15) + '" fill="rgba(148,163,184,.6)" font-size="9" text-anchor="middle" font-family="inherit">' + S_LABELS[i] + '</text>';
  }

  // ── Axes + Y-axis "LEXILE" rotated label ──
  svg += '<line x1="' + PL + '" y1="' + PT + '" x2="' + PL + '" y2="' + (PT + cH) + '" stroke="rgba(255,255,255,.12)" stroke-width="1"/>';
  svg += '<line x1="' + PL + '" y1="' + (PT + cH) + '" x2="' + (W - PR) + '" y2="' + (PT + cH) + '" stroke="rgba(255,255,255,.12)" stroke-width="1"/>';
  svg += '<text x="14" y="' + (PT + cH / 2) + '" fill="rgba(148,163,184,.55)" font-size="9" font-weight="600" letter-spacing="1" text-anchor="middle" font-family="inherit" transform="rotate(-90,14,' + (PT + cH / 2) + ')">LEXILE</text>';
  svg += '</svg>';
  el.innerHTML = svg;
}

// Save handler for the scores flip-back form. Reads all 9 entry inputs
// + the goal input, filters to numeric values > 0, persists, re-renders chart.
function saveScores(){
  if (!prefs.testingScores) prefs.testingScores = {goal:null, entries:{}};

  var entries = {};
  var GRADES  = ['6','7','8'];
  var SEASONS = ['fall','winter','spring'];
  GRADES.forEach(function(g){
    SEASONS.forEach(function(s){
      var key = g + '-' + s;
      var inp = document.getElementById('sc-inp-' + key);
      var v   = inp ? inp.value.trim() : '';
      if (v && !isNaN(Number(v)) && Number(v) > 0) entries[key] = Number(v);
    });
  });

  var goalEl = document.getElementById('sc-goal');
  var goalV  = goalEl ? goalEl.value.trim() : '';
  prefs.testingScores = {
    goal:    (goalV && !isNaN(Number(goalV)) && Number(goalV) > 0) ? Number(goalV) : null,
    entries: entries
  };
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  unflipWidget('scores');

  // Re-render just the scores tile
  var tile = document.getElementById('tile-scores');
  if (tile){
    var front = tile.querySelector('.face-front');
    if (front) try { front.innerHTML = WIDGET_HTML.scores(); } catch(e){}
  }
  setTimeout(renderScoresChart, 60); // wait for layout to settle
  toast('Scores saved', 'ok');
}

// Wipe all scores + goal. Confirms first.
function clearScores(){
  if (!confirm('Clear all saved scores and goal?')) return;
  prefs.testingScores = {goal:null, entries:{}};
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  unflipWidget('scores');
  var tile = document.getElementById('tile-scores');
  if (tile){
    var front = tile.querySelector('.face-front');
    if (front) try { front.innerHTML = WIDGET_HTML.scores(); } catch(e){}
  }
  toast('Scores cleared', 'inf');
}


/* ═══════════════════════════════════════════════════════════════════
   25. SUBJECT HELPERS
   Subject color resolution (saved → hashed fallback) and the dropdown
   builder used by task-add forms (deduped, with A/B-day annotation).
   ═══════════════════════════════════════════════════════════════════ */

// Resolve a color for a given subject. Saved prefs.subjectColors[subj]
// wins; otherwise hash the subject name into TAB_COLORS for stability.
function getSubjectColor(subject){
  if (!subject) return '#6366f1';
  var key = String(subject).trim();
  if (prefs.subjectColors && prefs.subjectColors[key]) return prefs.subjectColors[key];

  // Simple string hash → modulo into TAB_COLORS for a stable pseudo-random color
  var h = 0;
  for (var i = 0; i < key.length; i++) h = (h * 31 + key.charCodeAt(i)) | 0;
  return TAB_COLORS[Math.abs(h) % TAB_COLORS.length];
}

// Get a deduped list of unique subjects from the schedule, with A/B-day
// annotation when applicable. Strips [label](url) wrapping so the menu
// shows clean labels.
function getSubjectOptions(){
  var subjects = [];
  var seen     = {};
  (mySchedule || []).forEach(function(p){
    var subj = String(p.subject || '').trim();
    // Strip [label](url) wrapping — we only want the label
    var lm = subj.match(/^\[(.+?)\]\((https?:\/\/[^\)]+)\)$/);
    if (lm) subj = lm[1];
    if (subj && !seen[subj]){
      seen[subj] = true;
      subjects.push({label: p.abDay ? subj + ' (A)' : subj, value: subj, period: p.period});
    }
    // For A/B periods, also include the B-day subject (if different)
    if (p.abDay){
      var subjB = String(p.subjectB || '').trim();
      var lmB = subjB.match(/^\[(.+?)\]\((https?:\/\/[^\)]+)\)$/);
      if (lmB) subjB = lmB[1];
      if (subjB && !seen[subjB]){
        seen[subjB] = true;
        subjects.push({label: subjB + ' (B)', value: subjB, period: p.period});
      }
    }
  });
  return subjects;
}

// Build <option> tags for a subject dropdown. Special-cases the current
// value: if it's not in the schedule (e.g. a legacy task with a custom
// subject), it gets prepended as a "(custom)" option so the user can
// keep using it without forced re-mapping.
function buildSubjectDropdownOptions(currentValue){
  var opts = getSubjectOptions();
  var html = '<option value="">— No subject —</option>';
  var matched = false;

  opts.forEach(function(o){
    var sel = (o.value === currentValue) ? ' selected' : '';
    if (sel) matched = true;
    html += '<option value="' + esc(o.value) + '"' + sel + '>' + esc(o.label) + '</option>';
  });

  // Preserve unrecognized subjects so they stay selected
  if (currentValue && !matched){
    html = '<option value="' + esc(currentValue) + '" selected>' + esc(currentValue) + ' (custom)</option>' + html;
  }
  return html;
}


/* ═══════════════════════════════════════════════════════════════════
   26. DATE/TIME HELPERS
   Local-timezone formatters used by both the calendar tab and task
   add forms. Note: the calendar tab's index_calendar.html has its
   own copies of these (they live there too — not a duplicate, just
   parallel definitions for separation of concerns).
   ═══════════════════════════════════════════════════════════════════ */

// Format a Date as YYYY-MM-DD in LOCAL time. Avoids UTC conversion
// issues that plague Date.prototype.toISOString().slice(0,10).
function _ymdLocal(d){
  var y  = d.getFullYear();
  var m  = String(d.getMonth() + 1).padStart(2, '0');
  var dd = String(d.getDate()).padStart(2, '0');
  return y + '-' + m + '-' + dd;
}

// Format a Date as a time string honoring prefs.timeFormat.
// 24h: "HH:MM"  /  12h: "H:MMam" or "Ham" (drops :00)
function _fmtTimeLocal(d){
  var h = d.getHours(), m = d.getMinutes();
  if (prefs.timeFormat === '24h') return String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
  var ap = h >= 12 ? 'pm' : 'am';
  h = h % 12 || 12;
  return h + (m === 0 ? '' : ':' + String(m).padStart(2, '0')) + ap;
}


/* ═══════════════════════════════════════════════════════════════════
   27. CALENDAR INTEGRATION
   findClassTimesForSubject is used by task-add flows to auto-time a
   calendar event using the user's class schedule. openCalendarEvent
   wraps the server-side createCalendarEvent call with proper start/end
   ISO strings + guest list + cache invalidation.
   ═══════════════════════════════════════════════════════════════════ */

// Look up the user's start/end times for a given subject on a given date.
// Uses bell schedule period times when an override is active, otherwise
// the user's saved per-period times. Returns null if no match.
function findClassTimesForSubject(subject, dueDate){
  if (!subject || !mySchedule || !mySchedule.length) return null;

  // Determine effective day type. Today's bell schedule's dayType wins;
  // defaults to 'A' for non-AB schedules.
  // FUTURE: could look up the bell schedule for the actual due date,
  // but most tasks are for soon-upcoming dates so today's day type is fine.
  var dayType = 'A';
  if (dueDate && activeBell){
    dayType = (activeBell.dayType || 'A').toUpperCase();
    if (dayType !== 'A' && dayType !== 'B') dayType = 'A';
  }

  for (var i = 0; i < mySchedule.length; i++){
    var p = mySchedule[i];
    // Strip [label](url) wrapping from both A and B subjects for matching
    var subjA = String(p.subject  || '').replace(/^\[(.+?)\]\(.+\)$/, '$1').trim();
    var subjB = String(p.subjectB || '').replace(/^\[(.+?)\]\(.+\)$/, '$1').trim();
    if (subjA === subject || subjB === subject){
      // Bell schedule times override the saved times when active
      var startT = p.startTime;
      var endT   = p.endTime;
      if (activeBell && activeBell.schedule && activeBell.schedule.periods){
        for (var j = 0; j < activeBell.schedule.periods.length; j++){
          if (String(activeBell.schedule.periods[j].period) === String(p.period)){
            startT = activeBell.schedule.periods[j].startTime || startT;
            endT   = activeBell.schedule.periods[j].endTime   || endT;
            break;
          }
        }
      }
      if (startT && endT) return {startTime:startT, endTime:endT};
    }
  }
  return null;
}

// Create a Google Calendar event server-side. Builds proper ISO strings
// based on whether classTimes was provided (timed event) or not (all-day).
// Busts the calendar tab's event cache on success so newly-added events
// show up the next time the user opens that tab.
function openCalendarEvent(title, dueDate, details, guestEmails, classTimes){
  if (!title)   { toast('Need a title to create event',    'err'); return; }
  if (!dueDate) { toast('Need a due date to create event', 'err'); return; }

  // Build ISO strings + allDay flag
  var startISO, endISO;
  var allDay = false;
  if (classTimes && classTimes.startTime && classTimes.endTime){
    // Timed event — combine due date with class start/end times
    var sParts = classTimes.startTime.split(':');
    var eParts = classTimes.endTime.split(':');
    var sd = new Date(dueDate + 'T00:00:00');
    sd.setHours(parseInt(sParts[0], 10), parseInt(sParts[1], 10), 0, 0);
    var ed = new Date(dueDate + 'T00:00:00');
    ed.setHours(parseInt(eParts[0], 10), parseInt(eParts[1], 10), 0, 0);
    startISO = sd.toISOString();
    endISO   = ed.toISOString();
  } else {
    // All-day event — start = due date, end = next day (Google Calendar
    // conventions for all-day events use exclusive end dates)
    startISO = dueDate;
    var ed = new Date(dueDate + 'T00:00:00');
    ed.setDate(ed.getDate() + 1);
    endISO = _ymdLocal(ed);
    allDay = true;
  }

  var opts = {
    description: details || '',
    allDay:      allDay,
    guests:      (guestEmails && guestEmails.length) ? guestEmails : []
  };

  toast('Adding to Google Calendar…', 'inf');
  google.script.run
    .withSuccessHandler(function(r){
      if (r && r.success){
        toast('Added to Google Calendar', 'ok');
        // Bust the calendar tab's cache so the new event shows up next visit
        if (typeof _calCache !== 'undefined') _calCache = {};
      } else {
        toast((r && r.error) || 'Could not add event', 'err');
      }
    })
    .withFailureHandler(function(e){
      toast('Could not add event: ' + (e && e.message ? e.message : 'unknown error'), 'err');
    })
    .createCalendarEvent(title, startISO, endISO, JSON.stringify(opts));
}


/* ═══════════════════════════════════════════════════════════════════
   28. HOME DATA LOAD
   loadHomeData is the bulk loader called once at boot. Sets the
   homeDataLoaded flag so subsequent buildHomePage calls skip the load.
   refreshScheduleData is the auto-refresher (registered for the
   schedule widget; runs every 10 minutes via registerAutoRefresh).
   ═══════════════════════════════════════════════════════════════════ */

// Single-shot loader — pulls tasks + schedule + notes + links + embedded
// docs + bell schedules in one round trip. Falls back to four separate
// calls if the combined endpoint fails.
function loadHomeData(){
  google.script.run
    .withSuccessHandler(function(r){
      if (!r || r.error){
        // No data → still render whatever's locally cached
        renderTasks(); renderSchedule(); renderLinks(); renderCountdowns();
        return;
      }
      myTasks         = r.tasks         || [];
      mySchedule      = r.schedule      || [];
      myNotes         = r.notes         || '';
      myLinks         = r.links         || [];
      myEmbeddedDocs  = r.embeddedDocs  || [];
      bellSchedules   = r.bellSchedules || [];
      activeBell      = r.activeBell    || null;
      myNotesData     = parseNotesData(myNotes);
      homeDataLoaded  = true;

      // Reconcile embed tiles before render so deleted docs disappear cleanly
      syncEmbedTiles();

      renderTasks();
      renderSchedule();
      renderLinks();
      renderCountdowns();
      renderNotesWidget();

      // Schedule refreshes itself every 10 minutes (handles bell-schedule changes)
      registerAutoRefresh('schedule', refreshScheduleData, 10);
    })
    .withFailureHandler(function(){
      // Fallback path: four separate calls when getHomeData fails
      google.script.run.withSuccessHandler(function(ts){ myTasks    = ts || [];          renderTasks();          }).getMyTasks();
      google.script.run.withSuccessHandler(function(r){  mySchedule = r.schedule || [];  renderSchedule();       }).getMySchedule();
      google.script.run.withSuccessHandler(function(r){  myNotes    = r.notes || '';     myNotesData = parseNotesData(myNotes); renderNotesWidget(); }).getMyNotes();
      google.script.run.withSuccessHandler(function(r){  myLinks    = r.links || [];     renderLinks();          }).getMyLinks();
      renderCountdowns();
    })
    .getHomeData();
}

// Auto-refresh the schedule widget — called every 10 min by the
// auto-refresh runner. Uses today's date string to fetch the current
// bell schedule + day type. Only re-renders if the schedule widget is visible.
function refreshScheduleData(){
  var today = new Date();
  var ds    = today.getFullYear() + '-'
            + String(today.getMonth() + 1).padStart(2, '0') + '-'
            + String(today.getDate()).padStart(2, '0');
  google.script.run.withSuccessHandler(function(r){
    if (!r) return;
    mySchedule    = r.schedule      || [];
    bellSchedules = r.bellSchedules || [];
    activeBell    = r.activeBell    || null;
    if (prefs.tileOrder.indexOf('schedule') > -1) renderSchedule();
    hideWidgetLoader('schedule');
  }).withFailureHandler(function(){
    hideWidgetLoader('schedule');
  }).getMyScheduleWithBell(ds);
}

