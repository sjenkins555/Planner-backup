      + '</div>';
    return '<div class="card"><div class="card-top"><div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#w-weather"/></svg> Weather</div></div>' + vtabs + '<div id="weather-body">' + renderWeatherInit() + '</div></div>';
  },

  // ── QUOTE ── populated by newQuote() on render
  quote: function(){
    return '<div class="card"><div class="card-top"><div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#w-quote"/></svg> Daily Quote</div><button class="btn btn-ghost btn-sm" onclick="newQuote()">New</button></div><div id="quote-body" class="quote-body"></div></div>';
  },

  // ── TIMER ── two-tab (countdown + stopwatch); body filled by renderTimerBody
  timer: function(){
    return '<div class="card"><div class="card-top"><div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#w-timer"/></svg> Timer</div></div><div class="timer-tabs"><button class="timer-tab-btn active" id="tt-timer" onclick="setTimerMode(\'timer\')">Countdown</button><button class="timer-tab-btn" id="tt-sw" onclick="setTimerMode(\'stopwatch\')">Stopwatch</button></div><div id="timer-widget-body"></div></div>';
  },

  // ── SEARCH ── Google search input + quicklink shortcuts
  search: function(){
    return '<div class="card"><div class="card-top"><div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#w-search"/></svg> Google Search</div></div><div style="display:flex;gap:8px;margin-bottom:12px;"><input class="finp" id="gsearch-inp" placeholder="Search Google..." style="flex:1;" onkeydown="if(event.key===\'Enter\')doGSearch()"><button class="btn btn-primary" onclick="doGSearch()">Go</button></div><div style="display:flex;gap:6px;flex-wrap:wrap;"><a href="https://www.khanacademy.org" target="_blank" class="btn btn-ghost btn-sm">Khan Academy</a><a href="https://www.youtube.com" target="_blank" class="btn btn-ghost btn-sm">YouTube</a><a href="https://www.wikipedia.org" target="_blank" class="btn btn-ghost btn-sm">Wikipedia</a></div></div>';
  },

  // ── GAPPS ── 6 quicklinks to Google products
