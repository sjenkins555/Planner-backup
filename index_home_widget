// Render the notes tab bar + textarea content. If the active tab no
// longer exists (e.g. user just deleted it), fall back to the first tab.
function renderNotesWidget(){
  var tabBar = document.getElementById('notes-tab-bar');
  var ta     = document.getElementById('notes-ta');
  if (!tabBar) return;

  var tabs      = prefs.notesTabs || [{id:'default', name:'Notes', color:'#6366f1'}];
  var activeTab = prefs.notesActiveTab || 'default';
  if (!tabs.find(function(t){ return t.id === activeTab; })){
    activeTab = tabs[0].id;
    prefs.notesActiveTab = activeTab;
  }

  tabBar.innerHTML = tabs.map(function(t){
    var a = t.id === activeTab;
    return '<div class="wtab' + (a ? ' active' : '') + '" style="' + (a ? 'background:' + t.color + ';border-color:' + t.color + ';' : '') + '" onclick="switchNoteTab(\'' + t.id + '\')">'
      + '<div class="wtab-dot" style="background:' + (a ? 'rgba(255,255,255,.7)' : t.color) + ';"></div>' + esc(t.name)
      + '</div>';
  }).join('') + '<div class="wtab-edit-btn" onclick="flipWidget(\'notes\')" title="Manage tabs">&#9998;</div>';

  if (ta) ta.value = myNotesData[activeTab] || '';
}

// Parse the serialized notes blob. New format is JSON with _v=2 + a tabs map;
// legacy format is a plain string that becomes the 'default' tab's body.
function parseNotesData(raw){
  if (!raw) return {default:''};
  try {
    var p = JSON.parse(raw);
    if (p && p._v === 2 && p.tabs) return p.tabs;
  } catch(e){}
  return {default:raw};
}

// Switch the active notes tab. Saves the current tab's textarea value
// into myNotesData first so we don't lose unsaved edits.
function switchNoteTab(id){
  var ta = document.getElementById('notes-ta');
  if (ta) myNotesData[prefs.notesActiveTab || 'default'] = ta.value;
  prefs.notesActiveTab = id;
  renderNotesWidget();
}


