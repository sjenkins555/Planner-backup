}

// Optimistically delete a task — remove locally, post to server,
// roll back if server fails.
function removeTask(id){
  var removed = myTasks.filter(function(t){ return t.id === id; });
  myTasks = myTasks.filter(function(t){ return t.id !== id; });
  renderTasks();
  google.script.run.withSuccessHandler(function(){
    toast('Removed', 'inf');
  }).withFailureHandler(function(){
    myTasks = myTasks.concat(removed);
    renderTasks();
    toast('Error removing task', 'err');
  }).deleteTask(id);
}

// Add task via the modal form (m-tt, m-ts, m-td, m-tp, m-tn, m-tr).
// Optimistically inserts with a temp id; replaces with server id on success.
// If the modal had a reminder time set, creates a linked reminder too.
function doAddTask(){
  var title = document.getElementById('m-tt').value.trim();
  if (!title){ toast('Enter a title', 'err'); return; }
  var subject  = document.getElementById('m-ts').value.trim();
  var due      = document.getElementById('m-td').value;
  var priority = document.getElementById('m-tp').value;
  var notes    = document.getElementById('m-tn').value.trim();
  var remindAt = (document.getElementById('m-tr') || {}).value || '';

  closeModal('task-modal');
  var tempId = 'tmp-' + Date.now();
  myTasks.unshift({id:tempId, title:title, subject:subject, dueDate:due, priority:priority, status:'pending', notes:notes, assignedBy:CU.email});
  renderTasks();

  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      // Swap temp id for real server id
      for (var i = 0; i < myTasks.length; i++){
        if (myTasks[i].id === tempId){ myTasks[i].id = r.id; break; }
      }
      // If we're on a non-default list, map this task to it
      if (prefs.taskActiveList && prefs.taskActiveList !== 'default'){
        if (!prefs.taskListMap) prefs.taskListMap = {};
        prefs.taskListMap[r.id] = prefs.taskActiveList;
        google.script.run.saveMyPrefs(JSON.stringify(prefs));
      }
      renderTasks();
      toast('Task added', 'ok');
      // Linked reminder — fires at remindAt time, mentions subject/notes
      if (remindAt){
        var remISO = new Date(remindAt).toISOString();
        var bodyMsg = subject ? ('For ' + subject) : (notes || '');
        google.script.run.addMyReminder(title, bodyMsg, remISO, r.id, subject || '');
      }
    } else {
      // Roll back the optimistic insert
      myTasks = myTasks.filter(function(t){ return t.id !== tempId; });
      renderTasks();
      toast('Error saving task', 'err');
    }
  }).addMyTask(title, subject, due, priority, notes);
}

// Inline edit a task — replace its row with an editor form.
// Calling editTask on the currently-editing task cancels instead.
function editTask(id){
  if (editingTaskId === id){ cancelEditTask(); return; }
  cancelEditTask();
  editingTaskId = id;

  var task = null;
  for (var i = 0; i < myTasks.length; i++){
    if (myTasks[i].id === id){ task = myTasks[i]; break; }
  }
  if (!task) return;

  var row = document.getElementById('tr-' + id);
  if (!row) return;

  var priOpts  = ['high','medium','low'].map(function(p){ return '<option value="' + p + '"' + (task.priority === p ? ' selected' : '') + '>' + p.charAt(0).toUpperCase() + p.slice(1) + '</option>'; }).join('');
  var subjOpts = buildSubjectDropdownOptions(task.subject || '');
  row.innerHTML = '<div class="task-edit-form">'
    + '<input class="finp" id="te-title" value="' + esc(task.title) + '" style="font-size:13px;">'
    + '<div class="task-edit-row2">'
    +   '<select class="fsel" id="te-subj" style="font-size:12px;">' + subjOpts + '</select>'
    +   '<select class="fsel" id="te-pri" style="font-size:12px;">' + priOpts + '</select>'
    + '</div>'
    + '<input type="date" class="finp" id="te-due" value="' + (task.dueDate || '') + '" style="font-size:12px;">'
    + '<textarea class="finp" id="te-notes" placeholder="—Notes—" style="min-height:48px;resize:none;font-size:12px;">' + esc(task.notes || '') + '</textarea>'
    + '<div style="display:flex;gap:6px;justify-content:flex-end;">'
    +   '<button class="btn btn-ghost btn-sm" onclick="cancelEditTask()">Cancel</button>'
    +   '<button class="btn btn-primary btn-sm" onclick="saveEditTask(\'' + id + '\')">Save</button>'
    + '</div>'
    + '</div>';
  var te = document.getElementById('te-title');
  if (te) te.focus();
}

// Cancel inline task editing — reset state and re-render.
function cancelEditTask(){
  editingTaskId = null;
  renderTasks();
}

// Save inline task edits — update local + server.
function saveEditTask(id){
  var t = ((document.getElementById('te-title') || {}).value || '').trim();
  if (!t){ toast('Title required', 'err'); return; }
  var s = ((document.getElementById('te-subj')  || {}).value || '').trim();
  var p = (document.getElementById('te-pri')   || {}).value || 'medium';
  var d = (document.getElementById('te-due')   || {}).value || '';
  var n = ((document.getElementById('te-notes') || {}).value || '').trim();

  for (var i = 0; i < myTasks.length; i++){
    if (myTasks[i].id === id){
      myTasks[i].title    = t;
      myTasks[i].subject  = s;
      myTasks[i].priority = p;
      myTasks[i].dueDate  = d;
      myTasks[i].notes    = n;
      break;
    }
  }
  editingTaskId = null;
  renderTasks();
  google.script.run.withSuccessHandler(function(r){
    if (r && r.success) toast('Task updated', 'ok');
    else                 toast('Error', 'err');
  }).updateTask(id, t, s, d, p, n);
}

// Save handler for the flip-back add-task form. Differs from doAddTask:
// it's called from the widget's flip back, not the modal. Has an "also
// add to Google Calendar" checkbox that opens a synchronous calendar
// URL (must run in click event so popup blocker doesn't kill it).
function flipSaveTask(){
  var title    = document.getElementById('flip-task-title');
  var titleVal = title ? title.value.trim() : '';
  if (!titleVal){ toast('Enter a title', 'err'); return; }
  // Easter egg: science-mode trigger
  if (checkScienceTrigger(titleVal)){ activateScienceMode(); }

  var subj   = document.getElementById('flip-task-subj');
  var pri    = document.getElementById('flip-task-pri');
  var due    = document.getElementById('flip-task-due');
  var calCb  = document.getElementById('flip-task-cal');
  var subjVal = subj ? subj.value.trim() : '';
  var priVal  = pri  ? pri.value          : 'medium';
  var dueVal  = due  ? due.value          : '';
  var addCal  = calCb ? calCb.checked     : false;

  // IMPORTANT: open the calendar URL synchronously inside the click handler
  // so popup blockers don't kill it. Look up the class's start/end times so
  // it becomes a timed event instead of all-day.
  if (addCal){
    var classTimes = findClassTimesForSubject(subjVal, dueVal);
    openCalendarEvent(titleVal, dueVal, subjVal ? 'Subject: ' + subjVal : '', null, classTimes);
  }

  unflipWidget('tasks');

  // Optimistic insert + replace temp id pattern (same as doAddTask)
  var tempId = 'tmp-' + Date.now();
  myTasks.unshift({id:tempId, title:titleVal, subject:subjVal, dueDate:dueVal, priority:priVal, status:'pending', notes:'', assignedBy:CU.email});
  renderTasks();

  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      for (var i = 0; i < myTasks.length; i++){
        if (myTasks[i].id === tempId){ myTasks[i].id = r.id; break; }
      }
      if (prefs.taskActiveList && prefs.taskActiveList !== 'default'){
        if (!prefs.taskListMap) prefs.taskListMap = {};
        prefs.taskListMap[r.id] = prefs.taskActiveList;
        google.script.run.saveMyPrefs(JSON.stringify(prefs));
      }
      renderTasks();
      toast('Task added', 'ok');
    } else {
      myTasks = myTasks.filter(function(t){ return t.id !== tempId; });
      renderTasks();
      toast('Error saving task', 'err');
    }
  }).addMyTask(titleVal, subjVal, dueVal, priVal, '');
}

// Easter egg trigger: if any active task is titled exactly "put emojis
// everywhere", flip body class and re-paint widgets so icons swap to emojis.
// Marking that task complete turns the mode off again.
function checkEmojiEasterEgg(){
  var wasOn  = _emojiMode;
  var active = myTasks.some(function(t){
    return t.status !== 'completed' && t.status !== 'deleted'
        && String(t.title || '').trim().toLowerCase() === 'put emojis everywhere';
  });
  _emojiMode = active;

  if (wasOn !== active){
    document.body.classList.toggle('emoji-mode', active);
    if (active) toast('🎉 Emoji mode ON — mark task complete to turn off', 'inf');
    else        toast('Emoji mode off', 'inf');
    // Re-render so icon helpers (emo) pick up the new mode
    var hp = document.getElementById('tp-home') || document.getElementById('tp-my-home');
    if (hp && homeDataLoaded) reloadHomeWidgets();
  }
}

// Returns an emoji char (when emoji-mode is on) or an inline SVG icon ref.
// Used by widgets that want to swap their icons in emoji mode.
function emo(char, fallbackSvgId){
  if (_emojiMode && char) return char;
  if (fallbackSvgId)      return '<svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#' + fallbackSvgId + '"/></svg>';
  return '';
}

