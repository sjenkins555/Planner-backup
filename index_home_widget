// Apply selected bell schedule's period times to the schedule editor's
// current rows by matching period numbers. Doesn't save — user still
// needs to click Save Schedule afterwards.
function doImportBellTimes(){
  var sel = document.getElementById('ibt-sel');
  var id  = sel ? sel.value : '';
