/* ═══════════════════════════════════════════════════════════════════
   12. TASKS WIDGET — all handlers
   Includes the easter-egg "emoji mode" trigger (a task titled
   "put emojis everywhere") and the science-mode trigger.
   ═══════════════════════════════════════════════════════════════════ */

// Render the tasks list with current sort, list filter, and emoji-mode check.
// Splits into pending + done; both sorted by the chosen mode.
function renderTasks(){
  checkEmojiEasterEgg();
  renderTaskTabBar();

  var el = document.getElementById('task-area');
  if (!el) return;

  // Filter by active list — 'default' shows everything
  var activeList = prefs.taskActiveList || 'default';
  var listMap    = prefs.taskListMap    || {};
  var filtered   = myTasks.filter(function(t){ return activeList === 'default' || (listMap[t.id] === activeList); });

  if (!filtered.length){
    el.innerHTML = '<div class="empty"><p>' + (activeList === 'default' ? 'All clear!' : 'No tasks in this list.') + '</p></div>';
    return;
  }

  var pend = filtered.filter(function(t){ return t.status !== 'completed'; });
  var done = filtered.filter(function(t){ return t.status === 'completed'; });

  // Sort comparator — varies by prefs.taskSort
  var mode = prefs.taskSort || 'default';
  var PRI  = {high:0, medium:1, low:2};
  function sortFn(a, b){
    if (mode === 'duedate'){
      // No-due-date tasks sink to the bottom
      if (!a.dueDate && b.dueDate) return  1;
      if ( a.dueDate && !b.dueDate) return -1;
      if (!a.dueDate && !b.dueDate) return  0;
      return new Date(a.dueDate) - new Date(b.dueDate);
    }
    if (mode === 'subject'){
      // Use 'zzz' as a sort sentinel so blanks fall to the end
      return (a.subject || 'zzz').localeCompare(b.subject || 'zzz');
    }
    if (mode === 'dateadded'){
      // Newest first — sort by reverse position in myTasks (newer is unshifted, so lower index = newer)
      return (myTasks.indexOf(b) - myTasks.indexOf(a));
    }
    if (mode === 'alpha'){
      return (a.title || '').localeCompare(b.title || '');
    }
    // Default: priority high→low, then due date earliest first
    var p = (PRI[a.priority] || 1) - (PRI[b.priority] || 1);
    if (p !== 0) return p;
    if (!a.dueDate && b.dueDate) return  1;
    if ( a.dueDate && !b.dueDate) return -1;
    if ( a.dueDate && b.dueDate) return new Date(a.dueDate) - new Date(b.dueDate);
    return 0;
  }
  pend.sort(sortFn);
  done.sort(sortFn);

  el.innerHTML = '<div class="task-list">' + pend.concat(done).map(taskRow).join('') + '</div>';
}

// Render a single task row. Shows priority dot, title, subject pill,
// due-date pill (red if overdue), assigned-by pill, edit + delete buttons.
function taskRow(t){
  var today = new Date().toISOString().slice(0, 10);
  var ov    = t.dueDate && t.dueDate < today && t.status !== 'completed';
  return '<div class="task-row' + (t.status === 'completed' ? ' done' : '') + '" id="tr-' + t.id + '">'
    + '<button class="chk" onclick="toggleTask(\'' + t.id + '\',\'' + t.status + '\')"> ' + (t.status === 'completed' ? '&#10003;' : '') + '</button>'
    + '<div class="dot ' + t.priority + '"></div>'
    + '<div class="task-body">'
    +   '<div class="task-title">' + esc(t.title) + '</div>'
    +   '<div class="task-sub">'
    +     (t.subject ? '<span class="tchip">' + esc(t.subject) + '</span>' : '')
    +     (t.dueDate ? '<span class="tchip' + (ov ? ' overdue' : '') + '">' + (ov ? '&#9888; ' : '') + fmtDate(t.dueDate) + '</span>' : '')
    +     (t.assignedBy && t.assignedBy !== CU.email ? '<span class="tchip assigned">Assigned</span>' : '')
    +   '</div>'
    + '</div>'
    + '<button class="del-btn" onclick="editTask(\'' + t.id + '\')" title="Edit" style="font-size:14px;">&#9998;</button>'
    + '<button class="del-btn" onclick="removeTask(\'' + t.id + '\')">&#10005;</button>'
    + '</div>';
}

// Toggle a task between pending and completed. Updates locally first
// for snappy UI, then persists. No rollback on failure (intentional —
// errors here are rare and the next refresh would reconcile).
function toggleTask(id, cur){
  var next = cur === 'completed' ? 'pending' : 'completed';
  for (var i = 0; i < myTasks.length; i++){
    if (myTasks[i].id === id){ myTasks[i].status = next; break; }
  }
  renderTasks();
  google.script.run.setTaskStatus(id, next);
}

