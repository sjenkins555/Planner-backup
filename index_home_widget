/* ═══════════════════════════════════════════════════════════════════
   1. PAGE BUILDER
   ═══════════════════════════════════════════════════════════════════ */

// Build the Home tab. Teachers see it under #my-home, students under #home.
// Lays out an empty tile grid, then renders tiles. If home data was already
// loaded (warm path), re-renders directly; otherwise kicks off the load.
function buildHomePage(){
  var pid = CU.role === 'teacher' ? 'my-home' : 'home';
  panel(pid).innerHTML = '<div class="tile-grid" id="tile-grid"></div>';
  renderTileGrid();
  if (homeDataLoaded){
    renderTasks();
    renderSchedule();
    renderLinks();
    renderCountdowns();
    renderNotesWidget();
  } else {
    loadHomeData();
  }
}


/* ═══════════════════════════════════════════════════════════════════
   2. TILE GRID RENDERER
   Walks prefs.tileOrder and emits one .tile per id. Each tile has a
   minimize bar, a gear (opens flip-back), and a card-shell with a
   front face (WIDGET_HTML[id]()) and a back face (filled lazily by
   flipWidget / flipToCustomize). Wires up the notes auto-save handler
   here too because that's the only widget with a textarea on the front.
   ═══════════════════════════════════════════════════════════════════ */

// Render every tile in prefs.tileOrder into #tile-grid. Triggers any
// per-widget loaders that need to fire after the shells are on screen
// (timer, weather, lunch, scores, etc.). Wires the notes auto-save.
function renderTileGrid(){
  var grid = document.getElementById('tile-grid');
  if (!grid) return;
  var order = prefs.tileOrder || ['clock','schedule','tasks','notes','links'];
  var positions = prefs.tilePositions || {};

  // Auto-assign positions to any widgets that don't have one yet (legacy migration)
  // Walks the grid row-by-row finding the first empty slot that fits.
  var occupied = {};
  function isFree(c, r, cs, rs){
    for (var dc = 0; dc < cs; dc++){
      for (var dr = 0; dr < rs; dr++){
        if (occupied[(c+dc) + ',' + (r+dr)]) return false;
        if (c + dc > 4) return false;
      }
    }
    return true;
  }
  function markOccupied(c, r, cs, rs){
    for (var dc = 0; dc < cs; dc++){
      for (var dr = 0; dr < rs; dr++){
        occupied[(c+dc) + ',' + (r+dr)] = true;
      }
    }
  }

  // First pass: register existing positions
  order.forEach(function(id){
    var pos = positions[id];
    if (pos){
      var defSz = id.startsWith('embed-') ? DEF_TILE_SIZES['embed'] : DEF_TILE_SIZES[id];
      var sz = Object.assign({}, defSz || {c:2,r:1}, (prefs.tileSizes && prefs.tileSizes[id]) || {});
      markOccupied(pos.col, pos.row, sz.c, sz.r);
    }
  });

  // Second pass: place anything missing a position
  var dirty = false;
  order.forEach(function(id){
    if (positions[id]) return;
    var defSz = id.startsWith('embed-') ? DEF_TILE_SIZES['embed'] : DEF_TILE_SIZES[id];
    var sz = Object.assign({}, defSz || {c:2,r:1}, (prefs.tileSizes && prefs.tileSizes[id]) || {});
    for (var r = 1; r <= 20; r++){
      for (var c = 1; c <= 4 - sz.c + 1; c++){
        if (isFree(c, r, sz.c, sz.r)){
          positions[id] = {col:c, row:r};
          markOccupied(c, r, sz.c, sz.r);
          dirty = true;
          c = 99; r = 99;
        }
      }
    }
  });
  if (dirty){
    prefs.tilePositions = positions;
    google.script.run.saveMyPrefs(JSON.stringify(prefs));
  }

  grid.innerHTML = order.map(function(id){
    var wh = '';
    try {
      if (id.startsWith('embed-')){ wh = renderEmbedWidgetHTML(id); }
      else { wh = WIDGET_HTML[id] ? WIDGET_HTML[id]() : ''; }
    } catch(e){
      wh = '<div class="card"><div style="color:#ef4444;font-size:12px;">Widget error: ' + e.message + '</div></div>';
    }

    var isMin = prefs.minimizedWidgets && prefs.minimizedWidgets.indexOf(id) > -1;

    var wlabel;
    if (id.startsWith('embed-')){
      var _ed = null;
      for (var _ei = 0; _ei < myEmbeddedDocs.length; _ei++){
        if (myEmbeddedDocs[_ei].id === id.replace('embed-','')) _ed = myEmbeddedDocs[_ei];
      }
      wlabel = '&#128203; ' + (_ed ? esc(_ed.title) : 'Document');
    } else {
      var wdef = null;
      for (var wi = 0; wi < ALL_WIDGETS.length; wi++){
        if (ALL_WIDGETS[wi].id === id){ wdef = ALL_WIDGETS[wi]; break; }
      }
      wlabel = wdef ? wdef.icon + ' ' + wdef.name : id;
    }

    var defSz = id.startsWith('embed-') ? DEF_TILE_SIZES['embed'] : DEF_TILE_SIZES[id];
    var sz = Object.assign({}, defSz || {c:2,r:1}, (prefs.tileSizes && prefs.tileSizes[id]) || {});
    var colSpan = Math.min(Math.max(sz.c || 2, 1), 4);
    var rowSpan = Math.min(Math.max(sz.r || 1, 1), 3);
    var minH = (rowSpan * 160) + ((rowSpan - 1) * 14);
    var pos = positions[id] || {col:1, row:1};

    return '<div class="tile' + (isMin ? ' minimized' : '') + '" id="tile-' + id + '" draggable="true" data-tile="' + id
      + '" style="grid-column:' + pos.col + ' / span ' + colSpan + ';grid-row:' + pos.row + ' / span ' + rowSpan + ';min-height:' + minH + 'px;">'
      + '<div class="tile-min-bar" onclick="toggleMinimize(\'' + id + '\')">' + wlabel + '</div>'
      + '<div class="min-btn" onclick="toggleMinimize(\'' + id + '\')" title="' + (isMin ? 'Expand' : 'Collapse') + '"><svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + (isMin ? '<path d="M3 10l5-5 5 5"/>' : '<path d="M3 6l5 5 5-5"/>') + '</svg></div>'
      + '<div class="tile-gear" onclick="flipToCustomize(\'' + id + '\')" title="Widget settings"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="8" cy="8" r="2"/><path d="M8 2v1.5M8 12.5V14M14 8h-1.5M3.5 8H2M12.2 3.8l-1 1M4.8 11.2l-1 1M12.2 12.2l-1-1M4.8 4.8l-1-1"/></svg></div>'
      + '<div class="card-shell">'
      +   '<div class="face face-front">' + wh + '</div>'
      +   '<div class="face face-back" id="tb-' + id + '"></div>'
      + '</div>'
      + '</div>';
  }).join('');

  if (order.indexOf('quote')        > -1) newQuote();
  if (order.indexOf('timer')        > -1) renderTimerBody();
  if (order.indexOf('weather')      > -1) loadWeather();
  if (order.indexOf('countdowns')   > -1) renderCountdowns();
  if (order.indexOf('lunch')        > -1) loadLunchMenu();
  if (order.indexOf('scores')       > -1) setTimeout(renderScoresChart, 80);
  if (order.indexOf('rowbank')      > -1) loadMyRows();
  if (order.indexOf('reminders')    > -1) loadReminders();

  var ta = document.getElementById('notes-ta');
  if (ta) ta.addEventListener('input', function(){
    clearTimeout(notesTimer);
    var lbl = document.getElementById('save-lbl');
    if (lbl) lbl.textContent = 'Saving...';
    notesTimer = setTimeout(function(){
      var activeTab = prefs.notesActiveTab || 'default';
      myNotesData[activeTab] = ta.value;
      myNotes = serializeNotesData(myNotesData);
      google.script.run.withSuccessHandler(function(){
        var l = document.getElementById('save-lbl');
        if (l){ l.textContent = 'Saved'; setTimeout(function(){ if (l) l.textContent = ''; }, 2000); }
      }).saveMyNotes(myNotes);
    }, 900);
  });

  applyAllWidgetStyles();
  initDragDrop();
}

// Reconcile embed tiles against the current myEmbeddedDocs list. Removes
// embed tiles whose docs no longer exist; intentionally does NOT auto-add
// new ones (the user picks them via the "+ Add Widgets" picker).
function syncEmbedTiles(){
  var validIds = myEmbeddedDocs.map(function(d){ return 'embed-' + d.id; });
  var before = JSON.stringify(prefs.tileOrder);
  prefs.tileOrder = prefs.tileOrder.filter(function(t){
    return !t.startsWith('embed-') || validIds.indexOf(t) > -1;
  });
  if (JSON.stringify(prefs.tileOrder) !== before){
    google.script.run.saveMyPrefs(JSON.stringify(prefs));
    reloadHomeWidgets();
  }
}


/* ═══════════════════════════════════════════════════════════════════
   3. TILE SIZE PICKER
   Floating popup over the gear icon with a 4×2 grid of size choices.
   Anchored to the tile's bottom-right corner with viewport clamping.
   ═══════════════════════════════════════════════════════════════════ */

// Open the size picker for a home tile. Clicking the same gear twice
// closes the popup. Click outside also closes.
function openSzPicker(id, evt){
  evt.stopPropagation();
  var old = document.getElementById('sz-pop');
  if (old){ old.remove(); if (old.dataset.wid === id) return; }

  var cur = Object.assign({}, DEF_TILE_SIZES[id] || {c:2, r:1}, (prefs.tileSizes && prefs.tileSizes[id]) || {});

  var pop = document.createElement('div');
  pop.id = 'sz-pop';
  pop.dataset.wid = id;
  pop.className = 'sz-pop';
  var html = '<div class="sz-pop-title">Size (cols \u00d7 rows)</div><div class="sz-grid">';
  for (var r = 1; r <= 2; r++){
    for (var c = 1; c <= 4; c++){
      var isSel = (c === cur.c && r === cur.r) ? ' sel' : '';
      html += '<div class="sz-cell' + isSel + '" onclick="pickSz(\'' + id + '\',' + c + ',' + r + ')">' + c + '\u00d7' + r + '</div>';
    }
  }
  html += '</div>';
  pop.innerHTML = html;
  document.body.appendChild(pop);

  // Anchor to the tile's bottom-right corner, clamped to viewport
  var tile  = document.getElementById('tile-' + id);
  var tRect = tile ? tile.getBoundingClientRect() : {top:100, bottom:300, left:100, right:400};
  var popW = 215, popH = 152;
  var left = tRect.right - popW - 14;
  var top  = tRect.bottom - popH - 44;
  if (left < tRect.left + 8) left = tRect.left + 8;
  if (top  < tRect.top  + 8) top  = tRect.top  + 8;
  if (left + popW > window.innerWidth  - 8) left = window.innerWidth  - popW - 8;
  if (top  + popH > window.innerHeight - 8) top  = window.innerHeight - popH - 8;
  if (left < 8) left = 8;
  if (top  < 8) top  = 8;
  pop.style.top  = top  + 'px';
  pop.style.left = left + 'px';

  // Click-outside-to-close
  setTimeout(function(){
    function away(e){ if (!pop.contains(e.target)){ pop.remove(); document.removeEventListener('click', away); } }
    document.addEventListener('click', away);
  }, 10);
}

// Apply a picked size — update prefs, mutate the tile's grid spans in
// place (avoids a full re-render), and sync the size grid inside the
// flipped style panel if it's currently open.
function pickSz(id, cols, rows){
  if (!prefs.tileSizes) prefs.tileSizes = {};
  prefs.tileSizes[id] = {c:cols, r:rows};

  var tile = document.getElementById('tile-' + id);
  if (tile){
    var minH = (rows * 160) + ((rows - 1) * 14);
    tile.style.gridColumn = 'span ' + cols;
    tile.style.gridRow    = 'span ' + rows;
    tile.style.minHeight  = minH + 'px';
  }

  var pop = document.getElementById('sz-pop');
  if (pop) pop.remove();

  // Sync the size grid inside the back panel so the highlight stays consistent
  var back = document.getElementById('tb-' + id);
  if (back && back.querySelector('.style-sz-grid')){
    back.querySelectorAll('.style-sz-cell').forEach(function(el){ el.classList.remove('sel'); });
    back.querySelectorAll('.style-sz-cell').forEach(function(el){
      if (el.textContent === cols + '\u00d7' + rows) el.classList.add('sel');
    });
  }

  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}


/* ═══════════════════════════════════════════════════════════════════
   4. RELOAD HELPER
   Re-render the home tile grid while preserving the in-memory data so
   widgets re-attach their handlers without losing state.
   ═══════════════════════════════════════════════════════════════════ */

// Re-render the entire home grid — used after layout changes (drag-drop,
// add/remove widget, theme change). Snapshot data first because
// renderTileGrid rebuilds from scratch and would lose mid-edit values.
function reloadHomeWidgets(){
  var hp = document.getElementById('tp-home') || document.getElementById('tp-my-home');
  if (!hp) return;

  // Snapshot before re-render
  var sv = {
    tasks:     myTasks.slice(),
    links:     myLinks.slice(),
    sched:     mySchedule.slice(),
    notes:     myNotes,
    notesData: Object.assign({}, myNotesData)
  };

  renderTileGrid();

  // Restore + re-render widgets that need it
  myTasks     = sv.tasks;
  myLinks     = sv.links;
  mySchedule  = sv.sched;
  myNotes     = sv.notes;
  myNotesData = sv.notesData || {};

  renderTasks();
  renderSchedule();
  renderLinks();
  renderCountdowns();
  renderNotesWidget();
  if (prefs.tileOrder.indexOf('weather') > -1) loadWeather();
}


/* ═══════════════════════════════════════════════════════════════════
   5. WIDGET_HTML REGISTRY
   The front-face HTML factory for every widget. Each function returns
   an HTML string that gets injected into a tile's .face-front div.
   These are PURE markup — no event listeners are attached here. Inline
   onclick handlers wire up to global functions further down the file.
   ═══════════════════════════════════════════════════════════════════ */

var WIDGET_HTML = {
  // ── CLOCK ── 4 styles: digital, analog, minimal, word.
  // Time text is filled later by tickClock (defined in another chunk).
  clock: function(){
    var s   = prefs.clockStyle || 'digital';
    var now = new Date();
    var d   = DAYS[now.getDay()].toUpperCase();
    var dt  = MONTHS[now.getMonth()] + ' ' + now.getDate() + ', ' + now.getFullYear();
    var ds  = MONTHS[now.getMonth()] + ' ' + now.getDate();
    var inn = '';
    if (s === 'digital')      inn = '<div class="clock-card clk-digital"><div class="clk-day">' + d + '</div><div class="clk-time" id="clk-main">--:--:--</div><div class="clk-date">' + dt + '</div></div>';
    else if (s === 'analog')  inn = '<div class="clock-card"><div style="text-align:center;font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--a1);margin-bottom:8px;">' + d + '</div><div class="clk-analog"><svg id="analog-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" width="160" height="160"></svg></div><div style="color:var(--tx3);font-size:13px;text-align:center;margin-top:8px;">' + ds + '</div></div>';
    else if (s === 'minimal') inn = '<div class="clock-card clk-minimal"><div style="font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--a1);margin-bottom:10px;">' + d + '</div><div class="clk-time" id="clk-main">--</div><div class="clk-date">' + dt + '</div></div>';
    else if (s === 'word')    inn = '<div class="clock-card"><div style="font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--a1);margin-bottom:14px;">' + d + ' — ' + ds + '</div><div class="clk-word" id="clk-main"></div></div>';
    return '<div style="padding:0;background:transparent;border:none;height:100%;display:flex;flex-direction:column;">' + inn + '</div>';
  },

  // ── SCHEDULE ── delegates to schedCard helper
  schedule: function(){ return schedCard(); },

  // ── TASKS ── header with sort dropdown + add button, then tab bar
  // and task area. Sort options sync to prefs.taskSort.
  tasks: function(){
    var sortOpts = [['default','Priority'], ['duedate','Due Date'], ['subject','Subject'], ['dateadded','Date Added'], ['alpha','A–Z']];
    var curSort  = prefs.taskSort || 'default';
    var selHtml  = sortOpts.map(function(o){ return '<option value="' + o[0] + '"' + (curSort === o[0] ? ' selected' : '') + '>Sort: ' + o[1] + '</option>'; }).join('');
    return '<div class="card"><div class="card-top"><div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#w-todo"/></svg> To-Do List</div><div style="display:flex;gap:5px;align-items:center;"><select class="fsel" onchange="setTaskSort(this.value)" style="font-size:11px;padding:4px 8px;width:auto;">' + selHtml + '</select><button class="btn btn-primary btn-sm" onclick="flipWidget(\'tasks\')" title="Add task" style="padding:4px 10px;font-size:11px;">+ Add</button></div></div><div class="wtab-bar" id="task-tab-bar"></div><div id="task-area"><div class="empty"><p>All clear!</p></div></div></div>';
  },

  // ── NOTES ── textarea + tab bar, autosaves on input
  notes: function(){
    return '<div class="card"><div class="card-top"><div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#w-notes"/></svg> Notes</div><span class="save-lbl" id="save-lbl"></span></div><div class="wtab-bar" id="notes-tab-bar"></div><textarea id="notes-ta" placeholder="Jot anything here..."></textarea></div>';
  },

  // ── LINKS ── empty container; populated by renderLinks
  links: function(){
    return '<div class="card"><div class="card-top"><div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#w-link"/></svg> My Links</div></div><div id="links-area"><div class="empty"><p>No links yet.</p></div></div></div>';
  },

  // ── COUNTDOWNS ── empty container; populated by renderCountdowns
  countdowns: function(){
    return '<div class="card"><div class="card-top"><div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="#w-countdown"/></svg> Countdowns</div></div><div id="cd-area"><div class="empty"><p>No countdowns yet.</p></div></div></div>';
  },

  // ── WEATHER ── view-switcher tabs (today/5day/10day) + loading shell
  weather: function(){
    var vw = prefs.weatherView || 'today';
    var vtabs = '<div style="display:flex;gap:4px;margin-bottom:10px;">'
      + '<button class="btn btn-sm weather-vbtn ' + (vw === 'today' ? 'btn-primary' : 'btn-ghost') + '" data-view="today" onclick="setWeatherView(this.dataset.view)">Today</button>'
      + '<button class="btn btn-sm weather-vbtn ' + (vw === '5day'  ? 'btn-primary' : 'btn-ghost') + '" data-view="5day"  onclick="setWeatherView(this.dataset.view)">5-Day</button>'
