/* ═══════════════════════════════════════════════════════════════════
   7. TILE INTERACTIONS
   Flip-to-style (gear icon), unflip, minimize toggle, and the wrapper
   that re-applies all custom widget styles after a re-render.
   ═══════════════════════════════════════════════════════════════════ */

// User clicked a tile's gear → flip to style/customize panel.
// If the widget has both an Edit and Style tab, open Style by default.
function flipToCustomize(id){
  _flipMode[id] = 'style';
  var tile = document.getElementById('tile-' + id);
  if (!tile) return;
  var back = document.getElementById('tb-' + id);
  if (!back) return;
  back.innerHTML = buildBackPanel(id, 'style');
  tile.classList.add('flipped');
  setTimeout(function(){ attachStyleListeners(id); }, 10);
}

// Flip the back face away — used by Cancel buttons everywhere.
function unflipWidget(id){
  var tile = document.getElementById('tile-' + id);
  if (tile) tile.classList.remove('flipped');
}

// Toggle a widget's minimized state. Updates prefs, the tile's class,
// and the chevron direction on the minimize button.
function toggleMinimize(id){
  if (!prefs.minimizedWidgets) prefs.minimizedWidgets = [];
  var idx = prefs.minimizedWidgets.indexOf(id);
  if (idx > -1) prefs.minimizedWidgets.splice(idx, 1);
  else          prefs.minimizedWidgets.push(id);

  var tile = document.getElementById('tile-' + id);
  if (tile){
    var isMin = prefs.minimizedWidgets.indexOf(id) > -1;
    tile.classList.toggle('minimized', isMin);
    // Update the chevron: down arrow when expanded, up when minimized
    var btn = tile.querySelector('.min-btn');
    if (btn){
      btn.innerHTML = '<svg viewBox="0 0 16 16" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' + (isMin ? '<path d="M3 10l5-5 5 5"/>' : '<path d="M3 6l5 5 5-5"/>') + '</svg>';
      btn.title = isMin ? 'Expand' : 'Collapse';
    }
  }
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}

// Re-apply per-widget custom styles after a re-render.
function applyAllWidgetStyles(){
  (prefs.tileOrder || []).forEach(function(id){ applyWidgetStyle(id); });
}

