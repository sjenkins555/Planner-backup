// Delete a tab — works for both note tabs (type='note') and task lists (type='task').
// Refuses to delete the last tab. Cleans up associated data: note bodies for
// notes, taskListMap entries for tasks.
function deleteTabInline(type, id){
  if (type === 'note'){
    var tabs = prefs.notesTabs || [];
    if (tabs.length <= 1){ toast("Can't delete last tab", 'err'); return; }
    prefs.notesTabs = tabs.filter(function(t){ return t.id !== id; });
    if (prefs.notesActiveTab === id) prefs.notesActiveTab = prefs.notesTabs[0].id;
    delete myNotesData[id];
    myNotes = serializeNotesData(myNotesData);
    google.script.run.saveMyNotes(myNotes);
    var back = document.getElementById('tb-notes');
    if (back) back.innerHTML = WIDGET_BACK.notes();
  } else {
    var lists = prefs.taskLists || [];
    if (lists.length <= 1){ toast("Can't delete last list", 'err'); return; }
    prefs.taskLists = lists.filter(function(l){ return l.id !== id; });
    if (prefs.taskActiveList === id) prefs.taskActiveList = prefs.taskLists[0].id;
    // Strip taskListMap entries pointing to the deleted list
    if (prefs.taskListMap){
      Object.keys(prefs.taskListMap).forEach(function(k){
        if (prefs.taskListMap[k] === id) delete prefs.taskListMap[k];
      });
    }
    var back = document.getElementById('tb-tasks');
    if (back) back.innerHTML = WIDGET_BACK.tasks();
  }
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}


