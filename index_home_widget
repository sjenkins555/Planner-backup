/* ═══════════════════════════════════════════════════════════════════
   9. FLIP MECHANISM
   flipWidget opens the back face in Edit mode (default) — used by the
   "+ Add" buttons on widgets and by the tab edit pencils.
   flipToCustomize (defined in section 7) opens it in Style mode.
   buildBackPanel switches between tabbed (Edit + Style) and Style-only
   layouts based on HAS_EDIT_TAB membership.
   ═══════════════════════════════════════════════════════════════════ */

// Open a widget's back face in Edit mode. Used by + Add buttons.
function flipWidget(id, mode){
  _flipMode[id] = mode || 'default';
  var tile = document.getElementById('tile-' + id);
  if (!tile) return;
  var back = document.getElementById('tb-' + id);
  if (!back) return;
  back.innerHTML = buildBackPanel(id, 'edit');
  tile.classList.add('flipped');
}

// Build the back panel HTML. Two layouts:
//   - Tabbed (Edit | Style) for widgets in HAS_EDIT_TAB
//   - Style-only (no tabs) for everything else, wrapped in flip-back-card
//     so they share the same scrollable container + sticky footer
function buildBackPanel(id, activeTab){
  var hasEdit   = !!HAS_EDIT_TAB[id];
  var editHTML  = hasEdit && WIDGET_BACK[id] ? WIDGET_BACK[id]() : '';
  var styleHTML = buildStylePanelHTML(id);

  // Style-only path — non-tabbed widgets (Google Apps, Lunch, Search,
  // Quote, embedded docs, etc.). The flip-back-card wrapper is essential
  // here: without it the Settings panel overflows the tile and the user
  // can't scroll down to reach the Size grid.
  if (!hasEdit){
    return '<div class="flip-back-card">' + styleHTML + '</div>';
  }

  // Tabbed path
  var isStyle = activeTab === 'style';
  return '<div class="flip-back-card">'
    + '<div style="display:flex;gap:3px;padding:12px 14px 10px;border-bottom:1px solid rgba(255,255,255,.08);flex-shrink:0;background:rgba(0,0,0,.18);">'
    +   '<button class="flip-tab flip-tab-edit'  + (!isStyle ? ' active' : '') + '" onclick="switchBackTab(\'' + id + '\',\'edit\')">Edit</button>'
    +   '<button class="flip-tab flip-tab-style' + ( isStyle ? ' active' : '') + '" onclick="switchBackTab(\'' + id + '\',\'style\')">Style</button>'
    + '</div>'
    + '<div style="flex:1;overflow-y:auto;padding:0;">'
    +   '<div id="ftab-edit-'  + id + '" style="' + (isStyle ? 'display:none;' : '') + 'padding:4px 0;">' + editHTML + '</div>'
    +   '<div id="ftab-style-' + id + '" style="' + (isStyle ? '' : 'display:none;') + 'padding:4px 0;">' + styleHTML + '</div>'
    + '</div>'
    + '</div>';
}

// Switch between Edit and Style tabs on the back face. Re-renders the
// whole back panel and re-attaches style listeners if landing on Style.
function switchBackTab(id, tab){
  var back = document.getElementById('tb-' + id);
  if (!back) return;
  back.innerHTML = buildBackPanel(id, tab);
  if (tab === 'style') setTimeout(function(){ attachStyleListeners(id); }, 10);
}


/* ═══════════════════════════════════════════════════════════════════
   10. EMBED DOC RENDERER + DOC URL HELPERS
   Embedded Google Docs/Sheets/Slides/Forms render in iframes inside
   their own tile. Tile id format: 'embed-<docId>'. The doc record
   lives in myEmbeddedDocs.
   ═══════════════════════════════════════════════════════════════════ */

// Render an embedded doc widget by tile id. Tile id is 'embed-<docId>';
// looks up the doc record, derives an embed URL, and renders an iframe.
// Returns a "Document not found" card if the doc was deleted.
function renderEmbedWidgetHTML(tileId){
  var docId = tileId.replace('embed-', '');
  var doc = null;
  for (var i = 0; i < myEmbeddedDocs.length; i++){
    if (myEmbeddedDocs[i].id === docId){ doc = myEmbeddedDocs[i]; break; }
  }
  if (!doc) return '<div class="card"><div class="empty"><div class="empty-ico">&#128196;</div><p>Document not found.</p></div></div>';

  var embedUrl = getEmbedUrl(doc.url);
  // Icons keyed by docType (set when teacher embedded the doc)
  var icons = {doc:'&#128196;', sheet:'&#128202;', slides:'&#128250;', form:'&#128203;'};

  return '<div class="card" style="padding:0;display:flex;flex-direction:column;overflow:hidden;height:100%;">'
    + '<div style="display:flex;align-items:center;justify-content:space-between;padding:12px 16px 10px;flex-shrink:0;">'
    +   '<div class="card-lbl">' + (icons[doc.docType] || '&#128196;') + ' ' + esc(doc.title) + '</div>'
    +   '<a href="' + esc(doc.url) + '" target="_blank" class="btn btn-ghost btn-sm">&#128279; Open</a>'
    + '</div>'
    + '<div style="flex:1;min-height:0;">'
    +   '<iframe src="' + esc(embedUrl) + '" style="width:100%;height:100%;border:none;display:block;" allowfullscreen loading="lazy"></iframe>'
    + '</div></div>';
}

// Detect document type from URL — used when the teacher embeds a doc
// and we need to pick an icon and the right embed URL transform.
function detectDocType(url){
  if (!url) return 'doc';
  if (url.includes('/spreadsheets/')) return 'sheet';
  if (url.includes('/presentation/')) return 'slides';
  if (url.includes('/forms/d/'))      return 'form';
  return 'doc';
}

// Convert a Google Docs/Sheets/Slides/Forms edit URL into an embeddable
// preview URL. Each product has its own URL pattern:
//   Docs:   /edit → /preview
//   Sheets: /edit → /htmlembed (works without "Publish to web")
//   Slides: /edit → /embed
//   Forms:  /edit → /viewform?embedded=true
function getEmbedUrl(url){
  if (!url) return '';
  try {
    if (url.includes('/document/d/'))   return url.replace(/\/edit[^]*$/, '/preview');
    if (url.includes('/spreadsheets/')) return url.replace(/\/edit[^]*$/, '/htmlembed?widget=true&headers=false&chrome=false');
    if (url.includes('/presentation/')) return url.replace(/\/edit[^]*$/, '/embed?start=false&loop=false');
    if (url.includes('/forms/d/'))      return url.replace(/\/edit[^]*$/, '/viewform?embedded=true');
    return url;
  } catch(e){
    return url;
  }
}


