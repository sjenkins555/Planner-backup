// Save the schedule editor's contents. Walks every input via data-i
// (row index) + data-f (field) or data-cc (custom column id) attrs,
// builds a row-keyed object, then filters to rows with a subject.
// Also extracts the per-row color picker into prefs.subjectColors.
function flipSaveSchedule(){
  var allInputs = document.querySelectorAll('#flip-sched-rows input');
  var map = {};
  allInputs.forEach(function(inp){
    var i = inp.dataset.i;
    if (!i && i !== 0) return;
    if (!map[i]) map[i] = {custom:{}};
    if (inp.dataset.f){
      // Checkboxes use .checked, everything else .value
      if (inp.type === 'checkbox') map[i][inp.dataset.f] = inp.checked;
      else                          map[i][inp.dataset.f] = inp.value;
    }
    else if (inp.dataset.cc){
      map[i].custom[inp.dataset.cc] = inp.value;
    }
  });

  // Pull subject colors out into prefs.subjectColors before saving the schedule.
  // Both A-day subject and B-day subject get the same row color.
  if (!prefs.subjectColors) prefs.subjectColors = {};
  Object.values(map).forEach(function(p){
    if (p.subject  && p.subject.trim()  && p.color) prefs.subjectColors[p.subject.trim()]  = p.color;
    if (p.subjectB && p.subjectB.trim() && p.color) prefs.subjectColors[p.subjectB.trim()] = p.color;
    delete p.color; // color is stored separately, not on the period record
  });

  // Drop empty rows (no subject)
  var sched = Object.values(map).filter(function(p){ return p.subject && p.subject.trim(); });

  // Re-wrap subject as [label](url) if a link was provided
  sched = sched.map(function(p){
    var subj = (p.subject || '').trim();
    var link = (p.link || '').trim();
    if (link && link.startsWith('http') && subj) p.subject = '[' + subj + '](' + link + ')';
    delete p.link;
    return p;
  });

  // Read column-visibility checkboxes (period and subject are always shown)
  var newCols = ['period','subject'];
  ['teacher','room','time'].forEach(function(k){
    var cb = document.getElementById('sc-' + k);
    if (cb && cb.checked) newCols.push(k);
  });
  prefs.schedCols = newCols;

  var hlCb = document.getElementById('sc-highlight');
  prefs.schedHighlight = hlCb ? hlCb.checked : true;

  mySchedule = sched;
  unflipWidget('schedule');
  renderSchedule();
  toast('Schedule saved', 'ok');
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
  google.script.run.saveMySchedule(JSON.stringify(sched));
}

