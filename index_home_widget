/* ═══════════════════════════════════════════════════════════════════
   18. TIMER WIDGET
   Two modes (timer = countdown, stopwatch = elapsed) × three styles
   (circle / bar / minimal). Uses requestAnimationFrame for smooth ticks
   and tracks elapsed time deltas via performance.now().
   ═══════════════════════════════════════════════════════════════════ */

// Re-render the timer body for the current style + mode. Wires the
// minute/second input listeners on the timer mode so editing them
// updates the target on the fly while paused.
function renderTimerBody(){
  var el = document.getElementById('timer-widget-body');
  if (!el) return;

  var style   = prefs.timerStyle || 'circle';
  var isTimer = timerState.mode === 'timer';
  if (style === 'circle')      el.innerHTML = circleTimerHTML(isTimer);
  else if (style === 'bar')    el.innerHTML = barTimerHTML(isTimer);
  else                          el.innerHTML = minimalTimerHTML(isTimer);

  // Live-update the target as the user types min/sec (timer mode only)
  if (isTimer){
    var mIn = document.getElementById('t-min');
    var sIn = document.getElementById('t-sec');
    if (mIn) mIn.addEventListener('input', function(){
      timerState.target = (parseInt(mIn.value || 0) * 60 + parseInt(sIn.value || 0)) * 1000;
      updateTimerDisplay();
    });
    if (sIn) sIn.addEventListener('input', function(){
      timerState.target = (parseInt(mIn.value || 0) * 60 + parseInt(sIn.value || 0)) * 1000;
      updateTimerDisplay();
    });
  }
}

// Switch between countdown timer and stopwatch. Resets all state.
function setTimerMode(m){
  timerState.mode    = m;
  timerState.running = false;
  timerState.elapsed = 0;
  timerState.target  = 0;
  timerState.laps    = [];
  cancelAnimationFrame(timerState.raf);
  document.getElementById('tt-timer').classList.toggle('active', m === 'timer');
  document.getElementById('tt-sw').classList.toggle('active',    m === 'stopwatch');
  renderTimerBody();
}

// Style A: circular SVG progress ring with center digit display.
function circleTimerHTML(isTimer){
  var inputRow = isTimer ? '<div class="timer-input-row"><input class="finp" type="number" id="t-min" min="0" max="99" value="5" placeholder="mm"><span>:</span><input class="finp" type="number" id="t-sec" min="0" max="59" value="0" placeholder="ss"></div>' : '';
  var lapBtn   = isTimer ? '' : '<button class="btn btn-ghost btn-sm" onclick="timerLap()">Lap</button>';
  var lapList  = isTimer ? '' : '<div class="lap-list" id="lap-list"></div>';
  var startLbl = timerState.running ? 'Pause' : 'Start';
  var subLbl   = isTimer ? 'countdown' : 'elapsed';
  return '<div class="timer-circle-wrap">'
    + '<div class="timer-svg-wrap"><svg width="140" height="140" viewBox="0 0 140 140">'
    +   '<circle cx="70" cy="70" r="60" fill="none" stroke="rgba(255,255,255,.06)" stroke-width="10"/>'
    +   '<circle cx="70" cy="70" r="60" fill="none" stroke="var(--a1)" stroke-width="10" stroke-linecap="round" stroke-dasharray="377" stroke-dashoffset="0" id="timer-ring"/>'
    + '</svg><div class="timer-center"><div class="timer-time-disp" id="timer-disp">00:00</div><div class="timer-label" id="timer-sub-lbl">' + subLbl + '</div></div></div>'
    + inputRow
    + '<div class="timer-controls"><button class="btn btn-ghost btn-sm" onclick="timerReset()">Reset</button><button class="btn btn-primary" id="timer-start-btn" onclick="timerToggle()">' + startLbl + '</button>' + lapBtn + '</div>'
    + lapList
    + '</div>';
}

// Style B: horizontal progress bar with digit display above.
function barTimerHTML(isTimer){
  var inputRow = isTimer ? '<div class="timer-input-row"><input class="finp" type="number" id="t-min" min="0" max="99" value="5" style="width:60px;text-align:center;"><span>:</span><input class="finp" type="number" id="t-sec" min="0" max="59" value="0" style="width:60px;text-align:center;"></div>' : '';
  var lapBtn   = isTimer ? '' : '<button class="btn btn-ghost btn-sm" onclick="timerLap()">Lap</button>';
  var lapList  = isTimer ? '' : '<div class="lap-list" id="lap-list"></div>';
  var startLbl = timerState.running ? 'Pause' : 'Start';
  return '<div class="timer-bar-wrap">' + inputRow
    + '<div class="timer-bar-time" id="timer-disp">00:00</div>'
    + '<div class="timer-bar-track"><div class="timer-bar-fill" id="timer-ring" style="width:0%"></div></div>'
    + '<div class="timer-bar-controls"><button class="btn btn-ghost btn-sm" onclick="timerReset()">Reset</button><button class="btn btn-primary" id="timer-start-btn" onclick="timerToggle()">' + startLbl + '</button>' + lapBtn + '</div>'
    + lapList
    + '</div>';
}

// Style C: minimal — just the digits and controls, no progress visualization.
function minimalTimerHTML(isTimer){
  var inputRow = isTimer ? '<div style="display:flex;gap:8px;justify-content:center;margin-bottom:8px;"><input class="finp" type="number" id="t-min" min="0" max="99" value="5" style="width:64px;text-align:center;font-size:16px;"><span style="align-self:center;color:var(--tx3);font-size:18px;">:</span><input class="finp" type="number" id="t-sec" min="0" max="59" value="0" style="width:64px;text-align:center;font-size:16px;"></div>' : '';
  var lapBtn   = isTimer ? '' : '<button class="btn btn-ghost btn-sm" onclick="timerLap()">Lap</button>';
  var lapList  = isTimer ? '' : '<div class="lap-list" id="lap-list"></div>';
  var startLbl = timerState.running ? 'Pause' : 'Start';
  return '<div class="timer-min-wrap">' + inputRow
    + '<div class="timer-min-time" id="timer-disp">00:00</div>'
    + '<div class="timer-min-controls"><button class="btn btn-ghost btn-sm" onclick="timerReset()">Reset</button><button class="btn btn-primary" id="timer-start-btn" onclick="timerToggle()">' + startLbl + '</button>' + lapBtn + '</div>'
    + lapList
    + '</div>';
}

// Last animation-frame timestamp — captured per tick to compute deltas.
var _lastTs = null;

// Toggle running state. Reads min/sec inputs into target on first start.
function timerToggle(){
  timerState.running = !timerState.running;
  var btn = document.getElementById('timer-start-btn');
  if (btn) btn.textContent = timerState.running ? 'Pause' : 'Start';

  if (timerState.running){
    // First start of a fresh timer — capture target from inputs
    if (timerState.mode === 'timer' && timerState.elapsed === 0){
      var mIn = document.getElementById('t-min');
      var sIn = document.getElementById('t-sec');
      timerState.target = ((parseInt(mIn ? mIn.value : 5) || 0) * 60 + (parseInt(sIn ? sIn.value : 0) || 0)) * 1000;
    }
    _lastTs = performance.now();
    timerTick();
  } else {
    cancelAnimationFrame(timerState.raf);
  }
}

// Animation-frame loop. Accumulates elapsed time as wall-clock deltas
// (instead of counting frames) so it survives tab backgrounding.
function timerTick(){
  if (!timerState.running) return;
  var now   = performance.now();
  var delta = now - (_lastTs || now);
  _lastTs   = now;
  timerState.elapsed += delta;

  // Countdown reached zero — auto-stop
  if (timerState.mode === 'timer' && timerState.elapsed >= timerState.target){
    timerState.elapsed = timerState.target;
    timerState.running = false;
    updateTimerDisplay();
    var btn = document.getElementById('timer-start-btn');
    if (btn) btn.textContent = 'Start';
    toast("Time's up!", 'ok');
    return;
  }

  updateTimerDisplay();
  timerState.raf = requestAnimationFrame(timerTick);
}

// Repaint the digit display + progress visualization. Different progress
// math depending on style (SVG dashoffset vs CSS width).
function updateTimerDisplay(){
  var isTimer = timerState.mode === 'timer';
  // For countdown, show remaining; for stopwatch, show elapsed
  var ms      = isTimer ? Math.max(0, timerState.target - timerState.elapsed) : timerState.elapsed;
  var total   = Math.floor(ms / 1000);
  var m       = Math.floor(total / 60);
  var s       = total % 60;
  var el      = document.getElementById('timer-disp');
  if (el) el.textContent = String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');

  // Progress fraction (0..1)
  var pct = timerState.target > 0
    ? (isTimer ? 1 - timerState.elapsed / timerState.target : timerState.elapsed / timerState.target)
    : 0;

  var ring = document.getElementById('timer-ring');
  if (ring){
    var style = prefs.timerStyle || 'circle';
    if (style === 'circle'){
      // SVG circumference = 2πr where r=60 → 377
      ring.setAttribute('stroke-dashoffset', (2 * Math.PI * 60) * (1 - Math.min(pct, 1)));
    } else if (style === 'bar'){
      ring.style.width = (Math.min(pct, 1) * 100) + '%';
    }
  }
}

// Reset timer state and clear lap list.
function timerReset(){
  cancelAnimationFrame(timerState.raf);
  timerState.running = false;
  timerState.elapsed = 0;
  timerState.laps    = [];
  updateTimerDisplay();
  var btn = document.getElementById('timer-start-btn');
  if (btn) btn.textContent = 'Start';
  var ll = document.getElementById('lap-list');
  if (ll) ll.innerHTML = '';
}

// Capture a lap (stopwatch mode only). Stores time-since-last-lap.
function timerLap(){
  if (!timerState.running && timerState.elapsed === 0) return;
  var lapTime = timerState.elapsed - timerState.lapStart;
  timerState.lapStart = timerState.elapsed;
  var total = Math.floor(lapTime / 1000);
  var m     = Math.floor(total / 60);
  var s     = total % 60;
  timerState.laps.push(String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0'));

  var ll = document.getElementById('lap-list');
  if (ll) ll.innerHTML = timerState.laps.map(function(l, i){
    return '<div class="lap-row"><span>Lap ' + (i + 1) + '</span><span>' + l + '</span></div>';
  }).reverse().join('');
}


