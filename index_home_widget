/* ═══════════════════════════════════════════════════════════════════
   22. COUNTDOWNS WIDGET
   Stored in prefs.countdowns as {id, name, date (YYYY-MM-DD), emoji}.
   Render sorts by absolute distance from today, with future dates first.
   ═══════════════════════════════════════════════════════════════════ */

// Render the countdown list. Sorts: future-dates-first (sorted by
// nearest), then past-dates (sorted by most recent). Each row colors
// "today" / "urgent within a week" / "past" differently.
function renderCountdowns(){
  var el = document.getElementById('cd-area');
  if (!el) return;

  var cds = prefs.countdowns || [];
  if (!cds.length){
    el.innerHTML = '<div class="empty"><p>No countdowns yet. Use the gear to add.</p></div>';
    return;
  }

  // Anchor to start of today for stable comparisons
  var now = new Date();
  now.setHours(0, 0, 0, 0);

  // Sort: future-first (a is future, b is past → -1), within each group by absolute distance
  var sorted = cds.slice().sort(function(a, b){
    var da = new Date(a.date + 'T00:00:00');
    var db = new Date(b.date + 'T00:00:00');
    var diffa = da - now;
    var diffb = db - now;
    if (diffa >= 0 && diffb < 0) return -1;
    if (diffa < 0 && diffb >= 0) return  1;
    return Math.abs(diffa) - Math.abs(diffb);
  });

  el.innerHTML = '<div class="cd-list">' + sorted.map(function(cd){
    var target = new Date(cd.date + 'T00:00:00');
    var diff   = Math.round((target - now) / (1000 * 60 * 60 * 24));

    // Three render variants based on diff sign
    var daysHtml;
    if (diff === 0)      daysHtml = '<div class="cd-days today-cls">Today!<span class="cd-days-sub">is the day</span></div>';
    else if (diff > 0)   daysHtml = '<div class="cd-days' + (diff <= 7 ? ' urgent' : '') + '">' + diff + '<span class="cd-days-sub">days away</span></div>';
    else                  daysHtml = '<div class="cd-days past">' + Math.abs(diff) + '<span class="cd-days-sub">days ago</span></div>';

    return '<div class="cd-item" onclick="openCdModal(\'' + cd.id + '\')">'
      + '<div class="cd-emoji">' + (cd.emoji || '&#127881;') + '</div>'
      + '<div class="cd-body"><div class="cd-name">' + esc(cd.name) + '</div><div class="cd-date-lbl">' + fmtDateFull(cd.date) + '</div></div>'
      + daysHtml
      + '</div>';
  }).join('') + '</div>';
}

