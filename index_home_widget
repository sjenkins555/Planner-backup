// Test if the current minute (`cur` = h*60 + m) falls within a period's
// startTime/endTime window. Returns false if either time is missing or unparseable.
function isNowPeriod(p, cur){
  if (!p.startTime || !p.endTime) return false;
  try {
    var sp = p.startTime.split(':');
    var ep = p.endTime.split(':');
    return cur >= parseInt(sp[0]) * 60 + parseInt(sp[1])
        && cur <= parseInt(ep[0]) * 60 + parseInt(ep[1]);
  } catch(e){
    return false;
  }
}

