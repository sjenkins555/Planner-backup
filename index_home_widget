   16. WEATHER WIDGET
   ─────────────────────────────────────────────────────────────────
   Three views (today/5day/10day) use the same Open-Meteo API with
   different params. Geolocation reverse-lookup goes through Nominatim
   (OpenStreetMap). Both flip-back and modal-based setup paths exist;
   the modal versions appear to be legacy (no obvious caller in this file).
   ═══════════════════════════════════════════════════════════════════ */

// Show a loading state then trigger fetchWeatherData. Called on every
// home re-render, so it's safe to no-op when location hasn't been set.
function loadWeather(){
  if (!prefs.weatherLat || !prefs.weatherLon) return;
  showWidgetLoader('weather', 'sm');
  fetchWeatherData(prefs.weatherLat, prefs.weatherLon, prefs.weatherCity || '');
}

// Initial weather widget body — either a "loading" spinner (if location
// is set) or a "set up weather" CTA.
function renderWeatherInit(){
  if (prefs.weatherLat && prefs.weatherLon){
    return '<div class="weather-loading"><div class="spinner" style="margin:0 auto 8px;"></div>Loading weather...</div>';
  }
  return '<div style="text-align:center;padding:16px;"><p style="font-size:13px;color:var(--tx2);margin-bottom:14px;">Tap to set up weather.</p><button class="btn btn-primary" onclick="flipWidget(\'weather\')">Set Up Weather</button></div>';
}

// Switch between today/5day/10day views; persists to prefs and reloads.
function setWeatherView(v){
  prefs.weatherView = v;
  document.querySelectorAll('.weather-vbtn').forEach(function(b){
    b.className = 'btn btn-sm weather-vbtn ' + (b.dataset.view === v ? 'btn-primary' : 'btn-ghost');
  });
  loadWeather();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}

// Fetch weather from Open-Meteo and render based on the current view mode.
// Today view uses current_weather; multi-day uses daily forecast with
// max/min temps and precipitation probability.
function fetchWeatherData(lat, lon, city){
  var vw = prefs.weatherView || 'today';
  var el = document.getElementById('weather-body');
  if (!el) return;
  el.innerHTML = '<div class="weather-loading"><div class="spinner" style="margin:0 auto 8px;"></div>Loading...</div>';

  // Build the right URL for the current view
  var url;
  if (vw === 'today'){
    url = 'https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lon + '&current_weather=true&temperature_unit=fahrenheit&windspeed_unit=mph';
  } else {
    var days = vw === '5day' ? 5 : 10;
    url = 'https://api.open-meteo.com/v1/forecast?latitude=' + lat + '&longitude=' + lon + '&daily=weathercode,temperature_2m_max,temperature_2m_min,precipitation_probability_max&temperature_unit=fahrenheit&timezone=auto&forecast_days=' + days;
  }

  fetch(url).then(function(r){ return r.json(); }).then(function(data){
    if (vw === 'today'){
      var cw   = data.current_weather;
      var code = cw.weathercode;
      var icon = WMO_ICONS[code] || '&#127777;';
      var desc = WMO_DESC[code]  || '';
      el.innerHTML = '<div class="weather-display">'
        + '<div class="weather-icon">' + icon + '</div>'
        + '<div class="weather-temp">' + toDisplayTemp(cw.temperature) + tempLabel() + '</div>'
        + '<div class="weather-desc">' + desc + '</div>'
        + '<div class="weather-city">' + (city || 'Your Location') + '</div>'
        + '<div class="weather-meta"><div class="weather-meta-item">Wind: ' + Math.round(cw.windspeed) + ' mph</div></div>'
        + '<button class="btn btn-ghost btn-sm" style="margin-top:12px;width:100%;" onclick="loadWeather()">Refresh</button>'
        + '</div>';
    } else {
      // Multi-day: build a horizontally-scrollable column per day
      var d    = data.daily;
      var cols = d.time.length;
      var html = '<div style="display:grid;grid-template-columns:repeat(' + cols + ',1fr);gap:4px;overflow-x:auto;">';
      for (var i = 0; i < cols; i++){
        var dt     = new Date(d.time[i] + 'T12:00:00');  // T12 avoids tz landmines
        var dn     = DAYS[dt.getDay()].substring(0, 3);
        var ico    = WMO_ICONS[d.weathercode[i]] || '&#127777;';
        var precip = (d.precipitation_probability_max && d.precipitation_probability_max[i] != null) ? d.precipitation_probability_max[i] : null;
        html += '<div style="text-align:center;padding:8px 3px;background:var(--bg3);border:1px solid var(--border);border-radius:10px;">'
          + '<div style="font-size:9px;font-weight:600;color:var(--a2);margin-bottom:3px;letter-spacing:.3px;">' + dn + '</div>'
          + '<div style="font-size:18px;margin:2px 0;">' + ico + '</div>'
          + '<div style="font-size:12px;font-weight:700;color:var(--tx);">' + toDisplayTemp(d.temperature_2m_max[i]) + tempLabel() + '</div>'
          + '<div style="font-size:10px;color:var(--tx3);">' + toDisplayTemp(d.temperature_2m_min[i]) + tempLabel() + '</div>'
          + (precip != null ? '<div style="font-size:9px;color:#38bdf8;margin-top:2px;">&#128167;' + precip + '%</div>' : '')
          + '</div>';
      }
      html += '</div><button class="btn btn-ghost btn-sm" style="margin-top:10px;width:100%;" onclick="loadWeather()">Refresh</button>';
      el.innerHTML = html;
    }
  }).catch(function(){
    if (el) el.innerHTML = '<div class="weather-err">Could not load weather.</div>';
  }).finally(function(){
    hideWidgetLoader('weather');
  });
}

// Use browser geolocation + reverse-lookup (Nominatim) to set lat/lon/city.
// Falls back to an empty city string if the reverse-lookup fails.
function flipGeoLocate(){
  if (!navigator.geolocation){ toast('Geolocation not supported', 'err'); return; }
  var btn = document.querySelector('#tb-weather .btn-primary');
  if (btn) btn.textContent = 'Locating...';

  navigator.geolocation.getCurrentPosition(function(pos){
    var lat = pos.coords.latitude;
    var lon = pos.coords.longitude;
    prefs.weatherLat = lat;
    prefs.weatherLon = lon;

    fetch('https://nominatim.openstreetmap.org/reverse?lat=' + lat + '&lon=' + lon + '&format=json')
      .then(function(r){ return r.json(); })
      .then(function(d){
        var city = (d.address.city || d.address.town || d.address.village || '') + (d.address.state ? ', ' + d.address.state : '');
        prefs.weatherCity = city;
        google.script.run.saveMyPrefs(JSON.stringify(prefs));
        unflipWidget('weather');
        loadWeather();
      }).catch(function(){
        prefs.weatherCity = '';
        google.script.run.saveMyPrefs(JSON.stringify(prefs));
        unflipWidget('weather');
        loadWeather();
      });
  }, function(){
    toast('Could not get location. Try manual entry.', 'err');
  });
}

// Geocode a typed city name via Nominatim search and save the result.
function flipManualCity(){
  var inp  = document.getElementById('flip-w-city');
  var city = inp ? inp.value.trim() : '';
  if (!city){ toast('Enter a city name', 'err'); return; }

  fetch('https://nominatim.openstreetmap.org/search?q=' + encodeURIComponent(city) + '&format=json&limit=1')
    .then(function(r){ return r.json(); })
    .then(function(data){
      if (!data.length){ toast('City not found', 'err'); return; }
      prefs.weatherLat  = parseFloat(data[0].lat);
      prefs.weatherLon  = parseFloat(data[0].lon);
      prefs.weatherCity = city;
      google.script.run.saveMyPrefs(JSON.stringify(prefs));
      unflipWidget('weather');
      loadWeather();
    }).catch(function(){
      toast('Could not find city', 'err');
    });
}

