<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{min-height:100%;background:var(--bg)}body{min-height:100vh;background:transparent}
body{font-family:'DM Sans',sans-serif;color:#e2e8f0;font-size:14px;line-height:1.5;overflow-x:hidden}
:root{--a1:#6366f1;--a2:#818cf8;--a3:rgba(99,102,241,.12);--a4:rgba(99,102,241,.25);--a5:rgba(99,102,241,.07);--bg:#0a0e1a;--bg2:#111827;--bg3:#0f172a;--card:rgba(17,24,39,.88);--border:rgba(255,255,255,.07);--tx:#e2e8f0;--tx2:#94a3b8;--tx3:#475569;--tx4:#334155}
/* ── Tab tinting (Teacher = green, Admin = purple) ────── */
#content{transition:background-color .25s ease}
body[data-active-tab="t-dash"] #content{background-color:rgba(34,197,94,.10)}
body[data-active-tab="t-admin"] #content{background-color:rgba(168,85,247,.10)}
body[data-active-tab="t-dash"] .nav-btn#nb-t-dash.active{color:#22c55e;border-bottom-color:#22c55e}
body[data-active-tab="t-admin"] .nav-btn#nb-t-admin.active{color:#a855f7;border-bottom-color:#a855f7}
/* ── CH LOGO ───────────────────────────────────────── */
.ch-logo{background:linear-gradient(140deg,#1b2a5e,#0e1633);border:3px solid #f4b827;border-radius:22px;display:grid;place-items:center;color:#f4b827;font-family:'DM Sans',system-ui,sans-serif;font-weight:800;letter-spacing:-.04em;box-shadow:inset 0 1px 0 rgba(255,255,255,.08),0 10px 28px rgba(0,0,0,.4);user-select:none;flex-shrink:0;}
.ch-logo.xl{width:180px;height:180px;font-size:82px;border-radius:28px}
.ch-logo.lg{width:120px;height:120px;font-size:54px;border-radius:20px}
.ch-logo.md{width:72px;height:72px;font-size:32px;border-width:2px;border-radius:14px}
.ch-logo.sm{width:48px;height:48px;font-size:22px;border-width:2px;border-radius:11px}
.ch-logo.xs{width:36px;height:36px;font-size:17px;border-width:1.5px;border-radius:9px}
.ch-logo.fav{width:24px;height:24px;font-size:11px;border-width:1px;border-radius:6px}
/* ── LEFT RAIL ───────────────────────────────────────── */
#link-rail{position:fixed;left:0;top:54px;bottom:0;width:66px;background:var(--bg);border-right:1px solid var(--border);backdrop-filter:blur(14px);z-index:150;display:none;flex-direction:column;align-items:center;padding:14px 0 20px;gap:7px;overflow-y:auto;scrollbar-width:none}
#link-rail.visible{display:flex;background:var(--bg);opacity:.98}
#link-rail::-webkit-scrollbar{display:none}
.rail-sep{width:38px;height:1px;background:var(--border);flex-shrink:0;margin:3px 0}
.rail-item{display:flex;flex-direction:column;align-items:center;gap:3px}
.rail-link{width:46px;height:46px;border-radius:12px;overflow:hidden;cursor:pointer;border:1px solid var(--border);background:rgba(255,255,255,.04);transition:all .15s;display:flex;align-items:center;justify-content:center;text-decoration:none;flex-shrink:0;position:relative}
.rail-link:hover{border-color:var(--a4);background:var(--a5);transform:scale(1.08);z-index:10}
.rail-link img{width:30px;height:30px;object-fit:contain;pointer-events:none}
.rail-tip{position:absolute;left:54px;top:50%;transform:translateY(-50%);background:#1e293b;border:1px solid rgba(255,255,255,.12);border-radius:8px;padding:5px 10px;font-size:12px;font-weight:600;color:var(--tx);white-space:nowrap;pointer-events:none;opacity:0;transition:opacity .15s;z-index:300;box-shadow:0 4px 20px rgba(0,0,0,.5)}
.rail-link:hover .rail-tip{opacity:1}
.rail-label{font-size:8px;font-weight:600;color:var(--tx4);letter-spacing:.5px;text-transform:uppercase;width:46px;text-align:center;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.rail-collapse-btn{width:40px;height:28px;border-radius:8px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--tx4);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:12px;transition:all .15s;flex-shrink:0;margin-top:80px;user-select:none}
.rail-collapse-btn:hover{background:var(--a3);color:var(--a2);border-color:var(--a4)}
.rail-link{background:rgba(128,128,128,.06);border-color:var(--border)}
.rail-link:hover{border-color:var(--a4);background:var(--a5)}
.rail-collapse-btn{background:rgba(128,128,128,.06);border-color:var(--border);color:var(--tx4)}
body.has-rail .topbar{padding-left:74px}
body.has-rail .navstrip{padding-left:74px}
body.has-rail .page{margin-left:66px;width:calc(100% - 66px)}
#link-rail.rail-collapsed{width:20px;padding:14px 0;overflow:hidden}
#link-rail.rail-collapsed .rail-item,
#link-rail.rail-collapsed .rail-sep{display:none}
#link-rail.rail-collapsed .rail-collapse-btn{width:16px;border-radius:3px;border:none;background:rgba(255,255,255,.06)}
body.has-rail.rail-collapsed .topbar{padding-left:28px}
body.has-rail.rail-collapsed .navstrip{padding-left:28px}
body.has-rail.rail-collapsed .page{margin-left:20px;width:calc(100% - 20px)}
@media(max-width:700px){#link-rail{display:none!important}body.has-rail .topbar,body.has-rail.rail-collapsed .topbar{padding-left:18px}body.has-rail .navstrip,body.has-rail.rail-collapsed .navstrip{padding-left:16px}body.has-rail .page,body.has-rail.rail-collapsed .page{margin-left:0;width:100%}}
#bg-layer{position:fixed;inset:0;z-index:-2;background:var(--bg);}
#bg-overlay{position:fixed;inset:0;z-index:-1;background:transparent;pointer-events:none}
/* ── LOADING SCREEN ─────────────────────────────────── */
#loading{position:fixed;inset:0;background:#0e1633;display:flex;flex-direction:column;align-items:center;justify-content:center;z-index:9999;overflow:hidden;font-family:'DM Sans',sans-serif}
.ld-halo{position:absolute;width:700px;height:700px;border-radius:50%;background:conic-gradient(from 0deg,rgba(244,184,39,0) 0deg,rgba(244,184,39,.18) 60deg,rgba(244,184,39,0) 180deg,rgba(244,184,39,.1) 260deg,rgba(244,184,39,0) 360deg);filter:blur(40px);animation:ld-halo-spin 14s linear infinite;pointer-events:none}
@keyframes ld-halo-spin{to{transform:rotate(360deg)}}
.ld-specks{position:absolute;inset:0;pointer-events:none}
.ld-spark{position:absolute;border-radius:50%;background:#ffc83d;box-shadow:0 0 8px #ffc83d;animation:ld-rise 6s linear infinite}
@keyframes ld-rise{0%{transform:translateY(20px) scale(.6);opacity:0}10%{opacity:.9}90%{opacity:.8}100%{transform:translateY(-120vh) scale(1);opacity:0}}
.ld-brand{position:absolute;top:32px;left:32px;display:flex;align-items:center;gap:9px;font-size:11px;letter-spacing:.35em;color:rgba(246,236,210,.55);text-transform:uppercase}
.ld-pip{width:6px;height:6px;background:#ffc83d;border-radius:50%;box-shadow:0 0 8px #ffc83d;animation:ld-blink 1.4s infinite ease-in-out;flex-shrink:0}
.ld-crest-wrap{position:relative;width:380px;height:380px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.ld-ring{position:absolute;inset:0;width:100%;height:100%;transform:rotate(-90deg)}
.ld-track{fill:none;stroke:rgba(246,236,210,.08);stroke-width:3}
.ld-prog{fill:none;stroke:#ffc83d;stroke-width:3;stroke-linecap:round;stroke-dasharray:1131;stroke-dashoffset:1131;filter:drop-shadow(0 0 6px rgba(255,200,61,.55))}
.ld-logo-hold{width:290px;height:290px;display:flex;align-items:center;justify-content:center;animation:ld-float 4.2s ease-in-out infinite}
@keyframes ld-float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.ld-logo{width:100%;height:100%;object-fit:contain;filter:drop-shadow(0 18px 30px rgba(0,0,0,.45)) drop-shadow(0 0 22px rgba(244,184,39,.18));animation:ld-pulse 3s ease-in-out infinite}
@keyframes ld-pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.025)}}
#ls-wrap{display:flex;flex-direction:column;align-items:center;gap:12px;position:relative;z-index:2}
.ld-text{display:flex;align-items:center;gap:4px;font-size:13px;font-weight:600;letter-spacing:.3em;text-transform:uppercase;color:rgba(246,236,210,.85)}
.ld-dot{display:inline-block;width:5px;height:5px;border-radius:50%;background:#ffc83d;animation:ld-blink 1.4s infinite ease-in-out;margin:0 2px}
.ld-dot:nth-child(3){animation-delay:.18s}.ld-dot:nth-child(4){animation-delay:.36s}
@keyframes ld-blink{0%,80%,100%{opacity:.2;transform:scale(.85)}40%{opacity:1;transform:scale(1)}}
.ld-pbar{width:200px;height:3px;background:rgba(246,236,210,.1);border-radius:999px;overflow:hidden;position:relative}
.ld-pfill{position:absolute;inset:0;width:0%;background:linear-gradient(90deg,#f4b827,#ffd96a);border-radius:999px;box-shadow:0 0 10px rgba(255,200,61,.55);transition:width .25s ease-out}
#load-hint{display:none;color:rgba(246,236,210,.45);font-size:12px;letter-spacing:.02em;margin-top:4px}
#load-err{display:none;max-width:480px;margin:0 20px;background:rgba(239,68,68,.06);border:1px solid rgba(239,68,68,.2);border-radius:14px;padding:24px;position:relative;z-index:2}
#load-err h3{color:#f87171;margin-bottom:8px;font-size:15px}
#load-err p{color:#94a3b8;font-size:13px;line-height:1.7;white-space:pre-wrap}
.err-steps{margin-top:14px;background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.06);border-radius:10px;padding:14px;font-size:13px;color:#e2e8f0;line-height:1.9}
.err-steps strong{color:#ffc83d}
.spinner{width:36px;height:36px;border:3px solid rgba(255,255,255,.07);border-top-color:var(--a1);border-radius:50%;animation:spin .75s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
@media(max-width:600px){.ld-crest-wrap{width:270px;height:270px}.ld-logo-hold{width:205px;height:205px}.ld-halo{width:460px;height:460px}.ld-brand{top:18px;left:18px;font-size:9px}}
@media(prefers-reduced-motion:reduce){.ld-halo,.ld-logo-hold,.ld-logo,.ld-spark,.ld-pip{animation:none!important}}
#app{display:none;flex-direction:column;min-height:100vh}
.topbar{position:sticky;top:0;z-index:200;background:rgba(10,14,26,.92);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);height:54px;display:flex;align-items:center;justify-content:space-between;padding:0 18px;gap:12px}
.brand{display:flex;align-items:center;gap:10px}
.brand-name{font-size:14px;font-weight:700;background:linear-gradient(135deg,var(--a2),#14b8a6);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;white-space:nowrap}
.role-pill{font-size:10px;font-weight:600;letter-spacing:.7px;text-transform:uppercase;padding:2px 8px;border-radius:99px;background:var(--a3);color:var(--a2);border:1px solid var(--a4);white-space:nowrap}
.role-pill.is-teacher{background:rgba(168,85,247,.12);color:#c084fc;border-color:rgba(168,85,247,.3)}
.topbar-right{display:flex;align-items:center;gap:10px}
#live-clock{font-family:'DM Mono',monospace;font-size:12px;color:var(--tx4);letter-spacing:1px}
.icon-btn{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:9px;color:var(--tx3);width:32px;height:32px;display:flex;align-items:center;justify-content:center;cursor:pointer;transition:all .15s;font-size:15px;flex-shrink:0}
.icon-btn:hover{background:var(--a3);color:var(--a2);border-color:var(--a4)}
.user-pill{display:flex;align-items:center;gap:7px;background:rgba(255,255,255,.04);border:1px solid var(--border);padding:3px 12px 3px 3px;border-radius:99px;cursor:pointer;transition:all .15s}
.user-pill:hover{background:rgba(255,255,255,.07)}
.avatar{width:28px;height:28px;border-radius:50%;background:linear-gradient(135deg,var(--a1),#a855f7);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:white;flex-shrink:0}
.avatar.teacher{background:linear-gradient(135deg,#a855f7,#14b8a6)}
#uname{font-size:13px;color:var(--tx2);font-weight:500}
.navstrip{background:rgba(10,14,26,.85);border-bottom:1px solid var(--border);display:flex;align-items:stretch;padding:0 16px;gap:2px;overflow-x:auto;scrollbar-width:none}
.navstrip::-webkit-scrollbar{display:none}
.nav-btn{background:none;border:none;color:var(--tx3);font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;padding:0 12px;height:40px;cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;transition:all .15s;display:flex;align-items:center;gap:5px}
.nav-btn:hover{color:var(--tx2)}
.nav-btn.active{color:var(--a2);border-bottom-color:var(--a1)}
.nav-sep{width:1px;background:var(--border);margin:8px 5px;flex-shrink:0}
.page{padding:20px;max-width:100%;width:100%;margin:0;flex:1}
.tab-pane{display:none}
.tab-pane.active{display:block}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:none}}
@keyframes shimmer{0%,100%{opacity:.4}50%{opacity:1}}

/* ── 4-COLUMN GRID ─────────────────────────────── */
.tile-grid{display:grid;grid-template-columns:repeat(4,1fr);grid-auto-rows:minmax(160px,auto);gap:14px;grid-auto-flow:row dense}
@media(max-width:1100px){.tile-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.tile-grid{grid-template-columns:1fr}}
.tile{border-radius:16px;position:relative;transition:box-shadow .2s,opacity .2s;display:flex;flex-direction:column}
.tile.dragging{opacity:.4;box-shadow:0 0 0 2px var(--a1)}
.tile.drag-over{box-shadow:0 0 0 2px var(--a2)}
/* ── TOP-RIGHT MINIMIZE ONLY (no ghost) ─────────── */
.min-btn{position:absolute;top:8px;right:8px;color:var(--tx4);cursor:pointer;font-size:11px;opacity:0;transition:opacity .15s;z-index:10;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:5px;width:22px;height:22px;display:flex;align-items:center;justify-content:center}
.tile:hover .min-btn,.tile.minimized .min-btn{opacity:1}
.min-btn:hover{background:var(--a3);color:var(--a2);border-color:var(--a4)}
.tile-min-bar{display:none;align-items:center;gap:8px;padding:10px 14px;background:var(--card);border:1px solid var(--border);border-radius:16px;font-size:12px;font-weight:600;color:var(--tx3);letter-spacing:.5px;text-transform:uppercase;cursor:pointer}
.tile.minimized .tile-min-bar{display:flex}
.tile.minimized>*:not(.tile-min-bar):not(.min-btn):not(.tile-controls){display:none!important}
.tile.minimized{grid-row:span 1!important;display:block!important;min-height:unset!important}
/* ── BOTTOM-RIGHT CONTROLS (drag + resize) ──────── */
.tile-controls{position:absolute;bottom:8px;right:8px;display:flex;gap:4px;opacity:0;transition:opacity .15s;z-index:10}
.tile:hover .tile-controls{opacity:1}
.tile.minimized .tile-controls{display:none}
.tile-drag-hdl{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:6px;color:var(--tx4);cursor:grab;font-size:14px;width:24px;height:24px;display:flex;align-items:center;justify-content:center;transition:all .15s;user-select:none}
.tile-drag-hdl:hover{background:var(--a3);color:var(--a2);border-color:var(--a4)}
.tile-drag-hdl:active{cursor:grabbing}
.tile-sz-btn{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:6px;color:var(--tx4);cursor:pointer;font-size:13px;width:24px;height:24px;display:flex;align-items:center;justify-content:center;transition:all .15s;user-select:none}
.tile-sz-btn:hover{background:var(--a3);color:var(--a2);border-color:var(--a4)}
/* ── SIZE PICKER POPUP ───────────────────────────── */
.sz-pop{position:fixed;z-index:5000;background:#111827;border:1px solid rgba(255,255,255,.13);border-radius:14px;padding:14px;box-shadow:0 16px 48px rgba(0,0,0,.6);min-width:200px}
.sz-pop-title{font-size:10px;font-weight:600;color:var(--tx3);letter-spacing:.7px;text-transform:uppercase;margin-bottom:10px}
.sz-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:5px}
.sz-cell{padding:7px 2px;border:1px solid rgba(255,255,255,.07);border-radius:7px;cursor:pointer;background:rgba(255,255,255,.03);text-align:center;font-size:11px;font-weight:500;color:var(--tx3);transition:all .12s;line-height:1.3}
.sz-cell:hover{background:var(--a5);border-color:var(--a4);color:var(--a2)}
.sz-cell.sel{background:var(--a3);border-color:var(--a1);color:var(--a2)}
/* ── CARD ───────────────────────────────────────── */
.card{background:var(--card);border:1px solid var(--card-border,var(--border));border-radius:16px;padding:18px;height:100%;backdrop-filter:blur(4px)}
.card-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.card-lbl{font-size:11px;font-weight:600;letter-spacing:.7px;text-transform:uppercase;color:var(--tx3);display:flex;align-items:center;gap:6px}
.btn{display:inline-flex;align-items:center;justify-content:center;gap:5px;padding:7px 14px;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;border:1px solid transparent;transition:all .15s;white-space:nowrap;text-decoration:none}
.btn:hover{transform:translateY(-1px)}
.btn-primary{background:var(--a1);color:white;border-color:var(--a1)}
.btn-primary:hover{background:var(--a2);border-color:var(--a2)}
.btn-ghost{background:rgba(255,255,255,.04);color:var(--tx2);border-color:var(--border)}
.btn-ghost:hover{background:rgba(255,255,255,.08);color:var(--tx)}
.btn-danger{background:rgba(239,68,68,.08);color:#f87171;border-color:rgba(239,68,68,.2)}
.btn-danger:hover{background:rgba(239,68,68,.15)}
.btn-sm{padding:4px 10px;font-size:12px;border-radius:8px}
.fg{margin-bottom:12px}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.flbl{display:block;font-size:12px;font-weight:500;color:var(--tx3);margin-bottom:5px}
.finp,.fsel,.fta{width:100%;background:var(--bg3);border:1px solid rgba(255,255,255,.09);border-radius:10px;padding:8px 12px;color:var(--tx);font-size:13px;font-family:'DM Sans',sans-serif;outline:none;transition:all .15s}
.finp:focus,.fsel:focus,.fta:focus{border-color:var(--a4);box-shadow:0 0 0 3px var(--a5)}
.finp::placeholder,.fta::placeholder{color:var(--tx4)}
.fsel{cursor:pointer}
.fta{resize:vertical;min-height:78px;line-height:1.6}
.clock-card{background:var(--card);border:1px solid var(--card-border,var(--border));border-radius:16px;padding:20px;text-align:center;position:relative;overflow:hidden;backdrop-filter:blur(4px);height:100%;display:flex;flex-direction:column;justify-content:center;}
.clock-card::before{content:'';position:absolute;top:-40px;left:50%;transform:translateX(-50%);width:160px;height:160px;background:radial-gradient(circle,var(--a3) 0%,transparent 70%);pointer-events:none}
.clk-digital .clk-day{font-size:10px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--a1);margin-bottom:6px}
.clk-digital .clk-time{font-family:'DM Mono',monospace;font-size:44px;font-weight:300;letter-spacing:2px;background:linear-gradient(135deg,var(--tx),var(--a2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.clk-digital .clk-date{color:var(--tx3);font-size:13px;margin-top:6px}
.clk-analog{display:flex;justify-content:center;padding:8px 0}
#analog-svg{width:160px;height:160px}
.clk-minimal .clk-time{font-family:'DM Sans',sans-serif;font-size:52px;font-weight:700;color:var(--tx);letter-spacing:-2px}
.clk-minimal .clk-ampm{font-size:16px;font-weight:400;color:var(--tx3);margin-left:6px;vertical-align:super}
.clk-minimal .clk-date{color:var(--tx4);font-size:12px;margin-top:8px;letter-spacing:.5px}
.clk-word{font-size:20px;font-weight:600;color:var(--tx);line-height:1.5;text-align:center;padding:8px}
.task-list{display:flex;flex-direction:column;gap:5px}
.task-row{display:flex;align-items:center;gap:9px;background:rgba(15,23,42,.7);border:1px solid var(--border);border-radius:10px;padding:9px 11px;transition:all .15s}
.task-row:hover{border-color:rgba(255,255,255,.1)}
.task-row.done{opacity:.4}
.task-row.done .task-title{text-decoration:line-through;color:var(--tx4)}
.chk{width:19px;height:19px;border-radius:50%;border:2px solid var(--tx4);background:transparent;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;font-size:11px;color:white;transition:all .15s}
.chk:hover{border-color:#22c55e}
.task-row.done .chk{background:#22c55e;border-color:#22c55e}
.dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.dot.high{background:#ef4444}.dot.medium{background:#f59e0b}.dot.low{background:#22c55e}
.task-body{flex:1;min-width:0}
.task-title{font-size:13px;font-weight:500;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.task-sub{display:flex;align-items:center;gap:6px;margin-top:2px;flex-wrap:wrap}
.tchip{font-size:11px;color:var(--tx3);background:rgba(255,255,255,.04);border-radius:4px;padding:1px 5px}
.tchip.overdue{color:#ef4444;background:rgba(239,68,68,.08)}
.tchip.assigned{color:var(--a2);background:var(--a5)}
.del-btn{background:none;border:none;color:var(--tx4);cursor:pointer;width:22px;height:22px;border-radius:5px;display:flex;align-items:center;justify-content:center;opacity:0;transition:all .15s;flex-shrink:0;font-size:13px}
.task-row:hover .del-btn{opacity:1;color:var(--tx3)}
.del-btn:hover{background:rgba(239,68,68,.1);color:#ef4444!important}
.empty{text-align:center;padding:28px 16px;color:var(--tx4)}
.empty-ico{font-size:32px;margin-bottom:8px}
.sched-tbl{width:100%;border-collapse:collapse}
.sched-tbl th{font-size:10px;font-weight:600;letter-spacing:.7px;text-transform:uppercase;color:var(--tx4);text-align:left;padding:0 8px 8px}
.sched-tbl td{padding:7px 8px;font-size:13px;border-top:1px solid rgba(255,255,255,.04)}
.sched-tbl tr:hover td{background:rgba(255,255,255,.02)}
.sched-row-now td{background:var(--a3)!important;border-top-color:var(--a4)!important;border-bottom-color:var(--a4)!important;}
.sched-row-now td:first-child{border-left:3px solid var(--a1);padding-left:5px;}
#settings-modal .mbox{max-width:900px;max-height:90vh;overflow-y:auto;display:flex;flex-direction:column;}
.per-num{display:inline-flex;align-items:center;justify-content:center;width:24px;height:24px;border-radius:6px;background:var(--a5);color:var(--a2);font-size:11px;font-weight:700}
.now-tag{font-size:10px;font-weight:600;background:rgba(34,197,94,.1);color:#22c55e;border:1px solid rgba(34,197,94,.2);border-radius:99px;padding:1px 6px;margin-left:5px}
.muted{color:var(--tx4)}
.link-list{display:flex;flex-direction:column;gap:7px}
.link-row{display:flex;align-items:center;gap:9px;background:rgba(15,23,42,.7);border:1px solid var(--border);border-radius:10px;padding:9px 11px;transition:all .15s}
.link-row:hover{border-color:var(--a4)}
.link-ico{width:30px;height:30px;border-radius:8px;background:var(--a5);color:var(--a2);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0}
.link-body{flex:1;min-width:0}
.link-name{font-size:13px;font-weight:500}
.link-url{font-size:11px;color:var(--tx4);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.link-acts{display:flex;gap:4px;opacity:0;transition:opacity .15s}
.link-row:hover .link-acts{opacity:1}
#notes-ta{width:100%;min-height:180px;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:12px;color:var(--tx);font-size:13px;font-family:'DM Sans',sans-serif;resize:vertical;outline:none;transition:all .15s;line-height:1.7}
#notes-ta:focus{border-color:var(--a4);box-shadow:0 0 0 3px var(--a5)}
.save-lbl{font-size:11px;color:var(--tx4)}
/* ── WEATHER ─────────────────────────────────────── */
.weather-display{text-align:center;padding:8px 0}
.weather-icon{font-size:48px;margin-bottom:8px}
.weather-temp{font-size:36px;font-weight:600;color:var(--tx)}
.weather-desc{font-size:14px;color:var(--tx2);margin-top:4px;text-transform:capitalize}
.weather-city{font-size:12px;color:var(--tx3);margin-top:2px}
.weather-meta{display:flex;justify-content:center;gap:16px;margin-top:12px}
.weather-meta-item{font-size:12px;color:var(--tx3);display:flex;align-items:center;gap:4px}
.weather-err{font-size:13px;color:var(--tx3);text-align:center;padding:16px}
.weather-loading{text-align:center;padding:20px;color:var(--tx3)}
/* ── QUOTE ───────────────────────────────────────── */
.quote-body{padding:6px 0}
.quote-text{font-size:15px;font-style:italic;color:var(--tx);line-height:1.7;margin-bottom:10px;position:relative;padding-left:16px}
.quote-text::before{content:'"';position:absolute;left:0;top:-4px;font-size:28px;color:var(--a1);font-style:normal;line-height:1}
.quote-author{font-size:12px;color:var(--tx3);font-weight:500;padding-left:16px}
.quote-cat{display:inline-block;font-size:10px;font-weight:600;letter-spacing:.6px;text-transform:uppercase;background:var(--a5);color:var(--a2);border:1px solid var(--a4);border-radius:99px;padding:2px 7px;margin-left:16px;margin-top:6px}
/* ── TIMER ───────────────────────────────────────── */
.timer-tabs{display:flex;gap:4px;margin-bottom:14px}
.timer-tab-btn{flex:1;padding:6px;border-radius:8px;border:1px solid var(--border);background:rgba(255,255,255,.03);color:var(--tx3);font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;text-align:center;transition:all .15s}
.timer-tab-btn.active{background:var(--a3);border-color:var(--a1);color:var(--a2)}
.timer-circle-wrap{display:flex;flex-direction:column;align-items:center;gap:14px}
.timer-svg-wrap{position:relative;width:140px;height:140px}
.timer-svg-wrap svg{transform:rotate(-90deg)}
.timer-center{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.timer-time-disp{font-family:'DM Mono',monospace;font-size:26px;font-weight:400;color:var(--tx);letter-spacing:1px}
.timer-label{font-size:10px;color:var(--tx3);letter-spacing:.5px;text-transform:uppercase;margin-top:2px}
.timer-controls{display:flex;gap:8px;align-items:center}
.timer-bar-wrap{display:flex;flex-direction:column;gap:12px}
.timer-bar-time{font-family:'DM Mono',monospace;font-size:36px;font-weight:300;color:var(--tx);text-align:center;letter-spacing:2px}
.timer-bar-track{height:8px;background:rgba(255,255,255,.07);border-radius:99px;overflow:hidden}
.timer-bar-fill{height:100%;background:linear-gradient(90deg,var(--a1),var(--a2));border-radius:99px;transition:width .5s linear}
.timer-bar-controls{display:flex;gap:8px;justify-content:center}
.timer-min-wrap{text-align:center;padding:8px 0}
.timer-min-time{font-family:'DM Mono',monospace;font-size:52px;font-weight:200;color:var(--tx);letter-spacing:3px}
.timer-min-controls{display:flex;gap:8px;justify-content:center;margin-top:14px}
.timer-input-row{display:flex;gap:6px;align-items:center;justify-content:center;margin-bottom:10px}
.timer-input-row .finp{width:60px;text-align:center;font-family:'DM Mono',monospace}
.timer-input-row span{color:var(--tx3);font-family:'DM Mono',monospace;font-size:18px}
.lap-list{max-height:100px;overflow-y:auto;margin-top:8px}
.lap-row{display:flex;justify-content:space-between;font-size:12px;color:var(--tx3);padding:3px 4px;border-bottom:1px solid rgba(255,255,255,.04);font-family:'DM Mono',monospace}
/* ── COUNTDOWN WIDGET ────────────────────────────── */
.cd-list{display:flex;flex-direction:column;gap:7px}
.cd-item{display:flex;align-items:center;gap:10px;background:rgba(15,23,42,.7);border:1px solid var(--border);border-radius:10px;padding:10px 12px;cursor:pointer;transition:all .15s}
.cd-item:hover{border-color:var(--a4);background:rgba(99,102,241,.05)}
.cd-emoji{font-size:22px;flex-shrink:0;width:28px;text-align:center}
.cd-body{flex:1;min-width:0}
.cd-name{font-size:13px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cd-date-lbl{font-size:11px;color:var(--tx3);margin-top:2px}
.cd-days{font-family:'DM Mono',monospace;font-size:20px;font-weight:600;color:var(--a2);flex-shrink:0;text-align:right;min-width:70px}
.cd-days.urgent{color:#f59e0b}
.cd-days.today-cls{color:#22c55e}
.cd-days.past{color:var(--tx4);font-size:13px}
.cd-days-sub{font-size:9px;font-weight:400;color:var(--tx3);display:block;text-transform:uppercase;letter-spacing:.5px;text-align:right}
.emoji-pick-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.em-opt{font-size:20px;cursor:pointer;padding:5px 7px;border-radius:7px;border:1px solid var(--border);background:rgba(255,255,255,.03);transition:all .12s;line-height:1}
.em-opt:hover{background:var(--a5);border-color:var(--a4)}
.em-opt.sel{background:var(--a3);border-color:var(--a1)}

/* ── CALENDAR v2 ── tasks + Google Calendar events ──────── */
.cal2-shell{display:flex;flex-direction:column;height:calc(100vh - 130px);min-height:560px;background:var(--card);border:1px solid var(--border);border-radius:16px;overflow:hidden;backdrop-filter:blur(4px)}
.cal2-tb{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid var(--border);flex-shrink:0;gap:12px;flex-wrap:wrap}
.cal2-tb-l{display:flex;align-items:center;gap:6px}
.cal2-tb-r{display:flex;align-items:center;gap:8px}
.cal2-today{padding:6px 14px;font-size:12px;font-weight:600;background:var(--bg3);border:1px solid var(--border);border-radius:99px;color:var(--tx2);cursor:pointer;transition:all .15s;font-family:inherit}
.cal2-today:hover{background:var(--a3);color:var(--a2);border-color:var(--a4)}
.cal2-arrow{width:30px;height:30px;border-radius:50%;background:transparent;border:none;color:var(--tx2);cursor:pointer;font-size:18px;line-height:1;display:flex;align-items:center;justify-content:center;transition:all .15s;font-family:inherit}
.cal2-arrow:hover{background:var(--a3);color:var(--a2)}
.cal2-title{font-size:22px;font-weight:600;color:var(--tx);margin:0 8px;letter-spacing:-.01em}
body[data-ui-style="notebook"] .cal2-title,body[data-ui-style="notebook-dark"] .cal2-title{font-family:'Caveat',cursive;font-size:30px;font-weight:700}
body[data-ui-style="sunrise"] .cal2-title,body[data-ui-style="sunrise-dark"] .cal2-title{font-family:'Fraunces',Georgia,serif;font-weight:300}
.cal2-vsw{display:inline-flex;background:var(--bg3);border:1px solid var(--border);border-radius:99px;padding:3px;gap:2px}
.cal2-vopt{padding:5px 14px;border-radius:99px;font-size:12px;font-weight:500;color:var(--tx3);cursor:pointer;border:none;background:none;font-family:inherit;transition:all .12s}
.cal2-vopt:hover{color:var(--tx2)}
.cal2-vopt.sel{background:var(--a1);color:#fff;font-weight:600}
.cal2-new{padding:7px 16px;font-size:13px;font-weight:600;background:#f59e0b;color:#1a1a1a;border:none;border-radius:99px;cursor:pointer;transition:all .15s;font-family:inherit}
.cal2-new:hover{background:#fbbf24;transform:translateY(-1px)}
.cal2-body{display:grid;grid-template-columns:1fr 280px;gap:0;flex:1;min-height:0}
@media(max-width:980px){.cal2-body{grid-template-columns:1fr}}
.cal2-main{display:flex;flex-direction:column;min-width:0;overflow:hidden;position:relative}
.cal2-rail{border-left:1px solid var(--border);padding:14px;overflow-y:auto;display:flex;flex-direction:column;gap:14px;background:rgba(0,0,0,.07)}
@media(max-width:980px){.cal2-rail{border-left:none;border-top:1px solid var(--border);max-height:300px}}
#cal2-host{flex:1;min-height:0;display:flex;flex-direction:column;overflow:hidden}
.cal2-load{position:absolute;inset:0;background:rgba(0,0,0,.35);display:flex;align-items:center;justify-content:center;z-index:5;backdrop-filter:blur(2px);pointer-events:none;opacity:0;transition:opacity .15s}
.cal2-load.on{opacity:1;pointer-events:auto}
.cal2-mo{display:flex;flex-direction:column;flex:1;min-height:0}
.cal2-mh{display:grid;grid-template-columns:repeat(7,1fr);background:rgba(0,0,0,.18);border-bottom:1px solid var(--border);flex-shrink:0}
.cal2-mh>div{padding:8px 6px;font-size:10px;font-weight:700;letter-spacing:.6px;color:var(--tx3);text-align:center}
.cal2-mg{display:grid;grid-template-columns:repeat(7,1fr);grid-auto-rows:1fr;flex:1;min-height:0}
.cal2-cell{border-right:1px solid color-mix(in oklab, var(--border) 65%, transparent);border-bottom:1px solid color-mix(in oklab, var(--border) 65%, transparent);padding:6px 7px 5px;display:flex;flex-direction:column;gap:3px;cursor:pointer;transition:background .12s;overflow:hidden;position:relative;min-height:82px}
.cal2-cell:last-child,.cal2-cell:nth-child(7n){border-right:none}
.cal2-cell:hover{background:rgba(255,255,255,.025)}
.cal2-cell.om{opacity:.4}
.cal2-cell.today{background:color-mix(in oklab, var(--a1) 8%, transparent)}
.cal2-cell.sel{box-shadow:inset 0 0 0 2px var(--a1)}
.cal2-dn{font-size:12px;font-weight:600;color:var(--tx2);width:24px;height:24px;display:flex;align-items:center;justify-content:center;border-radius:50%;flex-shrink:0;align-self:flex-start}
.cal2-cell.today .cal2-dn{background:var(--a1);color:#fff}
.cal2-chip{font-size:10.5px;font-weight:500;padding:3px 7px 3px 22px;border-radius:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;cursor:pointer;border-left:3px solid var(--a1);background:var(--a3);color:var(--tx);line-height:1.3;position:relative;display:flex;align-items:center;gap:5px}
.cal2-chip:hover{transform:translateX(1px)}
.cal2-chip.done{opacity:.5;text-decoration:line-through}
.cal2-chip.ovd{background:rgba(239,68,68,.15)!important;color:#dc2626!important;border-left-color:#ef4444!important}
.cal2-foot-toggle{display:flex;align-items:center;gap:6px;font-size:11px;color:var(--tx3);cursor:pointer;user-select:none}
.cal2-foot-toggle input{accent-color:var(--a1);cursor:pointer;margin:0}
.cal2-foot-toggle:hover{color:var(--tx2)}
.cal2-chk{position:absolute;left:5px;top:50%;transform:translateY(-50%);width:13px;height:13px;border-radius:50%;border:1.5px solid currentColor;background:transparent;cursor:pointer;flex-shrink:0;transition:all .12s;padding:0}
.cal2-chk:hover{transform:translateY(-50%) scale(1.2)}
.cal2-chk.on{background:currentColor}
.cal2-chk.on::after{content:"\2713";position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);font-size:8px;color:#fff;font-weight:900;line-height:1}
.cal2-tt{flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis}
.cal2-time{font-size:9.5px;color:currentColor;opacity:.75;margin-right:4px;font-weight:600}
.cal2-more{font-size:10px;font-weight:600;color:var(--tx3);padding:1px 7px;cursor:pointer}
.cal2-more:hover{color:var(--a2)}
.cal2-wk{display:grid;grid-template-columns:repeat(7,1fr);flex:1;min-height:0;overflow:hidden}
.cal2-wk-day{border-right:1px solid var(--border);display:flex;flex-direction:column;cursor:pointer}
.cal2-wk-hd{padding:10px 8px;border-bottom:1px solid var(--border);text-align:center;background:rgba(0,0,0,.18)}
.cal2-wk-dow{display:block;font-size:10px;font-weight:700;letter-spacing:.6px;color:var(--tx3)}
.cal2-wk-dn{font-size:24px;font-weight:600;color:var(--tx);margin-top:2px;display:inline-block}
.cal2-wk-dn.today{background:var(--a1);color:#fff;width:36px;height:36px;border-radius:50%;display:inline-flex;align-items:center;justify-content:center}
.cal2-wk-day.today .cal2-wk-hd{background:var(--a3)}
.cal2-wk-body{flex:1;padding:8px;overflow-y:auto;display:flex;flex-direction:column;gap:4px}
.cal2-wk-empty{font-size:11px;color:var(--tx4);text-align:center;padding:14px 0;font-style:italic}
.cal2-ag{flex:1;overflow-y:auto;padding:14px}
.cal2-ag-day{margin-bottom:18px}
.cal2-ag-date{font-size:11px;font-weight:700;letter-spacing:.6px;color:var(--tx3);margin-bottom:8px;padding:0 4px}
.cal2-ag-date.today{color:var(--a2)}
.cal2-ag-row{display:flex;align-items:center;gap:10px;padding:11px 14px;background:var(--bg3);border:1px solid var(--border);border-left:3px solid var(--a1);border-radius:9px;margin-bottom:6px;cursor:pointer;transition:transform .1s}
.cal2-ag-row:hover{transform:translateX(2px)}
.cal2-ag-row.done{opacity:.5;text-decoration:line-through}
.cal2-ag-row.ovd{border-left-color:#ef4444!important;background:rgba(239,68,68,.05)}
.cal2-ag-chk{width:18px;height:18px;border-radius:50%;border:2px solid currentColor;background:transparent;cursor:pointer;flex-shrink:0;position:relative;transition:all .12s;padding:0}
.cal2-ag-chk:hover{transform:scale(1.1)}
.cal2-ag-chk.on{background:currentColor}
.cal2-ag-chk.on::after{content:"\2713";position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);font-size:11px;color:#fff;font-weight:900;line-height:1}
.cal2-ag-body{flex:1;min-width:0}
.cal2-ag-title{font-size:13px;font-weight:600;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cal2-ag-meta{font-size:11px;color:var(--tx3);margin-top:2px}
.cal2-ag-empty{padding:50px 20px;text-align:center;color:var(--tx4);font-size:13px}
.cal2-rail-today{padding:6px 4px}
.cal2-rail-dow{font-size:10px;font-weight:700;letter-spacing:.7px;color:var(--tx3);margin-bottom:3px}
.cal2-rail-date{font-size:32px;font-weight:600;color:var(--tx);line-height:1.1;margin-bottom:5px;letter-spacing:-.02em}
body[data-ui-style="notebook"] .cal2-rail-date,body[data-ui-style="notebook-dark"] .cal2-rail-date{font-family:'Caveat',cursive;font-size:42px;font-weight:700}
body[data-ui-style="sunrise"] .cal2-rail-date,body[data-ui-style="sunrise-dark"] .cal2-rail-date{font-family:'Fraunces',Georgia,serif;font-weight:300}
.cal2-rail-sum{font-size:12px;color:var(--tx3)}
.cal2-rail-ovd{display:flex;align-items:center;gap:9px;padding:9px 12px;background:rgba(239,68,68,.08);border:1px solid rgba(239,68,68,.25);border-radius:9px;font-size:12px;color:#dc2626}
.cal2-rail-ovd-mark{font-size:14px;flex-shrink:0}
.cal2-rail-ovd{cursor:pointer;transition:background .15s}
.cal2-rail-ovd:hover{background:rgba(239,68,68,.13)}
.cal2-rail-ovd-arr{font-size:11px;color:#dc2626;flex-shrink:0;font-weight:700}
.cal2-rail-ovd.op{border-radius:9px 9px 0 0;border-bottom-color:transparent}
.cal2-rail-ovd-list{background:rgba(239,68,68,.05);border:1px solid rgba(239,68,68,.25);border-top:none;border-radius:0 0 9px 9px;padding:6px;display:flex;flex-direction:column;gap:4px;margin-top:-1px}
.cal2-rail-ovd-row{display:flex;align-items:flex-start;gap:9px;padding:7px 9px;background:rgba(255,255,255,.55);border:1px solid rgba(239,68,68,.2);border-radius:7px;cursor:pointer;transition:transform .12s}
body[data-theme="dark"] .cal2-rail-ovd-row{background:rgba(0,0,0,.22)}
.cal2-rail-ovd-row:hover{transform:translateX(2px)}
.cal2-rail-cals-hdr{display:flex;align-items:center;justify-content:space-between;font-size:10px;font-weight:700;letter-spacing:.7px;color:var(--tx3);margin-bottom:2px;padding:4px 6px;cursor:pointer;border-radius:6px;transition:background .12s}
.cal2-rail-cals-hdr:hover{background:rgba(255,255,255,.04);color:var(--tx2)}
.cal2-rail-cals-arr{font-size:11px;color:var(--tx3)}
.cal2-rail-cals-list{display:flex;flex-direction:column;gap:3px;padding:2px 0}
.cal2-rail-cal{display:flex;align-items:center;gap:8px;padding:5px 9px;border-radius:8px;cursor:pointer;transition:background .12s;font-size:12px;color:var(--tx);user-select:none}
.cal2-rail-cal:hover{background:rgba(255,255,255,.04)}
.cal2-rail-cal input{accent-color:var(--a1);cursor:pointer;flex-shrink:0;margin:0}
.cal2-rail-cal-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0}
.cal2-rail-cal-name{flex:1;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.cal2-rail-cal.off{opacity:.55}
