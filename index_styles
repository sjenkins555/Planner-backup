/* ── WIDGET FLIP — 4-mode system ──────────────────── */
.card-shell{flex:1;min-height:0;position:relative;display:flex;flex-direction:column}
.face-front{flex:1;min-height:0;position:relative;display:flex;flex-direction:column}
.face-back{position:absolute;inset:0;border-radius:16px;overflow:hidden;pointer-events:none;background:linear-gradient(180deg,rgba(99,102,241,.12),rgba(14,18,44,.93));border:1px solid var(--a4);backdrop-filter:blur(10px);display:flex;flex-direction:column}
.tile.flipped .face-back{pointer-events:all}
.tile.flipped .face-front{pointer-events:none}
.tile.flipped .tile-gear,.tile.minimized .tile-gear{opacity:0!important;pointer-events:none}

/* 3D half-spin (default) */
body:not([data-flip]) .face-front,
body[data-flip="3d"] .face-front{transition:transform .38s cubic-bezier(0.4,0,1,1),opacity .28s ease-in;transform-origin:center}
body:not([data-flip]) .face-back,
body[data-flip="3d"] .face-back{transform:rotateY(90deg);opacity:0;transition:transform .38s cubic-bezier(0,0,0.6,1) .3s,opacity .28s ease-out .3s}
body:not([data-flip]) .tile.flipped .face-front,
body[data-flip="3d"] .tile.flipped .face-front{transform:rotateY(-90deg);opacity:0}
body:not([data-flip]) .tile.flipped .face-back,
body[data-flip="3d"] .tile.flipped .face-back{transform:rotateY(0);opacity:1}

/* Morph — scale + blur crossfade */
body[data-flip="morph"] .face-front{transition:transform .52s cubic-bezier(.34,1.3,.5,1),opacity .36s ease,filter .36s ease}
body[data-flip="morph"] .face-back{transform:scale(1.08);opacity:0;filter:blur(8px);transition:transform .52s cubic-bezier(.34,1.3,.5,1),opacity .36s ease,filter .36s ease}
body[data-flip="morph"] .tile.flipped .face-front{transform:scale(.88);opacity:0;filter:blur(6px)}
body[data-flip="morph"] .tile.flipped .face-back{transform:scale(1);opacity:1;filter:blur(0)}

/* Fold — hinge from top */
body[data-flip="fold"] .tile{perspective:1600px}
body[data-flip="fold"] .face-front{transition:transform .56s cubic-bezier(.65,0,.35,1),opacity .28s ease;transform-origin:50% 100%}
body[data-flip="fold"] .face-back{transform:rotateX(-90deg);opacity:0;transform-origin:50% 0%;transition:transform .56s cubic-bezier(.65,0,.35,1) .18s,opacity .28s ease .18s}
body[data-flip="fold"] .tile.flipped .face-front{transform:rotateX(90deg);opacity:0}
body[data-flip="fold"] .tile.flipped .face-back{transform:rotateX(0);opacity:1}

/* Slide — drawer from below */
body[data-flip="slide"] .tile{overflow:hidden}
body[data-flip="slide"] .face-front{transition:transform .48s cubic-bezier(.32,.72,0,1),opacity .24s ease}
body[data-flip="slide"] .face-back{transform:translateY(100%);opacity:0;transition:transform .48s cubic-bezier(.32,.72,0,1),opacity .24s ease}
body[data-flip="slide"] .tile.flipped .face-front{transform:translateY(-8%);opacity:0}
body[data-flip="slide"] .tile.flipped .face-back{transform:translateY(0);opacity:1}

@media(prefers-reduced-motion:reduce){
  .face-front,.face-back{transition:opacity .15s ease!important;transform:none!important;filter:none!important}
  .tile.flipped .face-front{opacity:0}
  .tile.flipped .face-back{opacity:1;transform:none!important}
}
