.t-mini-tab{padding:4px 9px;font-size:11px;font-weight:600;border-radius:6px;border:none;background:rgba(255,255,255,.03);color:var(--tx3);cursor:pointer;transition:all .12s;font-family:inherit}
.t-mini-tab:hover{color:var(--tx2);background:rgba(255,255,255,.06)}
.t-mini-tab.active{background:var(--a3);color:var(--a2)}

/* Segmented control (.seg / .seg-opt) — the new one-of-N picker */
.seg{display:inline-flex;background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:3px;gap:2px;flex-wrap:wrap}
.seg-opt{padding:6px 12px;border-radius:7px;font-size:12px;font-weight:500;color:var(--tx3);cursor:pointer;transition:all .12s;border:none;background:none;font-family:inherit;white-space:nowrap}
.seg-opt:hover{color:var(--tx2);background:color-mix(in oklab, var(--a1) 8%, transparent)}
.seg-opt.sel{background:var(--a3);color:var(--a2);box-shadow:inset 0 0 0 1px var(--a4)}

/* Compact field row used inside .wback */
.fld{display:flex;align-items:center;gap:8px;padding:5px 0;min-height:26px}
.fld-lbl{flex:1;font-size:11px;color:var(--tx2);font-weight:500;min-width:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.fld-ctl{display:flex;align-items:center;gap:5px;flex-shrink:0}

/* Focus ring — applied to every interactive element when keyboard-focused */
.smx :focus-visible,
.wpx :focus-visible,
.wback :focus-visible,
.wback-dd :focus-visible{outline:2px solid var(--a1);outline-offset:2px;border-radius:inherit}

/* ═══════════════════════════════════════════════════════════════
   SETTINGS MODAL (.smx) — redesign
   ═══════════════════════════════════════════════════════════════ */
.smx{background:var(--bg2);border:1px solid var(--border);border-radius:18px;width:100%;max-width:960px;height:min(680px,88vh);box-shadow:0 24px 60px rgba(0,0,0,.5);display:flex;flex-direction:column;overflow:hidden}
.smx-head{display:flex;align-items:center;justify-content:space-between;padding:16px 22px;border-bottom:1px solid var(--border);flex-shrink:0}
.smx-title{font-size:15px;font-weight:600;color:var(--tx);letter-spacing:-.01em}
.smx-title .sub{font-size:12px;color:var(--tx3);font-weight:500;margin-left:10px}
.smx-close{width:30px;height:30px;border-radius:8px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--tx2);cursor:pointer;display:grid;place-items:center;transition:all .15s}
.smx-close:hover{background:color-mix(in oklab, var(--a1) 12%, transparent);color:var(--a2);border-color:var(--a4)}
.smx-tabs{display:flex;gap:2px;padding:0 16px;border-bottom:1px solid var(--border);flex-shrink:0;overflow-x:auto;scrollbar-width:none}
.smx-tabs::-webkit-scrollbar{display:none}
.smx-tab{background:none;border:none;color:var(--tx3);font-family:inherit;font-size:12.5px;font-weight:500;padding:8px 11px;height:36px;cursor:pointer;white-space:nowrap;border-bottom:2px solid transparent;transition:all .15s;display:flex;align-items:center;gap:6px;margin-bottom:-1px}
.smx-tab:hover{color:var(--tx2);background:color-mix(in oklab, var(--a1) 7%, transparent)}
.smx-tab.active{color:var(--a2);border-bottom-color:var(--a1)}
.smx-body{flex:1;overflow-y:auto;padding:22px 26px 28px}
.smx-body::-webkit-scrollbar{width:8px}
.smx-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:4px}
.smx-foot{display:flex;align-items:center;justify-content:space-between;padding:12px 22px;border-top:1px solid var(--border);flex-shrink:0;background:rgba(0,0,0,.15);gap:12px}
.smx-foot-info{font-size:12px;color:var(--tx3)}
.smx-foot-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end}
.smx .pane{display:none;animation:fadeUp .2s ease}
.smx .pane.active{display:block}
.smx .grp{margin-bottom:22px}
.smx .grp:last-child{margin-bottom:0}
.smx .grp-hdr{display:flex;align-items:baseline;gap:10px;margin-bottom:10px;flex-wrap:wrap}
.smx .grp-title{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--tx2)}
.smx .grp-desc{font-size:12px;color:var(--tx3);font-weight:400}
.smx .row{display:flex;align-items:center;gap:14px;padding:10px 0;border-top:1px solid var(--border)}
.smx .row:first-child{border-top:none;padding-top:4px}
.smx .row-lbl{flex:1;min-width:0}
.smx .row-lbl-main{font-size:13px;font-weight:500;color:var(--tx)}
.smx .row-lbl-sub{font-size:11.5px;color:var(--tx3);margin-top:2px;line-height:1.4}
.smx .row-ctl{flex-shrink:0;display:flex;align-items:center;gap:8px;flex-wrap:wrap;justify-content:flex-end}
.smx .theme-row{display:flex;gap:8px;flex-wrap:wrap}
.smx .bg-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:8px}
@media(max-width:700px){.smx .bg-grid{grid-template-columns:repeat(4,1fr)}}
.smx .bg-preset{aspect-ratio:4/3;border-radius:9px;border:2px solid transparent;cursor:pointer;transition:all .12s;position:relative;overflow:hidden}
.smx .bg-preset:hover{transform:scale(1.04)}
.smx .bg-preset.sel{border-color:var(--a2);box-shadow:0 0 0 2px var(--a4)}
.smx .bg-preset-lbl{position:absolute;left:0;right:0;bottom:0;font-size:9px;font-weight:600;color:#fff;background:rgba(0,0,0,.55);padding:2px 0;text-align:center;letter-spacing:.3px}

/* ═══════════════════════════════════════════════════════════════
   WIDGET PICKER (.wpx) — redesign
   ═══════════════════════════════════════════════════════════════ */
.wpx{background:var(--bg2);border:1px solid var(--border);border-radius:18px;width:100%;max-width:960px;height:min(700px,90vh);box-shadow:0 24px 60px rgba(0,0,0,.5);display:flex;flex-direction:column;overflow:hidden}
.wpx-head{padding:16px 22px 14px;border-bottom:1px solid var(--border);display:flex;align-items:flex-end;justify-content:space-between;gap:16px;flex-shrink:0;flex-wrap:wrap}
.wpx-head-title{font-size:15px;font-weight:600;letter-spacing:-.01em;color:var(--tx)}
.wpx-head-sub{font-size:12px;color:var(--tx3);margin-top:3px}
.wpx-head-actions{display:flex;gap:8px;align-items:center}
.wpx-close{width:30px;height:30px;border-radius:8px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--tx2);cursor:pointer;display:grid;place-items:center;transition:all .15s}
.wpx-close:hover{background:color-mix(in oklab, var(--a1) 12%, transparent);color:var(--a2);border-color:var(--a4)}
.wpx-search{display:flex;align-items:center;gap:8px;padding:6px 12px;background:var(--bg3);border:1px solid var(--border);border-radius:9px;width:220px;transition:all .15s}
.wpx-search:focus-within{border-color:var(--a4);box-shadow:0 0 0 3px var(--a5)}
.wpx-search input{background:none;border:none;outline:none;color:var(--tx);font-family:inherit;font-size:13px;flex:1;padding:0;min-width:0}
.wpx-search input::placeholder{color:var(--tx3)}
.wpx-search-ico{color:var(--tx3);display:flex}
.wpx-tabs{display:flex;gap:2px;padding:0 22px;border-bottom:1px solid var(--border);flex-shrink:0}
.wpx-tab{background:none;border:none;color:var(--tx3);font-family:inherit;font-size:13px;font-weight:500;padding:10px 14px;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s;margin-bottom:-1px;display:flex;align-items:center;gap:7px}
.wpx-tab:hover{color:var(--tx2);background:color-mix(in oklab, var(--a1) 7%, transparent)}
.wpx-tab.active{color:var(--a2);border-bottom-color:var(--a1)}
.wpx-tab-count{font-family:'DM Mono',monospace;font-size:11px;color:var(--tx3);background:var(--bg3);padding:1px 6px;border-radius:99px}
.wpx-tab.active .wpx-tab-count{background:var(--a3);color:var(--a2)}
.wpx-body{flex:1;overflow-y:auto;padding:18px 22px 24px}
.wpx-body::-webkit-scrollbar{width:8px}
.wpx-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:4px}
.wpx-pane{display:none}
.wpx-pane.active{display:block}
.wpx .sec{margin-bottom:22px}
.wpx .sec:last-child{margin-bottom:0}
.wpx .sec-hdr{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:10px}
.wpx .sec-title{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--tx2)}
.wpx .sec-hint{font-size:11px;color:var(--tx3)}
.wpx-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
@media(max-width:700px){.wpx-grid{grid-template-columns:repeat(2,1fr)}}
.wpx .wpx-empty{text-align:center;padding:40px 20px;color:var(--tx3);font-size:13px}
.wcard{background:var(--bg3);border:1.5px solid var(--border);border-radius:13px;padding:0;overflow:hidden;transition:all .15s;position:relative;display:flex;flex-direction:column;cursor:pointer}
.wcard:hover{background:color-mix(in oklab, var(--a1) 8%, var(--bg3));transform:translateY(-2px);box-shadow:0 8px 24px rgba(0,0,0,.25)}
.wcard.active{border-color:var(--a1);box-shadow:0 0 0 1px var(--a4)}
.wcard.dragging{opacity:.4;cursor:grabbing}
.wcard.drag-over{border-color:var(--a2);box-shadow:0 0 0 2px var(--a2)}
.wcard-prev{height:96px;position:relative;display:flex;align-items:center;justify-content:center;border-bottom:1px solid var(--border);background:rgba(0,0,0,.25);overflow:hidden;padding:10px;color:var(--tx2)}
.wcard-foot{display:flex;align-items:center;gap:10px;padding:10px 12px}
.wcard-ico{width:30px;height:30px;border-radius:8px;background:var(--a3);color:var(--a2);display:grid;place-items:center;flex-shrink:0}
.wcard-info{flex:1;min-width:0}
.wcard-name{font-size:12.5px;font-weight:600;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.wcard-desc{font-size:10.5px;color:var(--tx3);margin-top:1px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.wcard-drag{position:absolute;top:8px;left:8px;width:22px;height:22px;border-radius:6px;background:rgba(0,0,0,.4);color:var(--tx2);display:none;align-items:center;justify-content:center;cursor:grab;user-select:none;backdrop-filter:blur(6px);z-index:3;opacity:0;transition:opacity .15s}
.wpx-pane[data-pane="on"] .wcard-drag{display:flex}
.wcard:hover .wcard-drag{opacity:1}
.wcard-size{position:absolute;top:8px;right:8px;font-family:'DM Mono',monospace;font-size:10px;padding:2px 6px;border-radius:5px;background:rgba(0,0,0,.4);color:var(--tx2);backdrop-filter:blur(6px);z-index:3}
.wpx-pane[data-pane="avail"] .wcard-size{display:none}
.sw{position:relative;width:32px;height:18px;flex-shrink:0}
.sw input{opacity:0;position:absolute;inset:0;cursor:pointer;z-index:2;margin:0}
.sw-track{position:absolute;inset:0;background:var(--bg);border:1px solid var(--border);border-radius:99px;transition:all .15s}
.sw-thumb{position:absolute;top:2px;left:2px;width:12px;height:12px;border-radius:50%;background:var(--tx3);transition:all .15s}
.sw input:checked + .sw-track{background:var(--a3);border-color:var(--a4)}
.sw input:checked + .sw-track .sw-thumb{left:16px;background:var(--a1)}
.wpx-foot{padding:12px 22px;border-top:1px solid var(--border);background:rgba(0,0,0,.15);display:flex;justify-content:space-between;align-items:center;flex-shrink:0;gap:12px}
.wpx-foot-info{font-size:12px;color:var(--tx3);display:flex;align-items:center;gap:6px}
/* Preview helpers used inside .wcard-prev */
.p-clock{font-family:'DM Mono',monospace;font-size:22px;font-weight:500;color:var(--tx);letter-spacing:-.02em}
.p-row{display:flex;align-items:center;gap:6px;font-size:10px;color:var(--tx2);margin-bottom:3px;white-space:nowrap}
.p-row .d{width:4px;height:4px;border-radius:50%;background:var(--a2);flex-shrink:0}
.p-lbl{font-size:8px;font-weight:700;letter-spacing:.15em;color:var(--tx3);text-transform:uppercase}

/* ═══════════════════════════════════════════════════════════════
   WIDGET BACK (.wback) — redesign (for 2×1 and larger tiles)
   ═══════════════════════════════════════════════════════════════ */
.wback{display:flex;flex-direction:column;height:100%;gap:10px;background:linear-gradient(180deg, color-mix(in oklab, var(--a1) 8%, transparent), color-mix(in oklab, var(--a1) 3%, transparent));margin:0;padding:12px 14px;border-radius:16px;box-sizing:border-box;overflow:hidden}
.wback-head{display:flex;align-items:center;gap:8px;padding-bottom:8px;border-bottom:1px solid var(--border);flex-shrink:0}
.wback-ico{width:22px;height:22px;border-radius:6px;background:var(--a3);color:var(--a2);display:grid;place-items:center;flex-shrink:0}
.wback-name{flex:1;min-width:0;display:flex;flex-direction:column;gap:1px}
.wback-name-main{font-size:12px;font-weight:600;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.wback-name-sub{font-size:9.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--tx3)}
.wback-done{background:var(--a1);color:#fff;border:none;border-radius:6px;padding:4px 10px;font-family:inherit;font-size:11px;font-weight:600;cursor:pointer;transition:all .15s;flex-shrink:0}
.wback-done:hover{background:var(--a2)}
.wback-tabs{display:flex;background:var(--bg3);border:1px solid var(--border);border-radius:8px;padding:2px;flex-shrink:0}
.wback-tab{flex:1;text-align:center;padding:5px 4px;font-size:11px;font-weight:600;background:none;border:none;color:var(--tx3);border-radius:6px;cursor:pointer;font-family:inherit;transition:all .12s;letter-spacing:.02em}
.wback-tab:hover{color:var(--tx2);background:color-mix(in oklab, var(--a1) 7%, transparent)}
.wback-tab.active{background:var(--a3);color:var(--a2);box-shadow:inset 0 0 0 1px var(--a4)}
.wback-body{flex:1;min-height:0;overflow-y:auto;padding-right:4px;margin-right:-4px}
.wback-body::-webkit-scrollbar{width:6px}
.wback-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:3px}
.wback-pane{display:none}
.wback-pane.active{display:block}
.wback-grp{margin-bottom:2px}
.wback-grp + .wback-grp{margin-top:8px;padding-top:6px;border-top:1px solid var(--border)}
.wback-grp-title{font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--tx3);margin-bottom:3px}
.wback .alpha{font-family:'DM Mono',monospace;font-size:9.5px;color:var(--tx3);min-width:26px;text-align:right}
.wback .mc-color{width:22px;height:20px;border:1px solid var(--border);border-radius:5px;background:none;cursor:pointer;padding:1px}
.wback .mc-range{flex:1;accent-color:var(--a1);min-width:50px;height:4px}
.wback .mc-seg{display:inline-flex;background:var(--bg3);border:1px solid var(--border);border-radius:6px;padding:1px;gap:1px;flex-wrap:wrap}
.wback .mc-seg-opt{padding:3px 7px;border-radius:4px;font-size:10px;font-weight:500;color:var(--tx3);cursor:pointer;transition:all .12s;border:none;background:none;font-family:inherit;line-height:1.2}
.wback .mc-seg-opt:hover{color:var(--tx2);background:color-mix(in oklab, var(--a1) 8%, transparent)}
.wback .mc-seg-opt.sel{background:var(--a3);color:var(--a2)}
.wback .sz-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:4px}
.wback .sz-cell{padding:5px 2px;border:1px solid var(--border);border-radius:5px;cursor:pointer;background:rgba(255,255,255,.03);text-align:center;font-size:10px;font-weight:500;color:var(--tx3);transition:all .12s;line-height:1.2;font-family:'DM Mono',monospace}
.wback .sz-cell:hover{background:color-mix(in oklab, var(--a1) 10%, var(--bg3));border-color:var(--a4);color:var(--a2)}
.wback .sz-cell.sel{background:var(--a3);border-color:var(--a1);color:var(--a2)}
.wback .tog{display:flex;align-items:flex-start;gap:7px;padding:4px 0;cursor:pointer}
.wback .tog input{accent-color:var(--a1);width:13px;height:13px;margin-top:2px;flex-shrink:0}
.wback .tog-body{min-width:0}
.wback .tog-lbl{font-size:11px;color:var(--tx2);font-weight:500;line-height:1.3}
.wback .tog-hint{font-size:9.5px;color:var(--tx4);margin-top:1px;line-height:1.35}
.wback-foot{display:flex;gap:5px;justify-content:space-between;padding-top:6px;border-top:1px solid var(--border);flex-shrink:0;flex-wrap:wrap}
.wback-foot-btn{font-size:10px;padding:4px 8px;border-radius:5px;background:rgba(255,255,255,.04);border:1px solid var(--border);color:var(--tx3);cursor:pointer;font-family:inherit;transition:all .12s;display:inline-flex;align-items:center;gap:4px}
.wback-foot-btn:hover{color:var(--a2);background:color-mix(in oklab, var(--a1) 10%, transparent);border-color:var(--a4)}
.wback-foot-btn.danger:hover{background:rgba(239,68,68,.1);color:#f87171;border-color:rgba(239,68,68,.3)}

/* ═══════════════════════════════════════════════════════════════
   WIDGET BACK DROPDOWN (.wback-dd) — for 1×1 tiles
   ═══════════════════════════════════════════════════════════════ */
.wback-dd{position:fixed;z-index:5000;width:220px;background:var(--bg2);border:1px solid var(--border);border-radius:10px;box-shadow:0 12px 32px rgba(0,0,0,.5);padding:6px;display:flex;flex-direction:column;gap:1px}
.wback-dd-hdr{font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--tx3);padding:6px 10px 4px}
.wback-dd-item{display:flex;align-items:center;gap:9px;padding:7px 10px;border-radius:6px;cursor:pointer;font-size:12px;color:var(--tx2);transition:all .12s;background:none;border:none;font-family:inherit;text-align:left;width:100%}
.wback-dd-item:hover{background:color-mix(in oklab, var(--a1) 12%, transparent);color:var(--a2)}
.wback-dd-item.danger:hover{background:rgba(239,68,68,.12);color:#f87171}
.wback-dd-ico{width:14px;height:14px;color:var(--tx3);flex-shrink:0}
.wback-dd-item:hover .wback-dd-ico{color:var(--a2)}
.wback-dd-sep{height:1px;background:var(--border);margin:4px 6px}
.wback-dd-row{display:flex;align-items:center;gap:7px;padding:6px 10px}
.wback-dd-row-lbl{flex:1;font-size:11px;color:var(--tx2)}
.wback-dd-sub{padding:2px 10px 5px;font-size:9.5px;color:var(--tx4);line-height:1.45}

/* ═══════════════════════════════════════════════════════════════
   STICKY ACTION BAR on flipped widget backs
   Keeps "Done / Reset / Cancel" visible while the panel scrolls
   ═══════════════════════════════════════════════════════════════ */
.face-back .flip-back-card{display:flex;flex-direction:column;height:100%;overflow:hidden}
.face-back .flip-back-card .flip-back-card{padding:8px 14px}
.face-back .flip-back-card > .style-panel{flex:1;min-height:0;overflow-y:auto;padding:14px 18px 0}
.face-back .style-footer,
.face-back .flip-back-footer{
  position:sticky;
  bottom:0;
  margin:14px -18px 0;
  padding:10px 18px 12px;
  background:var(--bg2);
  border-top:1px solid var(--border);
  z-index:5;
  flex-shrink:0;
  backdrop-filter:blur(6px);
}
.face-back .style-footer{display:flex;gap:7px;justify-content:space-between;flex-wrap:wrap}
.face-back .flip-back-footer{display:flex;gap:8px;justify-content:flex-end;margin:14px -14px 0;padding:10px 14px 12px;flex-wrap:wrap}
/* In the tabbed back (Edit + Style), the outer scroll is the flex tab body */
.face-back .flip-back-card > div[style*="overflow-y:auto"]{padding-bottom:0 !important}

/* ── CONTRAST + NO-EMOJI ICON STYLING ──────────────── */
.topbar{background:rgba(10,14,26,.97)!important}
.navstrip{background:rgba(10,14,26,.92)!important}
body[data-ui-style="zen"] .topbar{background:rgba(236,234,228,.98)!important}
body[data-ui-style="zen"] .navstrip{background:rgba(236,234,228,.95)!important}
body[data-ui-style="notebook"] .topbar{background:rgba(253,248,235,.98)!important}
body[data-ui-style="notebook"] .navstrip{background:rgba(253,248,235,.95)!important}
body[data-ui-style="sunrise"] .topbar{background:rgba(252,240,216,.98)!important}
body[data-ui-style="sunrise"] .navstrip{background:rgba(251,245,234,.95)!important}

/* Topbar buttons — always readable */
.icon-btn{background:rgba(255,255,255,.09);border:1px solid rgba(255,255,255,.20);color:#e2e8f0}
.icon-btn:hover{background:var(--a3);color:var(--a2);border-color:var(--a4)}
body[data-ui-style="zen"] .icon-btn,
body[data-ui-style="notebook"] .icon-btn,
