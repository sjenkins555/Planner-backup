.cal2-rail-sec{display:flex;flex-direction:column;gap:5px}
.cal2-rail-shdr{font-size:10px;font-weight:700;letter-spacing:.7px;color:var(--tx3);margin-bottom:2px;padding:0 4px}
.cal2-rail-row{display:flex;align-items:flex-start;gap:9px;padding:9px 11px;background:var(--bg3);border:1px solid var(--border);border-radius:9px;cursor:pointer;transition:all .12s}
.cal2-rail-row:hover{border-color:var(--a4);transform:translateX(2px)}
.cal2-rail-row.done{opacity:.5}
.cal2-rail-row.done .cal2-rail-title{text-decoration:line-through}
.cal2-rail-chk{width:16px;height:16px;border-radius:50%;border:2px solid var(--a1);background:transparent;cursor:pointer;flex-shrink:0;margin-top:2px;position:relative;transition:all .12s;padding:0}
.cal2-rail-chk:hover{transform:scale(1.15)}
.cal2-rail-chk.on{background:var(--a1)}
.cal2-rail-chk.on::after{content:"\2713";position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);font-size:10px;color:#fff;font-weight:900;line-height:1}
.cal2-rail-body{flex:1;min-width:0}
.cal2-rail-title{font-size:13px;font-weight:600;color:var(--tx);white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
