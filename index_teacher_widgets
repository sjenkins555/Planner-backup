// Open the group editor modal. Pass a name to edit, omit to create new.
// Renders a checkbox per student, pre-checked if already in the group.
function openGrpModal(editName){
  // Find the existing group (if editing)
  var ex = editName ? (function(){
    for (var i = 0; i < groups.length; i++){
      if (groups[i].name === editName) return groups[i];
    }
    return {};
  })() : {};
  var emails = ex.emails || [];

  document.getElementById('m-gn').value    = editName || '';
  document.getElementById('m-gn').disabled = !!editName; // can't rename existing groups
  document.getElementById('gm-title').textContent = editName ? 'Edit "' + editName + '"' : 'New Group';

  document.getElementById('grp-list').innerHTML = students.map(function(s){
    return '<label style="display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:8px;cursor:pointer;background:var(--bg3);border:1px solid var(--border);">'
      + '<input type="checkbox" value="' + esc(s.email) + '" ' + (emails.indexOf(s.email) > -1 ? 'checked' : '') + ' >'
      + '<span style="font-size:13px;font-weight:500;">' + esc(s.name) + '</span>'
      + '<span style="font-size:11px;color:var(--tx4);">' + esc(s.email) + '</span>'
      + '</label>';
  }).join('') || '<div style="color:var(--tx4);">No students yet.</div>';

  openModal('group-modal');
}

// Save the group from the modal (creates or updates) and refresh.
function doSaveGroup(){
  var name = document.getElementById('m-gn').value.trim();
  if (!name){ toast('Enter a name', 'err'); return; }

  var checked = Array.from(document.querySelectorAll('#grp-list input:checked')).map(function(i){ return i.value; });
  closeModal('group-modal');

  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      toast('Group saved', 'ok');
      // Force re-fetch on next render so new group shows up everywhere
      students = []; groups = [];
      buildGroupsPage();
    }
  }).saveGroup(name, JSON.stringify(checked));
}

// Confirm and delete a group, then refresh.
function doDelGroup(name){
  if (!confirm('Delete group "' + name + '"?')) return;
  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      toast('Deleted', 'inf');
      students = []; groups = [];
      buildGroupsPage();
    }
  }).deleteGroup(name);
}


/* ═══════════════════════════════════════════════════════════════════
   11. LEGACY PUSH PAGE
   Older standalone push UI using element IDs `to-*` / `pt-det` / `p-tt`
   etc. These are NOT used by the modern Push Tasks widget (which uses
   `twp-*` / `tp-*`). Kept verbatim per refactor rules — likely dead code
   but flagging here so a future pass can verify and remove.
   ═══════════════════════════════════════════════════════════════════ */

// Legacy: set push target on the older standalone push page.
function setPT(t){
  pushTarget = t;
  ['all','group','ind'].forEach(function(x){
    var b = document.getElementById('to-' + x);
    if (b) b.classList.remove('sel');
  });
  var k = t === 'individual' ? 'ind' : t;
  var b = document.getElementById('to-' + k);
  if (b) b.classList.add('sel');

  var g = groups.map(function(g){ return '<option value="' + esc(g.name) + '">' + esc(g.name) + ' (' + g.emails.length + ')</option>'; }).join('');
  var s = students.map(function(s){ return '<option value="' + esc(s.email) + '">' + esc(s.name) + '</option>'; }).join('');
  renderPTDet(g, s);
}

// Legacy: render push target detail row (group/student dropdown).
function renderPTDet(g, s){
  var el = document.getElementById('pt-det');
  if (!el) return;
  if (pushTarget === 'all') el.innerHTML = '<div style="font-size:12px;color:var(--tx3);background:var(--bg3);border:1px solid var(--border);border-radius:10px;padding:9px 12px;">Sends to all ' + students.length + ' registered student(s)</div>';
  else if (pushTarget === 'group') el.innerHTML = g ? '<select class="fsel" id="p-gs">' + g + '</select>' : '<div style="color:var(--tx3);font-size:12px;">No groups yet.</div>';
  else el.innerHTML = s ? '<select class="fsel" id="p-ss">' + s + '</select>' : '<div style="color:var(--tx3);font-size:12px;">No students yet.</div>';
}

// Legacy: submit the older push form via pushAssignment.
function doPush(){
  var title = document.getElementById('p-tt').value.trim();
  if (!title){ toast('Enter a title', 'err'); return; }

  var tv = '';
  if (pushTarget === 'group'){
    var sg = document.getElementById('p-gs');
    tv = sg ? sg.value : '';
    if (!tv){ toast('Select a group', 'err'); return; }
  }
  if (pushTarget === 'individual'){
    var ss = document.getElementById('p-ss');
    tv = ss ? ss.value : '';
    if (!tv){ toast('Select a student', 'err'); return; }
  }

  google.script.run.withSuccessHandler(function(r){
    if (r.success){
      toast('Pushed to ' + r.count + ' student(s)!', 'ok');
      document.getElementById('p-tt').value = '';
      document.getElementById('p-tn').value = '';
      document.getElementById('p-td').value = '';
    } else toast(r.error || 'Error', 'err');
  }).pushAssignment(
    document.getElementById('p-tt').value.trim(),
    document.getElementById('p-ts').value.trim(),
    document.getElementById('p-td').value,
    document.getElementById('p-tp').value,
    document.getElementById('p-tn').value.trim(),
    pushTarget,
    tv
  );
}


