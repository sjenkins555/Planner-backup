<script>
/* ═══════════════════════════════════════════════════════════════════
   ║  index_teacher_widgets.html — TEACHER TOOLS TAB CHUNK
   ║  ───────────────────────────────────────────────────
   ║  Owns the Teacher Tools tab: 6 widgets in a draggable/resizable grid.
   ║  Only renders for users with role === 'teacher' (router enforces this).
   ║
   ║  Widgets (teacher tile IDs):
   ║    tview   — View Student (browse a single student's planner)
   ║    tgrp    — Groups (create/edit student groups)
   ║    tpush   — Push Tasks (send a task to all/group/one student)
   ║    talink  — Assign Links (push links to all/group/one student)
   ║    tembed  — Embed Documents (push a Google Doc/Sheet/Slide/Form)
   ║    trem    — Send Reminder (push a reminder to all/group/one student)
   ║
   ║  TABLE OF CONTENTS
   ║  ─────────────────
   ║   1. STATE (per-widget UI flags + caches)
   ║   2. PAGE BUILDER (buildTeacherDashboard)
   ║   3. TILE SIZE PICKER (openTSzPicker, pickTSz)
   ║   4. WIDGET RENDERERS — shell HTML for each of the 6 widgets
   ║   5. VIEW STUDENT — load + inline add/delete tasks
   ║   6. PUSH TASKS — target picker + calendar-event opt-in
   ║   7. ASSIGN LINKS — tabbed Add / Current Links
   ║   8. EMBED DOCUMENTS — tabbed Embed New / Current Docs
   ║   9. SEND REMINDER — target picker + datetime
   ║  10. GROUPS MODAL (openGrpModal, doSaveGroup, doDelGroup)
   ║  11. LEGACY PUSH PAGE (older standalone push UI — see notes)
   ║  12. HELPERS (loadStuGroups data prefetch)
   ═══════════════════════════════════════════════════════════════════ */


/* ═══════════════════════════════════════════════════════════════════
   1. STATE
   Per-widget UI flags. Most widgets remember their currently-selected
   target (all/group/individual) and which tab they're on.
   _tvwActiveList tracks the View Student widget's task-list filter.
   ═══════════════════════════════════════════════════════════════════ */

var _tvwActiveList = 'default'; // currently-shown task list in View Student widget
var _twPushTarget  = 'all';     // Push Tasks: 'all' | 'group' | 'individual'
var _twLinkTarget  = 'all';     // Assign Links: 'all' | 'group' | 'individual'
var _twLinkTab     = 'add';     // Assign Links: 'add' | 'list'
var _twEdTarget    = 'all';     // Embed Docs: 'all' | 'group' | 'individual' | 'self'
var _twEdTab       = 'add';     // Embed Docs: 'add' | 'list'
var _twRemTarget   = 'all';     // Send Reminder: 'all' | 'group' | 'individual'


/* ═══════════════════════════════════════════════════════════════════
   2. PAGE BUILDER
   Builds the 6-widget grid. Order/size persist via prefs.teacherTileOrder
   and prefs.teacherTileSizes. Loads students+groups first, then renders.
   ═══════════════════════════════════════════════════════════════════ */

// Build the Teacher Tools tab. Defers widget renders by 50ms so the
// grid paints before any async loads kick in.
function buildTeacherDashboard(){
  // Tile definitions — one per teacher widget
  var tileDefs = {
    tview:  {fn:renderTViewWidget,     title:'View Student',    svg:'#w-student',    defC:2, defR:2},
    tgrp:   {fn:renderTGroupsWidget,   title:'Groups',          svg:'#w-group',      defC:2, defR:2},
    tpush:  {fn:renderTPushWidget,     title:'Push Tasks',      svg:'#w-push',       defC:2, defR:2},
    talink: {fn:renderTLinkWidget,     title:'Assign Links',    svg:'#w-assignlink', defC:2, defR:2},
    tembed: {fn:renderTEmbedWidget,    title:'Embed Documents', svg:'#w-embed',      defC:4, defR:2},
    trem:   {fn:renderTReminderWidget, title:'Send Reminder',   svg:'#w-timer',      defC:2, defR:2}
  };

  // Reconcile saved order with the canonical default — drop unknown IDs,
  // append any new IDs that weren't saved before.
  var defaultOrder = ['tview','tgrp','tpush','talink','tembed','trem'];
  if (!prefs.teacherTileOrder || !prefs.teacherTileOrder.length){
    prefs.teacherTileOrder = defaultOrder.slice();
  } else {
    var saved = prefs.teacherTileOrder.filter(function(id){ return tileDefs[id]; });
    defaultOrder.forEach(function(id){ if (saved.indexOf(id) === -1) saved.push(id); });
    prefs.teacherTileOrder = saved;
  }
  if (!prefs.teacherTileSizes) prefs.teacherTileSizes = {};

  // Empty grid first
  panel('t-dash').innerHTML = '<div class="tile-grid" id="t-tile-grid" style="grid-auto-rows:minmax(180px,auto);"></div>';

  // Pre-fetch students + groups so widgets like Push/Links/Embed can
  // populate their dropdowns immediately on first render.
  loadStuGroups(function(){
    var grid = document.getElementById('t-tile-grid');
    if (!grid) return;

    grid.innerHTML = prefs.teacherTileOrder.map(function(id){
      var t = tileDefs[id];
      if (!t) return '';
      var sz = prefs.teacherTileSizes[id] || {c:t.defC, r:t.defR};
      var colSpan = Math.min(Math.max(sz.c || t.defC, 1), 4);
      var rowSpan = Math.min(Math.max(sz.r || t.defR, 1), 3);
      var minH = (rowSpan * 180) + ((rowSpan - 1) * 14);

      return '<div class="tile" id="tile-' + id + '" draggable="true" data-tile="' + id + '" '
        + 'style="grid-column:span ' + colSpan + ';grid-row:span ' + rowSpan + ';min-height:' + minH + 'px;">'
        + '<div class="card" style="display:flex;flex-direction:column;height:100%;overflow:hidden;">'
        +   '<div class="card-top">'
        +     '<div class="card-lbl"><svg class="ui-ic-sm" viewBox="0 0 24 24"><use href="' + t.svg + '"/></svg> ' + t.title + '</div>'
        +     '<div class="tile-gear" onclick="openTSzPicker(\'' + id + '\',event)" title="Resize"><svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3h4M3 3v4M13 13h-4M13 13v-4M3 13h4M3 13v-4M13 3h-4M13 3v4"/></svg></div>'
        +   '</div>'
        +   '<div class="t-widget-body t-widget-scroll" id="tw-' + id + '"><div style="color:var(--tx3);font-size:12px;padding:20px;text-align:center;">Loading...</div></div>'
        + '</div></div>';
    }).join('');

    // Defer renders so DOM paints shells first; isolate per-widget errors.
    setTimeout(function(){
      prefs.teacherTileOrder.forEach(function(id){
        var t = tileDefs[id];
        if (!t) return;
        try {
          t.fn();
        } catch(e){
          var el = document.getElementById('tw-' + id);
          if (el) el.innerHTML = '<div style="color:#f87171;font-size:12px;padding:10px;">Error: ' + esc(e.message) + '</div>';
          console.error(e);
        }
      });
      initDragDrop();
    }, 50);
  });
}


/* ═══════════════════════════════════════════════════════════════════
   3. TILE SIZE PICKER
   Floating popup over a tile's gear icon with a 4×2 grid of size choices.
   Same UX as the admin tab's openASzPicker, but persists to
   prefs.teacherTileSizes.
   ═══════════════════════════════════════════════════════════════════ */

// Open the size picker for a teacher tile. Clicking the same gear twice
// closes the popup. Clicking outside also closes.
function openTSzPicker(id, evt){
  evt.stopPropagation();
  var old = document.getElementById('sz-pop');
  if (old){ old.remove(); if (old.dataset.wid === id) return; }

  // Default sizes (must match buildTeacherDashboard's tileDefs)
  var defs = {tview:{c:2,r:2}, tgrp:{c:2,r:2}, tpush:{c:2,r:2}, talink:{c:2,r:2}, tembed:{c:4,r:2}, trem:{c:2,r:2}};
  var cur  = Object.assign({}, defs[id] || {c:2,r:2}, (prefs.teacherTileSizes && prefs.teacherTileSizes[id]) || {});

  // Build popup
  var pop = document.createElement('div');
  pop.id = 'sz-pop';
  pop.dataset.wid = id;
  pop.className = 'sz-pop';
  var html = '<div class="sz-pop-title">Size (cols \u00d7 rows)</div><div class="sz-grid">';
  for (var r = 1; r <= 2; r++){
    for (var c = 1; c <= 4; c++){
      var isSel = (c === cur.c && r === cur.r) ? ' sel' : '';
      html += '<div class="sz-cell' + isSel + '" onclick="pickTSz(\'' + id + '\',' + c + ',' + r + ')">' + c + '\u00d7' + r + '</div>';
    }
  }
  html += '</div>';
  pop.innerHTML = html;
  document.body.appendChild(pop);

  // Position popup near the tile's gear, clamped to viewport
  var tile  = document.getElementById('tile-' + id);
  var tRect = tile ? tile.getBoundingClientRect() : {top:100, bottom:300, left:100, right:400};
  var popW = 215, popH = 152;
  var left = tRect.right - popW - 14;
  var top  = tRect.bottom - popH - 44;
  if (left < tRect.left + 8) left = tRect.left + 8;
  if (top  < tRect.top  + 8) top  = tRect.top  + 8;
  if (left + popW > window.innerWidth  - 8) left = window.innerWidth  - popW - 8;
  if (top  + popH > window.innerHeight - 8) top  = window.innerHeight - popH - 8;
  if (left < 8) left = 8;
  if (top  < 8) top  = 8;
  pop.style.top  = top  + 'px';
  pop.style.left = left + 'px';

  // Click-outside-to-close
  setTimeout(function(){
    function away(e){ if (!pop.contains(e.target)){ pop.remove(); document.removeEventListener('click', away); } }
    document.addEventListener('click', away);
  }, 10);
}

// Apply a picked size to the tile + persist to prefs.
function pickTSz(id, cols, rows){
  if (!prefs.teacherTileSizes) prefs.teacherTileSizes = {};
  prefs.teacherTileSizes[id] = {c:cols, r:rows};

  var tile = document.getElementById('tile-' + id);
  if (tile){
    var minH = (rows * 180) + ((rows - 1) * 14);
    tile.style.gridColumn = 'span ' + cols;
    tile.style.gridRow    = 'span ' + rows;
    tile.style.minHeight  = minH + 'px';
  }

  var pop = document.getElementById('sz-pop');
  if (pop) pop.remove();
  google.script.run.saveMyPrefs(JSON.stringify(prefs));
}


/* ═══════════════════════════════════════════════════════════════════
   4. WIDGET RENDERERS
   Each function paints the static HTML shell for its widget body, then
   triggers loads/sub-renderers as needed. Run from buildTeacherDashboard's
   setTimeout so the grid is already on screen.
   ═══════════════════════════════════════════════════════════════════ */

// View Student widget — student dropdown + inline planner viewer.
// Falls back to a separate getMyStudents call if the global `students`
// list isn't populated (e.g. loadStuGroups hadn't loaded yet).
function renderTViewWidget(){
  var el = document.getElementById('tw-tview');
  if (!el) return;

  var stuList = (typeof students !== 'undefined' && students) ? students : [];
  if (!stuList.length){
    el.innerHTML = '<div style="color:var(--tx3);font-size:12px;padding:20px;text-align:center;">Loading students...</div>';
    google.script.run.withSuccessHandler(function(r){
      if (r && r.students){ students = r.students; renderTViewWidget(); }
      else { el.innerHTML = '<div style="color:var(--tx3);font-size:12px;padding:20px;text-align:center;">No students yet.</div>'; }
    }).getMyStudents();
    return;
  }

  // Render dropdown + content area; auto-load the first student
  var sO = stuList.map(function(s){
    return '<option value="' + esc(s.email) + '">' + esc(s.name) + '</option>';
  }).join('');
  el.innerHTML = '<select class="fsel" id="tvw-sel" onchange="loadTViewInline()" style="margin-bottom:10px;">' + sO + '</select>'
    + '<div id="tvw-content"><div style="color:var(--tx3);font-size:12px;padding:20px;text-align:center;">Pick a student to view their planner data.</div></div>';
  document.getElementById('tvw-sel').value = stuList[0].email;
  loadTViewInline();
}

// Groups widget — counts header + list of groups with edit/delete buttons.
function renderTGroupsWidget(){
  var el = document.getElementById('tw-tgrp');
  if (!el) return;

  var studentCount = students.length;
  var groupRows = groups.map(function(g){
    return '<div style="background:rgba(15,23,42,.6);border:1px solid var(--border);border-radius:8px;padding:7px 10px;margin-bottom:5px;display:flex;align-items:center;gap:8px;">'
      + '<div style="flex:1;min-width:0;"><div style="font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">' + esc(g.name) + '</div>'
      + '<div style="font-size:10px;color:var(--tx4);">' + g.emails.length + ' student' + (g.emails.length !== 1 ? 's' : '') + '</div></div>'
      + '<button class="btn btn-ghost btn-sm" onclick="openGrpModal(\'' + esc(g.name) + '\')" title="Edit"><svg class="ui-ic-sm" viewBox="0 0 16 16"><use href="#w-edit"/></svg></button>'
      + '<button class="btn btn-danger btn-sm" onclick="doDelGroup(\'' + esc(g.name) + '\');setTimeout(renderTGroupsWidget,200);"><svg class="ui-ic-sm" viewBox="0 0 16 16"><use href="#w-x"/></svg></button>'
      + '</div>';
  }).join('') || '<div style="color:var(--tx4);font-size:12px;padding:12px;text-align:center;">No groups yet.</div>';

  el.innerHTML = '<div style="display:flex;gap:6px;align-items:center;margin-bottom:8px;">'
    +   '<div style="flex:1;font-size:11px;color:var(--tx3);"><strong style="color:var(--tx);">' + studentCount + '</strong> student' + (studentCount !== 1 ? 's' : '') + ' &middot; <strong style="color:var(--tx);">' + groups.length + '</strong> group' + (groups.length !== 1 ? 's' : '') + '</div>'
    +   '<button class="btn btn-primary btn-sm" onclick="openGrpModal();setTimeout(renderTGroupsWidget,200);">New Group</button>'
    + '</div>'
    + '<div style="font-size:10px;font-weight:700;color:var(--tx3);letter-spacing:.5px;text-transform:uppercase;margin-bottom:5px;">Groups</div>'
    + groupRows;
}

