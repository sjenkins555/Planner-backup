/* ═══════════════════════════════════════════════════════════════════
   5. VIEW STUDENT WIDGET — handlers
   Loads a student's planner data, renders task list with per-list filter
   tabs, supports inline add/delete of tasks.
   ═══════════════════════════════════════════════════════════════════ */

// Fetch the selected student's planner data and render it inside #tvw-content.
// Renders task counts (pending/done), an Add task button, optional task-list
// tab bar (only if the student has more than one list), and the first 8 tasks.
function loadTViewInline(){
  var sel = document.getElementById('tvw-sel');
  if (!sel || !sel.value) return;
  var email   = sel.value;
  var content = document.getElementById('tvw-content');
  content.innerHTML = '<div style="color:var(--tx3);font-size:12px;padding:20px;text-align:center;">Loading...</div>';

  google.script.run.withSuccessHandler(function(r){
    if (!r.success){ content.innerHTML = '<div style="color:#ef4444;font-size:12px;">' + esc(r.error || 'Error') + '</div>'; return; }

    // Resolve student name (for the Add Task button label)
    var name = '';
    for (var i = 0; i < students.length; i++){ if (students[i].email === email) name = students[i].name; }

    var allTasks = r.tasks || [];
    var lists    = r.taskLists || [{id:'default', name:'All Tasks', color:'#6366f1'}];
    var listMap  = r.taskListMap || {};

    // If the student deleted the list we were filtering by, fall back to default
    if (!lists.some(function(l){ return l.id === _tvwActiveList; })) _tvwActiveList = 'default';

    // Filter tasks to currently-selected list. The 'default' list shows everything.
    var filteredTasks = allTasks.filter(function(t){ return _tvwActiveList === 'default' || listMap[t.id] === _tvwActiveList; });
    var pending = filteredTasks.filter(function(t){ return t.status !== 'completed'; });
    var done    = filteredTasks.filter(function(t){ return t.status === 'completed'; });

    // Tab bar — only render if the student has 2+ task lists
    var tabBar = '';
    if (lists.length > 1){
