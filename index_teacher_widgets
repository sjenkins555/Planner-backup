// If the "also create calendar event" checkbox is checked, gather the
// task fields + resolved guest list and open the calendar event editor.
// Called BEFORE the push itself fires.
function twMaybeOpenCal(){
  var cb = document.getElementById('tp-cal');
  if (!cb || !cb.checked) return;

  var title = ((document.getElementById('tp-tt') || {}).value || '').trim();
  if (!title) return;
  var due   = (document.getElementById('tp-td') || {}).value || '';
  var notes = ((document.getElementById('tp-tn') || {}).value || '').trim();
  var subj  = ((document.getElementById('tp-ts') || {}).value || '').trim();

  // Resolve guest list from the current target choice
  var guests = [];
  if (_twPushTarget === 'all'){
    guests = students.map(function(s){ return s.email; });
  } else if (_twPushTarget === 'group'){
    var gs    = document.getElementById('twp-gs');
    var gname = gs ? gs.value : '';
    var grp   = groups.filter(function(g){ return g.name === gname; })[0];
    if (grp) guests = grp.emails || [];
  } else if (_twPushTarget === 'individual'){
    var ss = document.getElementById('twp-ss');
    if (ss && ss.value) guests = [ss.value];
  }

  // If subject matches one of teacher's own classes, auto-fill class times
  var classTimes = findClassTimesForSubject(subj, due);
  openCalendarEvent(title, due, notes, guests, classTimes);
}

