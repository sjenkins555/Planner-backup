// Pre-fetch students + groups for the teacher tab. Skips the round-trip
// if either global is already populated. Falls back to two sequential
// calls if the combined endpoint fails.
function loadStuGroups(cb){
  if (students.length || groups.length){ cb(); return; }

  google.script.run.withSuccessHandler(function(r){
    students = (r && r.students) || [];
    groups   = (r && r.groups)   || [];
    cb();
  }).withFailureHandler(function(){
    // Fallback path: two separate calls
    google.script.run.withSuccessHandler(function(sl){
      students = sl || [];
      google.script.run.withSuccessHandler(function(gl){
        groups = gl || [];
        cb();
      }).getGroups();
    }).getStudentList();
  }).getStuGroupData();
}

